null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to come to a stop, to come to a standstill","tags":["intransitive"]},{"pos":"verb","gloss":"to stop","tags":["intransitive"],"examples":[{"text":"قِف (qif, “halt!, stop!, whoa!”)"}]},{"pos":"verb","gloss":"to pause, to hesitate","tags":["intransitive"]},{"pos":"verb","gloss":"to stand","tags":["intransitive"]},{"pos":"verb","gloss":"to inquire, seek information, inform oneself","tags":["intransitive"]},{"pos":"verb","gloss":"to acquaint oneself"},{"pos":"verb","gloss":"to stop (something), to bring to a stop","tags":["transitive"],"examples":[{"text":"وَلَوْ تَرَىٰ إِذْ وُقِفُوا عَلَىٰ رَبِّهِمْ"}]},{"pos":"verb","gloss":"to make stand, to set up","tags":["transitive"]},{"pos":"verb","gloss":"to bring to a stop, to bring to a standstill"},{"pos":"verb","gloss":"to arrest, to halt, to stop"},{"pos":"verb","gloss":"to obstruct, to hamper"},{"pos":"verb","gloss":"to park (a car)"},{"pos":"verb","gloss":"to erect, to raise"},{"pos":"noun","gloss":"verbal noun of وَقَفَ (waqafa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"stopping, halting"},{"pos":"noun","gloss":"discontinuation, suspension"},{"pos":"noun","gloss":"stay, standstill"},{"pos":"noun","gloss":"pausing, resting"},{"pos":"noun","gloss":"blocking"},{"pos":"noun","gloss":"impediment, obstacle"},{"pos":"noun","gloss":"discharge, dismissal, removal"},{"pos":"noun","gloss":"a waqf, religious endowment, endowment fund"},{"pos":"noun","gloss":"inalienable property"},{"pos":"noun","gloss":"pausa"},{"pos":"noun","gloss":"bracelet, armlet","tags":["obsolete"]},{"pos":"noun","gloss":"metal or horn edge of a shield","tags":["obsolete"]}]},"etymology":{"source":"wiktextract","text":"Borrowed from Ge'ez ወቅፍ (wäḳf, “bracelet, armlet”), also ውቅፍ (wəḳf), of obscure African origin."},"ipa":["/wa.qa.fa/","/waq.qa.fa/","/waqf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44693","headword_ar":"وَقَفَ","root":"wqf","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary;"},{"kind":"text","text":"(Msb;) ["},{"kind":"italic_en","text":"he stood still;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he continued standing:"},{"kind":"text","text":"(K:) and [simply]"},{"kind":"italic_en","text":"he stood;"},{"kind":"text","text":"contr. of"},{"kind":"arabic","text_bw":"jalasa","text_ar":"جَلَسَ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"waqafa Ald~aAb~apa","text_ar":"وَقَفَ الدَّابَّةَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"waqofN","text_ar":"وَقْفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made the beast to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"waqafa Ealayohi","text_ar":"وَقَفَ عَلَيْهِ"},{"kind":"italic_en","text":"He stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paused, upon coming to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it; he stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"paused, at it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"where he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was."},{"kind":"text","text":"―         -b4-"},{"kind":"arabic","text_bw":"waqafa EalaY $aYo'K","text_ar":"وَقَفَ عَلَى شَىْءٍ"},{"kind":"italic_en","text":"He paused at, and paid attention to, a thing."},{"kind":"text","text":"―         -b5-"},{"kind":"arabic","text_bw":"waqafa Ealayohi","text_ar":"وَقَفَ عَلَيْهِ"},{"kind":"italic_en","text":"He comprehended it,"},{"kind":"text","text":"namely, a meaning:"},{"kind":"italic_en","text":"he understood it."},{"kind":"text","text":"(TA. [Or, correctly,"},{"kind":"arabic","text_bw":"wuqifa","text_ar":"وُقِفَ"},{"kind":"text","text":", for it is there altered.]) ―         -b6-"},{"kind":"italic_en","text":"He met with it;"},{"kind":"text","text":"namely, a word or the like, in reading: often occurring in this sense. ―         -b7-"},{"kind":"arabic","text_bw":"wuqifa Ealayohi","text_ar":"وُقِفَ عَلَيْهِ"},{"kind":"italic_en","text":"He saw it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he was introduced into it, and knew what was in it."},{"kind":"text","text":"(TA.)"},{"kind":"italic_en","text":"He was made to know it surely."},{"kind":"text","text":"See Bd, vi. 27 and 30. ―         -b8-"},{"kind":"arabic","text_bw":"waqafotuhu ElY *anobihi","text_ar":"وَقَفْتُهُ على ذَنْبِهِ"},{"kind":"italic_en","text":"I made him acquainted with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him to know, his crime, sin, fault, or the like;"},{"kind":"text","text":"(S, K:) and so"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^awoqafahu","text_ar":"اَوْقَفَهُ","orth_type":"arrow"},{"kind":"text","text":", q. v. (Mgh.) ―         -b9-"},{"kind":"arabic","text_bw":"waqafa","text_ar":"وَقَفَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"wuquwfN","text_ar":"وُقُوفٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He withstood, resisted:"},{"kind":"text","text":"governing by"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"text","text":". ―         -b10-"},{"kind":"arabic","text_bw":"waqafahu","text_ar":"وَقَفَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^awoqafahu","text_ar":"اَوْقَفَهُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"waq~afahu","text_ar":"وَقَّفَهُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He bequeathed it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave it, unalienably:"},{"kind":"text","text":"] the first of these is the most chaste: the last is disapproved and rare. (TA, art."},{"kind":"arabic","text_bw":"Hbs","text_ar":"حبس"},{"kind":"text","text":".) See"},{"kind":"arabic","text_bw":"muw^ab~adN","text_ar":"مُوَبَّدٌ"},{"kind":"text","text":"."}],"source_refs":["K","S"]}]}}