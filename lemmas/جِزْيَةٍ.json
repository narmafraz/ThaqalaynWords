{"lemma":"جِزْيَةٍ","slug":"جِزْيَةٍ","root":"ج.ز.#","root_slug":"ج-ز-_","root_link":"/words/roots/ج-ز-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"جِزْيَة","root":"جزي","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n5761"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%90%D8%B2%D9%92%D9%8A%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"jizya, tax paid by non-Muslims"},{"pos":"noun","gloss":"head tax"},{"pos":"noun","gloss":"customs tax"},{"pos":"noun","gloss":"land tax"},{"pos":"noun","gloss":"produce of the ground"}]},"etymology":{"source":"wiktextract","text":"Compare جَزَى (jazā, “to repay”). Or borrowed from Middle Persian 𐭢𐭦𐭩𐭲𐭪𐭩 (gzytky /⁠gazīdag⁠/), 𐭢𐭦𐭩𐭲 (gzyt /⁠gazīd⁠/, “poll tax”), at least semantic loan from Middle Persian."},"ipa":["/d͡ʒiz.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5761","headword_ar":"جِزْيَةٌ","root":"jzY","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"tax that is taken from the free nonMuslim subjects of a Muslim government;"},{"kind":"text","text":"(S, IAth, Mgh,* Msb, K;)"},{"kind":"italic_en","text":"whereby they ratify the compact that ensures them protection:"},{"kind":"text","text":"(IAth:) [from"},{"kind":"arabic","text_bw":"jazaY","text_ar":"جَزَى"},{"kind":"text","text":";] as though it were a compensation for their not being slain: (IAth, Mgh:) [or from the Persian"},{"kind":"arabic","text_bw":"Gizoyaho","text_ar":"گِزْيَهْ"},{"kind":"text","text":":] and also, (metaphorically, Mgh,) (tropical:)"},{"kind":"italic_en","text":"a land-tax;"},{"kind":"text","text":"(Mgh, K;)"},{"kind":"italic_en","text":"a tax that is paid by the owner of land:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"jizFY","text_ar":"جِزًى"},{"kind":"text","text":"(S,) or ↓"},{"kind":"arabic","text_bw":"jizoYN","text_ar":"جِزْىٌ"},{"kind":"text","text":", (Msb,) or both, (K,) [but the latter is, properly speaking, a coll. gen. n.,] and"},{"kind":"arabic","text_bw":"jizaA='N","text_ar":"جِزَا=ءٌ"},{"kind":"text","text":", (K, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"jazA'N","text_ar":"جَزاءٌ"},{"kind":"text","text":",]) like"},{"kind":"arabic","text_bw":"kitaAbN","text_ar":"كِتَابٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["IAth","Mgh","TA","S","Msb","K"]}]},"classical_definitions":null}