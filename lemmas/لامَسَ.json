orm": "لامَسْنا", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "لامَسْتُ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}], "frequency_in_corpus": 8, "cross_references": {"qac": {"found": false}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 2}, "lanes": {"found": true, "entry_ids": ["n38000"], "search_url": "https://lanelexicon.com/?s=%D9%84%D8%A7%D9%85%D9%8E%D8%B3%D9%8E"}}, "translations": {"en": "to touch", "fa": "لمس کردن", "ur": "چھونا", "tr": "dokunmak", "id": "menyentuh", "bn": "স্পর্শ করা", "es": "tocar", "fr": "toucher", "de": "berühren", "ru": "касаться", "zh": "触摸"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to be touching, to be in physical contact with", "tags": ["transitive"]}, {"pos": "verb", "gloss": "to have sexual intercourse with", "tags": ["euphemistic", "transitive"]}]}, "etymology": null, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n38000", "headword_ar": "لَامِسٌ", "root": "lms", "body": [{"kind": "text", "text": "act. part. n. of 1. (Msb, &c.) One says, of a woman who commits adultery, or fornication, or acts viciously,"}, {"kind": "arabic", "text_bw": "falaAnapu laA tarud~u yada laAmisK", "text_ar": "فَلَانَةُ لَا تَرُدُّ يَدَ لَامِسٍ"}, {"kind": "text", "text": ", (A, TA,) or"}, {"kind": "arabic", "text_bw": "laA tamonaEu yada laAmisK", "text_ar": "لَا تَمْنَعُ يَدَ لَامِسٍ"}, {"kind": "text", "text": ", (K,) but the latter is at variance with the written authorities, the former being the phrase commonly known, (TA,) [properly signifying,"}, {"kind": "italic_en", "text": "Such a woman does not repel the hand of a feeler;"}, {"kind": "text", "text": "] meaning, (tropical:)"}, {"kind": "italic_en", "text": "such a woman commits adultery,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "fornication, and acts viciously,"}, {"kind": "text", "text": "(K, TA,)"}, {"kind": "italic_en", "text": "not repelling from herself any one who desires of her that he may lie with her;"}, {"kind": "text", "text": "(TA;) and"}, {"kind": "italic_en", "text": "she is suspected of easiness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "compliance,"}, {"kind": "text", "text": "(K, TA,)"}, {"kind": "italic_en", "text": "towards him who desires of her that he may lie with her:"}, {"kind": "text", "text": "(TA:) or the meaning is,"}, {"kind": "italic_en", "text": "such a woman gives, of her husband's property, what is sought,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "demanded, from her;"}, {"kind": "text", "text": "and this is more probably meant in a trad. in which a man is related to have said thus of his wife; because Mohammad directed him to retain her, and did not require him to divorce her. (TA.) The like said of a man, (K,)"}, {"kind": "arabic", "text_bw": "fulaAnN laA yarud~u yada laAmisK", "text_ar": "فُلَانٌ لَا يَرُدُّ يَدَ لَامِسٍ"}, {"kind": "text", "text": ", (A, Msb,) means, (tropical:)"}, {"kind": "italic_en", "text": "Such a man has in him no force of resistance,"}, {"kind": "text", "text": "(A, Msb, K,)"}, {"kind": "italic_en", "text": "nor care of what is sacred,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "inviolable."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["A", "TA", "K", "Msb"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D9%84%D8%A7%D9%85%D8%B3/", "headword_ar": "لامستم", "entries": [{"lexicon_id": "dictionary_39", "lexicon_en": "ʿAbdullāh ibn ʿAbbās, Gharīb al-Qurʾān fī Shiʿr al-ʿArab, also known as Masāʾil Nāfiʿ b. al-Azraq (d. 687 CE)", "lexicon_ar": "غريب القرآن في شعر العرب لعبد الله بن عباس", "permalink": "https://arabiclexicon.hawramani.com/?p=94398#c232f4", "body_html": "<span class=\"title1\">ل م س [لامستم]</span><br><span>قال: يا ابن عباس: أخبرني عن قول الله عزّ وجلّ: أَوْ لامَسْتُمُ النِّساءَ .</span><br><span>قال: جامعتم النساء. وهذيل تقول: اللمس باليد.</span><br><span>قال: وهل تعرف العرب ذلك؟</span><br><span>قال: نعم، أما سمعت لبيد بن ربيعة وهو يقول:</span><br><span>يلمس الأحلس في منزله </span><span class=\"red\">...</span><span> بيديه كاليهودي المقل </span><br><span>وقال الأعشى :</span><br><span>ورادعة صفراء بالطّيب عندنا </span><span class=\"red\">...</span><span> للمس النّدامى في يد الدّرع مفتق </span>"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}