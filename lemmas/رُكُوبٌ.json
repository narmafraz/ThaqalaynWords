{"lemma":"رُكُوبٌ","slug":"رُكُوبٌ","root":"ر.ك.ب","root_slug":"ر-ك-ب","root_link":"/words/roots/ر-ك-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رُكُوبٌ","root":"ركب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n16467"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8F%D9%83%D9%8F%D9%88%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of رَكِبَ (rakiba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"riding"},{"pos":"noun","gloss":"embarking"},{"pos":"noun","gloss":"bend in a reed or cane"},{"pos":"noun","gloss":"mount, animal (especially a camel) for riding"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16467","headword_ar":"رَكُوبٌ","root":"rkb","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rakuwbapN","text_ar":"رَكُوبَةٌ","orth_type":"arrow"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rikaAbN","text_ar":"رِكَابٌ"},{"kind":"text","text":": both signify A beast"},{"kind":"italic_en","text":"that is ridden:"},{"kind":"text","text":"(S:) or a she-camel"},{"kind":"italic_en","text":"that is ridden:"},{"kind":"text","text":"(K:) or the latter has this meaning: and is metaphorically applied to anything"},{"kind":"italic_en","text":"ridden:"},{"kind":"text","text":"(Msb:) or the former signifies any beast"},{"kind":"italic_en","text":"that is ridden:"},{"kind":"text","text":"and the latter is a name for"},{"kind":"italic_en","text":"everything that is ridden;"},{"kind":"text","text":"applied to"},{"kind":"italic_en","text":"one,"},{"kind":"text","text":"and to"},{"kind":"italic_en","text":"a pl. number:"},{"kind":"text","text":"(TA:) or the former signifies"},{"kind":"italic_en","text":"ridden,"},{"kind":"text","text":"as a fem. epithet: and the latter, one"},{"kind":"italic_en","text":"specially appointed for riding;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"that is constantly kept to work;"},{"kind":"text","text":"of beasts (K, TA) of any kind: (TA:) and the latter and ↓"},{"kind":"arabic","text_bw":"rakobaAnapN","text_ar":"رَكْبَانَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rakobaApN","text_ar":"رَكْبَاةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rakabuwtN","text_ar":"رَكَبُوتٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"rakobaY","text_ar":"رَكْبَى","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rakabuwtaY","text_ar":"رَكَبُوتَى","orth_type":"arrow"},{"kind":"text","text":", (K * and TA in art."},{"kind":"arabic","text_bw":"Hlb","text_ar":"حلب"},{"kind":"text","text":", [see"},{"kind":"arabic","text_bw":"HaluwbN","text_ar":"حَلُوبٌ"},{"kind":"text","text":"in several places,]) a she-camel"},{"kind":"italic_en","text":"that is ridden;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that is broken, trained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered submissive"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manageable:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"rakuwbN","text_ar":"رَكُوبٌ"},{"kind":"text","text":"has this last signification, accord. to AZ: and its pl. is"},{"kind":"arabic","text_bw":"rukubN","text_ar":"رُكُبٌ"},{"kind":"text","text":": (TA:) the pl. of"},{"kind":"arabic","text_bw":"rakuwbapN","text_ar":"رَكُوبَةٌ"},{"kind":"text","text":"being"},{"kind":"arabic","text_bw":"rakaAy^ibu","text_ar":"رَكَايِبُ"},{"kind":"text","text":": (TA voce"},{"kind":"arabic","text_bw":"jazuwzN","text_ar":"جَزُوزٌ"},{"kind":"text","text":":) and ↓"},{"kind":"arabic","text_bw":"rakobaAnapN","text_ar":"رَكْبَانَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies [also] a she-camel"},{"kind":"italic_en","text":"fit to be ridden;"},{"kind":"text","text":"(S, TA;) like as"},{"kind":"arabic","text_bw":"HalobaAnapN","text_ar":"حَلْبَانَةٌ"},{"kind":"text","text":"signifies fit to be milked: the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"are [said to be] added in order to give intensiveness to the signification: (TA:) [and all the other epithets mentioned above seem also, accord. to some, to have an intensive sense: see"},{"kind":"arabic","text_bw":"HaluwbN","text_ar":"حَلُوبٌ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"maA lahu","text_ar":"مَا لَهُ"},{"kind":"arabic","text_bw":"rakuwbapN walaA HamuwlapN walaA HaluwbapN","text_ar":"رَكُوبَةٌ وَلَا حَمُولَةٌ وَلَا حَلُوبَةٌ"},{"kind":"italic_en","text":"He has not a she-camel to ride, nor one to carry burdens, nor one to be milked."},{"kind":"text","text":"(S, TA.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"baEiyrN rakuwbN","text_ar":"بَعِيرٌ رَكُوبٌ"},{"kind":"italic_en","text":"A camel having marks of galls,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sores, on his back, produced by the saddle."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"TariyqN","text_ar":"طَرِيقٌ"},{"kind":"arabic","text_bw":"rakuwbN","text_ar":"رَكُوبٌ"},{"kind":"italic_en","text":"A road ridden upon,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"and trodden so as to be rendered even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easy to be travelled."},{"kind":"text","text":"(TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"rak~aAbN","text_ar":"رَكَّابٌ"},{"kind":"text","text":"."}],"source_refs":["S","K","Msb","TA"]}]},"classical_definitions":null}