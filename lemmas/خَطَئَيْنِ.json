{"lemma":"خَطَئَيْنِ","slug":"خَطَئَيْنِ","root":"خ.ط.#","root_slug":"خ-ط-_","root_link":"/words/roots/خ-ط-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خَطَأ","root":"خطأ","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["name","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n10962","n11055"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B7%D9%8E%D8%A6%D9%8E%D9%8A%D9%92%D9%86%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to take a step forward, to step"},{"pos":"name","gloss":"Khitans","tags":["collective"]}]},"etymology":null,"ipa":["/xa.tˤaː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10962","headword_ar":"خَطَاٌ","root":"xTA^","body":[{"kind":"italic_en","text":"A wrong action; a mistake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an error; contr. of"},{"kind":"arabic","text_bw":"SawaAbN","text_ar":"صَوَابٌ"},{"kind":"text","text":"; as also ↓"},{"kind":"arabic","text_bw":"xaTaA='N","text_ar":"خَطَا=ءٌ"},{"kind":"text","text":"(S, Msb, K) and ↓"},{"kind":"arabic","text_bw":"xaTo'N","text_ar":"خَطْءٌ"},{"kind":"text","text":": (K:) accord. to some, it is syn. with"},{"kind":"arabic","text_bw":"xaTiyoy^apN","text_ar":"خَطِيْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xiTo'N","text_ar":"خِطْءٌ"},{"kind":"text","text":"; and is an inf. n. used as a simple subst; but accord. to others, (TA,) it signifies"},{"kind":"italic_en","text":"an unintentional fault"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disobedience;"},{"kind":"text","text":"(K, TA;) a subst. from"},{"kind":"arabic","text_bw":"A^axoTaA^a","text_ar":"اَخْطَاَ"},{"kind":"text","text":": (M, Msb: [see 1, first sentence:]) and accord. to the M, ↓"},{"kind":"arabic","text_bw":"xaTaA='N","text_ar":"خَطَا=ءٌ"},{"kind":"text","text":"is a subst. from"},{"kind":"arabic","text_bw":"xaTiy^","text_ar":"خَطِي"},{"kind":"text","text":"[and therefore"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"xaTiyoy^apN","text_ar":"خَطِيْيَةٌ"},{"kind":"text","text":"accord. to the general acceptation of"},{"kind":"arabic","text_bw":"xaTiy^a","text_ar":"خَطِيَ"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n11055","headword_ar":"خَطَا","root":"xTw","body":[{"kind":"text","text":", (S, Msb, K, &c.,) aor."},{"kind":"arabic","text_bw":"yaxoTuw","text_ar":"يَخْطُو"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xaTowN","text_ar":"خَطْوٌ"},{"kind":"text","text":"; (Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AxtTY","text_ar":"اختطى","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) said of a man (S, Msb, TA) [and of a beast]; both signify the same; (S, K;)"},{"kind":"italic_en","text":"He stepped, paced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"walked;"},{"kind":"text","text":"(MA, KL;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"ma$aY","text_ar":"مَشَى"},{"kind":"text","text":"; (M, Msb, K;) as also"},{"kind":"arabic","text_bw":"AixotaATa","text_ar":"اِخْتَاطَ"},{"kind":"text","text":", [which see in art."},{"kind":"arabic","text_bw":"xyT","text_ar":"خيط"},{"kind":"text","text":",] formed by transposition. (K.) You say,"},{"kind":"arabic","text_bw":"xaTawotu","text_ar":"خَطَوْتُ"},{"kind":"arabic","text_bw":"xaTowapF waAHidapF","text_ar":"خَطْوَةً وَاحِدَةً"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I stepped one step"},{"kind":"text","text":"]. (JK.) [And"},{"kind":"arabic","text_bw":"was~aEa AlxaTowa","text_ar":"وَسَّعَ الخَطْوَ"},{"kind":"italic_en","text":"He stepped wide."},{"kind":"text","text":"] See also the last sentence of the next paragraph."}],"source_refs":["Msb","S","TA"]}]},"classical_definitions":null}