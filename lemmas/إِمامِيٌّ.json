{"lemma":"إِمامِيٌّ","slug":"إِمامِيٌّ","root":"#.م.م","root_slug":"_-م-م","root_link":"/words/roots/_-م-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":1},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"anterior, front, frontal, fore-, forward"}]},"etymology":{"source":"wiktextract","text":"أَمَام (ʔamām, “front”) + ـِيّ (-iyy)."},"ipa":["/ʔa.maː.mijj/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A5%D9%85%D8%A7%D9%85%D9%8A/","headword_ar":"إمامية","entries":[{"lexicon_id":"dictionary_18","lexicon_en":"Al-Sharīf al-Jurjānī, Kitāb al-Taʿrīfāt (d. 1413 CE)","lexicon_ar":"كتاب التعريفات للشريف الجرجاني","permalink":"https://arabiclexicon.hawramani.com/?p=22965#3c2df9","body_html":"<span>الإمامية: هم الذين قالوا بالنص الجلي على إمامة علي رضي الله عنه، وكفَّروا الصحابة، وهم الذين خرجوا على علي رضي الله عنه، عند التحكيم وكفّروه، وهم إثنا عشر ألف رجل، كانوا أهل صلاة وصيام، وفيهم قال النبي صلى الله عليه وسلم: \"يحقر أحدكم صلاته في جنب صلاتهم، وصومه في جنب صومهم، ولكن لم يتجاوز إيمانهم تراقيهم\".</span>"}]}}