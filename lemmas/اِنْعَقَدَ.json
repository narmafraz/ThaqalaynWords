":["n29873"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%B9%D9%8E%D9%82%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29873","headword_ar":"انعقد","root":"Eqd","body":[{"kind":"text","text":", said of a cord, or rope, (S, O, L, Msb,) as also ↓"},{"kind":"arabic","text_bw":"tEq~d","text_ar":"تعقّد","orth_type":"arrow"},{"kind":"text","text":", (S, * O, * L,) [but the latter has an intensive or a frequentative signification,]"},{"kind":"italic_en","text":"It became tied, knit, complicated so as to form a knot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knots, tied in a knot"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knots, tied firmly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fast"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strongly."},{"kind":"text","text":"(L.) ―         -b2-  And the former, said of a sale or bargain, and of a contract or compact or the like, (S, O, L,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, concluded, settled, confirmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ratified."},{"kind":"text","text":"(L.) One says,"},{"kind":"arabic","text_bw":"AnEqd Aln~ikaAHu bayona Alz~awojayoni","text_ar":"انعقد النِّكَاحُ بَيْنَ الزَّوْجَيْنِ"},{"kind":"italic_en","text":"The marriage was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, concluded, settled,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"between the husband and wife."},{"kind":"text","text":"(L.) ―         -b3-  Said of an animal's tail,"},{"kind":"italic_en","text":"It became twisted"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though tied in a knot"},{"kind":"text","text":"]. (L.) ―         -b4-  And said of hair,"},{"kind":"italic_en","text":"It became knotted, and crisp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"curly."},{"kind":"text","text":"(L.) ―         -b5-  Said of the date [and other fruit,"},{"kind":"italic_en","text":"It became organized and compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compactly organized"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"bsr","text_ar":"بسر"},{"kind":"text","text":", &c.) See also 8, latter half. ―         -b6-  Said of sand: see 5. ―         -b7-  And said of rob, and of tar, and the like: see 1, last quarter."}],"source_refs":["S","O","L","Msb"]}]},"classical_definitions":null}