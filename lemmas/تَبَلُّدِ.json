{"lemma":"تَبَلُّدِ","slug":"تَبَلُّدِ","root":"ب.ل.د","root_slug":"ب-ل-د","root_link":"/words/roots/ب-ل-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n3162"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%A8%D9%8E%D9%84%D9%8F%D9%91%D8%AF%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be acclimatized, to be habituated"},{"pos":"noun","gloss":"verbal noun of تَبَلَّدَ (taballada) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3162","headword_ar":"تبلّد","root":"bld","body":[{"kind":"italic_en","text":"He obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercised, dominion over a"},{"kind":"arabic","text_bw":"balad","text_ar":"بَلَد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"belonging to others."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"italic_en","text":"He alighted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sojourned, in a"},{"kind":"arabic","text_bw":"balad","text_ar":"بَلَد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"country,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"wherein was no one,"},{"kind":"text","text":"(L, K,)"},{"kind":"italic_en","text":"saying within himself, O my grief,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regret!"},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"he went backwards and forwards in confusion or perplexity, unable to see his right course:"},{"kind":"text","text":"(T, * S:) because he who is in this state is like one in a"},{"kind":"arabic","text_bw":"balodap","text_ar":"بَلْدَة"},{"kind":"text","text":", meaning a desert in which he cannot find his way: (T, L:)"},{"kind":"italic_en","text":"he was overtaken by confusion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexity, such that he was unable to see his right course;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"A^abolada","text_ar":"اَبْلَدَ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"italic_en","text":"He fell to the ground,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"by reason of weakness."},{"kind":"text","text":"(TA.) [See also 2.] ―         -b5-"},{"kind":"italic_en","text":"He became submissive, and humble;"},{"kind":"text","text":"(T, TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"tajal~ada","text_ar":"تَجَلَّدَ"},{"kind":"text","text":". (T, M, K.) ―         -b6-"},{"kind":"italic_en","text":"He affected"},{"kind":"arabic","text_bw":"balaAdap","text_ar":"بَلَادَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"stupidity, dulness, want of intelligence,"},{"kind":"text","text":"&c.]. (S.) ―         -b7-  (assumed tropical:)"},{"kind":"italic_en","text":"He turned his hands over,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upside-down:"},{"kind":"text","text":"(K:) [thus one does in sorrow, or regret, or in perplexity: see Kur xviii. 40:] or the meaning is that which here next follows: (TA:) (assumed tropical:)"},{"kind":"italic_en","text":"he clapped his hands;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"smote palm upon palm;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Saf~aqa","text_ar":"صَفَّقَ"},{"kind":"text","text":"(M, K)"},{"kind":"arabic","text_bw":"biAlkaf~i","text_ar":"بِالكَفِّ"},{"kind":"text","text":". (TA.) [See"},{"kind":"arabic","text_bw":"balodapN","text_ar":"بَلْدَةٌ"},{"kind":"text","text":".] ―         -b8-  [And hence, app.,] (tropical:)"},{"kind":"italic_en","text":"He felt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expressed, grief, sorrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regret."},{"kind":"text","text":"(M, A, L, K.)       -A2-"},{"kind":"arabic","text_bw":"tabal~adati AlbilaAdu","text_ar":"تَبَلَّدَتِ البِلَادُ"},{"kind":"text","text":": see 2.       -A3-  Accord. to AAF,"},{"kind":"arabic","text_bw":"tbl~d","text_ar":"تبلّد"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the dawn, or daybreak,)"},{"kind":"italic_en","text":"shone, was bright,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shone brightly; i. q."},{"kind":"arabic","text_bw":"tbl~j","text_ar":"تبلّج"},{"kind":"text","text":". (M.)"}],"source_refs":["L","K","T","TA","M"]}]},"classical_definitions":null}