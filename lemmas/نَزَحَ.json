text_ar":"نُزُوحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling, became distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote."},{"kind":"text","text":"(S.) ―         -b3-"},{"kind":"arabic","text_bw":"nuziHa bifulaAnK","text_ar":"نُزِحَ بِفُلَانٍ"},{"kind":"text","text":", (S, K,) a verb like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", [pass. in form, but neut. in signification,] (K,)"},{"kind":"italic_en","text":"Such a one became far removed from his dwelling-place."},{"kind":"text","text":"(S, K.)       -A2-"},{"kind":"arabic","text_bw":"nazaHa Albiy^ora","text_ar":"نَزَحَ البِيْرَ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"(Msb) and"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"nazoHN","text_ar":"نَزْحٌ"},{"kind":"text","text":"(S, Msb) and"},{"kind":"arabic","text_bw":"nuzuwHN","text_ar":"نُزُوحٌ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"A^anozaHahaA","text_ar":"اَنْزَحَهَا","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He drew forth all the water of the well; exhausted it entirely:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"he drew from it until little water remained in it; nearly exhausted it."},{"kind":"text","text":"(K.) ―         -b2-"},{"kind":"arabic","text_bw":"nazaHati Albiy^oru","text_ar":"نَزَحَتِ البِيْرُ"},{"kind":"text","text":", (A, Msb, K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"nazaHN","text_ar":"نَزَحٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"nuzuwHN","text_ar":"نُزُوحٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The well became entirely exhausted:"},{"kind":"text","text":"(A, Msb, K:) or,"},{"kind":"italic_en","text":"became nearly exhausted."},{"kind":"text","text":"(K.) See 4. ―         -b3-"},{"kind":"arabic","text_bw":"qado nazaHotaniY","text_ar":"قَدْ نَزَحْتَنِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Thou hast exhausted me of what I had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"possessed."},{"kind":"text","text":"(L, from a trad.)"}],"source_refs":["S","K","Msb","TA","A"]}]}}