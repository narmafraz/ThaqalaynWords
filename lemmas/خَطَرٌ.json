{"lemma":"خَطَرٌ","slug":"خَطَرٌ","root":"خ.ط.ر","root_slug":"خ-ط-ر","root_link":"/words/roots/خ-ط-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":8,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":11},"lanes":{"found":true,"entry_ids":["n11002"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B7%D9%8E%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"danger, risk, hazard, peril, calamity, jeopardy"},{"pos":"noun","gloss":"eminence, nobility, excellence"},{"pos":"noun","gloss":"rank, station"},{"pos":"noun","gloss":"seriousness, importance"},{"pos":"noun","gloss":"bet, wager, stake"},{"pos":"adj","gloss":"dangerous, risky"},{"pos":"verb","gloss":"to swing, to shake, to wave","tags":["ambitransitive"]},{"pos":"verb","gloss":"to come up, to pop, to cross (of ideas that come to mind)","tags":["intransitive"],"examples":[{"text":"ولم يخطر على قلوب العباد.","english":"And (it) has never crossed the hearts (minds) of the servants."},{"text":"أي أسئلة تخطر على بالك؟","english":"What questions cross your mind?"}]},{"pos":"noun","gloss":"an unidentified dying plant, perhaps dyer's woad (Isatis tinctoria)","tags":["Yemen","collective","obsolete"]},{"pos":"noun","gloss":"plural of خَطَر (ḵaṭar)","tags":["form-of","plural"]},{"pos":"adj","gloss":"masculine plural of خَطِير (ḵaṭīr)","tags":["form-of","masculine","plural"]}]},"etymology":{"source":"wiktextract","text":"See the etymology of the corresponding lemma form."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11002","headword_ar":"خَطَرٌ","root":"xTr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"being at the point of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"near to, destruction;"},{"kind":"text","text":"(JK, S, A, Msb, K;) ["},{"kind":"italic_en","text":"imminent danger; peril; jeopardy; risk; hazard;"},{"kind":"text","text":"] and"},{"kind":"italic_en","text":"fear of perishing:"},{"kind":"text","text":"(Msb:) pl."},{"kind":"arabic","text_bw":"A^axoTaArN","text_ar":"اَخْطَارٌ"},{"kind":"text","text":". (A.) You say,"},{"kind":"arabic","text_bw":"huwa EalaY xaTarK EaZiymK","text_ar":"هُوَ عَلَى خَطَرٍ عَظِيمٍ"},{"kind":"italic_en","text":"He is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a state of great peril,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"on the brink of destruction."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"rakobuwA AlA^axoTaAra","text_ar":"رَكْبُوا الاَخْطَارَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They embarked in perilous undertakings;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"braved perils"},{"kind":"text","text":"]. (A.) [And"},{"kind":"arabic","text_bw":"A^amoru lahu","text_ar":"اَمْرُ لَهُ"},{"kind":"arabic","text_bw":"xaTarN","text_ar":"خَطَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"*uw xaTarK","text_ar":"ذُو خَطَرٍ"},{"kind":"italic_en","text":"A perilous affair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"a momentous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an important, affair"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case; an affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event,."},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a case, of moment"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"importance"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"magnitude:"},{"kind":"text","text":"see also"},{"kind":"arabic","text_bw":"xaTiyrN","text_ar":"خَطِيرٌ"},{"kind":"text","text":".] And"},{"kind":"arabic","text_bw":"xaTarN","text_ar":"خَطَرٌ"},{"kind":"text","text":"[alone] signifies"},{"kind":"italic_en","text":"A thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affair,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of great magnitude:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an affliction:"},{"kind":"text","text":"pl. as above. (Har p. 264.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"A bet, wager, stake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing wagered; a thing staked at a shooting-match"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a race, and taken by the winner:"},{"kind":"text","text":"(T, S, * A, * Mgh, * Msb, * K, * TA:) [accord. to the TA, this is the primary signification; but accord. to the A, it is tropical:] pl. as above; (Msb;) or"},{"kind":"arabic","text_bw":"xiTaArN","text_ar":"خِطَارٌ"},{"kind":"text","text":"; and pl. pl."},{"kind":"arabic","text_bw":"xuTurN","text_ar":"خُطُرٌ"},{"kind":"text","text":": (K: [but in some copies of the K, the last is written"},{"kind":"arabic","text_bw":"A^axoTaArN","text_ar":"اَخْطَارٌ"},{"kind":"text","text":"; and so in the TA, where it is added that some say it is pl. of"},{"kind":"arabic","text_bw":"xaTarN","text_ar":"خَطَرٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"A^asobaAbN","text_ar":"اَسْبَابٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"sababN","text_ar":"سَبَبٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^anodaAbN","text_ar":"اَنْدَابٌ"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":":])"},{"kind":"arabic","text_bw":"xaTarN","text_ar":"خَطَرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sabaqN","text_ar":"سَبَقٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nadabN","text_ar":"نَدَبٌ"},{"kind":"text","text":"all signify the same. (TA.) You say,"},{"kind":"arabic","text_bw":"waDaEuwA xaTarFA","text_ar":"وَضَعُوا خَطَرًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"They laid a bet"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"A^aHoraza fulaAnN AlxaTara","text_ar":"اَحْرَزَ فُلَانٌ الخَطَرَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one won the bet"},{"kind":"text","text":"]. (A.) ―         -b3-  Hence, [app. as being likened to a stake won,] (TA,) (tropical:)"},{"kind":"italic_en","text":"Eminence; nobility;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"xaTorN","text_ar":"خَطْرٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) in which sense it has become so much used as to be, in this acceptation, conventionally regarded as proper: (TA:) also"},{"kind":"italic_en","text":"excellence:"},{"kind":"text","text":"(TA:) and (as also ↓"},{"kind":"arabic","text_bw":"xaTorN","text_ar":"خَطْرٌ","orth_type":"arrow"},{"kind":"text","text":", TA)"},{"kind":"italic_en","text":"rank; degree of dignity; station;"},{"kind":"text","text":"of a man: (S, A, K, TA:) and"},{"kind":"italic_en","text":"highness of rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"account"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"wealth:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^axoTaArN","text_ar":"اَخْطَارٌ"},{"kind":"text","text":": (A:) accord. to some, it is only used to signify"},{"kind":"italic_en","text":"high rank:"},{"kind":"text","text":"but accord. to others, you say,"},{"kind":"arabic","text_bw":"A_in~ahu laEaZiymu AlxaTari","text_ar":"اـِنَّهُ لَعَظِيمُ الخَطَرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Verily he is of great dignity"},{"kind":"text","text":"] with respect to his good actions and his nobility, and"},{"kind":"arabic","text_bw":"Sagiyru AlxaTari","text_ar":"صَغِيرُ الخَطَرِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"of little rank"},{"kind":"text","text":"] with respect to his evil actions and his ignobleness. (TA.) Also (assumed tropical:)"},{"kind":"italic_en","text":"A lot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"share."},{"kind":"text","text":"(TA.) ―         -b4-  And (assumed tropical:)"},{"kind":"italic_en","text":"A compensation."},{"kind":"text","text":"(TA.)       -A2-  (assumed tropical:)"},{"kind":"italic_en","text":"A like,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fellow,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"in rank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"station,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"in eminence;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"xaTiyrN","text_ar":"خَطِيرٌ"},{"kind":"text","text":". (S, K.) You"},{"kind":"page_break","n":765},{"kind":"text","text":"say,"},{"kind":"arabic","text_bw":"h`*aA xaTarN lih`*aA","text_ar":"هٰذَا خَطَرٌ لِهٰذَا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"xaTiyrN","text_ar":"خَطِيرٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"This is like to that."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"Aljan~apu laA xaTara lahaA","text_ar":"الجَنَّةُ لَا خَطَرَ لَهَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Paradise has not its like."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"fulaAnN layosa lahu xaTiyrN","text_ar":"فُلَانٌ لَيْسَ لَهُ خَطِيرٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one has not his like"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fellow."},{"kind":"text","text":"(TA.)       -A3-  Also [an inf. n. of"},{"kind":"arabic","text_bw":"xaTara","text_ar":"خَطَرَ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"xaTara bibaAliY","text_ar":"خَطَرَ بِبَالِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalaY baAliY","text_ar":"عَلَى بَالِى"},{"kind":"text","text":", accord. to the Msb And hence,] (assumed tropical:)"},{"kind":"italic_en","text":"A vain suggestion"},{"kind":"text","text":"of the devil. (JK.) [See"},{"kind":"arabic","text_bw":"xaATirN","text_ar":"خَاطِرٌ"},{"kind":"text","text":".]"}],"source_refs":["Msb","TA","K","S","A"]}]},"classical_definitions":null}