p", "form": "صاحَبْنا", "in_corpus": true, "count": 13, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "صاحَبْتُ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}], "frequency_in_corpus": 274, "cross_references": {"qac": {"found": true, "lemma_key": "صاحَبَ", "root": "صحب", "pos": "N", "occurrence_count": 12}, "wiktextract": {"found": true, "entry_count": 2, "pos_tags": ["noun", "verb"], "has_etymology": true, "sense_count": 6}, "lanes": {"found": true, "entry_ids": ["n23783"], "search_url": "https://lanelexicon.com/?s=%D8%B5%D8%A7%D8%AD%D9%8E%D8%A8%D9%8E"}}, "translations": {"en": "to accompany", "fa": "همراهی کردن", "ur": "ساتھ جانا", "tr": "eşlik etmek", "id": "menemani", "bn": "সাথে যাওয়া", "es": "acompañar", "fr": "accompagner", "de": "begleiten", "ru": "сопровождать", "zh": "陪伴"}, "definition": {"source": "wiktextract", "senses": [{"pos": "noun", "gloss": "associate, companion, comrade, friend", "examples": [{"text": "صَاحِبِي فِي الْعَمَلِ مُسَاعِدٌ جَيِّدٌ وَنَتَعَاوَنُ مَعًا بِشَكْلٍ مُمْتَازٍ.", "english": "My colleague at work is a helpful and cooperative person, and we work together in a harmonious manner."}]}, {"pos": "noun", "gloss": "adherent, follower"}, {"pos": "noun", "gloss": "man, owner, possessor, holder, master, lord, commander, representative, author"}, {"pos": "noun", "gloss": "inhabitant, dweller", "examples": [{"text": "أَلَمْ يَأْتِهِمْ نَبَأُ الَّذِينَ مِن قَبْلِهِمْ قَوْمِ نُوحٍ وَعَادٍ وَثَمُودَ وَقَوْمِ إِبْرَاهِيمَ وَأَصْحَابِ مَدْيَنَ وَالْمُؤْتَفِكَاتِ ۚ أَتَتْهُمْ رُسُلُهُم بِالْبَيِّنَاتِ ۖ فَمَا كَانَ اللَّهُ لِيَظْلِمَهُمْ وَلَٰكِن كَانُوا أَنْفُسَهُمْ يَظْلِمُونَ"}]}, {"pos": "noun", "gloss": "warden", "examples": [{"text": "وَمَا جَعَلْنَا أَصْحَابَ النَّارِ إِلَّا مَلَائِكَةً[…]"}]}, {"pos": "verb", "gloss": "to accompany, to go with"}]}, "etymology": {"source": "wiktextract", "text": "Derived from the active participle of صَحِبَ (ṣaḥiba, “to accompany”)"}, "ipa": ["/sˤaː.ħib/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n23783", "headword_ar": "صَاحِبٌ", "root": "SHb", "body": [{"kind": "italic_en", "text": "A companion, an associate, a comrade, a fellow,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a friend;"}, {"kind": "text", "text": "(A, MA, KL, TA;)"}, {"kind": "italic_en", "text": "a fellow-traveller:"}, {"kind": "text", "text": "(MA:) ["}, {"kind": "italic_en", "text": "an accomplice:"}, {"kind": "text", "text": "(assumed tropical:)  an"}, {"kind": "italic_en", "text": "accompanier,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "attendant,"}, {"kind": "text", "text": "as applied to a thing:] and (tropical:)"}, {"kind": "italic_en", "text": "a lord,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "master; a possessor, an owner, an occupant, a haver,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "a proprietor;"}, {"kind": "text", "text": "of anything: (A, TA:) it is not trans. like the verb, therefore you may not say,"}, {"kind": "arabic", "text_bw": "zayodN SaAHibN EamorFA", "text_ar": "زَيْدٌ صَاحِبٌ عَمْرًا"}, {"kind": "text", "text": "; (TA;) [i. e.] it is not used as an act. part. n., but as a subst., like"}, {"kind": "arabic", "text_bw": "waAlidN", "text_ar": "وَالِدٌ"}, {"kind": "text", "text": "; (Ham p. 32:) the pl., (S, Msb,) or term applied to a pl. number, (A, K, TA,) is ↓"}, {"kind": "arabic", "text_bw": "SaHobN", "text_ar": "صَحْبٌ", "orth_type": "arrow"}, {"kind": "text", "text": ", (S, A, Msb, K,) a pl. like"}, {"kind": "arabic", "text_bw": "rakobN", "text_ar": "رَكْبٌ"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "raAkibN", "text_ar": "رَاكِبٌ"}, {"kind": "text", "text": ", (S,) or [rather] a quasi-pl. n., (TA,) and"}, {"kind": "arabic", "text_bw": "A^aSoHaAbN", "text_ar": "اَصْحَابٌ"}, {"kind": "text", "text": ", [the most common of all,] (A, Msb,) a pl. like"}, {"kind": "arabic", "text_bw": "A^a$ohaAdN", "text_ar": "اَشْهَادٌ"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "$aAhidN", "text_ar": "شَاهِدٌ"}, {"kind": "text", "text": ", (TA,) or pl. of"}, {"kind": "arabic", "text_bw": "SaHobN", "text_ar": "صَحْبٌ"}, {"kind": "text", "text": ", like"}, {"kind": "arabic", "text_bw": "A^aforaAxN", "text_ar": "اَفْرَاخٌ"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "faroxN", "text_ar": "فَرْخٌ"}, {"kind": "text", "text": ", (S,) and"}, {"kind": "arabic", "text_bw": "A^aSaAHiybu", "text_ar": "اَصَاحِيبُ"}, {"kind": "text", "text": ", (S, K,) pl. of"}, {"kind": "arabic", "text_bw": "A^aSoHaAbN", "text_ar": "اَصْحَابٌ"}, {"kind": "text", "text": ", (S,) and"}, {"kind": "arabic", "text_bw": "SuHobaAnN", "text_ar": "صُحْبَانٌ"}, {"kind": "text", "text": ", (S, K,) a pl. like"}, {"kind": "arabic", "text_bw": "$ub~aAnN", "text_ar": "شُبَّانٌ"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "$aAb~N", "text_ar": "شَابٌّ"}, {"kind": "text", "text": ", (S,) and"}, {"kind": "arabic", "text_bw": "SiHaAbN", "text_ar": "صِحَابٌ"}, {"kind": "text", "text": ", (S, A, K,) a pl. like"}, {"kind": "arabic", "text_bw": "jiyaAEN", "text_ar": "جِيَاعٌ"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "jaAy^iEN", "text_ar": "جَايِعٌ"}, {"kind": "text", "text": ", (S,) and"}, {"kind": "arabic", "text_bw": "SiHaAbapN", "text_ar": "صِحَابَةٌ"}, {"kind": "text", "text": ", (A, K,) in which the"}, {"kind": "arabic", "text_bw": "p", "text_ar": "ة"}, {"kind": "text", "text": "may be regarded, agreeably with analogy, as an affix to the pl."}, {"kind": "arabic", "text_bw": "SiHaAbN", "text_ar": "صِحَابٌ"}, {"kind": "text", "text": "characteristic of the fem. gender, (TA,) and ↓"}, {"kind": "arabic", "text_bw": "SaHaAbapN", "text_ar": "صَحَابَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": ", (S, A, Msb, K,) which is more common than"}, {"kind": "arabic", "text_bw": "SiHaAbapN", "text_ar": "صِحَابَةٌ"}, {"kind": "text", "text": ", (TA,) but the only instance of"}, {"kind": "arabic", "text_bw": "faEaAlapN", "text_ar": "فَعَالَةٌ"}, {"kind": "text", "text": "as the pl. measure of a word of the measure"}, {"kind": "arabic", "text_bw": "faAEilN", "text_ar": "فَاعِلٌ"}, {"kind": "text", "text": ", (L, TA,) or originally an inf. n., (S,) or not so, but a quasi-pl. n., though written like the inf. n. [that is said to be its original], (from a marginal note in a copy of the S,) and ↓"}, {"kind": "arabic", "text_bw": "SuHobapN", "text_ar": "صُحْبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": ", (S, A,) a pl. like"}, {"kind": "arabic", "text_bw": "furohapN", "text_ar": "فُرْهَةٌ"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "faArihN", "text_ar": "فَارِهٌ"}, {"kind": "text", "text": ", (S, TA,) or [rather] a quasi-pl. n.: (TA:) the fem. is"}, {"kind": "arabic", "text_bw": "SaAHibapN", "text_ar": "صَاحِبَةٌ"}, {"kind": "text", "text": ", and its pl. is"}, {"kind": "arabic", "text_bw": "SawaAHibu", "text_ar": "صَوَاحِبُ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "SawaAHibaAtN", "text_ar": "صَوَاحِبَاتٌ"}, {"kind": "text", "text": ", (Mgh, Msb,) the latter mentioned by AAF on the authority of Abu-l- Hasan: (TA:) hence, in a trad. of 'Áïsheh,"}, {"kind": "arabic", "text_bw": "A^anotun~a SawaAHibu yuwsufa", "text_ar": "اَنْتُنَّ صَوَاحِبُ يُوسُفَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Ye are the female companions,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "the mistresses, of Joseph;"}, {"kind": "text", "text": "meaning, enticers to lewdness]; or, as some relate it,"}, {"kind": "arabic", "text_bw": "SawaAHibaAtu yuwsufa", "text_ar": "صَوَاحِبَاتُ يُوسُفَ"}, {"kind": "text", "text": ": (Mgh:) the dim. of"}, {"kind": "arabic", "text_bw": "SaAHibN", "text_ar": "صَاحِبٌ"}, {"kind": "text", "text": "is ↓"}, {"kind": "arabic", "text_bw": "SuwayoHibN", "text_ar": "صُوَيْحِبٌ", "orth_type": "arrow"}, {"kind": "text", "text": "(A) [and that of"}, {"kind": "arabic", "text_bw": "SaAHibahN", "text_ar": "صَاحِبَهٌ"}, {"kind": "text", "text": "is ↓"}, {"kind": "arabic", "text_bw": "SuwayoHibapN", "text_ar": "صُوَيْحِبَةٌ", "orth_type": "arrow"}, {"kind": "text", "text": "]."}, {"kind": "arabic", "text_bw": "yaASaAHi", "text_ar": "يَاصَاحِ"}, {"kind": "text", "text": "for"}, {"kind": "arabic", "text_bw": "yaASaAHibiY", "text_ar": "يَاصَاحِبِى"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "O my companion,"}, {"kind": "text", "text": "&c.,] is the only allowable instance of such curtailing of a prefixed noun, related as heard from the Arabs. (S, TA.) One says,"}, {"kind": "arabic", "text_bw": "fulaAnN SaAHibu SidoqK", "text_ar": "فُلَانٌ صَاحِبُ صِدْقٍ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "Such a one is a good companion,"}, {"kind": "text", "text": "&c.]. (A, * TA.) [And"}, {"kind": "arabic", "text_bw": "SaAHibu jayo$i", "text_ar": "صَاحِبُ جَيْشِ"}, {"kind": "italic_en", "text": "The commander of an army."}, {"kind": "text", "text": "And"}, {"kind": "arabic", "text_bw": "SaAHibu Albariydi", "text_ar": "صَاحِبُ البَرِيدِ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "SaAHibu Al$~uroTapi", "text_ar": "صَاحِبُ الشُّرْطَةِ"}, {"kind": "text", "text": "&c.: see arts."}, {"kind": "arabic", "text_bw": "brd", "text_ar": "برد"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "$rT", "text_ar": "شرط"}, {"kind": "text", "text": "&c. And"}, {"kind": "arabic", "text_bw": "AlS~aAHibu", "text_ar": "الصَّاحِبُ"}, {"kind": "text", "text": ", alone, in post-classical times applied to"}, {"kind": "italic_en", "text": "The Wezeer, when an officer of the pen:"}, {"kind": "text", "text": "see De Sacy's Chrest. Ar., sec. ed., ii. 59.] And"}, {"kind": "arabic", "text_bw": "SaAHibu", "text_ar": "صَاحِبُ"}, {"kind": "arabic", "text_bw": "Alyamiyni", "text_ar": "اليَمِينِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The companion of the right hand"}, {"kind": "text", "text": "] and"}, {"kind": "arabic", "text_bw": "SaAHibu Al$~imaAli", "text_ar": "صَاحِبُ الشِّمَالِ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The companion of the left hand"}, {"kind": "text", "text": "]; appellations of each man's recording angels, who write down his good and evil actions. (A trad. thus commencing in the Jámi' es-Sagheer.) And"}, {"kind": "arabic", "text_bw": "SaAHibu AlS~uwri", "text_ar": "صَاحِبُ الصُّورِ"}, {"kind": "text", "text": "(assumed tropical:)  The angel who is"}, {"kind": "italic_en", "text": "the possessor of the horn."}, {"kind": "text", "text": "(Idem.) [And"}, {"kind": "arabic", "text_bw": "SaAHibu bayotK", "text_ar": "صَاحِبُ بَيْتٍ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "The owner,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "master, of a house"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "tent."}, {"kind": "text", "text": "] And"}, {"kind": "arabic", "text_bw": "A^aSoHaAbu", "text_ar": "اَصْحَابُ"}, {"kind": "arabic", "text_bw": "Aljan~api", "text_ar": "الجَنَّةِ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "The inmates,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "occupants, of Paradise"}, {"kind": "text", "text": "]: (Kur ii. 76, &c.:) and"}, {"kind": "arabic", "text_bw": "A^aSoHaAbu Aln~aAri", "text_ar": "اَصْحَابُ النَّارِ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "The inmates,"}, {"kind": "text", "text": "&c.,"}, {"kind": "italic_en", "text": "of the fire"}, {"kind": "text", "text": "of Hell]. (Kur ii. 37, &c.) And"}, {"kind": "arabic", "text_bw": "SaAHibu sijonK", "text_ar": "صَاحِبُ سِجْنٍ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "An inmate of a prison."}, {"kind": "text", "text": "(Bd and Jel in xii. 39.) And"}, {"kind": "arabic", "text_bw": "SaAHibu AlS~af~i waAljumoEapi", "text_ar": "صَاحِبُ الصَّفِّ وَالجُمْعَةِ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "He who keeps to praying in the first rank and to the prayer of Friday."}, {"kind": "text", "text": "(El-Munáwee on a trad. thus commencing in the Jámi' es-Sagheer.) And"}, {"kind": "arabic", "text_bw": "A^aSojaAbu", "text_ar": "اَصْجَابُ"}, {"kind": "arabic", "text_bw": "Al$~aAfiEiY~i", "text_ar": "الشَّافِعِىِّ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "The followers of the persuasion of EshSháfi'ee:"}, {"kind": "text", "text": "and in like manner one says of the followers of other persuasions. (Msb.) [And"}, {"kind": "arabic", "text_bw": "SaAHibu kitaAbK", "text_ar": "صَاحِبُ كِتَابٍ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "The author of a book."}, {"kind": "text", "text": "] And"}, {"kind": "arabic", "text_bw": "SaAHibu EilomK wamaAlK", "text_ar": "صَاحِبُ عِلْمٍ وَمَالٍ"}, {"kind": "text", "text": "(tropical:)"}, {"kind": "italic_en", "text": "A possessor of science and of wealth."}, {"kind": "text", "text": "(A, TA.) And"}, {"kind": "arabic", "text_bw": "SaAHibu witorK", "text_ar": "صَاحِبُ وِتْرٍ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "One who has a claim for blood-revenge:"}, {"kind": "text", "text": "see an ex. in a verse cited voce"}, {"kind": "arabic", "text_bw": "dar~aAkN", "text_ar": "دَرَّاكٌ"}, {"kind": "text", "text": "]. (Keys Ibn-Rifá'ah, TA in art."}, {"kind": "arabic", "text_bw": "drk", "text_ar": "درك"}, {"kind": "text", "text": ".) [And"}, {"kind": "arabic", "text_bw": "SaAHibu A^amorK wanahoYK", "text_ar": "صَاحِبُ اَمْرٍ وَنَهْىٍ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "One who possesses authority to command and to forbid."}, {"kind": "text", "text": "And"}, {"kind": "arabic", "text_bw": "SaAHibu A^amorK", "text_ar": "صَاحِبُ اَمْرٍ"}, {"kind": "text", "text": "also signifies (assumed tropical:)"}, {"kind": "italic_en", "text": "The author of an affair"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "event"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "action; the doer of a thing; the manager,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "disposer, thereof:"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "one who keeps,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "adheres, to a thing."}, {"kind": "text", "text": "And"}, {"kind": "arabic", "text_bw": "SaAHibu dayonK", "text_ar": "صَاحِبُ دَيْنٍ"}, {"kind": "text", "text": "(assumed tropical:)"}, {"kind": "italic_en", "text": "A debtor."}, {"kind": "text", "text": "] And one says,"}, {"kind": "arabic", "text_bw": "xaraja waSaAHibaAhu Als~ayofu", "text_ar": "خَرَجَ وَصَاحِبَاهُ السَّيْفُ"}, {"kind": "arabic", "text_bw": "waAlr~umoHu", "text_ar": "وَالرُّمْحُ"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "He went forth, the sword and the spear being his companions"}, {"kind": "text", "text": "]. (A, TA.)"}], "source_refs": ["MA", "A", "TA", "S", "Msb", "K", "L", "Mgh"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%B5%D8%A7%D8%AD%D8%A8/", "headword_ar": "صاحب أذن", "entries": [{"lexicon_id": "dictionary_32", "lexicon_en": "Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)", "lexicon_ar": "تكملة المعاجم العربية لرينهارت دوزي", "permalink": "https://arabiclexicon.hawramani.com/?p=49528#9ceb8e", "body_html": "صاحب أذن: رجل أَذن، سامع كل ما يقال له مصدق له. ساذج (بوشر).<br>ذكر من الجمل أذنه: مس المسألة مساً خفيفاً (بوشر)."}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}