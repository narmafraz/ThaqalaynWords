{"lemma":"إِير","slug":"إِير","root":"NTWS","root_slug":"NTWS","root_link":"/words/roots/NTWS","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n1592"],"search_url":"https://lanelexicon.com/?s=%D8%A5%D9%90%D9%8A%D8%B1"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"the penis","tags":["countable","mildly","vulgar"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1592","headword_ar":"اَيْرٌ","root":"Ayr","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"membrum virile; penis; veretrum:"},{"kind":"text","text":"(TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A=yurN","text_ar":"ا=يُرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A=yaArN","text_ar":"ا=يَارٌ"},{"kind":"text","text":"(S, M, K) and [of mult.]"},{"kind":"arabic","text_bw":"A^uyuwrN","text_ar":"اُيُورٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"A^uyurN","text_ar":"اُيُرٌ"},{"kind":"text","text":". (L.) ―         -b2-"},{"kind":"arabic","text_bw":"kaAna A^ayoruhu","text_ar":"كَانَ اَيْرُهُ"},{"kind":"arabic","text_bw":"TawylFA","text_ar":"طَويلًا"},{"kind":"text","text":"is a phrase meaning (tropical:)"},{"kind":"italic_en","text":"He had many male children."},{"kind":"text","text":"(T, TA.)"}],"source_refs":["TA","S","M","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A5%D9%8A%D8%B1/","headword_ar":"إير","entries":[{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10712#81b544","body_html":"<span>إير: إير: مَوْضعٌ بالبادية قال :</span><br><br><span>على أصلاب جأبٍ أَخْدريّ </span><span class=\"red\">...</span><span> من اللائي تَضَمَّنهنّ إيرُ</span><br><br><span>والإيرُ: ريحٌ حارّةٌ ذات إيار، ياؤها في الأصل واوٌ مثل واو الرّيح صارت ياءً لكسرة ما قبلها، وتصغيرها: رُوَيْحة وأُوَيْرة. وقال بعضهم: بل الإير: الشَّمالُ الباردة بلغة هُذيل، قال:</span><br><br><span>وإنّا مساميح إذا هبّت الصَّبا </span><span class=\"red\">...</span><span> وإنّا مساميح إذا الإير هبّتِ</span><br><br><span>وناس يقولون: هو جمع الأوار في هذا البيت كأنّهم يجعلون الأوار من حرّ السّموم.</span>"}]}}