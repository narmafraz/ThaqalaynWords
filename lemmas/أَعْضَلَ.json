ology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29465","headword_ar":"اعضل","root":"EDl","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an affair)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ai$otad~a","text_ar":"اِشْتَدَّ"},{"kind":"text","text":"; (S, O, Msb;) and"},{"kind":"italic_en","text":"as though it were closed against one"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Aisotagolaqa","text_ar":"اِسْتَغْلَقَ"},{"kind":"text","text":". (S, O.) You say,"},{"kind":"arabic","text_bw":"AEDl bihi AlA^amoru","text_ar":"اعضل بِهِ الاَمْرُ"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaDala","text_ar":"عَضَلَ","orth_type":"arrow"},{"kind":"text","text":", (IDrd, O, K,) and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaD~ala","text_ar":"عَضَّلَ","orth_type":"arrow"},{"kind":"text","text":", (TA, and Ham p. 258,) and"},{"kind":"arabic","text_bw":"AEDlhu","text_ar":"اعضلهُ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"The affair was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard, strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult, to him,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A$td~","text_ar":"اشتدّ"},{"kind":"text","text":"; (IDrd, O, K, TA, and Ham ubi suprà) and"},{"kind":"italic_en","text":"as though it were closed against him,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Astglq","text_ar":"استغلق"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"A^aEoDalaniY fulaAnN","text_ar":"اَعْضَلَنِى فُلَانٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"AEDl biY","text_ar":"اعضل بِى"},{"kind":"text","text":", (O,)"},{"kind":"italic_en","text":"Such a one's affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, wearied me."},{"kind":"text","text":"(S, O.) Hence the phrase, in a trad. of 'Omar,"},{"kind":"arabic","text_bw":"A^aEoDala biY A^aholu Alkuwfapi","text_ar":"اَعْضَلَ بِى اَهْلُ الكُوفَةِ"},{"kind":"text","text":", (O,) i. e. ["},{"kind":"italic_en","text":"The people of El-Koofeh have caused that"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the means of effecting my object in their affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, have become strait to me,"},{"kind":"text","text":"(O, TA,)"},{"kind":"italic_en","text":"and the treating them with gentleness has become difficult to me:"},{"kind":"text","text":"(TA:) from"},{"kind":"arabic","text_bw":"EuDaAlN","text_ar":"عُضَالٌ"},{"kind":"text","text":", (O, TA,) as applied to a disease, (O,) or as meaning a “ hard, ” or “ difficult, ” affair, “ which one will not undertake, ” or “ [be able to] manage. ” (TA.) One says of a disease [such as is termed"},{"kind":"arabic","text_bw":"EuDaAl","text_ar":"عُضَال"},{"kind":"text","text":"],"},{"kind":"arabic","text_bw":"AEDl","text_ar":"اعضل"},{"kind":"arabic","text_bw":"AlA^aTib~aA='a","text_ar":"الاَطِبَّا=ءَ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"taEaD~alahumo","text_ar":"تَعَضَّلَهُمْ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"It overcame the physicians,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and wearied them."},{"kind":"text","text":"(TA.) ―         -b3-  See also 2."}],"source_refs":["K","TA","IDrd","O","S"]}]}}