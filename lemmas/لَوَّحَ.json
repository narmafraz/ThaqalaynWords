_ids":["n38107","n38109","n38110"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D9%88%D9%8E%D9%91%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"board, tablet, slab, plank, signboard, sign","examples":[{"text":"فَتَحَ رَجُلٌ دُكَّانَ سَمَكٍ، وَعَلَّقَ فَوْقَ بَابِهِ لَوْحًا صَغِيرًا كَتَبَ عَلَيْهِ: «هُنَا يُبَاعُ ٱلسَّمَكُ».","english":"A man opened a fish shop and hung a small sign above his door on which he wrote: \"Fish are sold here\"."}]},{"pos":"verb","gloss":"to wave, gesticulate, insinuate"}]},"etymology":{"source":"wiktextract","text":"From the root ل و ح (l w ḥ). Cognate with Hebrew לוּחַ (lúakh)."},"ipa":["/lawħ/","/loːħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38107","headword_ar":"لوّح","root":"lwH","body":[{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"talowiyHN","text_ar":"تَلْوِيحٌ"},{"kind":"text","text":", TA,)"},{"kind":"italic_en","text":"He heated"},{"kind":"text","text":"(S, K) a thing with fire. (S; see MA, and see 1.) ―         -b2-"},{"kind":"arabic","text_bw":"lw~Hhu Al$~ayobu","text_ar":"لوّحهُ الشَّيْبُ"},{"kind":"italic_en","text":"Hoariness altered him;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"rendered him white."},{"kind":"text","text":"(K, TA.) ―         -b3-  See 1, and 4."}],"source_refs":["S","K"]},{"entry_id":"n38109","headword_ar":"لَوْحٌ","root":"lwH","body":[{"kind":"italic_en","text":"A look;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"naZorapN","text_ar":"نَظْرَةٌ"},{"kind":"text","text":"; [or rather"},{"kind":"italic_en","text":"a glance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"light"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quick look;"},{"kind":"text","text":"] like"},{"kind":"arabic","text_bw":"lamoHapN","text_ar":"لَمْحَةٌ"},{"kind":"text","text":". (K.)       -A2-  See"},{"kind":"arabic","text_bw":"luwHN","text_ar":"لُوحٌ"},{"kind":"text","text":"-A3-"},{"kind":"italic_en","text":"Any broad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wide, and thin, thing, such as a board"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plank"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, of wood"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of bone:"},{"kind":"text","text":"(T, M, Msb, K:) pl."},{"kind":"arabic","text_bw":"A^alowaAHN","text_ar":"اَلْوَاحٌ"},{"kind":"text","text":", and pl. pl."},{"kind":"arabic","text_bw":"A^alaAwiyHu","text_ar":"اَلَاوِيحُ"},{"kind":"text","text":". (K.) A word of this kind has not a pl. of the measure"},{"kind":"arabic","text_bw":"A^afoEulN","text_ar":"اَفْعُلٌ"},{"kind":"text","text":", because dammeh to the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is disliked. (Sb.) ―         -b2-"},{"kind":"arabic","text_bw":"A^alowaAHN","text_ar":"اَلْوَاحٌ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"lawaAy^iHu","text_ar":"لَوَايِحُ"},{"kind":"text","text":", q. v."},{"kind":"page_break","n":2680},{"kind":"text","text":"―         -b3-  The"},{"kind":"italic_en","text":"scapula"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shoulder-blade,"},{"kind":"text","text":"(T, S, Msb, K,)"},{"kind":"italic_en","text":"when it is written upon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inscribed."},{"kind":"text","text":"(T, Msb, K.) ―         -b4-"},{"kind":"italic_en","text":"Any wide bone:"},{"kind":"text","text":"(S, Msb:) or"},{"kind":"italic_en","text":"any bone"},{"kind":"text","text":"of the body,"},{"kind":"italic_en","text":"except the bones called"},{"kind":"arabic","text_bw":"qaSab","text_ar":"قَصَب"},{"kind":"italic_en","text":"of the arms and legs."},{"kind":"text","text":"(Msb.) See also"},{"kind":"arabic","text_bw":"milowaAHN","text_ar":"مِلْوَاحٌ"},{"kind":"text","text":". ―         -b5-"},{"kind":"arabic","text_bw":"lamo yaboqa minohu A_il~aA AlAlwAH","text_ar":"لَمْ يَبْقَ مِنْهُ اـِلَّا الالواح"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"There remained of him nothing but the wide bones."},{"kind":"text","text":"Said of one that is lean, or emaciated. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"lawoHu Alkatifi","text_ar":"لَوْحُ الكَتِفِ"},{"kind":"italic_en","text":"The smooth part of the shoulder-blade, where its projecting part"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Eayor","text_ar":"عَيْر"},{"kind":"text","text":"[so I read for"},{"kind":"arabic","text_bw":"gyr","text_ar":"غير"},{"kind":"text","text":", in the L])"},{"kind":"italic_en","text":"terminates, in the upper portion."},{"kind":"text","text":"(L.) ―         -b7-"},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ"},{"kind":"italic_en","text":"That"},{"kind":"text","text":"["},{"kind":"italic_en","text":"meaning a tablet"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon which one writes."},{"kind":"text","text":"(S.) ―         -b8-"},{"kind":"arabic","text_bw":"katabonaA lahu fiY AlA^alowaAHi","text_ar":"كَتَبْنَا لَهُ فِى الاَلْوَاحِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"We wrote for him upon the tablets,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tables"},{"kind":"text","text":"]. (Kur vii. 142.) They are said to have been two tablets; but it is allowable to call two tablets"},{"kind":"arabic","text_bw":"AlwAH","text_ar":"الواح"},{"kind":"text","text":". (Zj.) ―         -b9-"},{"kind":"arabic","text_bw":"All~awoHu AlmaHofuwZu","text_ar":"اللَّوْحُ المَحْفُوظُ"},{"kind":"text","text":", mentioned in the Kur, [chap. lxxxv. last verse,"},{"kind":"italic_en","text":"The Preserved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Guarded, Tablet, whereon are said to be inscribed all the divine decrees;"},{"kind":"text","text":"] (tropical:)"},{"kind":"italic_en","text":"the depository of the decrees,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"willed events, ordained by God:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^um~u AlkitaAbi","text_ar":"اُمُّ الكِتَابِ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"a light which appears to the angels, showing to them the things which they are commanded to do, and which they obey."},{"kind":"text","text":"(Msb.)"}],"source_refs":["T","M","Msb","K","S","TA"]},{"entry_id":"n38110","headword_ar":"لُوحٌ","root":"lwH","body":[{"kind":"text","text":"(S, K) and ↓"},{"kind":"arabic","text_bw":"lawoHN","text_ar":"لَوْحٌ","orth_type":"arrow"},{"kind":"text","text":", (Lh, K,) but the former is of higher authority, (K,) and the latter is mentioned by none but Lh, (TA,) The"},{"kind":"italic_en","text":"air,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"atmosphere,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"between heaven and earth:"},{"kind":"text","text":"(S:) the"},{"kind":"italic_en","text":"air next to the higher part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the clouds, of the sky;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sukaAk","text_ar":"سُكَاك"},{"kind":"text","text":": this is its meaning in the phrase"},{"kind":"arabic","text_bw":"laA A^afoEalu *`lika walawo nazawota fiY All~uwHi","text_ar":"لَا اَفْعَلُ ذٰلِكَ وَلَوْ نَزَوْتَ فِى اللُّوحِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will not do that even if thou leap into the air next to the higher part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the clouds, of the sky"},{"kind":"text","text":"]. (S.)"}],"source_refs":["S","K","Lh","TA"]}]},"classical_definitions":null}