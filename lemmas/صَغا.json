m":"d"},{"role":"present_3fd","form":"تَصْغُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُصْغَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُصْغَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْغُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْغُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْغُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُصْغَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصْغُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْغُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَغَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَغَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَصْغ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصْغ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُصْغَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُصْغَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n24392","n24394"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%BA%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to incline, to bend, to lean"},{"pos":"verb","gloss":"to incline one's ear, to hearken, to listen"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24392","headword_ar":"صَغَا","root":"Sgw and SgY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaSoguw","text_ar":"يَصْغُو"},{"kind":"text","text":"; (S, Msb, K;) and ["},{"kind":"arabic","text_bw":"SagaY","text_ar":"صَغَى"},{"kind":"text","text":", aor.]"},{"kind":"arabic","text_bw":"yaSogiY","text_ar":"يَصْغِى"},{"kind":"text","text":", (S, TA, and so in some copies of the K,) or"},{"kind":"arabic","text_bw":"yaSogaY","text_ar":"يَصْغَى"},{"kind":"text","text":"; (Msb, and so in some copies of the K, and in the M, but it is said in the TA that it is correctly"},{"kind":"arabic","text_bw":"yaSogiY","text_ar":"يَصْغِى"},{"kind":"text","text":", with kesr, as in the S;) inf. n."},{"kind":"arabic","text_bw":"Suguw~N","text_ar":"صُغُوٌّ"},{"kind":"text","text":"; (S, Msb, K;) and"},{"kind":"arabic","text_bw":"SagiYa","text_ar":"صَغِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaSogaY","text_ar":"يَصْغَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"SagFA","text_ar":"صَغًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SugiY~N","text_ar":"صُغِىٌّ"},{"kind":"text","text":"; (S, Msb, K;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it inclined,"},{"kind":"text","text":"(S, Msb, K, TA,)"},{"kind":"arabic","text_bw":"A_ilaY Al$~aYo'i","text_ar":"اـِلَى الشَّىْءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the thing"},{"kind":"text","text":"], (TA,) or"},{"kind":"arabic","text_bw":"A_ilaY ka*aA","text_ar":"اـِلَى كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to such a thing"},{"kind":"text","text":"]: (Msb:) or they signify [sometimes, for the meaning expl. above is unquestionably correct, and is that which is predominant,]"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"had an inclining of his"},{"kind":"arabic","text_bw":"Hanak","text_ar":"حَنَك"},{"kind":"text","text":"[here app. meaning the"},{"kind":"italic_en","text":"mouth"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"part below the mouth"},{"kind":"text","text":"]; (K, TA;) or"},{"kind":"italic_en","text":"of one of his lips;"},{"kind":"text","text":"thus correctly, as in the M and A;"},{"kind":"arabic","text_bw":"$idoqayohi","text_ar":"شِدْقَيْهِ"},{"kind":"text","text":"in [some of] the copies of the K [and"},{"kind":"arabic","text_bw":"$iq~ayohi","text_ar":"شِقَّيْهِ"},{"kind":"text","text":"in others] being a mistake for"},{"kind":"arabic","text_bw":"$afatayohi","text_ar":"شَفَتَيْهِ"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"Sagato A_ilayohi A^u*unuhu","text_ar":"صَغَتْ اـِلَيْهِ اُذُنُهُ"},{"kind":"italic_en","text":"His ear inclined to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(TA.) And hence, in the Kur [lxvi. 4],"},{"kind":"arabic","text_bw":"faqado Sagato quluwbukumaA","text_ar":"فَقَدْ صَغَتْ قُلُوبُكُمَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"For the hearts of you two have inclined"},{"kind":"text","text":"to that which is not right]. (Msb.) And"},{"kind":"arabic","text_bw":"Sagati Aln~ujuwmu","text_ar":"صَغَتِ النُّجُومُ"},{"kind":"text","text":", (S, Msb,) and"},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"The stars,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the sun, inclined to setting."},{"kind":"text","text":"(S, Msb, K.) And"},{"kind":"arabic","text_bw":"SagaA Alr~ajulu","text_ar":"صَغَا الرَّجُلُ"},{"kind":"italic_en","text":"The man inclined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaned, on one side:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bowed, himself upon his bow."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"SagiYa","text_ar":"صَغِىَ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"EalaY Alqawomi","text_ar":"عَلَى القَوْمِ"},{"kind":"text","text":"inf. n."},{"kind":"arabic","text_bw":"SagFA","text_ar":"صَغًا"},{"kind":"text","text":", [as though meaning"},{"kind":"italic_en","text":"He inclined to set himself against the people"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"] is said of one when his love, or affection, is with such as are not of the said people, or party. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"SagiYa","text_ar":"صَغِىَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaSogaY","text_ar":"يَصْغَى"},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"SagFA","text_ar":"صَغًا"},{"kind":"text","text":"agreeably with the S and M, accord. to the copies of the K, erroneously,"},{"kind":"arabic","text_bw":"SagoYN","text_ar":"صَغْىٌ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"SugiY~N","text_ar":"صُغِىٌّ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"He inclined and gave ear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hearkened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listened."},{"kind":"text","text":"(K. [See also the next paragraph.])"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n24394","headword_ar":"صَغًا","root":"Sgw and SgY","body":[{"kind":"text","text":"an inf. n. of"},{"kind":"arabic","text_bw":"SagiYa","text_ar":"صَغِىَ"},{"kind":"text","text":"[q. v.]: and also [used as] a simple subst. [meaning"},{"kind":"italic_en","text":"Inclination"},{"kind":"text","text":"]. (TA.) One says,"},{"kind":"arabic","text_bw":"A^aqaAma SagaAhu","text_ar":"اَقَامَ صَغَاهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He rectified"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his inclination."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"maEaka","text_ar":"مَعَكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sagowuhu","text_ar":"صَغْوُهُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Sigowuhu","text_ar":"صِغْوُهُ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"SagaAhu","text_ar":"صَغَاهُ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"His inclination"},{"kind":"text","text":"["},{"kind":"italic_en","text":"is with thee,"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"is agreeable with thine"},{"kind":"text","text":"]. (AZ, S, K.) In [some of] the copies of the K"},{"kind":"arabic","text_bw":"Sagowuhu","text_ar":"صَغْوُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Sigowuhu","text_ar":"صِغْوُهُ"},{"kind":"text","text":"are written"},{"kind":"arabic","text_bw":"SagowapN","text_ar":"صَغْوَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SigowapN","text_ar":"صِغْوَةٌ"},{"kind":"text","text":", which would lead the inadvertent to imagine these two words to be syn. with the word there next preceding, namely,"},{"kind":"arabic","text_bw":"SagowaA='u","text_ar":"صَغْوَا=ءُ"},{"kind":"text","text":"as an epithet applied to the sun. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}