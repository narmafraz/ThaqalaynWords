{"lemma":"كُزَّ","slug":"كُزَّ","root":"ك.ز.ز","root_slug":"ك-ز-ز","root_link":"/words/roots/ك-ز-ز","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"كُزِزْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"كُزِزْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"كُزِزْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"كُزِزْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"كُزِزْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"كُزَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"كُزَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"كُزّا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"كُزَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"كُزُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"كُزِزْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَكْزَز","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَكَزِّي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَكَزِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَكَزّا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَكَزّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَكَزُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَكَزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَكْزَزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَكْزَز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَكْزَز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكَزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكَزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكَزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكَزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكَزُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكَزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْزَزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"كُزِزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كُزِزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n36909","n36911"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8F%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36909","headword_ar":"كَزَّ","root":"kz","body":[{"kind":"text","text":", [second pers."},{"kind":"arabic","text_bw":"kazuzota","text_ar":"كَزُزْتَ"},{"kind":"text","text":",] (K,) aor."},{"kind":"text","text":", (MS, TA,) inf. n."},{"kind":"arabic","text_bw":"kazaAzapN","text_ar":"كَزَازَةٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"kuzuwzapN","text_ar":"كُزُوزَةٌ"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"It dried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough; and contracted."},{"kind":"text","text":"(S, A, K.) You say,"},{"kind":"arabic","text_bw":"kaz~ato yaduhu","text_ar":"كَزَّتْ يَدُهُ"},{"kind":"italic_en","text":"His hand became dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, and contracted."},{"kind":"text","text":"(A.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"kaz~ato xuTaAhu","text_ar":"كَزَّتْ خُطَاهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His steps were"},{"kind":"text","text":"["},{"kind":"italic_en","text":"contracted,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"near together."},{"kind":"text","text":"(A, K.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"kaz~ato nafosuhu","text_ar":"كَزَّتْ نَفْسُهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aktz~t","text_ar":"اكتزّت","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His soul became contracted;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"he became niggardly"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Alr~ajulu","text_ar":"الرَّجُلُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aktz~","text_ar":"اكتزّ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man shrank"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from giving"},{"kind":"text","text":"]. (K, * TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN laA yahotaz~u wal`kin~ahu","text_ar":"فُلَانٌ لَا يَهْتَزُّ وَلٰكِنَّهُ"},{"kind":"arabic","text_bw":"yakotaz~u","text_ar":"يَكْتَزُّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one does not rejoice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is not active,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prompt, and brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerfully excited, to give, but he shrinks from giving"},{"kind":"text","text":"]. (A, TA.) ["},{"kind":"arabic","text_bw":"kazazN","text_ar":"كَزَزٌ"},{"kind":"text","text":"(q. v. infra) seems to be an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"kaz~a","text_ar":"كَزَّ"},{"kind":"text","text":", second pers."},{"kind":"arabic","text_bw":"kazizota","text_ar":"كَزِزْتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", in the sense of ↓"},{"kind":"arabic","text_bw":"Aktz~","text_ar":"اكتزّ","orth_type":"arrow"},{"kind":"text","text":"as explained above.] ―         -b4-"},{"kind":"arabic","text_bw":"kuz~a","text_ar":"كُزَّ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"shrank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became contracted, in consequence of the cold:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he became affected by what is termed"},{"kind":"arabic","text_bw":"kuzaAz","text_ar":"كُزَاز"},{"kind":"text","text":": (A, K:) or"},{"kind":"italic_en","text":"he became affected by a rheum."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"kaz~ahu Albarodu","text_ar":"كَزَّهُ البَرْدُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ald~aA='u","text_ar":"الدَّا=ءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The cold,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"disease, made him to shrink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become contracted, and to be affected with a tremour"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"arabic","text_bw":"kaz~a Al$~aYo'a","text_ar":"كَزَّ الشَّىْءَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kaz~N","text_ar":"كَزٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He made the thing narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait."},{"kind":"text","text":"(S, K.) ―         -b3-"},{"kind":"arabic","text_bw":"kaz~ati AlmaroA^apu dumolujahaA","text_ar":"كَزَّتِ المَرْاَةُ دُمْلُجَهَا"},{"kind":"text","text":", (A, TA,) aor."},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The woman filled her armlet with her arm."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["K","MS","TA","S","A"]},{"entry_id":"n36911","headword_ar":"كَزٌّ","root":"kz","body":[{"kind":"italic_en","text":"Dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough; and contracted:"},{"kind":"text","text":"(A, K:) pl."},{"kind":"arabic","text_bw":"kuz~N","text_ar":"كُزٌّ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"yadN kaz~apN","text_ar":"يَدٌ كَزَّةٌ"},{"kind":"italic_en","text":"A dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, and contracted, hand."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"xa$abapN kaz~apN","text_ar":"خَشَبَةٌ كَزَّةٌ"},{"kind":"italic_en","text":"A stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"hard,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"and crooked, piece of wood."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"qanaApN kaz~apN","text_ar":"قَنَاةٌ كَزَّةٌ"},{"kind":"italic_en","text":"A hard and crooked spear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spear-shaft."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qawosN kaz~apN","text_ar":"قَوْسٌ كَزَّةٌ"},{"kind":"italic_en","text":"A stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, bow:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"a bow whereof the arrow does not go far, by reason of the narrowness of the former:"},{"kind":"text","text":"(TA:) Aboo-Ziyád says, that the bow thus called is the"},{"kind":"italic_en","text":"smallest of bows:"},{"kind":"text","text":"(AHn, TA:) pl."},{"kind":"arabic","text_bw":"qisiY~N kuz~aAtN","text_ar":"قِسِىٌّ كُزَّاتٌ"},{"kind":"text","text":". (A.) And"},{"kind":"arabic","text_bw":"bakorapN kaz~apN","text_ar":"بَكْرَةٌ كَزَّةٌ"},{"kind":"italic_en","text":"A narrow pulley-sheave, that makes a loud creaking"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"by reason of its narrowness."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"*ahabN kaz~N","text_ar":"ذَهَبٌ كَزٌّ"},{"kind":"italic_en","text":"Tough gold:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"very hard gold."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"jamalN kaz~N","text_ar":"جَمَلٌ كَزٌّ"},{"kind":"italic_en","text":"A hardy, strong camel."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"rajulN kaz~N","text_ar":"رَجُلٌ كَزٌّ"},{"kind":"text","text":", (S, A,) and"},{"kind":"arabic","text_bw":"kaz~N Alyadayoni","text_ar":"كَزٌّ اليَدَيْنِ"},{"kind":"text","text":", (S, A, K,) (tropical:)"},{"kind":"italic_en","text":"A niggardly man."},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"of little beneficence,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and of little compliance:"},{"kind":"text","text":"(A, TA:) pl."},{"kind":"arabic","text_bw":"kuz~N","text_ar":"كُزٌّ"},{"kind":"text","text":". (S.) ―         -b3-"},{"kind":"arabic","text_bw":"wajohN kaz~N","text_ar":"وَجْهٌ كَزٌّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ugly, face."},{"kind":"text","text":"(K.)"}],"source_refs":["A","K","TA","S","AHn"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%83%D8%B2/","headword_ar":"كز","entries":[{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=10550#e57bdf","body_html":"كز<br>الكَزَازُ: اليُبْسُ والانْقِباضُ. ورَجُلٌ كَزٌ: قَليلُ الخَيْرِ والمُوَاتاة. ويُقال للشَيْءِ إذا جَعَلْتَه ضَيقاً: كَزَزْتُه فهو مَكْزُوْزٌ. واكْتَزَّ الرجُلُ: من الكَزَازة.<br>والكُزَازُ: داءٌ يَأخُذُ من شِدَّة البَرْدِ والعَفَن، ورَجُلٌ مَكْزُوْزٌ. والكَزُّة من القِسِيِّ: التي إذا نُزِعَ فيها لم تَسْتَغْرِق السَّهْمَ."},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=10550#704d60","body_html":"كز: كزّ على: شدّ، ضغط، عَصَرَ (بوشر) و (ألف ليلة وليلة 6، 196): فيقوّي عضّته ويكزّ بأسنانه على أذنه.<br>كَزَّ على: صرَّ، صرَّف (الأسنان). (هلو، ألف ليلة وليلة 25:2) صار يكزّ على أسنانه.<br>كزّ من: كزّت نفس فلان من كذا (عامية) (في محيط المحيط: والعامة تقول كزّت نفس فلان من كذا أبته وكرهته أو هو كظّ بالظاء).<br>كزاز: تشنج، تقلّص عضلي لا إرادي.<br>كزاز: (تيتانوس) (الجريدة الآسيوية 1853، 1، 342، باين سميث 1433)."},{"lexicon_id":"dictionary_3","lexicon_en":"Al-Khalīl b. Aḥmad al-Farāhīdī, Kitāb al-ʿAin (d. 786 CE)","lexicon_ar":"كتاب العين للخليل بن أحمد الفراهيدي","permalink":"https://arabiclexicon.hawramani.com/?p=10550#c079f8","body_html":"<span class=\"title1\">باب الكاف والزاي ك ز مستعمل فقط</span><br><br><span>كز: الكَزازةُ: اليبس والانقباض. ورجل كَزٌّ: صلب، قليل الخير والمواتاة.</span><span> </span><a></a><span>وخشبة كزة. (أي) فيها يبس واعوجاج. وذهب كز: صلب جداً. قال الضرير: الكز في الناس، فأما في الخشب فلا. وكَزَزْتُ الشيء: ضيقته فهو مَكزوزٌ، قال: </span><br><br><span>يا رب بيضاء تكُزُّ الدملجا </span><span class=\"red\">...</span><span> تزوجت شيخاً كبيراً كوسجا</span><br><br><span>والكُزازُ: داء يأخذ من شدة البرد والعفز، تعتري [منه] الرعدة. يقال: رجل مكزوز.</span>"},{"lexicon_id":"dictionary_8","lexicon_en":"Ibn Sīda al-Mursī, Al-Muḥkam wa-l-Muḥīṭ al-Aʿẓam (d. 1066 CE)","lexicon_ar":"المحكم والمحيط الأعظم لابن سيده الأندلسي","permalink":"https://arabiclexicon.hawramani.com/?p=10550#86458e","body_html":"<span class=\"title1\">الْكَاف وَالزَّاي</span><br><br><span>الكَرْزَن، والكِرْزِن، والكِرزِينُ: الفأس لَهَا رَأس وَاحِد.</span><br><br><span>وَقيل: الكِريزن: نَحْو المطرقة. وَقَالَ أَبُو حنيفَة: الكَرْزَن، بِفَتْح الْكَاف وَالزَّاي جَمِيعًا: الفأس لَهَا حد، قَالَ: وأحسبني قد سَمِعت الكِرْزَن، بِكَسْر الْكَاف وَفتح الزَّاي.</span><br><br><span>الكُزْبُرَة: لُغَة فِي الكُسْبُرَة.</span><br><br><span>وَقَالَ أَبُو حنيفَة: الكُزْبَرة بِفَتْح الْبَاء عَرَبِيَّة مَعْرُوفَة.</span><br><br><span>والكَرْزَم: فأس مفلولة الْحَد.</span><br><br><span>وَقيل: الَّتِي لَهَا حد كالكَرْزَن.</span><br><br><span>وَهِي الكِرْزِيم، أَيْضا، عَن أبي حنيفَة، وَأنْشد:</span><br><br><span>إِن الدهور علينا ذاتُ كِرْزيم</span><br><br><span>أَي تَنْحتنا بالنوائب والهموم كَمَا تنحت الْخَشَبَة بِهَذِهِ الْقدوم.</span><br><br><span>والكِرْزمُ: الشدَّة من شَدَائِد الدَّهْر.</span><br><br><span>وَهِي: الكِرازِم على الْقيَاس والكرازيم على غير الْقيَاس. وَيحْتَمل أَن يكون قَوْله:</span><br><br><span>إِن الدهور علينا ذَات كرزيم</span><br><br><span>أَرَادَ بِهِ الشدَّة، فكرازيم إِذا جمع على الْقيَاس.</span><br><br><span>وَرجل مكرزَم: قصير مُجْتَمع.</span><br><br><span>والكَرْزَمة: أكل نصف النَّهَار.</span><br><br><span>وكَرْزَم: اسْم.</span><br><br><span>والزَّوْنْكَل: الْقصير.</span><br><br><span>وَكَذَلِكَ: الزَّوَنَّك.</span><br><br><span>وَقيل: إِنَّه ثلاثي، وَقد تقدم، قَالَ الشَّاعِر:</span><br><br><span>وبَعْلُها زَوَنَّك زَوَنْزَي</span><br><br><span>يَفْزَع إِن فُزِّع بالضَّبغْطَي</span><br><br><span>والزَّنْكمَة: الزَّكمة.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=10550#164f22","body_html":"<h3>كز</h3><span class=\"sense\">1</span> كَزَّ, [second <abbr title=\"Persian (Farsi)\">Pers\\.</abbr> كَزُزْتَ,] (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ (<abbr title=\"Mukhtār al-Ṣiḥāḥ of al-Rāzī\">MS</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> كَزَازَةٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and كُزُوزَةٌ, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) It dried, or dried up; or became stiff, rigid, or tough; and contracted. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) You say, كَزَّتْ يَدُهُ His hand became dry, or stiff, rigid, or tough, and contracted. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) <span class=\"sub-sense\">b2:</span> [Hence,] كَزَّتْ خُطَاهُ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) His steps were [contracted, or] near together. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b3:</span> [Hence also,] كَزَّتْ نَفْسُهُ and ↓ اكتزّت (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [His soul became contracted; meaning, he became niggardly]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) And الرَّجُلُ ↓ اكتزّ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The man shrank [from giving]. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) You say, فُلَانٌ لَا يَهْتَزُّ وَلٰكِنَّهُ يَكْتَزُّ (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [Such a one does not rejoice, or is not active, or prompt, and brisk, or cheerfully excited, to give, but he shrinks from giving]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) [كَزَزٌ (<abbr title=\"quod vide (i.e. on this [matter], go see...)\">q. v.</abbr> infra) seems to be an <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of which the verb is كَزَّ, second <abbr title=\"Persian (Farsi)\">Pers\\.</abbr> كَزِزْتَ, <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـَ in the sense of ↓ اكتزّ as explained above.] <span class=\"sub-sense\">b4:</span> كُزَّ He (a man) shrank, or became contracted, in consequence of the cold: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>:) or he became affected by what is termed كُزَاز: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or he became affected by a rheum. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">A2:</span> كَزَّهُ البَرْدُ and الدَّآءُ [The cold, and disease, made him to shrink, or become contracted, and to be affected with a tremour]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) <span class=\"sub-sense\">b2:</span> كَزَّ الشَّىْءَ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> كَزٌّ, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) He made the thing narrow, or strait. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b3:</span> كَزَّتِ المَرْأَةُ دُمْلُجَهَا, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) The woman filled her armlet with her arm. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) 4 اكزّهُ اللّٰهُ God smote him, or afflicted him, with what is termed كُزَاز. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) 8 إِكْتَزَ3َ see 1, in three places.<br><br>كَزٌّ Dry, or dried up; or stiff, rigid, or tough; and contracted: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> كُزٌّ. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) You say, يَدٌ كَزَّةٌ A dry, or stiff, rigid, or tough, and contracted, hand. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) And خَشَبَةٌ كَزَّةٌ A stiff, rigid, or tough, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) or hard, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>,) and crooked, piece of wood. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And قَنَاةٌ كَزَّةٌ A hard and crooked spear or spear-shaft. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) and قَوْسٌ كَزَّةٌ A stiff, rigid, or tough, bow: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or a bow whereof the arrow does not go far, by reason of the narrowness of the former: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) Aboo-Ziyád says, that the bow thus called is the smallest of bows: (<abbr title=\"Abū Ḥanīfah al-Dīnawarī, author of the Book of Plants\">AHn</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> قِسِىٌّ كُزَّاتٌ. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) And بَكْرَةٌ كَزَّةٌ A narrow pulley-sheave, that makes a loud creaking (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) by reason of its narrowness. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And ذَهَبٌ كَزٌّ Tough gold: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>:) or very hard gold. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) And جَمَلٌ كَزٌّ A hardy, strong camel. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> رَجُلٌ كَزٌّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>,) and كَزٌّ اليَدَيْنِ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) A niggardly man. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) of little beneficence, (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) and of little compliance: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> كُزٌّ. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b3:</span> وَجْهٌ كَزٌّ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) A foul, or an ugly, face. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) كَزَزٌ Hardness and crookedness in a piece of wood, or in a spear or spear-shaft. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b2:</span> (<abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) Niggardliness, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and littleness of compliance and of beneficence. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See 1.<br><br>كُزَازٌ (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) and ↓ كُزَّازٌ, (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or, <abbr title=\"according\">accord.</abbr> to <abbr title=\"al-Azharī, author of the Tahdhīb\">Az</abbr>, the latter is the correct form, and the former is vulgar, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>,) A contraction and tremour arising from cold: (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>:) or a tremour arising from intense cold: (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or a certain disease arising from intense cold; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) being a spasmodic contraction so occasioned: or, <abbr title=\"according\">accord.</abbr> to the physicians, arising from the egress of much blood: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or a certain disease arising from cold, in consequence of which the patient trembles until he dies. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) كُزَّازٌ: see كُزَازٌ.<br><br>مَكْزُوزٌ Made narrow, or strait. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>.) <span class=\"sub-sense\">b2:</span> A man affected by what is termed كُزَاز: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or affected by a rheum. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)"}]}}