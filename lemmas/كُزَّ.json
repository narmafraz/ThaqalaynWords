":"d"},{"role":"present_2mp","form":"تَكَزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَكَزُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَكْزَزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَكْزَز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَكْزَز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكَزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكَزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكَزّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكَزّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكَزُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكَزُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْزَزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكَزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"كُزِزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كُزِزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n36909","n36911"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8F%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n36909","headword_ar":"كَزَّ","root":"kz","body":[{"kind":"text","text":", [second pers."},{"kind":"arabic","text_bw":"kazuzota","text_ar":"كَزُزْتَ"},{"kind":"text","text":",] (K,) aor."},{"kind":"text","text":", (MS, TA,) inf. n."},{"kind":"arabic","text_bw":"kazaAzapN","text_ar":"كَزَازَةٌ"},{"kind":"text","text":"(S, A, K) and"},{"kind":"arabic","text_bw":"kuzuwzapN","text_ar":"كُزُوزَةٌ"},{"kind":"text","text":", (A, K,)"},{"kind":"italic_en","text":"It dried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough; and contracted."},{"kind":"text","text":"(S, A, K.) You say,"},{"kind":"arabic","text_bw":"kaz~ato yaduhu","text_ar":"كَزَّتْ يَدُهُ"},{"kind":"italic_en","text":"His hand became dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, and contracted."},{"kind":"text","text":"(A.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"kaz~ato xuTaAhu","text_ar":"كَزَّتْ خُطَاهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His steps were"},{"kind":"text","text":"["},{"kind":"italic_en","text":"contracted,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"near together."},{"kind":"text","text":"(A, K.) ―         -b3-  [Hence also,]"},{"kind":"arabic","text_bw":"kaz~ato nafosuhu","text_ar":"كَزَّتْ نَفْسُهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aktz~t","text_ar":"اكتزّت","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His soul became contracted;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"he became niggardly"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Alr~ajulu","text_ar":"الرَّجُلُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aktz~","text_ar":"اكتزّ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The man shrank"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from giving"},{"kind":"text","text":"]. (K, * TA.) You say,"},{"kind":"arabic","text_bw":"fulaAnN laA yahotaz~u wal`kin~ahu","text_ar":"فُلَانٌ لَا يَهْتَزُّ وَلٰكِنَّهُ"},{"kind":"arabic","text_bw":"yakotaz~u","text_ar":"يَكْتَزُّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one does not rejoice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is not active,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prompt, and brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerfully excited, to give, but he shrinks from giving"},{"kind":"text","text":"]. (A, TA.) ["},{"kind":"arabic","text_bw":"kazazN","text_ar":"كَزَزٌ"},{"kind":"text","text":"(q. v. infra) seems to be an inf. n. of which the verb is"},{"kind":"arabic","text_bw":"kaz~a","text_ar":"كَزَّ"},{"kind":"text","text":", second pers."},{"kind":"arabic","text_bw":"kazizota","text_ar":"كَزِزْتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", in the sense of ↓"},{"kind":"arabic","text_bw":"Aktz~","text_ar":"اكتزّ","orth_type":"arrow"},{"kind":"text","text":"as explained above.] ―         -b4-"},{"kind":"arabic","text_bw":"kuz~a","text_ar":"كُزَّ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"shrank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became contracted, in consequence of the cold:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he became affected by what is termed"},{"kind":"arabic","text_bw":"kuzaAz","text_ar":"كُزَاز"},{"kind":"text","text":": (A, K:) or"},{"kind":"italic_en","text":"he became affected by a rheum."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"kaz~ahu Albarodu","text_ar":"كَزَّهُ البَرْدُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ald~aA='u","text_ar":"الدَّا=ءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The cold,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"disease, made him to shrink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become contracted, and to be affected with a tremour"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"arabic","text_bw":"kaz~a Al$~aYo'a","text_ar":"كَزَّ الشَّىْءَ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"kaz~N","text_ar":"كَزٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He made the thing narrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strait."},{"kind":"text","text":"(S, K.) ―         -b3-"},{"kind":"arabic","text_bw":"kaz~ati AlmaroA^apu dumolujahaA","text_ar":"كَزَّتِ المَرْاَةُ دُمْلُجَهَا"},{"kind":"text","text":", (A, TA,) aor."},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The woman filled her armlet with her arm."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["K","MS","TA","S","A"]},{"entry_id":"n36911","headword_ar":"كَزٌّ","root":"kz","body":[{"kind":"italic_en","text":"Dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough; and contracted:"},{"kind":"text","text":"(A, K:) pl."},{"kind":"arabic","text_bw":"kuz~N","text_ar":"كُزٌّ"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"yadN kaz~apN","text_ar":"يَدٌ كَزَّةٌ"},{"kind":"italic_en","text":"A dry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, and contracted, hand."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"xa$abapN kaz~apN","text_ar":"خَشَبَةٌ كَزَّةٌ"},{"kind":"italic_en","text":"A stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"hard,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"and crooked, piece of wood."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"qanaApN kaz~apN","text_ar":"قَنَاةٌ كَزَّةٌ"},{"kind":"italic_en","text":"A hard and crooked spear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spear-shaft."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"qawosN kaz~apN","text_ar":"قَوْسٌ كَزَّةٌ"},{"kind":"italic_en","text":"A stiff, rigid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, bow:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"a bow whereof the arrow does not go far, by reason of the narrowness of the former:"},{"kind":"text","text":"(TA:) Aboo-Ziyád says, that the bow thus called is the"},{"kind":"italic_en","text":"smallest of bows:"},{"kind":"text","text":"(AHn, TA:) pl."},{"kind":"arabic","text_bw":"qisiY~N kuz~aAtN","text_ar":"قِسِىٌّ كُزَّاتٌ"},{"kind":"text","text":". (A.) And"},{"kind":"arabic","text_bw":"bakorapN kaz~apN","text_ar":"بَكْرَةٌ كَزَّةٌ"},{"kind":"italic_en","text":"A narrow pulley-sheave, that makes a loud creaking"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"by reason of its narrowness."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"*ahabN kaz~N","text_ar":"ذَهَبٌ كَزٌّ"},{"kind":"italic_en","text":"Tough gold:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"very hard gold."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"jamalN kaz~N","text_ar":"جَمَلٌ كَزٌّ"},{"kind":"italic_en","text":"A hardy, strong camel."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"rajulN kaz~N","text_ar":"رَجُلٌ كَزٌّ"},{"kind":"text","text":", (S, A,) and"},{"kind":"arabic","text_bw":"kaz~N Alyadayoni","text_ar":"كَزٌّ اليَدَيْنِ"},{"kind":"text","text":", (S, A, K,) (tropical:)"},{"kind":"italic_en","text":"A niggardly man."},{"kind":"text","text":"(S, A, K,)"},{"kind":"italic_en","text":"of little beneficence,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and of little compliance:"},{"kind":"text","text":"(A, TA:) pl."},{"kind":"arabic","text_bw":"kuz~N","text_ar":"كُزٌّ"},{"kind":"text","text":". (S.) ―         -b3-"},{"kind":"arabic","text_bw":"wajohN kaz~N","text_ar":"وَجْهٌ كَزٌّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ugly, face."},{"kind":"text","text":"(K.)"}],"source_refs":["A","K","TA","S","AHn"]}]}}