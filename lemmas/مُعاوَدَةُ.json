{"lemma":"مُعاوَدَةُ","slug":"مُعاوَدَةُ","root":"ع.#.د","root_slug":"ع-_-د","root_link":"/words/roots/ع-_-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n30930"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B9%D8%A7%D9%88%D9%8E%D8%AF%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30930","headword_ar":"مُعَاوَدَةٌ","root":"Ewd","body":[{"kind":"text","text":"signifies The"},{"kind":"italic_en","text":"returning to the first affair."},{"kind":"text","text":"(S, O.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EAwdhu","text_ar":"عاودهُ"},{"kind":"italic_en","text":"He returned to it time after time."},{"kind":"text","text":"(Msb.) ―         -b3-  [Hence,]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AiEotaAdahu","text_ar":"اِعْتَادَهُ"},{"kind":"text","text":", q. v., as syn. with"},{"kind":"arabic","text_bw":"taEaw~adahu","text_ar":"تَعَوَّدَهُ"},{"kind":"text","text":". (K.) ―         -b4-  ["},{"kind":"arabic","text_bw":"EAwdhu AlkalaAma","text_ar":"عاودهُ الكَلَامَ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"EAwdhu","text_ar":"عاودهُ"},{"kind":"text","text":"alone, or each of these phrases, the latter being probably used for the former, like as"},{"kind":"arabic","text_bw":"raAjaEahu","text_ar":"رَاجَعَهُ"},{"kind":"text","text":"is used for"},{"kind":"arabic","text_bw":"raAjaEahu AlkalaAma","text_ar":"رَاجَعَهُ الكَلَامَ"},{"kind":"text","text":", app. signifies primarily"},{"kind":"italic_en","text":"He returned time after time to talking with him:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"he talked with him alternately;"},{"kind":"text","text":"(compare a signification assigned to 6;)"},{"kind":"italic_en","text":"he returned him answer for answer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"answers for answers; held a dialogue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"colloquy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conference,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disputation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debate, with him; bandied words with him:"},{"kind":"text","text":"for it is said that]"},{"kind":"arabic","text_bw":"raAjaEahu AlkalaAma","text_ar":"رَاجَعَهُ الكَلَامَ"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"EaAwadahu","text_ar":"عَاوَدَهُ"},{"kind":"text","text":"[app. meaning"},{"kind":"arabic","text_bw":"EAwdhu AlkalaAma","text_ar":"عاودهُ الكَلَامَ"},{"kind":"text","text":"]; (S * and K in art."},{"kind":"arabic","text_bw":"rjE","text_ar":"رجع"},{"kind":"text","text":";) [and that]"},{"kind":"arabic","text_bw":"raAjaEotuhu","text_ar":"رَاجَعْتُهُ"},{"kind":"text","text":"is syn. with"},{"kind":"arabic","text_bw":"EaAwadotuhu","text_ar":"عَاوَدْتُهُ"},{"kind":"text","text":". (Msb in that art.) ―         -b5-  And"},{"kind":"arabic","text_bw":"EAwdhu biA@lomasoA^alapi","text_ar":"عاودهُ بِا@لْمَسْاَلَةِ"},{"kind":"italic_en","text":"He asked him the question repeatedly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time after time."},{"kind":"text","text":"(S, O.) ―         -b6-  [Hence,]"},{"kind":"arabic","text_bw":"EAwd maA kaAna fiyhi","text_ar":"عاود مَا كَانَ فِيهِ"},{"kind":"italic_en","text":"He persevered in that in which he was engaged."},{"kind":"text","text":"(TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"EaAwadatohu AlHum~aY","text_ar":"عَاوَدَتْهُ الحُمَّى"},{"kind":"text","text":"(S, O, TA) [may signify"},{"kind":"italic_en","text":"The fever returned to him time after time:"},{"kind":"text","text":"or] means"},{"kind":"italic_en","text":"the fever clave perseveringly to him."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","O","TA"]}]},"classical_definitions":null}