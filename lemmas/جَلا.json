sent_3fd","form":"تُجْلَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجْلَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَجْلُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْل","in_corpus":true,"count":101,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُجْلَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجْلَى","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَلَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَلَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْلُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْلُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":127,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n6187","n6197","n6198"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6187","headword_ar":"جَلَا","root":"jlw","body":[{"kind":"text","text":", (S, Mgh, Msb,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"jalaA='N","text_ar":"جَلَا=ءٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, and (assumed tropical:)  an affair, or a case, Mgh, or (assumed tropical:)  information, or tidings, Msb,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, clear, unobscured, exposed to view, displayed, laid open, disclosed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncovered,"},{"kind":"text","text":"(Mgh, Msb,)"},{"kind":"arabic","text_bw":"llin~aAsi","text_ar":"للِنَّاسِ"},{"kind":"italic_en","text":"to men,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the people;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"tjl~Y","text_ar":"تجلّى","orth_type":"arrow"},{"kind":"text","text":", said of a thing: (S, Mgh, Msb:)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"((assumed tropical:)  information, or tidings, S, Msb, or (assumed tropical:)  an affair, or a case, Mgh,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly apparent, overt, conspicuous, manifest, notorious, plain, obvious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident,"},{"kind":"text","text":"(S, Mgh, Msb,)"},{"kind":"arabic","text_bw":"liY","text_ar":"لِى"},{"kind":"italic_en","text":"to me,"},{"kind":"text","text":"(S,) or"},{"kind":"arabic","text_bw":"liln~aAsi","text_ar":"لِلنَّاسِ"},{"kind":"italic_en","text":"to men,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the people."},{"kind":"text","text":"(Msb.) One says,"},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjl~t","text_ar":"تجلّت","orth_type":"arrow"},{"kind":"italic_en","text":"The sun became unobscured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exposed to view, and ceased to be eclipsed."},{"kind":"text","text":"(TA from a trad.) Er-Rághib says that ↓"},{"kind":"arabic","text_bw":"waAln~ahaAri A_i*aA tajal~aY","text_ar":"وَالنَّهَارِ اـِذَا تَجَلَّى","orth_type":"arrow"},{"kind":"text","text":"is sometimes by the thing itself; as in the phrase [in the Kur xcii. 2],"},{"kind":"arabic","text_bw":"falam~aA tajal~aY rab~uhu lilojabali","text_ar":"فَلَمَّا تَجَلَّى رَبُّهُ لِلْجَبَلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"By the day when it becometh clear,"},{"kind":"text","text":"&c.]: and sometimes, by the case, and the action; as in the saying [in the Kur vii. 139],"},{"kind":"arabic","text_bw":"falam~aA tajal~aY rab~uhu lilojabali","text_ar":"فَلَمَّا تَجَلَّى رَبُّهُ لِلْجَبَلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And when his Lord became manifested to the mountain"},{"kind":"text","text":"]: Zj says that the meaning in this instance is,"},{"kind":"italic_en","text":"appeared,"},{"kind":"text","text":"and so say the Sunnees; El-Hasan says that the meaning is,"},{"kind":"arabic","text_bw":"tjl~Y biAln~uwri","text_ar":"تجلّى بِالنُّورِ"},{"kind":"arabic","text_bw":"AlEaro$i","text_ar":"العَرْشِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"became manifested by light,"},{"kind":"text","text":"the light of"},{"kind":"italic_en","text":"the empyrean"},{"kind":"text","text":"]. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"jalaA='N","text_ar":"جَلَا=ءٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"jalowN","text_ar":"جَلْوٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AjlY","text_ar":"اجلى","orth_type":"arrow"},{"kind":"text","text":"; (S, Mgh, Msb, K;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(a man, Msb,) or"},{"kind":"italic_en","text":"they,"},{"kind":"text","text":"(a company of men, Mgh, Msb,)"},{"kind":"italic_en","text":"went forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emigrated,"},{"kind":"text","text":"(S, Mgh, Msb,)"},{"kind":"arabic","text_bw":"Eani Albaladi","text_ar":"عَنِ البَلَدِ"},{"kind":"italic_en","text":"from the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town,"},{"kind":"text","text":"(S, Msb,) and"},{"kind":"arabic","text_bw":"Eano","text_ar":"عَنْ"},{"kind":"arabic","text_bw":"A^awoTaAnihimo","text_ar":"اَوْطَانِهِمْ"},{"kind":"italic_en","text":"from their homes:"},{"kind":"text","text":"(S, Mgh:) [like"},{"kind":"arabic","text_bw":"jal~a","text_ar":"جَلَّ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"they"},{"kind":"text","text":"(a company of men)"},{"kind":"italic_en","text":"dispersed themselves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became dispersed,"},{"kind":"arabic","text_bw":"Eani AlmawoDiEi","text_ar":"عَنِ المَوْضِعِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":","},{"kind":"italic_en","text":"from the place:"},{"kind":"text","text":"(K:) or"},{"kind":"arabic","text_bw":"jlA","text_ar":"جلا"},{"kind":"text","text":"means,"},{"kind":"italic_en","text":"in consequence of fear:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AjlY","text_ar":"اجلى","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"in consequence of drought:"},{"kind":"text","text":"(AZ, K:) or"},{"kind":"arabic","text_bw":"manozilahumo","text_ar":"مَنْزِلَهُمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^ajolawoA","text_ar":"اَجْلَوْا","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"they left their place of abode in consequence of fear;"},{"kind":"text","text":"the verb in this case being trans. by itself: but if they have left for some other reason than fear, you say,"},{"kind":"arabic","text_bw":"Eano manozilihimo","text_ar":"عَنْ مَنْزِلِهِمْ"},{"kind":"text","text":": (Msb:) accord. to IAar,"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he fled, being driven away,"},{"kind":"text","text":"from his home. (TA.) [See also 12.] ―         -b3-"},{"kind":"arabic","text_bw":"jaliYa","text_ar":"جَلِىَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jalFA","text_ar":"جَلًا"},{"kind":"text","text":","},{"kind":"italic_en","text":"He had that degree of baldness which is termed"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jalFA","text_ar":"جَلًا","orth_type":"arrow"},{"kind":"text","text":"; (K;) i. e."},{"kind":"italic_en","text":"baldness of the fore part of the head;"},{"kind":"text","text":"(S, K;) like"},{"kind":"arabic","text_bw":"jalahN","text_ar":"جَلَهٌ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"baldness of half of the head;"},{"kind":"text","text":"(S, K;) which is the beginning of"},{"kind":"arabic","text_bw":"SalaEN","text_ar":"صَلَعٌ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"baldness less than what is termed"},{"kind":"arabic","text_bw":"SalaEN","text_ar":"صَلَعٌ"},{"kind":"text","text":". (K.) And"},{"kind":"arabic","text_bw":"jalA Aljabiyni","text_ar":"جَلا الجَبِينِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jalFA","text_ar":"جَلًا"},{"kind":"text","text":", signifies the same as"},{"kind":"arabic","text_bw":"jaliYa","text_ar":"جَلِىَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The part above the temple became bald"},{"kind":"text","text":"]. (A'Obeyd, TA.)       -A2-"},{"kind":"arabic","text_bw":"jalaAhu","text_ar":"جَلَاهُ"},{"kind":"text","text":", [aor."},{"kind":"text","text":", inf. n., app.,"},{"kind":"arabic","text_bw":"jilaA='N","text_ar":"جِلَا=ءٌ"},{"kind":"text","text":", or perhaps"},{"kind":"arabic","text_bw":"jalaA='N","text_ar":"جَلَا=ءٌ"},{"kind":"text","text":", but the former seems to be indicated by what follows;] (S, Mgh, Msb;) and ↓"},{"kind":"arabic","text_bw":"jl~Ahu","text_ar":"جلّاهُ","orth_type":"arrow"},{"kind":"text","text":"; (MA;)"},{"kind":"italic_en","text":"He made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered it, clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unobscured; exposed it to view, displayed it, laid it open, disclosed it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uncovered it;"},{"kind":"text","text":"(S, Mgh, MA;) namely, a thing: (S, Mgh:)"},{"kind":"italic_en","text":"he made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered it, apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plainly apparent, overt, conspicuous, manifest, notorious, plain, obvious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evident;"},{"kind":"text","text":"(S, Mgh, Msb, MA;) namely, (assumed tropical:)  an affair, (Mgh,) or (assumed tropical:)  information, or tidings. (Msb.) You say,"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"arabic","text_bw":"AlEaruwsa","text_ar":"العَرُوسَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jilaA='N","text_ar":"جِلَا=ءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jilowapN","text_ar":"جِلْوَةٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"jalowapN","text_ar":"جَلْوَةٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"julowapN","text_ar":"جُلْوَةٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"AjtlAhA","text_ar":"اجتلاها","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb, K;)"},{"kind":"italic_en","text":"He displayed the bride,"},{"kind":"arabic","text_bw":"EalaY baEolihaA","text_ar":"عَلَى بَعْلِهَا"},{"kind":"italic_en","text":"to her husband:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he looked at the bride"},{"kind":"page_break","n":447},{"kind":"italic_en","text":"displayed:"},{"kind":"text","text":"(S:) and you say also,"},{"kind":"arabic","text_bw":"juliyato EalaY","text_ar":"جُلِيَتْ عَلَى"},{"kind":"arabic","text_bw":"zawojihaA","text_ar":"زَوْجِهَا"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"She mas shown to her husband, and he looked at her displayed:"},{"kind":"text","text":"(Har p. 30:) and"},{"kind":"arabic","text_bw":"jalaAhaA zawojuhaA","text_ar":"جَلَاهَا زَوْجُهَا"},{"kind":"italic_en","text":"Her husband presented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave, to her"},{"kind":"text","text":"a female slave (S, K) or some other thing"},{"kind":"italic_en","text":"at the time of her being displayed to him;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jl~AhA","text_ar":"جلّاها","orth_type":"arrow"},{"kind":"text","text":": (K:) and"},{"kind":"arabic","text_bw":"jalati AlmaA$iTapu AlEaruwsa","text_ar":"جَلَتِ المَاشِطَةُ العَرُوسَ"},{"kind":"italic_en","text":"The female hairdresser adorned the bride"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to display her to her husband"},{"kind":"text","text":"]. (TA.) You also say,"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"arabic","text_bw":"fulaAnN AlA^amora","text_ar":"فُلَانٌ الاَمْرَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one displayed, discovered, disclosed, revealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manifested, the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jl~Ahu","text_ar":"جلّاهُ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"jalaA Eanohu","text_ar":"جَلَا عَنْهُ"},{"kind":"text","text":": (K, * TA:) or"},{"kind":"arabic","text_bw":"jalaA fulaAnFA AlA^amori","text_ar":"جَلَا فُلَانًا الاَمْرِ"},{"kind":"italic_en","text":"he displayed, discovered,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to such a one the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jl~Ah","text_ar":"جلّاه","orth_type":"arrow"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"jl~Ahu AlA^amora","text_ar":"جلّاهُ الاَمْرَ"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"jalaA Eanohu","text_ar":"جَلَا عَنْهُ"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"jlA Enh AlA^amora","text_ar":"جلا عنه الاَمْرَ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"jlA fulaAnFA Eani AlA^amori","text_ar":"جلا فُلَانًا عَنِ الاَمْرِ"},{"kind":"text","text":"]. (So accord. to the CK and my MS. copy of the K. [The reading in the TA is, in my opinion, preferable to the latter.]) And"},{"kind":"arabic","text_bw":"Als~aAEapa","text_ar":"السَّاعَةَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aall~`hu yujal~iY","text_ar":"اَللّٰهُ يُجَلِّى","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"God will make manifest the hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time of the resurrection;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will make it to appear."},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"jlY","text_ar":"جلى"},{"kind":"text","text":": [but it belongs to the present art.:]) so in the Kur vii. 186. (TA.) And"},{"kind":"arabic","text_bw":"Eano nafosihi","text_ar":"عَنْ نَفْسِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa yujal~iY","text_ar":"هُوَ يُجَلِّى","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He declares,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"explains, his mind."},{"kind":"text","text":"(S.) ―         -b2-"},{"kind":"arabic","text_bw":"jalawotu Als~ayofa","text_ar":"جَلَوْتُ السَّيْفَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jilaA='N","text_ar":"جِلَا=ءٌ"},{"kind":"text","text":", (S, Msb, K, [in the CK"},{"kind":"arabic","text_bw":"jalA'","text_ar":"جَلاء"},{"kind":"text","text":", but it is]) with kesr, (S, Msb,) and"},{"kind":"arabic","text_bw":"jalowN","text_ar":"جَلْوٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"I removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleared off, the rust from the sword;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"I polished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"furbished, the sword;"},{"kind":"text","text":"(S, K;) and"},{"kind":"arabic","text_bw":"AlmiroA=pa","text_ar":"المِرْا=ةَ"},{"kind":"italic_en","text":"the mirror;"},{"kind":"text","text":"(K;) and the like; (TA;) [as, for instance,]"},{"kind":"arabic","text_bw":"AlfiD~apa","text_ar":"الفِضَّةَ"},{"kind":"italic_en","text":"the silver;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"jalayotuhaA","text_ar":"جَلَيْتُهَا"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"jlY","text_ar":"جلى"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"jalawotu baSariY biAlkuHoli","text_ar":"جَلَوْتُ بَصَرِى بِالكُحْلِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I cleared my sight with collyrium"},{"kind":"text","text":"]: (S:) [whence,]"},{"kind":"arabic","text_bw":"jalaA","text_ar":"جَلَا"},{"kind":"italic_en","text":"He applied collyrium to his eye"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eyes."},{"kind":"text","text":"(IAar, TA.) And"},{"kind":"arabic","text_bw":"jalawotu ham~iY Ean~iY","text_ar":"جَلَوْتُ هَمِّى عَنِّى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I removed my anxiety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused it to depart, from me:"},{"kind":"text","text":"(S, K, * TA: *) and"},{"kind":"arabic","text_bw":"Eanohu Alham~a","text_ar":"عَنْهُ الهَمَّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjlY","text_ar":"اجلى","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleared away, from him anxiety."},{"kind":"text","text":"(Lth, TA.) And"},{"kind":"arabic","text_bw":"jalaA A@ll~`hu Eanohu AlmaraDa","text_ar":"جَلَا ا@للّٰهُ عَنْهُ المَرَضَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"God removed from him the disease."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"jalaAhumo","text_ar":"جَلَاهُمْ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AjlAhm","text_ar":"اجلاهم","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh,) or"},{"kind":"arabic","text_bw":"jalaAhu","text_ar":"جَلَاهُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AjlAhu","text_ar":"اجلاهُ","orth_type":"arrow"},{"kind":"text","text":", (Msb, K,) and ↓"},{"kind":"arabic","text_bw":"AjtlAhu","text_ar":"اجتلاهُ","orth_type":"arrow"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"(a man, S, Msb, or the Sultán, Mgh,) or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(drought, K,)"},{"kind":"italic_en","text":"caused them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him, to go forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emigrate;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expelled them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drove them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him, forth;"},{"kind":"text","text":"(S, Mgh, Msb, K;) [from their homes, or from his home.] And"},{"kind":"arabic","text_bw":"jalaA Aln~aHoli","text_ar":"جَلَا النَّحْلِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jilaA='N","text_ar":"جِلَا=ءٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"jalaA='N","text_ar":"جَلَا=ءٌ"},{"kind":"text","text":", (accord. to different copies of the K,) and"},{"kind":"arabic","text_bw":"jlwp","text_ar":"جلوة"},{"kind":"text","text":"[thus written without any syll. signs]; and ↓"},{"kind":"arabic","text_bw":"AjtlAhA","text_ar":"اجتلاها","orth_type":"arrow"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"He smoked"},{"kind":"text","text":"["},{"kind":"italic_en","text":"out"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the bees, in order to collect the honey;"},{"kind":"text","text":"(K;)"},{"kind":"italic_en","text":"he drove away the bees by means of smoke."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Mgh","Msb","K","AZ","TA"]},{"entry_id":"n6197","headword_ar":"جَلًا","root":"jlw","body":[{"kind":"text","text":": see 1, voce"},{"kind":"arabic","text_bw":"jaliYa","text_ar":"جَلِىَ"},{"kind":"text","text":":       -A2-  and see"},{"kind":"arabic","text_bw":"jilaA='N","text_ar":"جِلَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n6198","headword_ar":"جِلًا","root":"jlw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jilaA='N","text_ar":"جِلَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}