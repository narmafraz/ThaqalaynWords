{"lemma":"فَزِعَ","slug":"فَزِعَ","root":"ف.ز.ع","root_slug":"ف-ز-ع","root_link":"/words/roots/ف-ز-ع","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"فَزِعْتَ","in_corpus":true,"count":5,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"فَزِعْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"فَزِعْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"فَزِعْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"فَزِعْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"فَزِعَ","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"فَزِعَت","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"فَزِعا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"فَزِعَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"فَزِعُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"فَزِعْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَفْزَع","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَفْزَعِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَفْزَعِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَفْزَعا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَفْزَعانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَفْزَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفْزَعُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْزَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْزَع","in_corpus":true,"count":19,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْزَع","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْزَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْزَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْزَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْزَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْزَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْزَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْزَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَفْزَع","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْزَع","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"فَزِعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَزِعْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":56,"cross_references":{"qac":{"found":true,"lemma_key":"فَزِعَ","root":"فزع","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n33797"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B2%D9%90%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be terrified, to be afraid"},{"pos":"verb","gloss":"to flee, to take refuge"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33797","headword_ar":"فَزِعَ","root":"fzE","body":[{"kind":"text","text":", (S, O, Msb, K,) and"},{"kind":"arabic","text_bw":"fazaEa","text_ar":"فَزَعَ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", of the former verb, (Msb, K,) and of the latter also, (K,) inf. n."},{"kind":"arabic","text_bw":"fazaEN","text_ar":"فَزَعٌ"},{"kind":"text","text":", (S, O, Msb, K,) which is of the former verb, (S, * O, Msb, TA,) and [of the latter verb]"},{"kind":"arabic","text_bw":"fazoEN","text_ar":"فَزْعٌ"},{"kind":"text","text":"["},{"kind":"arabic","text_bw":"fazaEFA","text_ar":"فَزَعًا"},{"kind":"text","text":"in the CK being a mistake for"},{"kind":"arabic","text_bw":"fazoEFA","text_ar":"فَزْعًا"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"fizoEn","text_ar":"فِزْعن"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"He feared;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in fear, afraid, frightened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified;"},{"kind":"text","text":"(S, O, Msb, K, TA;) and so ↓"},{"kind":"arabic","text_bw":"tfz~E","text_ar":"تفزّع","orth_type":"arrow"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"rwE","text_ar":"روع"},{"kind":"text","text":":) you say,"},{"kind":"arabic","text_bw":"faziEa minohu","text_ar":"فَزِعَ مِنْهُ"},{"kind":"italic_en","text":"he feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in fear,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(MA, Msb, TA:) accord. to Er-Rághib,"},{"kind":"arabic","text_bw":"fazaEN","text_ar":"فَزَعٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a shrinking,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"an aversion,"},{"kind":"text","text":"that comes upon a man,"},{"kind":"italic_en","text":"from a thing causing fear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fright;"},{"kind":"text","text":"and is"},{"kind":"italic_en","text":"a kind of"},{"kind":"arabic","text_bw":"jazaE","text_ar":"جَزَع"},{"kind":"text","text":"[q. v.]; and one should not say"},{"kind":"arabic","text_bw":"faziEotu mina A@ll~`hi","text_ar":"فَزِعْتُ مِنَ ا@للّٰهِ"},{"kind":"text","text":"like as one says"},{"kind":"arabic","text_bw":"xifotu minohu","text_ar":"خِفْتُ مِنْهُ"},{"kind":"text","text":": or, as Mbr says, in the “ Kámil, ” its primary signification is the"},{"kind":"italic_en","text":"fearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"being in fear"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afraid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"frightened"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"terrified:"},{"kind":"text","text":"then, by a metonymical application, it signifies a people's"},{"kind":"italic_en","text":"going forth quickly to repel an enemy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, that has come"},{"kind":"text","text":"upon them"},{"kind":"italic_en","text":"suddenly;"},{"kind":"text","text":"and this meaning has become [conventionally regarded as] proper. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"fazaEN","text_ar":"فَزَعٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"seeking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding, aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour:"},{"kind":"text","text":"(Az, K, TA:) and the"},{"kind":"italic_en","text":"aiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succouring;"},{"kind":"text","text":"(Az, S, O, K, TA;) this latter being likewise a signification of ↓"},{"kind":"arabic","text_bw":"A_ifozaAEN","text_ar":"اـِفْزَاعٌ","orth_type":"arrow"},{"kind":"text","text":": (S, O:) an ex. of the former word (S, O, TA) in the latter sense (O, TA) occurs in the saying of the Prophet to the Ansár,"},{"kind":"arabic","text_bw":"A_in~akumo latakovuruwna Einoda AlfazaEi","text_ar":"اـِنَّكُمْ لَتَكْثُرُونَ عِنْدَ الفَزَعِ"},{"kind":"arabic","text_bw":"wa taqil~uwna Einoda AlT~amaEi","text_ar":"وَ تَقِلُّونَ عِنْدَ الطَّمَعِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily ye are many on the occasion of aiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succouring, and ye are few on the occasion of coveting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"greed"},{"kind":"text","text":"]; (S, O, TA;) or in this saying the implied meaning may be,"},{"kind":"italic_en","text":"on the occasion of men's betaking themselves to you in fear"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Einoda fazaEi Aln~aAsi A_ilayokumo","text_ar":"عِنْدَ فَزَعِ النَّاسِ اـِلَيْكُمْ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in order that ye may aid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour them"},{"kind":"text","text":"[which is virtually the same as"},{"kind":"italic_en","text":"their seeking your aid"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour"},{"kind":"text","text":"]: (TA:) thus [it is said]"},{"kind":"arabic","text_bw":"fazaEN","text_ar":"فَزَعٌ"},{"kind":"text","text":"has two contr. significations: (K:) and both of these significations are expressed by the verb"},{"kind":"arabic","text_bw":"faziEa","text_ar":"فَزِعَ"},{"kind":"text","text":": (O:) you say"},{"kind":"arabic","text_bw":"faziEa A_ilayohi","text_ar":"فَزِعَ اـِلَيْهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faziEa","text_ar":"فَزِعَ"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":"; (K in continuation of what has been last cited therefrom above, and TA; [app. meant to indicate that both of these phrases signify"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour, of him;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succoured, him;"},{"kind":"text","text":"or that the former phrase has the former signification; and the latter phrase, the latter signification; though accord. to the TK, both phrases have the former signification, and the former phrase has also the latter signification;]) but you should not say"},{"kind":"arabic","text_bw":"fazaEahu","text_ar":"فَزَعَهُ"},{"kind":"text","text":", (K, TA,) i. e. like"},{"kind":"arabic","text_bw":"manaEahu","text_ar":"مَنَعَهُ"},{"kind":"text","text":": (TA:) [or] from"},{"kind":"arabic","text_bw":"AlfazaEu","text_ar":"الفَزَعُ"},{"kind":"text","text":"as signifying “ fear, ” or “ fright, ” you say"},{"kind":"arabic","text_bw":"faziEotu","text_ar":"فَزِعْتُ"},{"kind":"arabic","text_bw":"A_ilayoka","text_ar":"اـِلَيْكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faziEotu minoka","text_ar":"فَزِعْتُ مِنْكَ"},{"kind":"text","text":"; [app. meant to indicate that the former phrase signifies"},{"kind":"italic_en","text":"I betook myself to thee in fear,"},{"kind":"text","text":"which is a meaning thereof well known, and nearly agreeing with an explanation of the verb followed by"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":"which will be found below in this paragraph; and that the latter phrase signifies"},{"kind":"italic_en","text":"I feared thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in fear,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of thee,"},{"kind":"text","text":"the only meaning, of this phrase, for which I find any explicit authority, and one for which I have given three authorities in the first sentence of this art.;] but you should not say"},{"kind":"arabic","text_bw":"faziEotuka","text_ar":"فَزِعْتُكَ"},{"kind":"text","text":": (S: [thus in my copies,"},{"kind":"arabic","text_bw":"faziEotuka","text_ar":"فَزِعْتُكَ"},{"kind":"text","text":", not"},{"kind":"arabic","text_bw":"fazaEotuka","text_ar":"فَزَعْتُكَ"},{"kind":"text","text":":]) or"},{"kind":"arabic","text_bw":"faziEa A_ilayohimo","text_ar":"فَزِعَ اـِلَيْهِمْ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, of them, aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fazaEahumo","text_ar":"فَزَعَهُمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faziEahumo","text_ar":"فَزِعَهُمْ"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"he aided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succoured, them,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^agaAvahumo","text_ar":"اَغَاثَهُمْ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"AaEAnahumo","text_ar":"اَعانَهُمْ"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"naSarahumo","text_ar":"نَصَرَهُمْ"},{"kind":"text","text":", like ↓"},{"kind":"arabic","text_bw":"A^afozaEahumo","text_ar":"اَفْزَعَهُمْ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) accord. to IB,"},{"kind":"arabic","text_bw":"faziEotuhu","text_ar":"فَزِعْتُهُ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"A^agavotuhu","text_ar":"اَغَثْتُهُ"},{"kind":"text","text":"is originally"},{"kind":"arabic","text_bw":"faziEotu lh","text_ar":"فَزِعْتُ له"},{"kind":"text","text":"[primarily signifying"},{"kind":"italic_en","text":"I feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became in fear"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for him"},{"kind":"text","text":"]; then the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"was dropped; for one says"},{"kind":"arabic","text_bw":"faziEotuhu","text_ar":"فَزِعْتُهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faziEotu","text_ar":"فَزِعْتُ"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"faziEa","text_ar":"فَزِعَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"fariHa","text_ar":"فَرِحَ"},{"kind":"text","text":", signifies"},{"kind":"arabic","text_bw":"AinotaSara","text_ar":"اِنْتَصَرَ"},{"kind":"text","text":": (K: [thus in the copies of the K, and hence in the TA, app. a mistranscription for"},{"kind":"arabic","text_bw":"AisotanoSara","text_ar":"اِسْتَنْصَرَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"aid against an enemy:"},{"kind":"text","text":"]) and"},{"kind":"arabic","text_bw":"faziEa A_ilayohi","text_ar":"فَزِعَ اـِلَيْهِ"},{"kind":"italic_en","text":"he betook himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had recourse, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, for refuge, protection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preservation,"},{"kind":"text","text":"(S, O, Msb, K, TA,)"},{"kind":"italic_en","text":"by reason of fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fright,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"and sought,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded, aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour, by him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"whence, in a trad. respecting the eclipse of the sun,"},{"kind":"arabic","text_bw":"faA@fozaEuwAA_ilaY AlS~alaAp","text_ar":"فَا@فْزَعُوااـِلَى الصَّلَاة"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"Then betake yourselves,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to prayer, and seek,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demand, aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour, by it."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"faziEa mino nawomihi","text_ar":"فَزِعَ مِنْ نَوْمِهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He became roused from his sleep;"},{"kind":"text","text":"(O, K;) because he who is roused is not free from some fear, or fright: occurring in a trad. in this sense. (O.) And one says,"},{"kind":"arabic","text_bw":"faziEotu bimajiYo'i fulaAnK","text_ar":"فَزِعْتُ بِمَجِىْءِ فُلَانٍ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I prepared"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"roused"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"myself by reason of the coming of such a one, by a change of state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, like as the sleeper passes from the state of sleeping to that of waking."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"fazaEahu","text_ar":"فَزَعَهُ"},{"kind":"text","text":"in the phrase"},{"kind":"arabic","text_bw":"fafazaEahu","text_ar":"فَفَزَعَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"faAzaEahu","text_ar":"فَازَعَهُ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He exceeded him in fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fright."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"fuziEa Eano quluwbihimo","text_ar":"فُزِعَ عَنْ قُلُوبِهِمْ"},{"kind":"text","text":": see the next paragraph."}],"source_refs":["S","O","Msb","K","TA","MA","Az"]}]}}