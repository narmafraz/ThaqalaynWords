_ids":["n40288"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%AA%D9%8E%D9%81%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40288","headword_ar":"انتفض","root":"nfD","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Mgh, Msb, or a garment, or piece of cloth, S, A, K, and a tree, S, A)"},{"kind":"italic_en","text":"shook,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became shaken,"},{"kind":"text","text":"(S, A, Mgh, Msb, K,)"},{"kind":"italic_en","text":"so that what was upon it, of dust &c., fell off,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"so that the dust and the like became removed from it."},{"kind":"text","text":"(Msb.) Hence the saying in a trad.,"},{"kind":"arabic","text_bw":"yanotafiDu","text_ar":"يَنْتَفِضُ"},{"kind":"arabic","text_bw":"bihi AlS~iraATu","text_ar":"بِهِ الصِّرَاطُ"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"The bridge extending over hell will shake with him so that he will fall from it:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"will shake him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shake him violently,"},{"kind":"text","text":"or [app. a mistake for"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"make him to fall."},{"kind":"text","text":"(Mgh.) ―         -b2-  (tropical:)"},{"kind":"italic_en","text":"He trembled, quaked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shivered:"},{"kind":"text","text":"said of a man, and of a horse. (A, TA.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a grapevine)"},{"kind":"italic_en","text":"became beautiful and bright in its leaves:"},{"kind":"text","text":"(K:) [as though its dust became shaken off.]       -A2-  It is also used transitively: see 1, latter half: and see 10, in three places."}],"source_refs":["S","A","Mgh","Msb","K"]}]},"classical_definitions":null}