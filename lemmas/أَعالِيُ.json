{"lemma":"أَعالِيُ","slug":"أَعالِيُ","root":"ع.ل.#","root_slug":"ع-ل-_","root_link":"/words/roots/ع-ل-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"أَعْلَى","root":"علو","pos":"N","occurrence_count":9},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n30434"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D8%A7%D9%84%D9%90%D9%8A%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30434","headword_ar":"اَعْلَى","root":"Elw","body":[{"kind":"italic_en","text":"Higher,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"highest; contr. of"},{"kind":"arabic","text_bw":"A^asofalu","text_ar":"اَسْفَلُ"},{"kind":"text","text":": (M and Msb and K in art."},{"kind":"arabic","text_bw":"sfl","text_ar":"سفل"},{"kind":"text","text":":) the fem. is"},{"kind":"arabic","text_bw":"EuloyaA","text_ar":"عُلْيَا"},{"kind":"text","text":"; (TA;) which is like"},{"kind":"arabic","text_bw":"dunoyaA","text_ar":"دُنْيَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"quSoyaA","text_ar":"قُصْيَا"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"; (ISd, TA voce"},{"kind":"arabic","text_bw":"buqowaY","text_ar":"بُقْوَى"},{"kind":"text","text":";) and of which the pl. is"},{"kind":"arabic","text_bw":"EulFY","text_ar":"عُلًى"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"kubarN","text_ar":"كُبَرٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"kuboraY","text_ar":"كُبْرَى"},{"kind":"text","text":". (Msb, TA.) See"},{"kind":"arabic","text_bw":"EaliY~N","text_ar":"عَلِىٌّ"},{"kind":"text","text":". ―         -b2-  One says"},{"kind":"arabic","text_bw":"$afapN EuloyaA","text_ar":"شَفَةٌ عُلْيَا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaloyaA='u","text_ar":"عَلْيَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", but the former is the more usual, meaning"},{"kind":"italic_en","text":"An upper lip."},{"kind":"text","text":"(IAmb, Msb, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"EuloyaA muDara","text_ar":"عُلْيَا مُضَرَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The higher"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"in respect of territory"},{"kind":"text","text":"(see a note in p. xi. of the preface to this work)]"},{"kind":"italic_en","text":"of Mudar;"},{"kind":"text","text":"(K, TA;) said to denote"},{"kind":"italic_en","text":"Kureysh and Keys;"},{"kind":"text","text":"the rest being called"},{"kind":"arabic","text_bw":"sufolaY muDara","text_ar":"سُفْلَى مُضَرَ"},{"kind":"text","text":". (TA.) ―         -b4-  And one says,"},{"kind":"arabic","text_bw":"jaA='a mino A^aEolaY waA^rowaHa","text_ar":"جَا=ءَ مِنْ اَعْلَى وَارْوَحَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"It came from the sky and the place whence the wind blows."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"A^aEolaY","text_ar":"اَعْلَى"},{"kind":"text","text":"applied to a word, or form of word, means (assumed tropical:)  ["},{"kind":"italic_en","text":"Of higher authority, more approved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"more chaste;"},{"kind":"text","text":"and also, hence, as frequency of usage is a necessary condition of"},{"kind":"arabic","text_bw":"faSaAHapN","text_ar":"فَصَاحَةٌ"},{"kind":"text","text":", q. v.,]"},{"kind":"italic_en","text":"more usual"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"common."},{"kind":"text","text":"(M and TA in art."},{"kind":"arabic","text_bw":"qr","text_ar":"قر"},{"kind":"text","text":".) ―         -b6-  One says also,"},{"kind":"arabic","text_bw":"humo bihimo A^aEolaY","text_ar":"هُمْ بِهِمْ اَعْلَى"},{"kind":"arabic","text_bw":"EayonFA","text_ar":"عَيْنًا"},{"kind":"text","text":"i. e. (assumed tropical:)"},{"kind":"italic_en","text":"They are most knowing respecting them, and most acquainted with their state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(TA.) ―         -b7-  And"},{"kind":"arabic","text_bw":"huwa A^aEolaY bikumo EayonFA","text_ar":"هُوَ اَعْلَى بِكُمْ عَيْنًا"},{"kind":"text","text":"i. e. (assumed tropical:)"},{"kind":"italic_en","text":"He is in the highest degree a magnifier,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honourer, of you; ye being greatly esteemed by him."},{"kind":"text","text":"(TA.) ―         -b8-"},{"kind":"arabic","text_bw":"Alyadu","text_ar":"اليَدُ"},{"kind":"arabic","text_bw":"AlEuloyaA","text_ar":"العُلْيَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The abstinent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chaste, hand:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the expending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disbursing, hand."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"A^aEolaY","text_ar":"اَعْلَى"},{"kind":"text","text":"formed by transposition from"},{"kind":"arabic","text_bw":"A^aEuwalu","text_ar":"اَعُوَلُ"},{"kind":"text","text":": see the latter, in art."},{"kind":"arabic","text_bw":"Ewl","text_ar":"عول"},{"kind":"text","text":"."}],"source_refs":[]}]}}