per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعَوِّذُوا","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعَوِّذْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعَوِّذ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعَوِّذ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعَوِّذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعَوِّذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعَوِّذانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعَوِّذا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعَوِّذُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعَوِّذُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعَوِّذْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَوَّذْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَوَّذْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعَوِّذ","in_corpus":true,"count":10,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعَوِّذ","in_corpus":true,"count":43,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":60,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n30961","n30965"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%88%D9%8E%D9%91%D8%B0%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of عَاذَ (ʕāḏa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30961","headword_ar":"عَوَذٌ","root":"Ew*","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"maEaA*N","text_ar":"مَعَاذٌ"},{"kind":"text","text":", in two places. ―         -b2-  Also"},{"kind":"italic_en","text":"A tree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"some other thing, beneath which,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in which, one takes refuge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shelter."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"italic_en","text":"A thing, such as a stone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trunk of a tree, surrounded by things blown against it and around it by the wind."},{"kind":"text","text":"(T, L.) ―         -b4-"},{"kind":"italic_en","text":"Fallen leaves;"},{"kind":"text","text":"(AHn, L, K:) so called because they shelter themselves against any rising thing, such as a building or a sand-hill or a mountain. (AHn, L.) ―         -b5-"},{"kind":"italic_en","text":"Vile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble, persons;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"worse"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"viler,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"worst"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vilest, of mankind."},{"kind":"text","text":"(IAar, L, K.)       -A2-"},{"kind":"arabic","text_bw":"A^afolata fulaAnN minohu Eawa*FA","text_ar":"اَفْلَتَ فُلَانٌ مِنْهُ عَوَذًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one escaped from him without being beaten;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without being killed, though beaten;"},{"kind":"text","text":"] is said when one has frightened the other; but not beaten him; (S, O, L, K; *) or beaten him, desiring to kill him, but not killed him. (S, O, L.) ―         -b2-  And"},{"kind":"arabic","text_bw":"maA tarakotuhu A_il~aA Eawa*FA minohu","text_ar":"مَا تَرَكْتُهُ اـِلَّا عَوَذًا مِنْهُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"I left him not save from dislike,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred, of him;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"mnh","text_ar":"منه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EawaA*FA","text_ar":"عَوَاذًا","orth_type":"arrow"},{"kind":"text","text":". (S, O, L.)"}],"source_refs":["AHn","L","K"]},{"entry_id":"n30965","headword_ar":"عُوَّذٌ","root":"Ew*","body":[{"kind":"text","text":"Birds"},{"kind":"italic_en","text":"taking refuge in a mountain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in some other place;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EiyaA*N","text_ar":"عِيَاذٌ","orth_type":"arrow"},{"kind":"text","text":": [each app. a pl. of"},{"kind":"arabic","text_bw":"EaAy^i*N","text_ar":"عَايِذٌ"},{"kind":"text","text":"; like as"},{"kind":"arabic","text_bw":"nuw~amN","text_ar":"نُوَّمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"niyaAmN","text_ar":"نِيَامٌ"},{"kind":"text","text":"are pls. of"},{"kind":"arabic","text_bw":"naAy^imN","text_ar":"نَايِمٌ"},{"kind":"text","text":":] (L, K:) Bakhdaj says,"},{"kind":"quote","text":"Euw~a*aA ↓ \n      kaAlT~ayori yanojuwna EiyaA*FA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Like birds saving themselves, taking refuge in a mountain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in some other place"},{"kind":"text","text":"]; repeating the epithet for the sake of emphasis: or"},{"kind":"arabic","text_bw":"EyA*A","text_ar":"عياذا"},{"kind":"text","text":"may be here an inf. n. (L.) ―         -b2-  And (tropical:)"},{"kind":"italic_en","text":"Herbage growing at the feet of thorn-trees,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a rugged place,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"which the cattle can hardly reach,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"which they cannot reach;"},{"kind":"text","text":"(S, * O, * K;) as also ↓"},{"kind":"arabic","text_bw":"muEaw~a*N","text_ar":"مُعَوَّذٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muEaw~i*N","text_ar":"مُعَوِّذٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"herbage that has not risen so high as the branches"},{"kind":"text","text":"["},{"kind":"italic_en","text":"around it"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and which the trees prevent the beasts from depasturing:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as is in rugged ground and cannot be reached by the cattle:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trees growing at the foot of some rising thing, such as a building"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a sand-hill"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a mountain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a tree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a rock, that protects them;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muEaw~a*N","text_ar":"مُعَوَّذٌ","orth_type":"arrow"},{"kind":"text","text":": or ↓"},{"kind":"arabic","text_bw":"muEaw~i*N","text_ar":"مُعَوِّذٌ","orth_type":"arrow"},{"kind":"text","text":", with kesr, signifies"},{"kind":"italic_en","text":"any herbage,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plant, at the foot of a tree"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stone"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other thing whereby it shelters,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protects, itself:"},{"kind":"text","text":"(L:) and ↓"},{"kind":"arabic","text_bw":"muEaw~a*N","text_ar":"مُعَوَّذٌ","orth_type":"arrow"},{"kind":"text","text":", (O, K,) with fet-h to the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"(O,)"},{"kind":"italic_en","text":"herbage upon which camels pasture around tents"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"houses:"},{"kind":"text","text":"(O, K:) or"},{"kind":"arabic","text_bw":"Euw~a*u","text_ar":"عُوَّذُ"},{"kind":"page_break","n":2193},{"kind":"arabic","text_bw":"$ajarK","text_ar":"شَجَرٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"muEaw~a*uhu","text_ar":"مُعَوَّذُهُ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"herbage that shelters,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protects, itself by trees, and spreads beneath them."},{"kind":"text","text":"(A.) [See also"},{"kind":"arabic","text_bw":"dux~alN","text_ar":"دُخَّلٌ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"Euw~a*u All~aHomi","text_ar":"عُوَّذُ اللَّحْمِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The parts of flesh-meat that cleave to the bone:"},{"kind":"text","text":"(S, A, O, L, K: *) such are the sweetest of flesh-meat. (S, A, O, L.)"}],"source_refs":["L","K","S","O"]}]}}