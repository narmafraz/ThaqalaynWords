{"lemma":"مِعْوَلَيْ","slug":"مِعْوَلَيْ","root":"ع.#.ل","root_slug":"ع-_-ل","root_link":"/words/roots/ع-_-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n31076","n31077","n31078","n31079","n31081"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%90%D8%B9%D9%92%D9%88%D9%8E%D9%84%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"pickaxe, mattock used to undermine"}]},"etymology":{"source":"wiktextract","text":"Tool noun from the root ع و ل (ʕ w l)."},"ipa":["/miʕ.wal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31076","headword_ar":"مَعُولٌ","root":"Ewl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Fed, nourished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sustained:"},{"kind":"text","text":"&c.       -A2-  And]"},{"kind":"italic_en","text":"Overcome:"},{"kind":"text","text":"applied in this sense to patience: (K:) and to a man, in respect of his opinion, or judgment. (TA.)"}],"source_refs":["K"]},{"entry_id":"n31077","headword_ar":"مُعْوَلٌ","root":"Ewl","body":[{"kind":"text","text":", followed by"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"Wailed for:"},{"kind":"text","text":"thus in the trad.,"},{"kind":"arabic","text_bw":"AlmuEowalu Ealayohi yuEa*~abu","text_ar":"المُعْوَلُ عَلَيْهِ يُعَذَّبُ"},{"kind":"text","text":", (S, O,) or, as some relate it, ↓"},{"kind":"arabic","text_bw":"AlmuEaw~alu","text_ar":"المُعَوَّلُ","orth_type":"arrow"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(of the dead)"},{"kind":"italic_en","text":"who is wailed for will be punished."},{"kind":"text","text":"(O.)"}],"source_refs":["S","O"]},{"entry_id":"n31078","headword_ar":"مُعْوِلٌ","root":"Ewl","body":[{"kind":"text","text":": see 2:       -A2-  and see also 4, last sentence."}],"source_refs":[]},{"entry_id":"n31079","headword_ar":"مِعْوَلٌ","root":"Ewl","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A pickaxe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stone-cutter's pick;"},{"kind":"text","text":"(so in the present day;)] the"},{"kind":"italic_en","text":"iron implement,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"a"},{"kind":"page_break","n":2202},{"kind":"italic_en","text":"large"},{"kind":"arabic","text_bw":"faA^os","text_ar":"فَاْس"},{"kind":"text","text":", (S, O, Msb,)"},{"kind":"italic_en","text":"with which are pecked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hollowed out,"},{"kind":"text","text":"(S, O, K,)"},{"kind":"italic_en","text":"rocks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"great masses of stone,"},{"kind":"text","text":"(S, O,) or"},{"kind":"italic_en","text":"mountains:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"maEaAwilu","text_ar":"مَعَاوِلُ"},{"kind":"text","text":". (S, O.) [See also"},{"kind":"arabic","text_bw":"SaAquwrN","text_ar":"صَاقُورٌ"},{"kind":"text","text":".]"}],"source_refs":["K","S","O","Msb"]},{"entry_id":"n31081","headword_ar":"مُعَوَّلٌ","root":"Ewl","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"of whom aid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"succour, is asked:"},{"kind":"text","text":"(S, O, TA:) and one"},{"kind":"italic_en","text":"upon whom reliance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confidence is placed."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"maA lahu fiY Alqawomi","text_ar":"مَا لَهُ فِى القَوْمِ"},{"kind":"arabic","text_bw":"mino muEaw~alK","text_ar":"مِنْ مُعَوَّلٍ"},{"kind":"italic_en","text":"He has not, among the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, any of whom aid is"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to be"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"asked."},{"kind":"text","text":"(S, O.) [See also"},{"kind":"arabic","text_bw":"EawolN","text_ar":"عَوْلٌ"},{"kind":"text","text":".]       -A2-  It is also an inf. n. of"},{"kind":"arabic","text_bw":"Eaw~ala","text_ar":"عَوَّلَ"},{"kind":"text","text":". (Th. K. TA.) See that verb, in three places.       -A3-  Also"},{"kind":"italic_en","text":"A place of weeping"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"of wailing"},{"kind":"text","text":"]: so, accord. to some, in the verse cited in the second paragraph [q. v.]. (O.)       -A4-  See also"},{"kind":"arabic","text_bw":"muEowalN","text_ar":"مُعْوَلٌ"},{"kind":"text","text":"."}],"source_refs":["S","O","TA"]}]}}