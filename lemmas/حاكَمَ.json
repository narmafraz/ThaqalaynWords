num":"p"},{"role":"present_2mp","form":"تُحاكِمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحاكِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحاكِم","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحاكِم","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحاكِما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحاكِمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحاكِما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحاكِمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحاكِمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحاكِمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحاكِمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حاكَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حاكَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحاكِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحاكِم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":true,"lemma_key":"حاكَمَ","root":"حكم","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n8720"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D8%A7%D9%83%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"ruling, governing"},{"pos":"adj","gloss":"decisive"},{"pos":"noun","gloss":"judge"},{"pos":"noun","gloss":"ruler, sovereign"},{"pos":"noun","gloss":"governor"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb حَكَمَ (ḥakama, “to pass judgment”)."},"ipa":["/ħaː.kim/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8720","headword_ar":"حَاكِمٌ","root":"Hkm","body":[{"kind":"italic_en","text":"One who judges, gives judgment, passes sentence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decides judicially; a judge; an arbiter, arbitrator,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"umpire;"},{"kind":"text","text":"(S * Msb, K, TA;)"},{"kind":"italic_en","text":"between people:"},{"kind":"text","text":"(Msb, TA:) ["},{"kind":"italic_en","text":"one who exercises judicial authority, jurisdiction, rule, dominion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"government; a ruler,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"governor:"},{"kind":"text","text":"] and ↓"},{"kind":"arabic","text_bw":"HakamN","text_ar":"حَكَمٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: (S, Mgh, Msb, K:) the"},{"kind":"arabic","text_bw":"HaAkim","text_ar":"حَاكِم"},{"kind":"text","text":"between people is so called because he restrains from wrongdoing: (As, TA:) the pl. is"},{"kind":"arabic","text_bw":"Huk~aAmN","text_ar":"حُكَّامٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"HakamapN","text_ar":"حَكَمَةٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"judges,"},{"kind":"text","text":"[&c.,] (TA,) and"},{"kind":"arabic","text_bw":"HaAkimuwna","text_ar":"حَاكِمُونَ"},{"kind":"text","text":"is allowable. (Msb.) It is said in a prov., ↓"},{"kind":"arabic","text_bw":"fiY bayotihi yuw^otaY AlHakamu","text_ar":"فِى بَيْتِهِ يُوْتَى الحَكَمُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In his house the judge is to be come to"},{"kind":"text","text":"]. (S. [See Freytag's Arab. Prov. ii. 204.])"},{"kind":"arabic","text_bw":"AlHaAkimu","text_ar":"الحَاكِمُ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"The Supreme Judge"},{"kind":"text","text":"] is one of the names of God. (TA.) See also the next paragraph.       -A2-  [The pl.]"},{"kind":"arabic","text_bw":"HakamapN","text_ar":"حَكَمَةٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Mockers, scoffers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deriders."},{"kind":"text","text":"(TA. [The"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":"in this case seems to be a substitute for"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"hkm","text_ar":"هكم"},{"kind":"text","text":".]) ↓"},{"kind":"arabic","text_bw":"A^aHokamu AlHaAkimiyna","text_ar":"اَحْكَمُ الحَاكِمِينَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The most qualified to judge of those who judge:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"the most knowing and most just"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of them"},{"kind":"text","text":"]: (Bd and Jel in xi. 47, where it is applied to God:) or it may mean"},{"kind":"italic_en","text":"the wisest of those who possess attributes of wisdom;"},{"kind":"text","text":"supposing"},{"kind":"arabic","text_bw":"HaAkimN","text_ar":"حَاكِمٌ"},{"kind":"text","text":"to be [a possessive epithet] from"},{"kind":"arabic","text_bw":"AlHikomapu","text_ar":"الحِكْمَةُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"daAriEN","text_ar":"دَارِعٌ"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Ald~iroEu","text_ar":"الدِّرْعُ"},{"kind":"text","text":". (Bd.)"}],"source_refs":["Msb","TA","S","Mgh","K","As"]}]},"classical_definitions":null}