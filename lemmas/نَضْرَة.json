ant and easy life;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"naEomapN","text_ar":"نَعْمَةٌ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"niEomap","text_ar":"نِعْمَة"},{"kind":"text","text":"]. (A, K.) ―         -b4-"},{"kind":"italic_en","text":"Richness;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"competence"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sufficiency."},{"kind":"text","text":"(A, K.) ―         -b5-"},{"kind":"italic_en","text":"Life."},{"kind":"text","text":"(A, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"naDorN","text_ar":"نَضْرٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K","TA","Bd","Jel"]}]}}