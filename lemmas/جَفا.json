{"lemma":"جَفا","slug":"جَفا","root":"ج.ف.#","root_slug":"ج-ف-_","root_link":"/words/roots/ج-ف-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَفَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَفَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَفَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَفَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَفَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَفا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَفَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَفَوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَفَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَفَوْا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَفَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجْف","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَجْفُو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَجْفَى","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجْفِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْفِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجْفُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْفُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْفَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْفُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْفُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْفُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَجْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْف","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْفُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْفَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْف","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْفُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْفَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْفُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْفُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْفُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْفُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْفُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْفُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَجْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْف","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْف","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"جَفَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَفَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَجْفُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْفُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْفَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْفَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":23,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n5959","n5996","n6003"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%81%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to deposit flotsam on the shore or riverbank, to wash up"},{"pos":"verb","gloss":"to deposit foam on the sides of a boiling pot"},{"pos":"verb","gloss":"to remove foam or debris from the side of a river or pot"},{"pos":"verb","gloss":"to tip over (a pot, to empty the contents into the bowl)"},{"pos":"verb","gloss":"to open (a door)"},{"pos":"verb","gloss":"to close (a door)"},{"pos":"verb","gloss":"uproot"},{"pos":"verb","gloss":"throw to the ground, overthrow"}]},"etymology":null,"ipa":["/d͡ʒa.fa.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5959","headword_ar":"جَفَاَ","root":"jfA^","body":[{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jafo'N","text_ar":"جَفْءٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a valley [flowing with water])"},{"kind":"italic_en","text":"cast forth froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and particles of rubbish"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refuse;"},{"kind":"text","text":"(S;) as also ↓"},{"kind":"arabic","text_bw":"AjfA^","text_ar":"اجفا","orth_type":"arrow"},{"kind":"text","text":"; (K;) but this latter is said in the O to be of weak authority. (TA.) And"},{"kind":"arabic","text_bw":"jafaA^ati Alqidoru","text_ar":"جَفَاَتِ القِدْرُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AjfA^t","text_ar":"اجفات","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The cooking-pot cast forth its froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"in boiling:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"jfA^t bizabadihaA","text_ar":"جفات بِزَبَدِهَا"},{"kind":"italic_en","text":"it cast forth its froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam:"},{"kind":"text","text":"(Ham p. 132:) originally"},{"kind":"arabic","text_bw":"jafat","text_ar":"جَفَت"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ajft","text_ar":"اجفت"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":". (Er-Rághib, TA in art."},{"kind":"arabic","text_bw":"jfw","text_ar":"جفو"},{"kind":"text","text":".)       -A2-"},{"kind":"arabic","text_bw":"jafaA^a AlwaAdiY","text_ar":"جَفَاَ الوَادِى"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"jafaA^a AlguvaA='a Eani AlwaAdiY","text_ar":"جَفَاَ الغُثَا=ءَ عَنِ الوَادِى"},{"kind":"text","text":", (IAar, O,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, IAar, O)"},{"kind":"italic_en","text":"swept off the scum and rubbish of the valley"},{"kind":"text","text":"[after it had flowed, or while it was flowing, with water]. (IAar, O, K.) And"},{"kind":"arabic","text_bw":"jafaA^a Alqidora","text_ar":"جَفَاَ القِدْرَ"},{"kind":"italic_en","text":"He cleared off the froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam, of the cooking-pot."},{"kind":"text","text":"(K, TA.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"jafaA^a Alqidora","text_ar":"جَفَاَ القِدْرَ"},{"kind":"text","text":", (S, Z in the Fáïk, TA,) inf. n. as above; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"A^ajofaA^ahaAs","text_ar":"اَجْفَاَهَاس","orth_type":"arrow"},{"kind":"text","text":"; (Z ubi suprà, TA;) but the former is that which is commonly known; (ISd, TA;) the latter is rare; (IAth, TA:) or the latter should not be said, though it occurs in a trad., (S, TA, *) accord. to one relation; (TA;)"},{"kind":"italic_en","text":"He turned the cooking-pot upsidedown,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inclined it,"},{"kind":"text","text":"(S, Z ubi suprà, TA,)"},{"kind":"italic_en","text":"and poured out what was in it:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"he emptied the cooking-pot, and turned it upside-down:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"jafaA^a Alburomapa fiY AlqaSoEapi","text_ar":"جَفَاَ البُرْمَةَ فِى القَصْعَةِ"},{"kind":"italic_en","text":"He turned the cookingpot upside-down upon the bowl."},{"kind":"text","text":"(K.) ―         -b3-"},{"kind":"arabic","text_bw":"jafaA^ahu","text_ar":"جَفَاَهُ"},{"kind":"text","text":", (S, K,) [like"},{"kind":"arabic","text_bw":"HafaA^ahu","text_ar":"حَفَاَهُ"},{"kind":"text","text":",] and"},{"kind":"arabic","text_bw":"jafaA^a bihi AlA^aroDa","text_ar":"جَفَاَ بِهِ الاَرْضَ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He threw him down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prostrated him, on the ground:"},{"kind":"text","text":"(S, K, TA;) namely, a man: (S:) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjfA^","text_ar":"اجفا","orth_type":"arrow"},{"kind":"text","text":"[signifies the same; or]"},{"kind":"italic_en","text":"he threw him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"on the ground."},{"kind":"text","text":"(TA.) ―         -b4-  See also 8."}],"source_refs":["S","K","IAar","O","IAth","TA"]},{"entry_id":"n5996","headword_ar":"جَفَا","root":"jfw","body":[{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"jafaA='N","text_ar":"جَفَا=ءٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tjAfY","text_ar":"تجافى","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"It did not keep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleave, to its place."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"jafaA janobuhu Eani AlfiraA$i","text_ar":"جَفَا جَنْبُهُ عَنِ الفِرَاشِ"},{"kind":"text","text":", (Mgh,) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tjAfY","text_ar":"تجافى","orth_type":"arrow"},{"kind":"text","text":", (S, Mgh,)"},{"kind":"italic_en","text":"His side did not rest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was restless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uneasy, upon the bed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shrank from it;"},{"kind":"text","text":"(S, Mgh;) and"},{"kind":"italic_en","text":"heaved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rose, from it:"},{"kind":"text","text":"(Mgh:) or the former,"},{"kind":"italic_en","text":"his side did not keep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleave, to its place upon the bed:"},{"kind":"text","text":"and the latter,"},{"kind":"italic_en","text":"it became withdrawn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, from it."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"jafaA Als~aroju Eano Zahori Alfarasi","text_ar":"جَفَا السَّرْجُ عَنْ ظَهْرِ الفَرَسِ"},{"kind":"text","text":", (S Msb, TA,) aor. and inf. n. as above; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tjAfY","text_ar":"تجافى","orth_type":"arrow"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"The saddle heaved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rose, from the back of the horse:"},{"kind":"text","text":"(S, Msb:) or"},{"kind":"italic_en","text":"did not keep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleave, to its place upon his back."},{"kind":"text","text":"(TA.) ―         -b2-  [Hence,] it is said in a trad. of 'Omar,"},{"kind":"arabic","text_bw":"A_in~iY A^ajofuw Eano A^a$oyaA='a mina AlEilomi","text_ar":"اـِنِّى اَجْفُو عَنْ اَشْيَا=ءَ مِنَ العِلْمِ"},{"kind":"italic_en","text":"Verily I recoil, shrink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"am averse, from some matters of knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science, and ignore them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglect them."},{"kind":"text","text":"(Mgh.) ―         -b3-  Also"},{"kind":"arabic","text_bw":"jafaA","text_ar":"جَفَا"},{"kind":"text","text":", (Msb, TA,) aor. as above, (Msb,) [and so the inf. n.,] said of a garment, or piece of cloth,"},{"kind":"italic_en","text":"It was thick, coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough:"},{"kind":"text","text":"(Msb, TA:) and in like manner said of a reed-pen,"},{"kind":"italic_en","text":"it was thick, coarse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rough, in its nib."},{"kind":"text","text":"(TA.) ―         -b4-  [And hence, (see"},{"kind":"arabic","text_bw":"jafaA='N","text_ar":"جَفَا=ءٌ"},{"kind":"text","text":", below, and"},{"kind":"arabic","text_bw":"jaAfK","text_ar":"جَافٍ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thick, gross, coarse, rough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rude, of make:"},{"kind":"text","text":"and, more commonly,"},{"kind":"italic_en","text":"coarse, rough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rude, of nature"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in his intercourse and dealings with others; unkind, hard, churlish, uncivil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surly."},{"kind":"text","text":"(See also 10.)] It is said in a trad.,"},{"kind":"arabic","text_bw":"mano badaA jafaA","text_ar":"مَنْ بَدَا جَفَا"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"He who abides in the desert"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"becomes coarse, rough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rude, of nature"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposition;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"unkind, hard, churlish,"},{"kind":"text","text":"&c.;] by reason of mixing little with men. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"jafaA Ealayohi ka*aA","text_ar":"جَفَا عَلَيْهِ كَذَا"},{"kind":"italic_en","text":"Such a thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, heavy, onerous, burdensome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"oppressive, to him."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"jafaA janobahu Eani","text_ar":"جَفَا جَنْبَهُ عَنِ"},{"kind":"arabic","text_bw":"AlfiraA$i","text_ar":"الفِرَاشِ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"jafaA Als~aroja","text_ar":"جَفَا السَّرْجَ"},{"kind":"text","text":": see 3. ―         -b2-"},{"kind":"arabic","text_bw":"jafati Alqidoru","text_ar":"جَفَتِ القِدْرُ"},{"kind":"arabic","text_bw":"zabadahaA","text_ar":"زَبَدَهَا"},{"kind":"italic_en","text":"The cooking-pot cast forth its froth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foam;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ajft","text_ar":"اجفت","orth_type":"arrow"},{"kind":"text","text":"; (TA;) [like"},{"kind":"arabic","text_bw":"jafaA^at","text_ar":"جَفَاَت"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"AjfA^t","text_ar":"اجفات"},{"kind":"text","text":";] originally without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":". (Er- Rághib, TA.) And"},{"kind":"arabic","text_bw":"jafaA Als~ayolu","text_ar":"جَفَا السَّيْلُ"},{"kind":"italic_en","text":"The torrent drove away"},{"kind":"text","text":"[things in its course]. (Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"jafaA Alr~ajula","text_ar":"جَفَا الرَّجُلَ"},{"kind":"text","text":", aor. as above,"},{"kind":"italic_en","text":"He turned away from the man; avoided him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shunned him:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he drove away the man;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"jfA Als~ayolu","text_ar":"جفا السَّيْلُ"},{"kind":"text","text":", explained above: sometimes meaning,"},{"kind":"italic_en","text":"with hatred."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"jafaAhu","text_ar":"جَفَاهُ"},{"kind":"italic_en","text":"He withdrew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removed, far,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to a distance, from him:"},{"kind":"text","text":"whence the saying of Mohammad Ibn-Sookah,"},{"kind":"arabic","text_bw":"lam~aA qal~a maAliY jafaAniY A_ixowaAniY","text_ar":"لَمَّا قَلَّ مَالِى جَفَانِى اـِخْوَانِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"When my property became little, my brethren withdrew far from me"},{"kind":"text","text":"]. (TA) ―         -b4-  And"},{"kind":"arabic","text_bw":"jafaA maAlahu","text_ar":"جَفَا مَالَهُ"},{"kind":"italic_en","text":"He did not keep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleave,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hold fast, to his property."},{"kind":"text","text":"(K.) ―         -b5-  And"},{"kind":"arabic","text_bw":"jafaAhu","text_ar":"جَفَاهُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"jafaA='N","text_ar":"جَفَا=ءٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"jafowN","text_ar":"جَفْوٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He treated him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved towards him, coarsely, roughly, rudely, unkindly, hardly, churlishly, uncivilly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"surlily:"},{"kind":"text","text":"(S, K:) you should not say"},{"kind":"arabic","text_bw":"jafayotu","text_ar":"جَفَيْتُ"},{"kind":"text","text":". (S.) The pass. part. n. is ↓"},{"kind":"arabic","text_bw":"majofuw~N","text_ar":"مَجْفُوٌّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"majofiY~N","text_ar":"مَجْفِىٌّ","orth_type":"arrow"},{"kind":"text","text":": (S, and K in art."},{"kind":"arabic","text_bw":"jfY","text_ar":"جفى"},{"kind":"text","text":":) the latter formed in accordance with"},{"kind":"arabic","text_bw":"jufiYa","text_ar":"جُفِىَ"},{"kind":"text","text":", in which the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":". (Fr, S.) ―         -b6-"},{"kind":"italic_en","text":"He did to him what displeased, grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vexed, him; did to him what he disliked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated; did evil to him."},{"kind":"text","text":"(TA.) So in the trad.,"},{"kind":"arabic","text_bw":"mano Haj~a walamo yazuroniY faqado jafaA","text_ar":"مَنْ حَجَّ وَلَمْ يَزُرْنِى فَقَدْ جَفَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He who performs the pilgrimage"},{"kind":"text","text":"to Mekkeh"},{"kind":"italic_en","text":"and does not visit me,"},{"kind":"text","text":"i.e. does not visit my tomb afterwards, either on his homeward journey or by journeying to ElMedeeneh for that special purpose,"},{"kind":"italic_en","text":"does what displeases"},{"kind":"text","text":"me]. (TA.) ―         -b7-"},{"kind":"arabic","text_bw":"jafati AlmaroA^upu waladahaA","text_ar":"جَفَتِ المَرْاُةُ وَلَدَهَا"},{"kind":"italic_en","text":"The woman neglected to take care of her child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to pay frequent attention to it."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA","Mgh","S","Msb"]},{"entry_id":"n6003","headword_ar":"جَفًا","root":"jfw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jafaA='N","text_ar":"جَفَا=ءٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}