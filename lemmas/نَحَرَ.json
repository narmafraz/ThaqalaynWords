"role":"present_2mp","form":"تَنْحُرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَنْحُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَنْحُر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَنْحُر","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَنْحُرانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَنْحُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْحُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْحُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْحُرُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْحُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْحُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"نَحَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَحَرْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْحُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْحُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":29,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n39485"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%AD%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to slaughter, to butcher"},{"pos":"verb","gloss":"to massacre, to slay"},{"pos":"noun","gloss":"verbal noun of نَحَرَ (naḥara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"slaughter, butchering, killing, massacring"},{"pos":"noun","gloss":"throat"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39485","headword_ar":"نَحَرَ","root":"nHr","body":[{"kind":"text","text":", (A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"naHorN","text_ar":"نَحْرٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"manoHarN","text_ar":"مَنْحَرٌ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"tanoHaArN","text_ar":"تَنْحَارٌ"},{"kind":"text","text":"[an intensive form], (K,)"},{"kind":"italic_en","text":"He stabbed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stuck,"},{"kind":"text","text":"(A, K,) a camel, (A, TA,) or a beast, (Msb,) [but generally the former,]"},{"kind":"italic_en","text":"in his"},{"kind":"arabic","text_bw":"naHor","text_ar":"نَحْر"},{"kind":"text","text":", (A,) or"},{"kind":"italic_en","text":"in his"},{"kind":"arabic","text_bw":"manoHar","text_ar":"مَنْحَر"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"where the windpipe"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Huloquwm","text_ar":"حُلْقُوم"},{"kind":"text","text":")"},{"kind":"italic_en","text":"commences in the uppermost part of the breast;"},{"kind":"text","text":"(K, TA;) [i. e.,"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"lab~ap","text_ar":"لَبَّة"},{"kind":"text","text":"; for]"},{"kind":"arabic","text_bw":"naHorN","text_ar":"نَحْرٌ"},{"kind":"text","text":"in the"},{"kind":"arabic","text_bw":"lab~ap","text_ar":"لَبَّة"},{"kind":"text","text":"is like"},{"kind":"arabic","text_bw":"*aboHN","text_ar":"ذَبْحٌ"},{"kind":"text","text":"in the throat. (S.) [Hence,]"},{"kind":"arabic","text_bw":"yawomN Aln~aHori","text_ar":"يَوْمٌ النَّحْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The day of the stabbing of the camels &c."},{"kind":"text","text":"]; (K;) and"},{"kind":"arabic","text_bw":"Eiydu Aln~aHori","text_ar":"عِيدُ النَّحْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the festival of the stabbing of the camels"},{"kind":"text","text":"&c.]; (Msb;)"},{"kind":"italic_en","text":"the tenth of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the month"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Dhu-l-Hijjeh;"},{"kind":"text","text":"(K;) because then the camels and cows and bulls brought as offerings to Mekkeh, for sacrifice, are stabbed. (TA.) ―         -b2-"},{"kind":"italic_en","text":"He slew."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"naHarahu","text_ar":"نَحَرَهُ"},{"kind":"text","text":", aor. and inf. ns. as above,"},{"kind":"italic_en","text":"He hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, his"},{"kind":"arabic","text_bw":"naHor","text_ar":"نَحْر"},{"kind":"text","text":". (K.) You say"},{"kind":"arabic","text_bw":"naHarotu Alr~ajula","text_ar":"نَحَرْتُ الرَّجُلَ"},{"kind":"italic_en","text":"I hit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hurt, the"},{"kind":"arabic","text_bw":"naHor","text_ar":"نَحْر"},{"kind":"italic_en","text":"of the man."},{"kind":"text","text":"(S.)       -A2-  [Hence,]"},{"kind":"arabic","text_bw":"naHara AlA^umuwra EilomFA","text_ar":"نَحَرَ الاُمُورَ عِلْمًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He mastered affairs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the affairs, by knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science"},{"kind":"text","text":"]: (A):"},{"kind":"italic_en","text":"he knew affairs soundly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thoroughly."},{"kind":"text","text":"(Har, 2nd ed. of Paris, p. 95, Com.) And"},{"kind":"arabic","text_bw":"yanoHaru AlEiloma","text_ar":"يَنْحَرُ العِلْمَ"},{"kind":"arabic","text_bw":"naHorFA","text_ar":"نَحْرًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He masters knowledge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science, indeed"},{"kind":"text","text":"]. (A, K.) Jereer was asked respecting the Islámee poets, and answered,"},{"kind":"arabic","text_bw":"naboEapu Al$~uEaraA='i lilofarazodaqi","text_ar":"نَبْعَةُ الشُّعَرَا=ءِ لِلْفَرَزْدَقِ"},{"kind":"text","text":"[meaning, “ The bow, ” or “ the arrow, of the poets belongs to El-Farezdak; ” applying the term"},{"kind":"arabic","text_bw":"nbEp","text_ar":"نبعة"},{"kind":"text","text":"in this manner because bows and arrows were made of the tree called"},{"kind":"arabic","text_bw":"naboE","text_ar":"نَبْع"},{"kind":"text","text":"]: so it was said, “ Then what hast thou left for thyself? ” and he answered,"},{"kind":"arabic","text_bw":"A^anaA naHarotu Al$~iEora naHorFA","text_ar":"اَنَا نَحَرْتُ الشِّعْرَ نَحْرًا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I have mastered poetry indeed"},{"kind":"text","text":"]. (A.) You say also,"},{"kind":"arabic","text_bw":"naHarotu Al$~aYo'a EilomFA","text_ar":"نَحَرْتُ الشَّىْءَ عِلْمًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I knew the thing thoroughly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superlatively well;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"qatalotuhu EilomFA","text_ar":"قَتَلْتُهُ عِلْمًا"},{"kind":"text","text":". (Bd in iv. 156.)       -A3-  [Hence also,]"},{"kind":"arabic","text_bw":"naHara AlS~alaApa","text_ar":"نَحَرَ الصَّلَاةَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He performed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recited, the prayer in the first part of its time."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"naHarahumu A@ll~`hu","text_ar":"نَحَرَهُمُ ا@للّٰهُ"},{"kind":"text","text":", occurring in a trad., may mean either (assumed tropical:)"},{"kind":"italic_en","text":"May God hasten to do them good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may God slay them."},{"kind":"text","text":"(IAth.)       -A4-  [Hence also,]"},{"kind":"arabic","text_bw":"naHarotu Alr~ajula","text_ar":"نَحَرْتُ الرَّجُلَ"},{"kind":"text","text":", (S, A,) inf. n."},{"kind":"arabic","text_bw":"naHorN","text_ar":"نَحْرٌ"},{"kind":"text","text":", (A,) (tropical:)"},{"kind":"italic_en","text":"I became opposite to the man;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Sirotu fiY naHorihi","text_ar":"صِرْتُ فِى نَحْرِهِ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"I faced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fronted, him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaAbalotuhu","text_ar":"قَابَلْتُهُ"},{"kind":"text","text":". (A, TA.) And"},{"kind":"arabic","text_bw":"naHara Ald~aAru Ald~aAra","text_ar":"نَحَرَ الدَّارُ الدَّارَ"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"naHarat","text_ar":"نَحَرَت"},{"kind":"text","text":",] (K,) aor."},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The house faced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fronted, the house;"},{"kind":"text","text":"(K, TA;) as also ↓"},{"kind":"arabic","text_bw":"naAHarat","text_ar":"نَاحَرَت","orth_type":"arrow"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"diyaAruhumo tanoHaru AlT~ariyqa","text_ar":"دِيَارُهُمْ تَنْحَرُ الطَّرِيقَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Their houses face,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"front, the road."},{"kind":"text","text":"(A.) [See also 6.] And Abu-lGheyth says, that the last night of the month, with its day, is called"},{"kind":"arabic","text_bw":"Aln~aHiyrapu","text_ar":"النَّحِيرَةُ"},{"kind":"text","text":"for this reason,"},{"kind":"arabic","text_bw":"liA^an~ahaA tanoHaru Al$~ahora A@l~a*iY baEodahaA","text_ar":"لِاَنَّهَا تَنْحَرُ الشَّهْرَ ا@لَّذِى بَعْدَهَا"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"Because it becomes opposite to the month that is after it:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"because it reaches the first part of the month that is after it."},{"kind":"text","text":"(S.)"}],"source_refs":["A","Msb","K","S","TA"]}]}}