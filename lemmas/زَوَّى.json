pos":"noun","gloss":"verbal noun of زَوَى (zawā) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18447","headword_ar":"زوّى","root":"zwY","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tazowiyapN","text_ar":"تَزْوِيَةٌ"},{"kind":"text","text":": see 5.       -A2-"},{"kind":"arabic","text_bw":"zay~ayotuhu","text_ar":"زَيَّيْتُهُ"},{"kind":"text","text":", (S, Msb, K,) which by rule should be"},{"kind":"arabic","text_bw":"zaw~ayotuhu","text_ar":"زَوَّيْتُهُ"},{"kind":"text","text":", (S, Msb,) but is made to accord with"},{"kind":"arabic","text_bw":"ziY~N","text_ar":"زِىٌّ"},{"kind":"text","text":"in order to facilitate the pronunciation, (Msb,) inf. n. accord. to the K"},{"kind":"arabic","text_bw":"tazoyiyapN","text_ar":"تَزْيِيَةٌ"},{"kind":"text","text":", but correctly, as Lth says,"},{"kind":"arabic","text_bw":"taziy~apN","text_ar":"تَزِيَّةٌ"},{"kind":"text","text":", in measure like"},{"kind":"arabic","text_bw":"taHiy~apN","text_ar":"تَحِيَّةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"I invested him with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made him to have, a"},{"kind":"arabic","text_bw":"ziY~","text_ar":"زِىّ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"garb, guise,"},{"kind":"text","text":"&c.]; (S, * Msb, K, * TA;) by means of, or with, such a thing: you say,"},{"kind":"arabic","text_bw":"zay~ayotuhu bika*aA","text_ar":"زَيَّيْتُهُ بِكَذَا"},{"kind":"text","text":"[which may be rendered"},{"kind":"italic_en","text":"I invested, decked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adorned, him with such a thing;"},{"kind":"text","text":"agreeably with what follows]. (Msb.) Accord. to Fr, they say,"},{"kind":"arabic","text_bw":"zay~ayotu AljaAriyapa","text_ar":"زَيَّيْتُ الجَارِيَةَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I invested the girl,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young woman, with a garb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guise,"},{"kind":"text","text":"&c.; and"},{"kind":"italic_en","text":"decked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adorned, her."},{"kind":"text","text":"(TA.) ―         -b2-  You say also,"},{"kind":"arabic","text_bw":"zw~Y AlkalaAma","text_ar":"زوّى الكَلَامَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He prepared the speech in his mind;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"zaw~arahu","text_ar":"زَوَّرَهُ"},{"kind":"text","text":". (TA.)       -A3-"},{"kind":"arabic","text_bw":"zay~ayotu zaAyFA","text_ar":"زَيَّيْتُ زَايًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zaw~ayotu zaAyFA","text_ar":"زَوَّيْتُ زَايًا"},{"kind":"text","text":"[mean"},{"kind":"italic_en","text":"I wrote,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uttered, a"},{"kind":"arabic","text_bw":"z","text_ar":"ز"},{"kind":"text","text":"]: some [hold the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"zAY","text_ar":"زاى"},{"kind":"text","text":"to be originally"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", and therefore] say"},{"kind":"arabic","text_bw":"zay~ayotu","text_ar":"زَيَّيْتُ"},{"kind":"text","text":": others [hold it to be originally"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":", and therefore] say"},{"kind":"arabic","text_bw":"zaw~ayotu","text_ar":"زَوَّيْتُ"},{"kind":"text","text":". (IB, on the letter"},{"kind":"arabic","text_bw":"A^alif","text_ar":"اَلِف"},{"kind":"text","text":".) Zeyd Ibn-Thábit said, in relation to the expression in the Kur [ii. 261]"},{"kind":"arabic","text_bw":"nuno$izuhaA","text_ar":"نُنْشِزُهَا"},{"kind":"text","text":", [accord. to one reading, or reciting,]"},{"kind":"arabic","text_bw":"hiYa zaAYN fazay~ihaA","text_ar":"هِىَ زَاىٌ فَزَيِّهَا"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"It is"},{"kind":"arabic","text_bw":"zAY","text_ar":"زاى"},{"kind":"text","text":","},{"kind":"italic_en","text":"therefore make thou it"},{"kind":"arabic","text_bw":"zAY","text_ar":"زاى"},{"kind":"text","text":"in thy reading, or reciting; or]"},{"kind":"italic_en","text":"read thou it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recite thou it, with the"},{"kind":"arabic","text_bw":"zAY","text_ar":"زاى"},{"kind":"text","text":". (S.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}