E%D8%B1%D9%8E%D8%B5%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to conjecture, to guess","examples":[{"text":"إِن تَتَّبِعُونَ إِلَّا الظَّنَّ وَإِنْ أَنتُمْ إِلَّا تَخْرُصُونَ"}]},{"pos":"verb","gloss":"to lie"},{"pos":"noun","gloss":"verbal noun of خَرَصَ (ḵaraṣa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"earring"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10347","headword_ar":"خُرْصٌ","root":"xrS","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"xiroSN","text_ar":"خِرْصٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"A ring:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"a ring of gold,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of silver:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"an ear-ring with one bead,"},{"kind":"text","text":"(A, TA,)"},{"kind":"italic_en","text":"of the kind called"},{"kind":"arabic","text_bw":"quroT","text_ar":"قُرْط"},{"kind":"text","text":": (TA:) or the"},{"kind":"italic_en","text":"ring of a"},{"kind":"arabic","text_bw":"quroT","text_ar":"قُرْط"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"a small ring; one of the ornaments of women;"},{"kind":"text","text":"(Sh, K;)"},{"kind":"italic_en","text":"in the form of the"},{"kind":"arabic","text_bw":"quroT","text_ar":"قُرْط"},{"kind":"italic_en","text":"or some other thing:"},{"kind":"text","text":"(Sh:) pl."},{"kind":"arabic","text_bw":"xiroSaAnN","text_ar":"خِرْصَانٌ"},{"kind":"text","text":". (S, K.) [Hence,]"},{"kind":"arabic","text_bw":"maA tamoliku fulaAnapu xuroSFA","text_ar":"مَا تَمْلِكُ فُلَانَةُ خُرْصًا"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"Such a woman has not in her possession anything."},{"kind":"text","text":"(A.)"}],"source_refs":["S","A","Msb","K","TA","Sh"]},{"entry_id":"n10348","headword_ar":"خِرْصٌ","root":"xrS","body":[{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"xaraSa","text_ar":"خَرَصَ"},{"kind":"text","text":"as explained above; (S, A, Msb, K)"},{"kind":"italic_en","text":"Conjectural computation of quantity:"},{"kind":"text","text":"(ISh:) or"},{"kind":"italic_en","text":"quantity computed by conjecture"},{"kind":"text","text":"of the fruit upon palm-trees. (A, Mgh.) You say,"},{"kind":"arabic","text_bw":"kamo xiroSu naxolika","text_ar":"كَمْ خِرْصُ نَخْلِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What is the conjectural computation of the quantity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the quantity computed by conjecture, of the produce of thy palm-trees?"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"kamo xiroSu A^aroDika","text_ar":"كَمْ خِرْصُ اَرْضِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What is the conjectural computation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the quantity computed by conjecture, of the produce of the palm-trees of thy land?"},{"kind":"text","text":"]. (S, A, K.)       -A2-  See also"},{"kind":"arabic","text_bw":"xuroSN","text_ar":"خُرْصٌ"},{"kind":"text","text":".       -A3-  And see"},{"kind":"arabic","text_bw":"xarosN","text_ar":"خَرْسٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","Msb","K","ISh"]},{"entry_id":"n10349","headword_ar":"خَرِصٌ","root":"xrS","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"hungry and cold:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"hungry in cold:"},{"kind":"text","text":"(K:) and ↓"},{"kind":"arabic","text_bw":"xaAriSN","text_ar":"خَارِصٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (TA.) [See also"},{"kind":"arabic","text_bw":"xaSirN","text_ar":"خَصِرٌ"},{"kind":"text","text":".]"}],"source_refs":["S","TA","K"]}]},"classical_definitions":null}