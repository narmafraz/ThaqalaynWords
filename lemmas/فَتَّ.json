{"lemma":"فَتَّ","slug":"فَتَّ","root":"ف.ت.ت","root_slug":"ف-ت-ت","root_link":"/words/roots/ف-ت-ت","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"فَتَتَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"فَتَتِّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"فَتَتُّما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"فَتَتُّم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"فَتَتُّنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"فَتَّ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"فَتَّت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"فَتّا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"فَتَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"فَتُّوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"فَتَتْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَفُتّ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَفْتُت","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَفُتِّي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَفُتِّينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَفُتّا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَفُتّانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَفُتُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفُتُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْتُتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفُتّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَفْتُت","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفُتّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَفْتُت","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفُتّا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفُتّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفُتّا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفُتّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفُتُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفُتُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْتُتْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَفُتّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفُتّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"فَتَتُّ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَتَتْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n32859"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AA%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to break, to bruise, to bray, to disintegrate","tags":["transitive"]},{"pos":"verb","gloss":"to weaken, to enervate, to discourage, to defeat","tags":["figuratively","transitive"]},{"pos":"noun","gloss":"verbal noun of فَتَّ (fatta) (form I)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"noun","gloss":"crumb, morsel","tags":["transitive"]},{"pos":"noun","gloss":"fissure","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32859","headword_ar":"فَتَّ","root":"ft","body":[{"kind":"text","text":", (S, M, O, Msb,) aor."},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"fat~N","text_ar":"فَتٌّ"},{"kind":"text","text":", (Lth, T, M, Msb, K,)"},{"kind":"italic_en","text":"He crumbled"},{"kind":"text","text":"a thing, or"},{"kind":"italic_en","text":"broke"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"into small pieces, with his fingers:"},{"kind":"text","text":"(Lth, T, TA:) or"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"(a thing, M)"},{"kind":"italic_en","text":"with his fingers:"},{"kind":"text","text":"(M, K:) or [simply]"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"a thing: (S, O:) or (M)"},{"kind":"italic_en","text":"he bruised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brayed,"},{"kind":"text","text":"(M, K,) a thing: (M:) and ↓"},{"kind":"arabic","text_bw":"ft~t","text_ar":"فتّت","orth_type":"arrow"},{"kind":"text","text":", (M, TA,) inf. n."},{"kind":"arabic","text_bw":"tafotiytN","text_ar":"تَفْتِيتٌ"},{"kind":"text","text":", (O,) signifies the same; (M, TA;) or [rather]"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"[a thing, or"},{"kind":"italic_en","text":"crumbled"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"with his fingers,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"much."},{"kind":"text","text":"(O.) You say of a man,"},{"kind":"arabic","text_bw":"fat~a","text_ar":"فَتَّ"},{"kind":"arabic","text_bw":"Alxuboza","text_ar":"الخُبْزَ"},{"kind":"text","text":", (A, Msb,) aor. and inf. n. as above; (Msb;) and ↓"},{"kind":"arabic","text_bw":"ft~thu","text_ar":"فتّتهُ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He crumbled the bread with his fingers."},{"kind":"text","text":"(A.) ―         -b2-  [Hence,] one says,"},{"kind":"arabic","text_bw":"*aA mim~aA","text_ar":"ذَا مِمَّا"},{"kind":"arabic","text_bw":"yafut~u kabidiY","text_ar":"يَفُتُّ كَبِدِى"},{"kind":"text","text":"(assumed tropical:)  [lit."},{"kind":"italic_en","text":"This is of what crumbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crushes, my liver;"},{"kind":"text","text":"like as we say, “ of what breaks my heart ”]. (A, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"kal~amahu","text_ar":"كَلَّمَهُ"},{"kind":"arabic","text_bw":"bi$aYo'K fafat~a fiY saAEidihi","text_ar":"بِشَىْءٍ فَفَتَّ فِى سَاعِدِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He told him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoke to him, of a thing, and it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"crushed,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"weakened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enervated, him."},{"kind":"text","text":"(M, K, * TA.) And"},{"kind":"arabic","text_bw":"fat~a fiY","text_ar":"فَتَّ فِى"},{"kind":"arabic","text_bw":"EaDudiY wahad~a rukoniY","text_ar":"عَضُدِى وَهَدَّ رُكْنِى"},{"kind":"text","text":"(O, TA) (assumed tropical:)"},{"kind":"italic_en","text":"He broke my strength, and dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated, my assistants."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"fat~a fiY EaDudi fulaAnK","text_ar":"فَتَّ فِى عَضُدِ فُلَانٍ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"fiY A^aholi bayotihi","text_ar":"فِى اَهْلِ بَيْتِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He sought to injure such a one by diminishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impairing,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in number"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the people of his house."},{"kind":"text","text":"(T, O. [See also art."},{"kind":"arabic","text_bw":"EDd","text_ar":"عضد"},{"kind":"text","text":".]) The verb in this phrase is also used in the pass. form. (O.)"}],"source_refs":["S","M","O","Msb","Lth","T","K","TA","A"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%81%D8%AA/","headword_ar":"فت","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=52458#249fbf","body_html":"فت: فت: هرم اللحم، قطعه قطعاً صغاراً، فرم اللحم، (ألكالا).<br>فت: فتات الخبز، كسر الخبز. (بوشر).<br>فتة: قطعة، شقة، جذمة، شريحة، قدة، قطعة، دقيقة. (برجرن، مارسيل) فتة: فطيرة تحشى بقطع لحم، فطيرة محشوة (بوشر).<br>فتة: حساء فيه قطع أو كسر من الخبز، ثريدة.<br>ثريد: (بوشر).<br>فتة: طعام يتخذ من اللحم المفروم يوضع على قطع صغيرة من الخبز وتبل (لين عادات 280:2).<br>فتة خبز: ثريد، حساء من ماء وخبز وزبدة مغلية معاً، وطعام يتخذ من كسر الخبز المنقوع في مرقة اللحم، (بوشر).<br>فتات: نوع من العجين يتخذ من دقيق القمح، يخبز ويعتبر من الأطعمة اللذيذة. (دنهام 20:2).<br>فتات: طعام يتخذ من عجين لا خميرة فيه ويخبز بالفرن فترة قليلة ثم يفت، وتوضع طبقة منه في قصعة وتصب عليه شوربة الخضراوات ثم توضع عليه طبقة أخرى منه وتصب عليه شوربة الخضراوات وهكذا دواليك حتى تمتلئ القصعة (ليون ص51).<br>فتوت: نوع من الطعام (انظر لين). وفي رياض النفوس (ص31 و) في الكلام عن امرأة متزوجة: خفاقة هي التي تصبح غدوة جائعة فتقول أبغي روسا أبغي فتوتاً. فتيت: فتات الخبز كسر الخبز (بوشر، ابن البيطار 245:2، عباد 220:3).<br>فتاتة: الواحدة من فئات الخبز، وهي فتاتة في المعجم اللاتيني - العربي، وفتاتة في معجم فوك (وجمعها فتات وفتائت) وهي فتاتة عند همبرت ص 13.<br>فتيتة: نوع من العصيد (النقانق) يتخذ من اللبن الرائب وكثير من الزبد. (برجرن، بوركهارت سورية ص385، وبوركهارت البد ص32).<br>تفتيت: طعام من الخبز واللبن الحليب. (ميهرن ص34).<br>دواء مفتت: مطهر، منظف، منق، ودواء ملين يزيل التصلب، دواء يفرق الأخلاط. (بوشر، محيط المحيط)."},{"lexicon_id":"dictionary_36","lexicon_en":"Al-Ṣāḥib bin ʿAbbād, Al-Muḥīṭ fī l-Lugha (d. c. 995 CE)","lexicon_ar":"المحيط في اللغة للصاحب بن عباد","permalink":"https://arabiclexicon.hawramani.com/?p=52458#67754c","body_html":"<span class=\"title1\">فت</span><br><span>الفُتَاتُ: ما يَتَفَتتُ من الخُبْزِ. والفَتِيْتُ: الشيْءُ المَفْتُوْتُ. والمُتَقَطَعُ، والفَتُوْتُ أيضاً. والفَتَةُ: بَعْرَةٌ أوْ رَوْثَة مَفْتُوْتَةٌ، وهي الفِتَةُ أيضاً. وفي المَثَلِ: \" هو أشْبَهُ به من الفِتةِ بالفِتَّةِ \". وفَت في عَضُدِه: كقَوْلهم رَتَا في ذَرْعِه.</span><br><span>وما في يَدي منكَ حَت ولا فَت: أي شَيْءٌ.</span><br><span>وتَرَكَه اللَّهُ حَتّاً فَتاً: لايَمْلأ كَفّاً.</span><br><span>والفَتْفَتَةُ: أنْ تَشْرَبَ الِإبِلُ دُوْنَ رِيها. والسِّرَارُ، يُقال: كانَ بَيْنَ القَوْمِ فَتَافِتُ: في السَرِّ الذي يُسْمَعُ ولا يُفْهَمُ.</span>"},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=52458#b36890","body_html":"<h3>فت</h3><span class=\"sense\">1</span> فَتَّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> ـُ (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَتٌّ, (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) He crumbled a thing, or broke it into small pieces, with his fingers: (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or he broke (a thing, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>) with his fingers: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) or [simply] he broke a thing: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, O:) or (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>) he bruised, or brayed, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) a thing: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>:) and ↓ فتّت, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>,) <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> تَفْتِيتٌ, (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) signifies the same; (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) or [rather] he broke [a thing, or crumbled it with his fingers,] much. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>.) You say of a man, فَتَّ الخُبْزَ, (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) <abbr title=\"aorist (shows the vowel of the second consonant of the aorist/muḍāriʿ form)\">aor.</abbr> and <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> as above; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>;) and ↓ فتّتهُ; He crumbled the bread with his fingers. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) <span class=\"sub-sense\">b2:</span> [Hence,] one says, ذَا مِمَّا يَفُتُّ كَبِدِى (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) [<abbr title=\"literally\">lit.</abbr> This is of what crumbles, or crushes, my liver; like as we say, “of what breaks my heart ”]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) <span class=\"sub-sense\">b3:</span> And كَلَّمَهُ بِشَىْءٍ فَفَتَّ فِى سَاعِدِهِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He told him, or spoke to him, of a thing, and it [crushed, or] weakened, or enervated, him. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>, * <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And فَتَّ فِى<br><br>عَضُدِى وَهَدَّ رُكْنِى (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>) (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He broke my strength, and dispersed, or separated, my assistants. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) And فَتَّ فِى عَضُدِ فُلَانٍ i. e. فِى أَهْلِ بَيْتِهِ (assumed <abbr title=\"مَجَازٌ and مَجَازِيٌّ\">tropical</abbr>:) He sought to injure such a one by diminishing, or impairing, [in number or power,] the people of his house. (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, O. [See also art. عضد.]) The verb in this phrase is also used in the <abbr title=\"passive, مَبْنِيٌّ لِلْمَفْعُولِ or لِلْمَجْهُولِ\">pass.</abbr> form. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>.) 2 فَتَّّ see the preceding paragraph, in two places.<span class=\"sense\">5</span> تَفَتَّّ see the paragraph here following.<span class=\"sense\">7</span> انفتّ It became crumbled, or broken into small pieces, with the fingers: (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or it became broken with the fingers: (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>:) or [simply] it became broken: (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, O:) or it became bruised, or brayed: and ↓ تفتّت signifies the same; (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>;) or [rather] it became broken [or crumbled with the fingers] much. (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, O.) <abbr title=\"al-Rawḍ al-Unuf of al-Suhaylī\">R</abbr>. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 1 فَتْفَتَةٌ [<abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> of فَتْفَتَ] The drinking, of camels, less than satisfies thirst. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> [And it is also <abbr title=\"transitive, مَتَعَدٌّ and وَاقِعٌ\">trans.</abbr>:] one says of a pastor, فَتْفَتَ إِبِلَهُ He drove back his camels from the water when they had not satisfied their thirst. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, O.) <span class=\"sub-sense\">A2:</span> And فَتْفَتَ إِلَيْهِ, <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَتْفَتَةٌ, He spoke secretly to him: one says, مَا هٰذِهِ الدَّنْدَنَةُ وَالفَتْفَتَةُ [What is this whispering, and secret speaking?]. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) فَتٌّ A fissure in a rock: (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) as also ثَتٌّ: (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>:) <abbr title=\"plural, جَمْعٌ\">pl.</abbr> فُتُوتٌ. (<abbr title=\"Ibn al-Aʿrābī\">IAar</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, O.) <span class=\"sub-sense\">A2:</span> مَا فِى يَدِى مِنْكَ حَتٌّ وَلَا فَتٌّ There is not in my hand, from thee, aught. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>.) <span class=\"sub-sense\">A3:</span> أُولٰئِكَ أَهْلُ بَيْتٍ فَتٍّ and ↓ فُتٍّ (<abbr title=\"al-Farrāʾ\">Fr</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr> *) and ↓ فِتٍّ (<abbr title=\"al-Farrāʾ\">Fr</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>) Those are the people of a house dispersed, or scattered, (<abbr title=\"al-Farrāʾ\">Fr</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>. *) فُتٌّ and فِتٌّ: see what next precedes.<br><br>فَتَّةٌ, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, and so in some copies of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or ↓ فُتَّةٌ, (so in other copies of the <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>,) or both, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or the latter and ↓ فِتَّةٌ, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) The thing, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) or piece of dung, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) [i. e.] of dry dung, (<abbr title=\"The Calcutta edition of the Qāmūs of Firuzabadi\">CK</abbr>,) of the camel, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or of the horse or any solid-hoofed animal, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>,) that is broken, or crumbled, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and put beneath the زَنْدَة, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) or put beneath the زَنْد, on the occasion of striking fire, (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>,) [i. e.] in which one strikes fire. (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) [Hence,] one says, فُلَانٌ لَا يُسَاوِى فَتَّةً, meaning [Such a one is not worth] a crumbled piece of dung of the camel. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) <span class=\"sub-sense\">b2:</span> Also, i. e. فَتَّةٌ and ↓ فُتَّةٌ, (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) or the latter [only], (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) A كُتْلَة [i. e. lump, or compact portion,] of dates. (<abbr title=\"Abū ʿAmr b. al-ʿAlāʾ and Abū ʿAmr al-Shaybānī\">AA</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) فُتَّةٌ and فِتَّةٌ: see the next preceding paragraph; the former in two places.<br><br>فُتَاتٌ Broken bits or particles, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) and (A) such as have fallen off, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>,) of a thing, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) [as] of coloured wool, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>,) and of wool in general, (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>,) and of musk, and [crumbs] of bread. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>.) فَتُوتٌ: see the next paragraph, in two places.<br><br>فَتِيتٌ <abbr title=\"idem quod (i.e. the same as)\">i. q.</abbr> ↓ مَفْتُوتٌ [i. e. Crumbled, or broken into small pieces, with the fingers: or broken with the fingers: or simply broken: or bruised, or brayed]; (<abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) as also ↓ فَتُوتٌ. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) <span class=\"sub-sense\">b2:</span> And particularly, (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) and so ↓ فَتُوتٌ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>, <abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>,) Crumbled bread, (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, &amp;c.,) like سَوِيق. (<abbr title=\"Asās al-Balāghah by al-Zamakhsharī\">A</abbr>, <abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>.) ↓ فَتِيتَةٌ has a more special signification than فَتِيتٌ, [being a <abbr title=\"noun of unity, وَاحِدَةٌ or وَاحِدٌ\">n. un.</abbr>, meaning A mess of crumbled bread,] (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>, <abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>,) and is said to be eaten by a woman in order that she may become fat. (<abbr title=\"The Mughrib of al-Mutarrizī\">Mgh</abbr>.) <span class=\"sub-sense\">b3:</span> And فَتِيتٌ signifies also A thing that falls, (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>, <abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>,) and becomes crumbled, (<abbr title=\"El-Leyth Ibn-Nasr Ibn-Seiyar, held by El-Azberee to be the author of the “Eyn,” which he calls “Kitab Leyth” (al-Layth b. Muẓahffar al-Kināni)\">Lth</abbr>, <abbr title=\"The Tahdhīb of al-Azharī\">T</abbr>,) or breaks off. (<abbr title=\"The Muḥkam of Ibn Sīdah\">M</abbr>.) فَتِيتَةٌ: see the next preceding paragraph.<br><br>بَيْنَهُمْ فَتَافِتُ Between them is secret speaking, [or between them are secret speakings, for فَتَافِتُ is <abbr title=\"apparently\">app.</abbr> <abbr title=\"plural, جَمْعٌ\">pl.</abbr> of the <abbr title=\"infinitive noun, مَصْدَرٌ\">inf. n.</abbr> فَتْفَتَةٌ used as a simple <abbr title=\"substantive, إِسْمٌ\">subst.</abbr>, (see <abbr title=\"al-Rawḍ al-Unuf of al-Suhaylī\">R</abbr>. <abbr title=\"quadriliteral-radical verb, فِعْلٌ رُبَاعِيٌّ\">Q.</abbr> 1,)] not heard nor understood [by others]. (<abbr title=\"The ʿUbāb of al-Saghānī\">O</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>.) مَفْتُوت: see فَتِيتٌ."}]}}