mp","form":"تَفُتُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَفُتُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْتُتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفُتّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَفْتُت","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفُتّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَفْتُت","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفُتّا","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفُتّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفُتّا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفُتّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفُتُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفُتُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْتُتْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَفُتّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَفُتّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"فَتَتْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَتَتُّ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n32859"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%AA%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to break, to bruise, to bray, to disintegrate","tags":["transitive"]},{"pos":"verb","gloss":"to weaken, to enervate, to discourage, to defeat","tags":["figuratively","transitive"]},{"pos":"noun","gloss":"verbal noun of فَتَّ (fatta) (form I)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"noun","gloss":"crumb, morsel","tags":["transitive"]},{"pos":"noun","gloss":"fissure","tags":["transitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32859","headword_ar":"فَتَّ","root":"ft","body":[{"kind":"text","text":", (S, M, O, Msb,) aor."},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"fat~N","text_ar":"فَتٌّ"},{"kind":"text","text":", (Lth, T, M, Msb, K,)"},{"kind":"italic_en","text":"He crumbled"},{"kind":"text","text":"a thing, or"},{"kind":"italic_en","text":"broke"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"into small pieces, with his fingers:"},{"kind":"text","text":"(Lth, T, TA:) or"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"(a thing, M)"},{"kind":"italic_en","text":"with his fingers:"},{"kind":"text","text":"(M, K:) or [simply]"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"a thing: (S, O:) or (M)"},{"kind":"italic_en","text":"he bruised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brayed,"},{"kind":"text","text":"(M, K,) a thing: (M:) and ↓"},{"kind":"arabic","text_bw":"ft~t","text_ar":"فتّت","orth_type":"arrow"},{"kind":"text","text":", (M, TA,) inf. n."},{"kind":"arabic","text_bw":"tafotiytN","text_ar":"تَفْتِيتٌ"},{"kind":"text","text":", (O,) signifies the same; (M, TA;) or [rather]"},{"kind":"italic_en","text":"he broke"},{"kind":"text","text":"[a thing, or"},{"kind":"italic_en","text":"crumbled"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"with his fingers,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"much."},{"kind":"text","text":"(O.) You say of a man,"},{"kind":"arabic","text_bw":"fat~a","text_ar":"فَتَّ"},{"kind":"arabic","text_bw":"Alxuboza","text_ar":"الخُبْزَ"},{"kind":"text","text":", (A, Msb,) aor. and inf. n. as above; (Msb;) and ↓"},{"kind":"arabic","text_bw":"ft~thu","text_ar":"فتّتهُ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He crumbled the bread with his fingers."},{"kind":"text","text":"(A.) ―         -b2-  [Hence,] one says,"},{"kind":"arabic","text_bw":"*aA mim~aA","text_ar":"ذَا مِمَّا"},{"kind":"arabic","text_bw":"yafut~u kabidiY","text_ar":"يَفُتُّ كَبِدِى"},{"kind":"text","text":"(assumed tropical:)  [lit."},{"kind":"italic_en","text":"This is of what crumbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"crushes, my liver;"},{"kind":"text","text":"like as we say, “ of what breaks my heart ”]. (A, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"kal~amahu","text_ar":"كَلَّمَهُ"},{"kind":"arabic","text_bw":"bi$aYo'K fafat~a fiY saAEidihi","text_ar":"بِشَىْءٍ فَفَتَّ فِى سَاعِدِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He told him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoke to him, of a thing, and it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"crushed,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"weakened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enervated, him."},{"kind":"text","text":"(M, K, * TA.) And"},{"kind":"arabic","text_bw":"fat~a fiY","text_ar":"فَتَّ فِى"},{"kind":"arabic","text_bw":"EaDudiY wahad~a rukoniY","text_ar":"عَضُدِى وَهَدَّ رُكْنِى"},{"kind":"text","text":"(O, TA) (assumed tropical:)"},{"kind":"italic_en","text":"He broke my strength, and dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated, my assistants."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"fat~a fiY EaDudi fulaAnK","text_ar":"فَتَّ فِى عَضُدِ فُلَانٍ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"fiY A^aholi bayotihi","text_ar":"فِى اَهْلِ بَيْتِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He sought to injure such a one by diminishing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impairing,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in number"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"power,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the people of his house."},{"kind":"text","text":"(T, O. [See also art."},{"kind":"arabic","text_bw":"EDd","text_ar":"عضد"},{"kind":"text","text":".]) The verb in this phrase is also used in the pass. form. (O.)"}],"source_refs":["S","M","O","Msb","Lth","T","K","TA","A"]}]},"classical_definitions":null}