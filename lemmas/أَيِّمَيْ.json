{"lemma":"أَيِّمَيْ","slug":"أَيِّمَيْ","root":"#.#.م","root_slug":"_-_-م","root_link":"/words/roots/_-_-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n1619","n1620","n1624"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D9%8A%D9%90%D9%91%D9%85%D9%8E%D9%8A%D9%92"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1619","headword_ar":"اَيْمَ","root":"Aym","body":[{"kind":"text","text":"is a contraction of"},{"kind":"arabic","text_bw":"A^aY~u maA","text_ar":"اَىُّ مَا"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"A^aY~u $aYo'K","text_ar":"اَىُّ شَىْءٍ"},{"kind":"text","text":": it is thus in the saying,"},{"kind":"arabic","text_bw":"A^ayoma huwayaA fulaAnu","text_ar":"اَيْمَ هُوَيَا فُلَانُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What thing is it, O such a one?"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"A^ayoma taquwlu","text_ar":"اَيْمَ تَقُولُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What thing sayest thou?"},{"kind":"text","text":"]. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Aayomu A@ll~`hi","text_ar":"اَيْمُ ا@للّٰهِ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"Aayomunu","text_ar":"اَيْمُنُ"},{"kind":"arabic","text_bw":"A@ll~`hi","text_ar":"ا@للّٰهِ"},{"kind":"text","text":"]: see in art."},{"kind":"arabic","text_bw":"ymn","text_ar":"يمن"},{"kind":"text","text":". (K.)"}],"source_refs":[]},{"entry_id":"n1620","headword_ar":"اَيَمُّ","root":"Aym","body":[{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"A^aA^am~u","text_ar":"اَاَمُّ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Am","text_ar":"ام"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n1624","headword_ar":"اَيِّمٌ","root":"Aym","body":[{"kind":"text","text":"A woman"},{"kind":"italic_en","text":"having no husband;"},{"kind":"text","text":"(Lth, T, S, M, Mgh, Msb, K;)"},{"kind":"italic_en","text":"whether she be a virgin or not;"},{"kind":"text","text":"(IAar, T, S, M, Mgh, K;) or"},{"kind":"italic_en","text":"whether she have married before or not;"},{"kind":"text","text":"(Sgh, Msb;) as also"},{"kind":"arabic","text_bw":"A^ay~imapN","text_ar":"اَيِّمَةٌ"},{"kind":"text","text":"; (Msb;) [said to be] applied to one"},{"kind":"italic_en","text":"who has not married:"},{"kind":"text","text":"(IAar, T:) or"},{"kind":"italic_en","text":"if not a virgin;"},{"kind":"text","text":"accord. to [the Imám] Mohammad; agreeably with a reading of a trad. by which the"},{"kind":"arabic","text_bw":"A^ay~im","text_ar":"اَيِّم"},{"kind":"text","text":"is distinguished from the virgin: (Mgh:) also, the former, a man"},{"kind":"italic_en","text":"having no wife;"},{"kind":"text","text":"(S, M, Mgh, Msb, K;)"},{"kind":"italic_en","text":"whether he have married before or not:"},{"kind":"text","text":"(S, Sgh, K:) or"},{"kind":"italic_en","text":"who has not married:"},{"kind":"text","text":"(IAar, T:) pl."},{"kind":"arabic","text_bw":"A^ayaAmaY","text_ar":"اَيَامَى"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"A^ayaAy^imu","text_ar":"اَيَايِمُ"},{"kind":"text","text":"; (M, K;) the latter of which is the original form: (S, M:) [or both, accord. to the Msb, are pls. of"},{"kind":"arabic","text_bw":"A^ayomaAnu","text_ar":"اَيْمَانُ"},{"kind":"text","text":", q. v.:] and"},{"kind":"arabic","text_bw":"A^ay~imuwna","text_ar":"اَيِّمُونَ"},{"kind":"text","text":"is a pl. applied to men, and"},{"kind":"arabic","text_bw":"A^ay~imaAtN","text_ar":"اَيِّمَاتٌ"},{"kind":"text","text":"applied to women: and"},{"kind":"arabic","text_bw":"A=mapN","text_ar":"ا=مَةٌ"},{"kind":"text","text":", also, signifying men"},{"kind":"italic_en","text":"having no wives,"},{"kind":"text","text":"is pl. of ↓"},{"kind":"arabic","text_bw":"A=y^imN","text_ar":"ا=يِمٌ","orth_type":"arrow"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"A^ay~imN","text_ar":"اَيِّمٌ"},{"kind":"text","text":". (TA.) ―         -b2-  Also A"},{"kind":"italic_en","text":"free"},{"kind":"text","text":"woman: (K:) pl., in this sense also,"},{"kind":"arabic","text_bw":"A^ayaAmaY","text_ar":"اَيَامَى"},{"kind":"text","text":", used in this sense in the Kur xxiv. 32, (T, TA,) accord. to some. (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"A female relation;"},{"kind":"text","text":"(K;) in which sense also"},{"kind":"arabic","text_bw":"A^ayaAmaY","text_ar":"اَيَامَى"},{"kind":"text","text":"is pl.; (T, TA;) meaning"},{"kind":"italic_en","text":"such as the daughter and the sister and the maternal aunt."},{"kind":"text","text":"(T, K.)"}],"source_refs":["IAar","T","Mgh","S","Sgh","K","M","TA"]}]}}