le":"present_1ms","form":"أَعْت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْت","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n28011"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AA%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28011","headword_ar":"عَتَا","root":"Etw and EtY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEotuw","text_ar":"يَعْتُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eutuw~N","text_ar":"عُتُوٌّ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"EutiY~N","text_ar":"عُتِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EitiY~N","text_ar":"عِتِىٌّ"},{"kind":"text","text":", (S, K,) of which"},{"kind":"arabic","text_bw":"Eutuw~N","text_ar":"عُتُوٌّ"},{"kind":"text","text":"is the original form, one [i. e. the second] of the two dammehs being changed into a kesreh and therefore the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"and then the other dammeh being assimilated to the kesreh, (S, TA,)"},{"kind":"italic_en","text":"He behaved proudly,"},{"kind":"text","text":"(Msb, K,)"},{"kind":"italic_en","text":"and was immoderate, inordinate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exorbitant:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"he was excessively, immoderately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inordinately, proud"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unbelieving:"},{"kind":"text","text":"(AO, TA; and so in a copy of the S as on the authority of A'Obeyd:) or"},{"kind":"italic_en","text":"he revolted, recoiled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was averse, from obedience:"},{"kind":"text","text":"(Er-Rághib, TA:) and ↓"},{"kind":"arabic","text_bw":"taEat~ayotu","text_ar":"تَعَتَّيْتُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"Eatawotu","text_ar":"عَتَوْتُ"},{"kind":"text","text":"; (S, K;) or"},{"kind":"italic_en","text":"I"},{"kind":"text","text":"["},{"kind":"italic_en","text":"disobeyed,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"did not obey;"},{"kind":"text","text":"(TA;) and so does"},{"kind":"arabic","text_bw":"Eatayotu","text_ar":"عَتَيْتُ"},{"kind":"text","text":"; (K, accord. to some copies; but in some,"},{"kind":"arabic","text_bw":"Eatiytu","text_ar":"عَتِيتُ"},{"kind":"text","text":";) or, accord. to J and others, one should not say"},{"kind":"arabic","text_bw":"Eatayotu","text_ar":"عَتَيْتُ"},{"kind":"text","text":". (TA.) It is said in the Kur [li. 44],"},{"kind":"arabic","text_bw":"faEatawoA Eano","text_ar":"فَعَتَوْا عَنْ"},{"kind":"arabic","text_bw":"A^amori rab~ihimo","text_ar":"اَمْرِ رَبِّهِمْ"},{"kind":"text","text":"(TA) i. e."},{"kind":"italic_en","text":"But they turned with disdain from"},{"kind":"text","text":"obeying"},{"kind":"italic_en","text":"the command of their Lord."},{"kind":"text","text":"(Bd, Jel.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Eatati Alr~iyHu","text_ar":"عَتَتِ الرِّيحُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wind blew immoderately."},{"kind":"text","text":"(IKtt, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EataA","text_ar":"عَتَا"},{"kind":"text","text":"said of and old man, (S, Msb, K, [but in my copy of the Msb"},{"kind":"arabic","text_bw":"Al$Y","text_ar":"الشى"},{"kind":"text","text":"is put for"},{"kind":"arabic","text_bw":"Al$yx","text_ar":"الشيخ"},{"kind":"text","text":",]) aor."},{"kind":"arabic","text_bw":"yaEotuw","text_ar":"يَعْتُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"Eutuw~N","text_ar":"عُتُوٌّ"},{"kind":"text","text":"(S, Msb) and"},{"kind":"arabic","text_bw":"EitiY~N","text_ar":"عِتِىٌّ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"EutiY~N","text_ar":"عُتِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EatiY~N","text_ar":"عَتِىٌّ"},{"kind":"text","text":", with damm and also with fet-h, (K,)"},{"kind":"italic_en","text":"He became advanced in age,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in a declining state:"},{"kind":"text","text":"(S, Msb, * K:) [or"},{"kind":"italic_en","text":"he became dried up;"},{"kind":"text","text":"as is shown by what here follows.] It is said in the Kur [xix. 9], accord. to one reading,"},{"kind":"arabic","text_bw":"waqado balagotu","text_ar":"وَقَدْ بَلَغْتُ"},{"kind":"arabic","text_bw":"mina A@lokibari Eutiy~FA","text_ar":"مِنَ ا@لْكِبَرِ عُتِيًّا"},{"kind":"text","text":", (TA,) from"},{"kind":"arabic","text_bw":"EataA","text_ar":"عَتَا"},{"kind":"italic_en","text":"It became dried up;"},{"kind":"text","text":"(Ksh, * Jel;) said of wood, or a branch; as also"},{"kind":"arabic","text_bw":"EasaA","text_ar":"عَسَا"},{"kind":"text","text":": (Ksh:) the meaning here being, ["},{"kind":"italic_en","text":"And I have reached"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the extreme degree of old age:"},{"kind":"text","text":"(Jel:) or"},{"kind":"italic_en","text":"dryness, and hardness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rigidness, in the joints and the bones; like the dry wood"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"branch."},{"kind":"text","text":"(Ksh.)"}],"source_refs":["S","Msb","K","TA","Ksh","Jel"]}]}}