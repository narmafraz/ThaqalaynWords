text_ar":"عُصُوفٌ"},{"kind":"text","text":"; each a pl. of ↓"},{"kind":"arabic","text_bw":"EaSofapN","text_ar":"عَصْفَةٌ","orth_type":"arrow"},{"kind":"text","text":": (MA: [or rather"},{"kind":"arabic","text_bw":"EaSofN","text_ar":"عَصْفٌ"},{"kind":"text","text":"is a coll. gen. n. of which"},{"kind":"arabic","text_bw":"EuSuwfN","text_ar":"عُصُوفٌ"},{"kind":"text","text":"is the pl. and ↓"},{"kind":"arabic","text_bw":"EaSofapN","text_ar":"عَصْفَةٌ","orth_type":"arrow"},{"kind":"text","text":"is the n. un.:]) or"},{"kind":"italic_en","text":"the leaves,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blades, that are upon the stalk of corn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seedproduce, and that dry up and crumble;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaSofapN","text_ar":"عَصْفَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EaSiyfapN","text_ar":"عَصِيفَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EuSaAfapN","text_ar":"عُصَافَةٌ","orth_type":"arrow"},{"kind":"text","text":": or the"},{"kind":"italic_en","text":"leaves, and what is not eaten, thereof:"},{"kind":"text","text":"in these three different senses it is expl. as used in the Kur lv. 11: (TA:) or it there means the"},{"kind":"italic_en","text":"stalk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stem,"},{"kind":"text","text":"of corn: (Fr, S voce"},{"kind":"arabic","text_bw":"rayoHaAnN","text_ar":"رَيْحَانٌ"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"straw;"},{"kind":"text","text":"(Jel, TA;) and so"},{"kind":"arabic","text_bw":"Alz~aroEi","text_ar":"الزَّرْعِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaSiyfu","text_ar":"عَصِيفُ","orth_type":"arrow"},{"kind":"text","text":"; (M voce"},{"kind":"arabic","text_bw":"tibonN","text_ar":"تِبْنٌ"},{"kind":"text","text":";) or"},{"kind":"arabic","text_bw":"Alz~aroEi","text_ar":"الزَّرْعِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"EaSiyfapu","text_ar":"عَصِيفَةُ","orth_type":"arrow"},{"kind":"text","text":": (so in copies of the K voce"},{"kind":"arabic","text_bw":"tibonN","text_ar":"تِبْنٌ"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"EuSuwfN","text_ar":"عُصُوفٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"straws:"},{"kind":"text","text":"(IAar, TA:) or"},{"kind":"arabic","text_bw":"EaSofN","text_ar":"عَصْفٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"dry leaves, like straw:"},{"kind":"text","text":"(Bd in lv. 11:) or"},{"kind":"italic_en","text":"corn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seed-produce,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"barley, cut while green, for fodder;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"qaSiylN","text_ar":"قَصِيلٌ"},{"kind":"text","text":": (En-Nadr, TA:) or"},{"kind":"italic_en","text":"leaves of corn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seed-produce, that are cut, and eaten while fresh:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"leaves of the ears of corn;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaSiyfapN","text_ar":"عَصِيفَةٌ","orth_type":"arrow"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"what are cut thereof;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EaSiyfN","text_ar":"عَصِيفٌ","orth_type":"arrow"},{"kind":"text","text":": or both signify the"},{"kind":"italic_en","text":"leaves, of corn, that incline in its lower part, and which one cuts off, in order that it may become lightened:"},{"kind":"text","text":"or the former signifies the"},{"kind":"italic_en","text":"ears,"},{"kind":"text","text":"themselves,"},{"kind":"italic_en","text":"of corn:"},{"kind":"text","text":"and the pl. is"},{"kind":"arabic","text_bw":"EuSuwfN","text_ar":"عُصُوفٌ"},{"kind":"text","text":". (TA.)"},{"kind":"arabic","text_bw":"kaEaSofK maA^okuwlK","text_ar":"كَعَصْفٍ مَاْكُولٍ"},{"kind":"text","text":", in the Kur [cv. last verse], means"},{"kind":"italic_en","text":"Like corn of which the grain has been eaten and the straw thereof remains:"},{"kind":"text","text":"(El- Hasan El-Basree, S, O, K:) or"},{"kind":"italic_en","text":"like leaves of which the contents have been taken and which remain without any grain therein:"},{"kind":"text","text":"(O, K:) or"},{"kind":"italic_en","text":"like"},{"kind":"arabic","text_bw":"EaSof","text_ar":"عَصْف"},{"kind":"text","text":", (O,) or"},{"kind":"italic_en","text":"leaves,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"which the beasts have eaten:"},{"kind":"text","text":"(O, K:) or, as Sa'eed Ibn-Jubeyr is related to have said,"},{"kind":"italic_en","text":"like barley growing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"growing forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that has been eaten"},{"kind":"text","text":"]. (TA.) ―         -b2-  And IAar says, (O, TA,) [the pl.]"},{"kind":"arabic","text_bw":"EuSuwfN","text_ar":"عُصُوفٌ"},{"kind":"text","text":", (O, K, TA,) with damm to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":", (TA,) [in the CK, erroneously,"},{"kind":"arabic","text_bw":"EaSuwf","text_ar":"عَصُوف"},{"kind":"text","text":",] signifies"},{"kind":"italic_en","text":"Handfuls of reaped corn;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kadarN","text_ar":"كَدَرٌ"},{"kind":"text","text":"[a coll. gen. n. of which the n. un. is"},{"kind":"arabic","text_bw":"kadarapN","text_ar":"كَدَرَةٌ"},{"kind":"text","text":"]: (O, TA:) in the copies of the K,"},{"kind":"arabic","text_bw":"kudorap","text_ar":"كُدْرَة"},{"kind":"text","text":"; and in the L,"},{"kind":"arabic","text_bw":"kd","text_ar":"كد"},{"kind":"text","text":". (TA.)       -A2-  And accord. to IAar, (O,)"},{"kind":"arabic","text_bw":"EuSuwfN","text_ar":"عُصُوفٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"Wines;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xumuwrN","text_ar":"خُمُورٌ"},{"kind":"text","text":". (O, L, K. [In the CK"},{"kind":"arabic","text_bw":"xamorap","text_ar":"خَمْرَة"},{"kind":"text","text":"; and in the TA, as from the K,"},{"kind":"arabic","text_bw":"xmr","text_ar":"خمر"},{"kind":"text","text":".])"}],"source_refs":["Fr","S","O","K","TA","IAar"]}]},"classical_definitions":null}