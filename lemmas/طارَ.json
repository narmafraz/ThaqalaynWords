":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n26487","n27448"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fly"}]},"etymology":null,"ipa":["/tˤaː.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26487","headword_ar":"طَارٌّ","root":"Tr","body":[{"kind":"text","text":"(tropical:)  A boy"},{"kind":"italic_en","text":"whose mustache is growing forth:"},{"kind":"text","text":"(S, A, Msb:) or"},{"kind":"italic_en","text":"whose mustache has grown forth;"},{"kind":"text","text":"(Lth, L, K;) as also ↓"},{"kind":"arabic","text_bw":"TariyrN","text_ar":"طَرِيرٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xaz~N","text_ar":"خَزٌّ"},{"kind":"arabic","text_bw":"TaAr~N","text_ar":"طَارٌّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A sort of"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cloth of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"xaz~","text_ar":"خَزّ"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"having a nap"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","A","Msb"]},{"entry_id":"n27448","headword_ar":"طَارَ","root":"Tyr","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaTiyru","text_ar":"يَطِيرُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"TayaraAnN","text_ar":"طَيَرَانٌ"},{"kind":"text","text":"(S, A, Msb, K) and"},{"kind":"arabic","text_bw":"TayoruwrapN","text_ar":"طَيْرُورَةٌ"},{"kind":"text","text":"(Lh, S, K, &c.) and"},{"kind":"arabic","text_bw":"TayorN","text_ar":"طَيْرٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a winged creature)"},{"kind":"italic_en","text":"moved in the air by means of his wings; flew;"},{"kind":"text","text":"(A, K;)"},{"kind":"italic_en","text":"moved in the air as a beast does upon the ground."},{"kind":"text","text":"(Msb.) ―         -b2-  It is also said of other things than those which have wings; as in the saying of El- 'Amberee (Kureyt Ibn-Uneyf, Ham p. 3):"},{"kind":"quote","text":"TaAruwA A_ilayohi zaraAfaAtK wawuHodaAnaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They fly to it in companies and one by one"},{"kind":"text","text":"]; (TA;) i. e."},{"kind":"italic_en","text":"they hasten to it:"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"Tirotu A_ilaY ka*aA","text_ar":"طِرْتُ اـِلَى كَذَا"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"I hastened to such a thing:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Tirotu","text_ar":"طِرْتُ"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"I outstripped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became foremost, with such a thing."},{"kind":"text","text":"(Ham p. 6.) And"},{"kind":"arabic","text_bw":"TAr EalaY matoni farasihi","text_ar":"طار عَلَى مَتْنِ فَرَسِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He fled upon the back of his horse."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"TAr Alqawomu","text_ar":"طار القَوْمُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The people took fright and ran away quickly."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"TaAruwA siraAEFA","text_ar":"طَارُوا سِرَاعًا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They went away quickly."},{"kind":"text","text":"(TA.) ―         -b3-  [One says also,"},{"kind":"arabic","text_bw":"TAr Euqoluhu","text_ar":"طار عُقْلُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His reason fled."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"TAr fuw^aAduhu","text_ar":"طار فُوَادُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"His courage"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"his heart"},{"kind":"text","text":")"},{"kind":"italic_en","text":"fled away:"},{"kind":"text","text":"see also 10: and see"},{"kind":"arabic","text_bw":"$aEaAEN","text_ar":"شَعَاعٌ"},{"kind":"text","text":". (Both are phrases of frequent occurrence.)] ―         -b4-  And"},{"kind":"arabic","text_bw":"TAr TaAy^ruhu","text_ar":"طار طَايرُهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"TaAy^irN","text_ar":"طَايِرٌ"},{"kind":"text","text":". ―         -b5-  [And see an ex. voce"},{"kind":"arabic","text_bw":"$iq~apN","text_ar":"شِقَّةٌ"},{"kind":"text","text":".] ―         -b6-"},{"kind":"arabic","text_bw":"TAr qalobiY maTaArahu","text_ar":"طار قَلْبِى مَطَارَهُ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"My heart inclined towards that which it loved, and clung to it."},{"kind":"text","text":"(TA, from a trad.) And"},{"kind":"arabic","text_bw":"TiyriY bihi","text_ar":"طِيرِى بِهِ"},{"kind":"text","text":", addressed to a woman, is expl. by IAar as meaning (assumed tropical:)"},{"kind":"italic_en","text":"Love thou,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become attached, to him."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"TArt Eayonuhu","text_ar":"طارت عَيْنُهُ"},{"kind":"text","text":"(S and K in art."},{"kind":"arabic","text_bw":"xlj","text_ar":"خلج"},{"kind":"text","text":") (assumed tropical:)"},{"kind":"italic_en","text":"His eye throbbed."},{"kind":"text","text":"(PS and TK in that art.) ―         -b8-"},{"kind":"arabic","text_bw":"TAr lahu SiytN fiY Aln~aAsi","text_ar":"طار لَهُ صِيتٌ فِى النَّاسِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He became famous among the people;"},{"kind":"text","text":"lit. means"},{"kind":"italic_en","text":"fame among the people became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to be,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"his"},{"kind":"text","text":"]. (A.) [And in like manner one says,]"},{"kind":"arabic","text_bw":"TAr lahu mino","text_ar":"طار لَهُ مِنْ"},{"kind":"arabic","text_bw":"naSiybihi ka*aA","text_ar":"نَصِيبِهِ كَذَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a thing became his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to him, of his lot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HaSala","text_ar":"حَصَلَ"},{"kind":"text","text":". (Mgh.) And"},{"kind":"arabic","text_bw":"TAr lanaA","text_ar":"طار لَنَا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"It came to our lot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"TAr likul~K minohumo sahomuhu","text_ar":"طار لِكُلٍّ مِنْهُمْ سَهْمُهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The share of each came to him."},{"kind":"text","text":"(TA.) ―         -b9-  See also 6, in two places.       -A2-"},{"kind":"arabic","text_bw":"TaAra bihi","text_ar":"طَارَ بِهِ"},{"kind":"text","text":"is also syn. with"},{"kind":"arabic","text_bw":"Tay~arahu","text_ar":"طَيَّرَهُ"},{"kind":"text","text":", q. v. (TA.) ―         -b2-  [Hence the metaphorical phrase"},{"kind":"arabic","text_bw":"TaArato bihaA AlEarabu","text_ar":"طَارَتْ بِهَا العَرَبُ"},{"kind":"text","text":"expl. voce"},{"kind":"arabic","text_bw":"EarabapN","text_ar":"عَرَبَةٌ"},{"kind":"text","text":".] ―         -b3-"},{"kind":"arabic","text_bw":"TArt AlA_ibilu","text_ar":"طارت الاـِبِلُ"},{"kind":"arabic","text_bw":"biA=*aAnihaA","text_ar":"بِا=ذَانِهَا"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"biA^a*onaAbihaA","text_ar":"بِاَذْنَابِهَا"},{"kind":"text","text":", (O, TA,) thus [correctly] in the TS, (TA,) [like"},{"kind":"arabic","text_bw":"$aAlato biA^a*onaAbihaA","text_ar":"شَالَتْ بِاَذْنَابِهَا"},{"kind":"text","text":",] means (assumed tropical:)"},{"kind":"italic_en","text":"The she-camels conceived."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["S","Msb","A","K","TA","O"]}]}}