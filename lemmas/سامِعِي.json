{"lemma":"سامِعِي","slug":"سامِعِي","root":"س.م.ع","root_slug":"س-م-ع","root_link":"/words/roots/س-م-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n20732"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D9%85%D9%90%D8%B9%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"hearing, listening, who hears"},{"pos":"noun","gloss":"listener, hearer (person listening to something)"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of سَمِعَ (samiʕa, “to hear”)."},"ipa":["/saː.miʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20732","headword_ar":"سَامِعٌ","root":"smE","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"samiyEN","text_ar":"سَمِيعٌ","orth_type":"arrow"},{"kind":"text","text":"are syn.; [signifying"},{"kind":"italic_en","text":"Hearing;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"hearkening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listening;"},{"kind":"text","text":"] (Az, S, Msb, K;) like"},{"kind":"arabic","text_bw":"EaAlimN","text_ar":"عَالِمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaliymN","text_ar":"عَلِيمٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qaAdirN","text_ar":"قَادِرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qadiyrN","text_ar":"قَدِيرٌ"},{"kind":"text","text":". (Az, TA.) [↓"},{"kind":"arabic","text_bw":"Als~amiyEu","text_ar":"السَّمِيعُ","orth_type":"arrow"},{"kind":"text","text":", applied to God, signifies"},{"kind":"italic_en","text":"He whose hearing comprehends everything; who hears everything."},{"kind":"text","text":"(TA.) And [hence, also,] ↓ this same epithet is applied to"},{"kind":"italic_en","text":"The lion that hears the faint sound"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"of man and of the prey"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"from afar."},{"kind":"text","text":"(K, TA.) You say also,"},{"kind":"arabic","text_bw":"A^u*unN saAmiEapN","text_ar":"اُذُنٌ سَامِعَةٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samiyEapN","text_ar":"سَمِيعَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samiyEN","text_ar":"سَمِيعٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samoEapN","text_ar":"سَمْعَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samaEapN","text_ar":"سَمَعَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samiEapN","text_ar":"سَمِعَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"sam~aAEapN","text_ar":"سَمَّاعَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"samuwEN","text_ar":"سَمُوعٌ","orth_type":"arrow"},{"kind":"text","text":": [the first signifying"},{"kind":"italic_en","text":"A hearing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a hearkening"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listening, ear:"},{"kind":"text","text":"and the last two, and app. all but the first,"},{"kind":"italic_en","text":"an ear that hears,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hearkens"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"listens, much;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that is quick of hearing:"},{"kind":"text","text":"] the pl. of ↓ the last is"},{"kind":"arabic","text_bw":"sumuEN","text_ar":"سُمُعٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["K","TA"]}]},"classical_definitions":null}