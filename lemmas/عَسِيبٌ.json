{"lemma":"عَسِيبٌ","slug":"عَسِيبٌ","root":"ع.س.ب","root_slug":"ع-س-ب","root_link":"/words/roots/ع-س-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n29058"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%B3%D9%90%D9%8A%D8%A8%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n29058","headword_ar":"عَسِيبٌ","root":"Esb","body":[{"kind":"italic_en","text":"A palm-branch from which the leaves have been removed:"},{"kind":"text","text":"(T, Msb, TA:) or"},{"kind":"italic_en","text":"a straight and slender palm-branch from which the leaves have been stripped off:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"one upon which leaves have not grown:"},{"kind":"text","text":"(K:) or the"},{"kind":"italic_en","text":"part, of a palmbranch, a little above the"},{"kind":"arabic","text_bw":"karab","text_ar":"كَرَب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"lower, thick,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"broad, portions,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"upon which no leaves have grown;"},{"kind":"text","text":"that [or those parts] upon which leaves have grown being termed"},{"kind":"arabic","text_bw":"saEafN","text_ar":"سَعَفٌ"},{"kind":"text","text":": (S, O:) pl. [of mult.]"},{"kind":"arabic","text_bw":"EusubN","text_ar":"عُسُبٌ"},{"kind":"text","text":", (O, Msb, TA,) with two dammehs, (TA,) and"},{"kind":"arabic","text_bw":"EusobaAnN","text_ar":"عُسْبَانٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"EisobaAnN","text_ar":"عِسْبَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EusuwbN","text_ar":"عُسُوبٌ"},{"kind":"text","text":"and [of pauc.]"},{"kind":"arabic","text_bw":"A^aEosibapN","text_ar":"اَعْسِبَةٌ"},{"kind":"text","text":". (TA.) It is said of the Prophet, in a trad.,"},{"kind":"arabic","text_bw":"qubiDa waAlquroA=nu fiY AlEusubi","text_ar":"قُبِضَ وَالقُرْا=نُ فِى العُسُبِ"},{"kind":"arabic","text_bw":"waAlquDumi waAlkaraAniyfi","text_ar":"وَالقُضُمِ وَالكَرَانِيفِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was taken,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he died, while the Kur-án was"},{"kind":"text","text":"written only"},{"kind":"italic_en","text":"upon leafless palm-branches, and skins,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"white skins, and stumps of palm-branches"},{"kind":"text","text":"]. (O, TA.*) ―         -b2-  Also The"},{"kind":"italic_en","text":"bone of the tail;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"EasiybapN","text_ar":"عَسِيبَةٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) or the"},{"kind":"italic_en","text":"slender part thereof:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"part where grows the hair thereof,"},{"kind":"text","text":"(K, TA,) i. e."},{"kind":"italic_en","text":"of the tail:"},{"kind":"text","text":"(TA:) or"},{"kind":"arabic","text_bw":"Easiybu Al*~anabi","text_ar":"عَسِيبُ الذَّنَبِ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"part, of the skin and bone of the tail, where the hair grows."},{"kind":"text","text":"(S, O, TA.) ―         -b3-  And The"},{"kind":"italic_en","text":"outer"},{"kind":"text","text":"[here meaning"},{"kind":"italic_en","text":"upper"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"part of the human foot:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"likewise"},{"kind":"text","text":"[i. e. the"},{"kind":"italic_en","text":"shorter side,"},{"kind":"text","text":"or app., accord. to some, the"},{"kind":"italic_en","text":"shaft"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"as used in relation to a feather),]"},{"kind":"italic_en","text":"of a feather, lengthwise."},{"kind":"text","text":"(K.) ―         -b4-  And"},{"kind":"italic_en","text":"A cleft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fissure, in a mountain;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"EasobapN","text_ar":"عَسْبَةٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":["T","Msb","TA","K","S","O"]}]},"classical_definitions":null}