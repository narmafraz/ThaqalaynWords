,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْنُنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْنُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْنِنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَعْنُنَّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعُنّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعُنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعِنّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعِنّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْنِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَعْنُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْنُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَنَنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَنَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":90,"cross_references":{"qac":{"found":true,"lemma_key":"عَنَّ","root":"عنت","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["prep"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n30640","n30649"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%86%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"prep","gloss":"contraction of عَنْ (ʕan) + مَنْ (man)","tags":["abbreviation","alt-of","contraction"]}]},"etymology":null,"ipa":["/ʕam.man/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30640","headword_ar":"عَنَّ","root":"En","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"text","text":", (S, Msb, K,) the former accord. to some relaters, and the latter accord. to others, occurring in a verse of a Hudhalee, (TA,) inf. n."},{"kind":"arabic","text_bw":"EananN","text_ar":"عَنَنٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"Ean~N","text_ar":"عَنٌّ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"EunuwnN","text_ar":"عُنُونٌ"},{"kind":"text","text":", the first of which is also [or is properly] a simple subst., (K, [and such, in one sense, it is said to be in the Msb, as will be shown in what follows,]) said of an affair, or event, (Msb,) or of a thing, (S, * K,)"},{"kind":"italic_en","text":"It appeared before one:"},{"kind":"text","text":"(K:) [and]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":"(S, Mgh) and (S, K)"},{"kind":"arabic","text_bw":"AiEotaraDa","text_ar":"اِعْتَرَضَ"},{"kind":"text","text":"(S, Msb, K) [i. e."},{"kind":"italic_en","text":"it appeared; it showed, presented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offered, itself: it occurred:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it presented itself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intervened between a person and an object before him, as an obstacle: it opposed itself"},{"kind":"text","text":"]: and so ↓"},{"kind":"arabic","text_bw":"AiEotan~a","text_ar":"اِعْتَنَّ","orth_type":"arrow"},{"kind":"text","text":". (S, K.) [See also"},{"kind":"arabic","text_bw":"EananN","text_ar":"عَنَنٌ"},{"kind":"text","text":", below.] Imra-el-Keys says,"},{"kind":"quote","text":"faEan~a lanaA sirobN kaA^an~a niEaAjahu\n                      \n                     \n                        Ea*aAraY dawaArK fiY mulaA='K mu*ay~ali"},{"kind":"page_break","n":2163},{"kind":"text","text":"(Mgh, TA, *) meaning,"},{"kind":"arabic","text_bw":"EaraDa","text_ar":"عَرَضَ"},{"kind":"text","text":", (TA,) i. e."},{"kind":"italic_en","text":"And there appeared to us a herd"},{"kind":"text","text":"of wild oxen,"},{"kind":"italic_en","text":"as though the females thereof were virgins"},{"kind":"text","text":"making the circuit"},{"kind":"italic_en","text":"of Dawár,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Duwár, in long-skirted garments of the kind called"},{"kind":"arabic","text_bw":"mulaA='","text_ar":"مُلَا=ء"},{"kind":"text","text":"; Dawár, or Duwár, being the name of an idol around which the people of the Time of Ignorance used to curcuit. (Mgh, * and EM pp. 46 and 47.) And one says,"},{"kind":"arabic","text_bw":"laA A^afoEaluhu maA Ean~a fiY Als~amaA='i najomN","text_ar":"لَا اَفْعَلُهُ مَا عَنَّ فِى السَّمَا=ءِ نَجْمٌ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"maA EaraDa","text_ar":"مَا عَرَضَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I will not do it as long as a star appears in the sky"},{"kind":"text","text":"]. (S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Ean~a","text_ar":"عَنَّ"},{"kind":"text","text":", (Msb, TA,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"EananN","text_ar":"عَنَنٌ"},{"kind":"text","text":", (TA,) or this is a simple subst., (Msb, TA,) and the inf. n. is"},{"kind":"arabic","text_bw":"Ean~N","text_ar":"عَنٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He opposed himself"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"AiEotaraDa","text_ar":"اِعْتَرَضَ"},{"kind":"text","text":", Msb, or"},{"kind":"arabic","text_bw":"taEar~aDa","text_ar":"تَعَرَّضَ"},{"kind":"text","text":", TA)"},{"kind":"italic_en","text":"to another"},{"kind":"text","text":"(Msb)"},{"kind":"italic_en","text":"from right and left,"},{"kind":"text","text":"(TA,) or"},{"kind":"italic_en","text":"from either side of him,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"with an abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil, action."},{"kind":"text","text":"(Msb, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Ean~a","text_ar":"عَنَّ"},{"kind":"arabic","text_bw":"Eani Al$~aYo'i","text_ar":"عَنِ الشَّىْءِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", [inf. n., app.,"},{"kind":"arabic","text_bw":"Ean~N","text_ar":"عَنٌّ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"He turned aside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away, from the thing."},{"kind":"text","text":"(Msb.) ―         -b4-  Hence the saying of the lawyers,"},{"kind":"arabic","text_bw":"Ean~a Eani A@moraA^apK duwna A^uxoraY","text_ar":"عَنَّ عَنِ ا@مْرَاَةٍ دُونَ اُخْرَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He turned away from one woman, not"},{"kind":"text","text":"from"},{"kind":"italic_en","text":"another"},{"kind":"text","text":"]; meaning"},{"kind":"italic_en","text":"he desired not one woman, but desired another:"},{"kind":"text","text":"thus in the active form: and one may also say"},{"kind":"arabic","text_bw":"Eun~a","text_ar":"عُنَّ"},{"kind":"text","text":"i. e. in the passive form [from one or another of the following significations of the trans. verb]. (Msb.) For the latter of these, and its var."},{"kind":"arabic","text_bw":"Eunina","text_ar":"عُنِنَ"},{"kind":"text","text":", see 2.       -A2-"},{"kind":"arabic","text_bw":"Eananotu All~ijaAma","text_ar":"عَنَنْتُ اللِّجَامَ"},{"kind":"text","text":": see 4. ―         -b2-"},{"kind":"arabic","text_bw":"Ean~a daAb~atahu","text_ar":"عَنَّ دَابَّتَهُ"},{"kind":"italic_en","text":"He put a rein"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"EinaAn","text_ar":"عِنَان"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to his beast."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eananotu Alfarasa","text_ar":"عَنَنْتُ الفَرَسَ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"; (Msb;) in the M [↓"},{"kind":"arabic","text_bw":"Ean~anotu","text_ar":"عَنَّنْتُ","orth_type":"arrow"},{"kind":"text","text":",] with tesh-deed; (TA;)"},{"kind":"italic_en","text":"I withheld the horse by means of his"},{"kind":"arabic","text_bw":"EinaAn","text_ar":"عِنَان"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rein"},{"kind":"text","text":"]; (S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"A^aEonanotuhu","text_ar":"اَعْنَنْتُهُ","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"arabic","text_bw":"Alfarasa","text_ar":"الفَرَسَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aEonanotu","text_ar":"اَعْنَنْتُ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"I put a rein to the horse:"},{"kind":"text","text":"(Msb:) and it is said in the T that"},{"kind":"arabic","text_bw":"AlfaArisu","text_ar":"الفَارِسُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aEan~a","text_ar":"اَعَنَّ","orth_type":"arrow"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"the horseman drew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulled, the rein of his beast, to turn him back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"away, from his course."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Eananotuhu","text_ar":"عَنَنْتُهُ"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"Eun~a","text_ar":"عُنَّ"},{"kind":"text","text":", (Mgh,)"},{"kind":"italic_en","text":"I confined him,"},{"kind":"text","text":"(Msb,) and"},{"kind":"italic_en","text":"he was confined,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"in the"},{"kind":"arabic","text_bw":"Eun~ap","text_ar":"عُنَّة"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"enclosure"},{"kind":"text","text":"(Mgh, Msb)"},{"kind":"italic_en","text":"of the camels."},{"kind":"text","text":"(Mgh.)       -A3-"},{"kind":"arabic","text_bw":"Eananotu fulaAnFA","text_ar":"عَنَنْتُ فُلَانًا"},{"kind":"italic_en","text":"I reviled such a one; vilified him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave a bad name to him."},{"kind":"text","text":"(K.)       -A4-  See also Q. Q. 1."}],"source_refs":["S","Mgh","Msb","K","TA"]},{"entry_id":"n30649","headword_ar":"عَنَّ","root":"En","body":[{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"A^an~a","text_ar":"اَنَّ"},{"kind":"text","text":": see the next preceding paragraph, last quarter."}],"source_refs":[]}]}}