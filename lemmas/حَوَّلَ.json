"m","num":"p"},{"role":"present_2mp","form":"تُحَوِّلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحَوِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحَوِّل","in_corpus":true,"count":18,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحَوِّل","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحَوِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحَوِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحَوِّلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَوِّلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَوِّلُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَوِّلُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَوِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُحَوِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَوِّل","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"حَوَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَوَّلْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":62,"cross_references":{"qac":{"found":true,"lemma_key":"حَوَّلَ","root":"حول","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":10,"pos_tags":["adj","noun","prep","verb"],"has_etymology":true,"sense_count":27},"lanes":{"found":true,"entry_ids":["n9582","n9583","n9584","n9585","n9586","n9604"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%88%D9%8E%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of حَالَ (ḥāla) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"power, might"},{"pos":"noun","gloss":"strength","examples":[{"text":"لَا حَوْل وَلَا قُوَّة إِلَّا بِٱللّٰه.","english":"There is no strength or power except in God."}]},{"pos":"noun","gloss":"change, exchange"},{"pos":"noun","gloss":"year"},{"pos":"noun","gloss":"partition"},{"pos":"verb","gloss":"to change, to transform, to convert, to turn (into), to make","examples":[{"text":"وهي ستحوِّل الأرض إلى فردوس.","english":"It will turn the earth into paradise."}]},{"pos":"verb","gloss":"to transplant"},{"pos":"verb","gloss":"to transfer, to forward"},{"pos":"verb","gloss":"to convert"},{"pos":"verb","gloss":"to switch, to commutate"},{"pos":"verb","gloss":"to shunt"},{"pos":"verb","gloss":"to remit, to send, to transmit"},{"pos":"verb","gloss":"to pass on, to hand on, to forward"},{"pos":"verb","gloss":"to endorse"},{"pos":"verb","gloss":"to direct"},{"pos":"verb","gloss":"to divert, to distract, to deflect"},{"pos":"verb","gloss":"to avert, to turn away"},{"pos":"verb","gloss":"to turn off, to switch off, to disconnect"},{"pos":"verb","gloss":"to turn the helm, to change course"},{"pos":"prep","gloss":"around","examples":[{"text":"فَبِمَا رَحۡمَةࣲ مِّنَ ٱللَّهِ لِنتَ لَهُمۡ ۖ وَلَوۡ كُنتَ فَظًّا غَلِيظَ ٱلۡقَلۡبِ لَٱنفَضُّوا۟ مِنۡ حَوۡلِكَ ۖ فَٱعۡفُ عَنۡهُمۡ وَٱسۡتَغۡفِرۡ لَهُمۡ وَشَاوِرۡهُمۡ فِي ٱلۡأَمۡرِ ۖ فَإِذَا عَزَمۡتَ فَتَوَكَّلۡ عَلَى ٱللَّهِ ۚ إِنَّ ٱللَّهَ يُحِبُّ ٱلۡمُتَوَكِّلِينَ"}]},{"pos":"noun","gloss":"plural of حَائِل (ḥāʔil)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of حَائِل (ḥāʔil)","tags":["form-of","plural"]},{"pos":"adj","gloss":"masculine plural of حَائِل (ḥāʔil)","tags":["form-of","masculine","plural"]},{"pos":"adj","gloss":"masculine plural of حَائِل (ḥāʔil)","tags":["form-of","masculine","plural"]},{"pos":"verb","gloss":"to have strabismus, to be cross-eyed, to squint eyes"},{"pos":"adj","gloss":"wily, crafty"}]},"etymology":{"source":"wiktextract","text":"Compare Ugaritic 𐎈𐎍 (ḥl), Hebrew חַיִל (kháyil, “strength, might”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9582","headword_ar":"حَوْلٌ","root":"Hwl","body":[{"kind":"italic_en","text":"A year;"},{"kind":"text","text":"(S Msb, K, Er-Rághib, &c. ;) so termed in consideration of its changing, and of the revolution of the sun in its places of rising and setting; (Er-Rághib, TA;) or as being the period in which [certain] plants attain their complete strength: (El-Harállee, TA:) and"},{"kind":"italic_en","text":"even if it has not passed;"},{"kind":"text","text":"because it will be [properly speaking] a"},{"kind":"arabic","text_bw":"Hawol","text_ar":"حَوْل"},{"kind":"text","text":": an inf. n. used as a simple subst.: (Msb:) pl. [of pauc., but also used as a pl. of mult.,]"},{"kind":"arabic","text_bw":"A^aHowaAlN","text_ar":"اَحْوَالٌ"},{"kind":"text","text":"(M, Msb, K) and [of mult.]"},{"kind":"arabic","text_bw":"Huw^uwlN","text_ar":"حُوُولٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HuwuwlN","text_ar":"حُوُولٌ"},{"kind":"text","text":", (M, K,) the former with"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"and the latter with"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":". (TA.)       -A2-"},{"kind":"italic_en","text":"Strength, power, might,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"force;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"quw~apN","text_ar":"قُوَّةٌ"},{"kind":"text","text":"; (S, TA;) as also ↓"},{"kind":"arabic","text_bw":"HiylapN","text_ar":"حِيلَةٌ","orth_type":"arrow"},{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"HiwolapN","text_ar":"حِوْلَةٌ"},{"kind":"text","text":"] (TA) and ↓"},{"kind":"arabic","text_bw":"HawolapN","text_ar":"حَوْلَةٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) or this last is a n. un. from"},{"kind":"arabic","text_bw":"HawolN","text_ar":"حَوْلٌ"},{"kind":"text","text":": (TA:) it is"},{"kind":"italic_en","text":"in the soul and the body and the acquisitions:"},{"kind":"text","text":"and hence the saying, in a trad.,"},{"kind":"arabic","text_bw":"laA Hawola wa laA quw~apa A_il~aA biA@ll~`hi AlEaliY~i AlEaZiymi","text_ar":"لَا حَوْلَ وَ لَا قُوَّةَ اـِلَّا بِا@للّٰهِ العَلِىِّ العَظِيمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is no strength nor power but in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by means of, God, the High, the Great"},{"kind":"text","text":"]: (Er-Rághib, TA:) or it here signifies"},{"kind":"italic_en","text":"motion;"},{"kind":"text","text":"[see also"},{"kind":"arabic","text_bw":"HawolapN","text_ar":"حَوْلَةٌ"},{"kind":"text","text":";] and the meaning is,"},{"kind":"italic_en","text":"there is no motion nor power,"},{"kind":"page_break","n":676},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, but by the will of God:"},{"kind":"text","text":"(AHeyth, TA:) or, as some say, the meaning is,"},{"kind":"italic_en","text":"there is no"},{"kind":"arabic","text_bw":"Hwl","text_ar":"حول"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"changing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receding,"},{"kind":"text","text":"] from disobedience,"},{"kind":"italic_en","text":"nor"},{"kind":"arabic","text_bw":"qw~p","text_ar":"قوّة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"power"},{"kind":"text","text":"] to obey,"},{"kind":"italic_en","text":"but by the accommodating,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposing, of God."},{"kind":"text","text":"(Msb.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"HiylapN","text_ar":"حِيلَةٌ"},{"kind":"text","text":".       -A3-"},{"kind":"arabic","text_bw":"Hawolu $aYo'i","text_ar":"حَوْلُ شَىْءِ"},{"kind":"italic_en","text":"The lateral,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adjacent, part to which a thing may shift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remove:"},{"kind":"text","text":"(Er-Rághib, TA:) or"},{"kind":"italic_en","text":"the environs"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of a thing"},{"kind":"text","text":"]. (Msb.) You say,"},{"kind":"arabic","text_bw":"qaEaduwA","text_ar":"قَعَدُوا"},{"kind":"arabic","text_bw":"Hawolahu","text_ar":"حَوْلَهُ"},{"kind":"text","text":", (S, K, *) or"},{"kind":"arabic","text_bw":"qaEadonaA Hawolahu","text_ar":"قَعَدْنَا حَوْلَهُ"},{"kind":"text","text":", the noun being in the accus. case as an adv. n. of place, i. e., ["},{"kind":"italic_en","text":"They sat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"we sat, around him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"in his,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"its, environs;"},{"kind":"text","text":"(Msb;) and ↓"},{"kind":"arabic","text_bw":"HawaAlahu","text_ar":"حَوَالَهُ","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Hawolayohi","text_ar":"حَوْلَيْهِ"},{"kind":"text","text":", (S, K,) dual of"},{"kind":"arabic","text_bw":"Hawol","text_ar":"حَوْل"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"HawaAlayohi","text_ar":"حَوَالَيْهِ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) dual of"},{"kind":"arabic","text_bw":"HawaAl","text_ar":"حَوَال"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"A^aHowaAlahu","text_ar":"اَحْوَالَهُ"},{"kind":"text","text":", (ISd, K,) pl. of"},{"kind":"arabic","text_bw":"Hawol","text_ar":"حَوْل"},{"kind":"text","text":", and used to give intensiveness to the meaning: (ISd, TA:) but you should not say"},{"kind":"arabic","text_bw":"HawaAliyhi","text_ar":"حَوَالِيهِ"},{"kind":"text","text":". (S, Sgh.) And"},{"kind":"arabic","text_bw":"walaA EalayonaA","text_ar":"وَلَا عَلَيْنَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aall~`hum~a HawaAlayonaA","text_ar":"اَللّٰهُمَّ حَوَالَيْنَا","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O God,"},{"kind":"text","text":"be Thou"},{"kind":"italic_en","text":"around us"},{"kind":"text","text":"as our protector,"},{"kind":"italic_en","text":"and not against us,"},{"kind":"text","text":"] occurs in a trad. respecting prayer. (TA.) It is said, in the Expos. of the exs. cited as testimonies by Sb, that one sometimes says ↓"},{"kind":"arabic","text_bw":"HawaAlayoka","text_ar":"حَوَالَيْكَ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Hawolayoka","text_ar":"حَوْلَيْكَ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Around thee, in every direction;"},{"kind":"text","text":"dividing the surrounding parts into two; like as one says,"},{"kind":"arabic","text_bw":"A^aHaATuwA bihi","text_ar":"اَحَاطُوا بِهِ"},{"kind":"arabic","text_bw":"mino jaAnibayohi","text_ar":"مِنْ جَانِبَيْهِ"},{"kind":"text","text":", not meaning that any of the surrounding parts remained vacant. (TA.) [See also an ex. voce"},{"kind":"arabic","text_bw":"danodana","text_ar":"دَنْدَنَ"},{"kind":"text","text":".]"}],"source_refs":["Msb","M","K","TA","AHeyth","S","ISd"]},{"entry_id":"n9583","headword_ar":"حَوَلٌ","root":"Hwl","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"Hawilato Eayonuhu","text_ar":"حَوِلَتْ عَيْنُهُ"},{"kind":"text","text":". (S, K. [See 1, last sentence.])       -A2-  See also"},{"kind":"arabic","text_bw":"HaAy^ilN","text_ar":"حَايِلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n9584","headword_ar":"حَوِلٌ","root":"Hwl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Huw~alN","text_ar":"حُوَّلٌ"},{"kind":"text","text":": ―         -b2-  and see also 1, last sentence."}],"source_refs":[]},{"entry_id":"n9585","headword_ar":"حُوَلٌ","root":"Hwl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Huw~alN","text_ar":"حُوَّلٌ"},{"kind":"text","text":": ―         -b2-  and"},{"kind":"arabic","text_bw":"HaAy^ilN","text_ar":"حَايِلٌ"},{"kind":"text","text":": ―         -b3-  and"},{"kind":"arabic","text_bw":"HiyaAlN","text_ar":"حِيَالٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n9586","headword_ar":"حِوَلٌ","root":"Hwl","body":[{"kind":"italic_en","text":"Removal"},{"kind":"text","text":"from one place to another,"},{"kind":"italic_en","text":"in a passive sense;"},{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"taHaw~ala","text_ar":"تَحَوَّلَ"},{"kind":"text","text":": (S, O, K:) and"},{"kind":"italic_en","text":"in an active sense;"},{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"Haw~alahu","text_ar":"حَوَّلَهُ"},{"kind":"text","text":"; (K;) accord. to ISd, it is the latter [only]; (TA;) as also ↓"},{"kind":"arabic","text_bw":"HawiylN","text_ar":"حَوِيلٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) Hence, in the Kur [xviii. 108],"},{"kind":"arabic","text_bw":"laA yaboguwna EanohaA HawolFA","text_ar":"لَا يَبْغُونَ عَنْهَا حَوْلًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They shall not desire removal from it"},{"kind":"text","text":"]"},{"kind":"text","text":"(S, M, O, K:) or, as some say, it here means ↓"},{"kind":"arabic","text_bw":"HiylapF","text_ar":"حِيلَةً","orth_type":"arrow"},{"kind":"text","text":"; i. e."},{"kind":"italic_en","text":"they shall not"},{"kind":"text","text":"["},{"kind":"italic_en","text":"desire to"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"practise,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seek to practise, any evasion from it"},{"kind":"text","text":"to another abode. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"HiyalpN","text_ar":"حِيَلةٌ"},{"kind":"text","text":"[of which it is said to be both a syn. and a pl.]. ―         -b3-  And see"},{"kind":"arabic","text_bw":"HuwlapN","text_ar":"حُولَةٌ"},{"kind":"text","text":".       -A2-  Also"},{"kind":"italic_en","text":"A furrow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trench, in the ground, in which palm-trees are planted in a row."},{"kind":"text","text":"(ISd, K.)"}],"source_refs":["S","O","K","M"]},{"entry_id":"n9604","headword_ar":"حُوَّلٌ","root":"Hwl","body":[{"kind":"text","text":", applied to a man, signifies"},{"kind":"arabic","text_bw":"baSiyru bitaHowiyli","text_ar":"بَصِيرُ بِتَحْوِيلِ"},{"kind":"arabic","text_bw":"AlA^umuwri","text_ar":"الاُمُورِ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Knowing, skilful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligent, in turning affairs over,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, in his mind, considering what may be their results, and so managing them"},{"kind":"text","text":"]; (S, TA;) as also"},{"kind":"arabic","text_bw":"Huw~alN qul~abN","text_ar":"حُوَّلٌ قُلَّبٌ"},{"kind":"text","text":", (TA, and so in copies of the S,) and"},{"kind":"arabic","text_bw":"qul~abN","text_ar":"قُلَّبٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Huw~aliY~N","text_ar":"حُوَّلِىٌّ","orth_type":"arrow"},{"kind":"text","text":", (TA, and so in a copy of the S,) and"},{"kind":"arabic","text_bw":"qul~abiY~N","text_ar":"قُلَّبِىٌّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Huw~aliY~N","text_ar":"حُوَّلِىٌّ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Haw~aAlN","text_ar":"حَوَّالٌ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"HuwalapN","text_ar":"حُوَلَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies ↓"},{"kind":"arabic","text_bw":"muHotaAlN","text_ar":"مُحْتَالٌ","orth_type":"arrow"},{"kind":"text","text":"[i. e. one"},{"kind":"italic_en","text":"who exercises art, artifice, cunning, ingenuity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill, and excellence of consideration"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deliberation, and ability to manage according to his own free will, with subtilty;"},{"kind":"text","text":"&c.; see the verb (8) of which"},{"kind":"arabic","text_bw":"muHotaAlN","text_ar":"مُحْتَالٌ"},{"kind":"text","text":"is the part. n.]: (S:) or"},{"kind":"arabic","text_bw":"Huw~alN","text_ar":"حُوَّلٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HuwalN","text_ar":"حُوَلٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HuwalapN","text_ar":"حُوَلَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HuwolapN","text_ar":"حُوْلَةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Huw~aliY~N","text_ar":"حُوَّلِىٌّ","orth_type":"arrow"},{"kind":"text","text":", [in the CK, erroneously,"},{"kind":"arabic","text_bw":"Hawol`Y","text_ar":"حَوْلٰى"},{"kind":"text","text":",] like"},{"kind":"arabic","text_bw":"suk~ariY~N","text_ar":"سُكَّرِىٌّ"},{"kind":"text","text":", [in the CK like"},{"kind":"arabic","text_bw":"sakorY`","text_ar":"سَكْرىٰ"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"HaAliY~N","text_ar":"حَالِىٌّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HuwaAliY~N","text_ar":"حُوَالِىٌّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"HawalowalN","text_ar":"حَوَلْوَلٌ","orth_type":"arrow"},{"kind":"text","text":", signify"},{"kind":"arabic","text_bw":"$adiydu AlAiHotiyaAli","text_ar":"شَدِيدُ الاِحْتِيَالِ"},{"kind":"text","text":"[i. e. one"},{"kind":"italic_en","text":"who exercises great art, artifice,"},{"kind":"text","text":"&c.]: (Sgh, K:) all of these forms are mentioned by ISd, except"},{"kind":"arabic","text_bw":"HuwolapN","text_ar":"حُوْلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Huw~aliY~N","text_ar":"حُوَّلِىٌّ"},{"kind":"text","text":": (TA:) accord. to some,"},{"kind":"arabic","text_bw":"qul~abN Huw~alN","text_ar":"قُلَّبٌ حُوَّلٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"experienced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expert, in affairs;"},{"kind":"text","text":"or one"},{"kind":"italic_en","text":"who has been tried,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved, and strengthened by experience in affairs:"},{"kind":"text","text":"(Har p. 312:) and ↓"},{"kind":"arabic","text_bw":"HawilN","text_ar":"حَوِلٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"Huw~alN","text_ar":"حُوَّلٌ"},{"kind":"text","text":"; (Ham p. 34;)"},{"kind":"italic_en","text":"having much"},{"kind":"arabic","text_bw":"Hiylap","text_ar":"حِيلَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"art, artifice,"},{"kind":"text","text":"&c.]: accord. to analogy, it should be ["},{"kind":"arabic","text_bw":"HaAlN","text_ar":"حَالٌ"},{"kind":"text","text":",] like"},{"kind":"arabic","text_bw":"maAlN","text_ar":"مَالٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"SaAtN","text_ar":"صَاتٌ"},{"kind":"text","text":"as epithets applied to a man: (Idem pp. 530 and 531:)"},{"kind":"arabic","text_bw":"Hay~aAlN","text_ar":"حَيَّالٌ"},{"kind":"text","text":", also, [in like manner,] signifies"},{"kind":"arabic","text_bw":"SaAHibu HiylapK","text_ar":"صَاحِبُ حِيلَةٍ"},{"kind":"text","text":"[i. e. one"},{"kind":"italic_en","text":"who exercises art, artifice,"},{"kind":"text","text":"&c., as above]; and so ↓"},{"kind":"arabic","text_bw":"HiyaliY~N","text_ar":"حِيَلِىٌّ","orth_type":"arrow"},{"kind":"text","text":"[from"},{"kind":"arabic","text_bw":"HiyalN","text_ar":"حِيَلٌ"},{"kind":"text","text":", pl. of, or syn. with,"},{"kind":"arabic","text_bw":"HiylapN","text_ar":"حِيلَةٌ"},{"kind":"text","text":"]: (TA:) and ↓"},{"kind":"arabic","text_bw":"HawolowalN","text_ar":"حَوْلْوَلٌ","orth_type":"arrow"},{"kind":"text","text":"[mentioned above (in the CK, erroneously, in this instance,"},{"kind":"arabic","text_bw":"HawAwil","text_ar":"حَواوِل"},{"kind":"text","text":")] signifies also"},{"kind":"italic_en","text":"cunning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skilful and knowing;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"quick and sharp"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigorous"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effective;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"munokarN kamiy$N","text_ar":"مُنْكَرٌ كَمِيشٌ"},{"kind":"text","text":"; (K, TA;) applied to a man. (TA.)"}],"source_refs":["S","Sgh","K","TA"]}]}}