B4%D9%8E%D9%8A%D9%8E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of شَاعَ (šāʕa, “to spread (intransitive), become public”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"amount, quantity, measure"},{"pos":"noun","gloss":"space"},{"pos":"noun","gloss":"someone born immediately after another"},{"pos":"noun","gloss":"whelp of a lion"},{"pos":"noun","gloss":"follower, partisan, disciple"},{"pos":"noun","gloss":"partisan, follower, helper"},{"pos":"noun","gloss":"plural of شِيعَة (šīʕa)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to see someone off, escort, accompany, bid farewell, pay the last honors, send, show courtesy or honors"},{"pos":"verb","gloss":"to spread, make public, publish, encourage"},{"pos":"verb","gloss":"to burn or replenish the fire"},{"pos":"verb","gloss":"to adhere to (of a faction)"},{"pos":"verb","gloss":"to make follow or be followed"},{"pos":"verb","gloss":"to blow in the reed-pipe"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23525","headword_ar":"شَيْعٌ","root":"$yE","body":[{"kind":"italic_en","text":"A space"},{"kind":"text","text":"[of time]. (S, O, K.) One says,"},{"kind":"arabic","text_bw":"A^aqaAma fulaAnN $ahorFA A^awo $ayoEahu","text_ar":"اَقَامَ فُلَانٌ شَهْرًا اَوْ شَيْعَهُ"},{"kind":"text","text":"(S, O) i. e."},{"kind":"italic_en","text":"Such a one remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stayed, a month or the space thereof:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nearly the space thereof."},{"kind":"text","text":"(TA.) ―         -b2-  One says also,"},{"kind":"arabic","text_bw":"A=tiyka gadFA A^awo $ayoEahu","text_ar":"ا=تِيكَ غَدًا اَوْ شَيْعَهُ"},{"kind":"italic_en","text":"I will come to thee to-morrow or after it:"},{"kind":"text","text":"(S, O, K:) or"},{"kind":"italic_en","text":"to-morrow or the day after it."},{"kind":"text","text":"(L, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"h`*aA $ayoEu h`*aA","text_ar":"هٰذَا شَيْعُ هٰذَا"},{"kind":"italic_en","text":"This is he that was born next after this;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"$awoEuhu","text_ar":"شَوْعُهُ"},{"kind":"text","text":": (S, O, K, all in art."},{"kind":"arabic","text_bw":"$wE","text_ar":"شوع"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"this is the like of this."},{"kind":"text","text":"(A 'Obeyd, O and K in the present art.) ―         -b4-"},{"kind":"arabic","text_bw":"$ayoEN","text_ar":"شَيْعٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"A follower:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a friend,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a comrade,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an assistant."},{"kind":"text","text":"(KL.) ―         -b5-  And"},{"kind":"italic_en","text":"A lion's whelp:"},{"kind":"text","text":"(Lth, IDrd, S, O, K:) or"},{"kind":"italic_en","text":"when he has attained to taking prey;"},{"kind":"text","text":"so in the L: and some say the"},{"kind":"italic_en","text":"lion"},{"kind":"text","text":"[himself]. (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"$aAy^iEN","text_ar":"شَايِعٌ"},{"kind":"text","text":"."}],"source_refs":["S","O","K","Lth","IDrd"]},{"entry_id":"n23535","headword_ar":"شَيِّعٌ","root":"$yE","body":[{"kind":"italic_en","text":"A sharer,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"partner:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"$uyaEaA='u","text_ar":"شُيَعَا=ءُ"},{"kind":"text","text":". (O, K, TA.) One says,"},{"kind":"arabic","text_bw":"humo $uyaEaA='u fiyhaA","text_ar":"هُمْ شُيَعَا=ءُ فِيهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They are sharers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"partners, in it,"},{"kind":"text","text":"i. e. a house ("},{"kind":"arabic","text_bw":"daAr","text_ar":"دَار"},{"kind":"text","text":") or land;] i. e."},{"kind":"italic_en","text":"every one of them is a"},{"kind":"arabic","text_bw":"$ay~iE","text_ar":"شَيِّع"},{"kind":"italic_en","text":"to his fellow"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fellows"},{"kind":"text","text":"]. (O, K.) And ↓"},{"kind":"arabic","text_bw":"humaA muta$aAyiEaAni","text_ar":"هُمَا مُتَشَايِعَانِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"fiY daArK","text_ar":"فِى دَارٍ"},{"kind":"text","text":", (O, K,) or"},{"kind":"arabic","text_bw":"A^aroDK","text_ar":"اَرْضٍ"},{"kind":"text","text":"; (O;) and ↓"},{"kind":"arabic","text_bw":"mu$otaAEaAni","text_ar":"مُشْتَاعَانِ","orth_type":"arrow"},{"kind":"text","text":", (O, TA,) in the copies of the K, erroneously,"},{"kind":"arabic","text_bw":"muta$aAEaAni","text_ar":"مُتَشَاعَانِ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"They two are sharers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"partners, in a house,"},{"kind":"text","text":"(O, K,) or"},{"kind":"italic_en","text":"land."},{"kind":"text","text":"(O.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Ald~aAru $ay~iEapN bayonahumo","text_ar":"الدَّارُ شَيِّعَةٌ بَيْنَهُمْ"},{"kind":"italic_en","text":"The house is undivided"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"shared"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"among them;"},{"kind":"text","text":"syn. ↓"},{"kind":"arabic","text_bw":"mu$aAEapN","text_ar":"مُشَاعَةٌ","orth_type":"arrow"},{"kind":"text","text":". (O, K. [See also"},{"kind":"arabic","text_bw":"$aAy^iEN","text_ar":"شَايِعٌ"},{"kind":"text","text":".])"}],"source_refs":["TA","O","K"]}]}}