,"frequency_in_corpus":437,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n5180"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AC%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"elative degree of جَدِيد (jadīd)"},{"pos":"adj","gloss":"elative degree of جَدِيد (jadīd):; newer; newest"},{"pos":"adj","gloss":"elative degree of جَادّ (jādd):; more serious; most serious"},{"pos":"adj","gloss":"elative degree of جَادّ (jādd):; more earnest; most earnest"}]},"etymology":{"source":"wiktextract","text":"Elative of جَدِيد (jadīd, “new”) and جَادّ (jādd, “serious, earnest”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5180","headword_ar":"اَجَدُّ","root":"jd","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Having some part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"parts, cut,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut off:"},{"kind":"text","text":"fem."},{"kind":"arabic","text_bw":"jad~aA='u","text_ar":"جَدَّا=ءُ"},{"kind":"text","text":"]. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"jad~aA='u","text_ar":"جَدَّا=ءُ"},{"kind":"text","text":"A ewe, or she-goat, or she-camel, (TA,)"},{"kind":"italic_en","text":"having her ear cut off."},{"kind":"text","text":"(K, TA.) ―         -b3-  A ewe, or she-goat,"},{"kind":"italic_en","text":"having her teats cut off;"},{"kind":"text","text":"(Sh, TA;) as also ↓"},{"kind":"arabic","text_bw":"mujad~adapN","text_ar":"مُجَدَّدَةٌ","orth_type":"arrow"},{"kind":"text","text":"[q. v.], applied to a she-camel: (As, TA:) or"},{"kind":"italic_en","text":"having her udder cut off."},{"kind":"text","text":"(Khálid, TA.) ―         -b4-  [And hence,] (assumed tropical:)  A milch animal (TA [in the S app. restricted to a ewe])"},{"kind":"italic_en","text":"whose milk has passed away,"},{"kind":"text","text":"(ISk, S, K,)"},{"kind":"italic_en","text":"by reason of some fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection:"},{"kind":"text","text":"(ISk, S:) see also"},{"kind":"arabic","text_bw":"jaduwdN","text_ar":"جَدُودٌ"},{"kind":"text","text":": or a ewe, or she-camel, or she-ass,"},{"kind":"italic_en","text":"having little milk; having a dry udder:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having dry teats, being hurt by the"},{"kind":"arabic","text_bw":"SiraAr","text_ar":"صِرَار"},{"kind":"text","text":"[q. v.]: (L:) and"},{"kind":"arabic","text_bw":"A^ajad~u","text_ar":"اَجَدُّ"},{"kind":"text","text":"(assumed tropical:)  a breast"},{"kind":"italic_en","text":"that has become dry."},{"kind":"text","text":"(AHeyth.) ―         -b5-  (assumed tropical:)  A woman"},{"kind":"italic_en","text":"small in the breast:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"having short breasts."},{"kind":"text","text":"(TA from a trad.) ―         -b6-  (assumed tropical:)  A desert, ("},{"kind":"arabic","text_bw":"falaAp","text_ar":"فَلَاة"},{"kind":"text","text":", S, K,) or land, ("},{"kind":"arabic","text_bw":"A^aroD","text_ar":"اَرْض"},{"kind":"text","text":", A,)"},{"kind":"italic_en","text":"in which is no water:"},{"kind":"text","text":"(S, A, K:) a desert ("},{"kind":"arabic","text_bw":"mafaAzap","text_ar":"مَفَازَة"},{"kind":"text","text":") that is"},{"kind":"italic_en","text":"dry."},{"kind":"text","text":"(TA.) ―         -b7-"},{"kind":"arabic","text_bw":"EaAmN A^ajad~u","text_ar":"عَامٌ اَجَدُّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sanapN","text_ar":"سَنَةٌ"},{"kind":"arabic","text_bw":"jad~aA='u","text_ar":"جَدَّا=ءُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A year of drought, and of dryness o the earth."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"AlA^ajad~aAni","text_ar":"الاَجَدَّانِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jadiydN","text_ar":"جَدِيدٌ"},{"kind":"text","text":", in two places.       -A3-"},{"kind":"arabic","text_bw":"A^ajad~u","text_ar":"اَجَدُّ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"More"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"easy to walk or ride upon,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"more"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"plain"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"level;"},{"kind":"text","text":"applied to a road. (TA.)       -A4-  And"},{"kind":"italic_en","text":"More"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"most"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"fortunate;"},{"kind":"text","text":"applied to a man. (ISd, A, L.)"}],"source_refs":["TA","As","ISk","S","K","L","A"]}]}}