ind":"text","text":"(M, K, *)"},{"kind":"italic_en","text":"and longed,"},{"kind":"text","text":"(K,) ["},{"kind":"italic_en","text":"as though hungering,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to meet with him;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"EaTi$a","text_ar":"عَطِشَ"},{"kind":"text","text":". (M, K. *) And"},{"kind":"arabic","text_bw":"jaAEa A_ilaY maAlihi","text_ar":"جَاعَ اـِلَى مَالِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He longed for his property."},{"kind":"text","text":"(AZ.)"}],"source_refs":["S","Msb","K","TA","M"]}]},"classical_definitions":null}