{"lemma":"حَبَطَ","slug":"حَبَطَ","root":"ح.ب.ط","root_slug":"ح-ب-ط","root_link":"/words/roots/ح-ب-ط","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"حَبَطْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"حَبَطْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"حَبَطْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"حَبَطْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"حَبَطْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"حَبَطَ","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"حَبَطَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"حَبَطا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"حَبَطَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"حَبَطُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"حَبَطْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَحْبِط","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَحْبِطِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَحْبِطِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَحْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَحْبِطا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَحْبِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْبِطُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْبِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْبِط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْبِط","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْبِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْبِطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْبِطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْبِطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْبِطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْبِطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَبَطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَبَطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْبِط","in_corpus":true,"count":11,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْبِط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":15,"cross_references":{"qac":{"found":true,"lemma_key":"حَبَطَ","root":"حبط","pos":"V","occurrence_count":12},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n6934","n6936","n6937"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%A8%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become worthless"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6934","headword_ar":"حَبِطَ","root":"HbT","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":", (Az, S, K, &c.,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a beast, Az, S, or a camel, ISd, K)"},{"kind":"italic_en","text":"ate much,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"had pain in his belly from pasture which he found unwholesome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from eating much of herbage,"},{"kind":"text","text":"(ISd, K,)"},{"kind":"italic_en","text":"so that he became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, thereby"},{"kind":"text","text":"(S, ISd, K)"},{"kind":"italic_en","text":"in his belly,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"and there would not come forth from him"},{"kind":"text","text":"(S, ISd, K)"},{"kind":"italic_en","text":"what was in it,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"anything;"},{"kind":"page_break","n":502},{"kind":"text","text":"(ISd, K;)"},{"kind":"italic_en","text":"he did not void either thin dung or urine, his belly being bound:"},{"kind":"text","text":"(Az:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a sheep, or goat, ISk, S)"},{"kind":"italic_en","text":"became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, in his belly, in consequence of eating"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the herb called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"*uraq","text_ar":"ذُرَق"},{"kind":"text","text":", (ISk, S, K, *)"},{"kind":"italic_en","text":"which is the"},{"kind":"arabic","text_bw":"Hanoda quwq","text_ar":"حَنْدَ قُوق"},{"kind":"text","text":"[i. e. the herb"},{"kind":"italic_en","text":"lotus, melilot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bird's-foot-trefoil"},{"kind":"text","text":"]: (ISk, S:) or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"(a beast)"},{"kind":"italic_en","text":"lighted upon good pasturage, and ate immoderately, so that he became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, and died:"},{"kind":"text","text":"(Z, IAth:) or, in speaking of a horse, you do not say,"},{"kind":"arabic","text_bw":"HabiTa Alfarasu","text_ar":"حَبِطَ الفَرَسُ"},{"kind":"text","text":", but"},{"kind":"arabic","text_bw":"HabiTa quSayoraY Alfarasi","text_ar":"حَبِطَ قُصَيْرَى الفَرَسِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"xaASiratuhu","text_ar":"خَاصِرَتُهُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"mawoqifuhu","text_ar":"مَوْقِفُهُ"},{"kind":"text","text":", because it means that"},{"kind":"italic_en","text":"the horse's belly became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated:"},{"kind":"text","text":"(ISd, Z, L:) you say also,"},{"kind":"arabic","text_bw":"HabiTa baTonuhu","text_ar":"حَبِطَ بَطْنُهُ"},{"kind":"italic_en","text":"his belly became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, so that he died:"},{"kind":"text","text":"(Az, TA:) or"},{"kind":"italic_en","text":"his"},{"kind":"text","text":"(a man's)"},{"kind":"italic_en","text":"belly became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, by food &c.:"},{"kind":"text","text":"(Mbr, TA in art."},{"kind":"arabic","text_bw":"HbTA^","text_ar":"حبطا"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"HabiTa","text_ar":"حَبِطَ"},{"kind":"text","text":"is also said of the skin, meaning"},{"kind":"italic_en","text":"it became swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated."},{"kind":"text","text":"(TA.) [See also Q. Q. 3; and see"},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":"below.] ―         -b2-  Hence, app., i. e. from"},{"kind":"arabic","text_bw":"HabiTa","text_ar":"حَبِطَ"},{"kind":"text","text":"said of the belly, (Az, TA,) or it is from this verb said of a beast, (Z, IAth, TA,)"},{"kind":"arabic","text_bw":"HabiTa Eamaluhu","text_ar":"حَبِطَ عَمَلُهُ"},{"kind":"text","text":", (Az, S, Msb, K, &c.,) aor."},{"kind":"text","text":"; (Az, Msb, K;) and"},{"kind":"arabic","text_bw":"HabaTa","text_ar":"حَبَطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (AZ, Az, Msb, K;) the latter, says Az, heard by AZ from an Arab of the desert, but I have not heard it on any other authority; (TA;) inf. n."},{"kind":"arabic","text_bw":"HaboTN","text_ar":"حَبْطٌ"},{"kind":"text","text":", (Az, S, K, [but in the Msb it seems to be indicated that it is"},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":",]) with the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"quiescent, (Az, S,) thus differing from the inf. n. of"},{"kind":"arabic","text_bw":"HabiTa","text_ar":"حَبِطَ"},{"kind":"text","text":"said of the belly, (Az, TA,) and"},{"kind":"arabic","text_bw":"HubuwTN","text_ar":"حُبُوطٌ"},{"kind":"text","text":", (Az, S, Msb, K,) which latter, accord. to AZ, is the inf. n. of"},{"kind":"arabic","text_bw":"HabaTa","text_ar":"حَبَطَ"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"Daraba","text_ar":"ضَرَبَ"},{"kind":"text","text":"; (T, TA;) (tropical:)"},{"kind":"italic_en","text":"His work,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deed, became null,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"void,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of no account; it went for nothing; it perished;"},{"kind":"text","text":"(Az, Msb, TA;) for like as he of whom one says"},{"kind":"arabic","text_bw":"HabiTa baTonuhu","text_ar":"حَبِطَ بَطْنُهُ"},{"kind":"text","text":"perishes, so does the work, or deed, of the hypocrite: (Az, TA:) or"},{"kind":"italic_en","text":"it became ineffective of reward; its reward became annulled."},{"kind":"text","text":"(S, K.) And hence also, (Z, TA,)"},{"kind":"arabic","text_bw":"HabiTa damuhu","text_ar":"حَبِطَ دَمُهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (Z, Msb, K, TA,) but not"},{"kind":"arabic","text_bw":"HabaTa","text_ar":"حَبَطَ"},{"kind":"text","text":"also, as is implied in the K, (TA,) and in this case the inf. n. is"},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":", (Msb, * TA,) with the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"movent, (TA,) (tropical:)"},{"kind":"italic_en","text":"His blood"},{"kind":"text","text":"(the blood of one slain, K)"},{"kind":"italic_en","text":"went for nothing; unretaliated, and uncompensated by a mulct."},{"kind":"text","text":"(Msb, K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"HabiTa","text_ar":"حَبِطَ"},{"kind":"text","text":"said of the water of a well,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aHobaTa","text_ar":"اَحْبَطَ"},{"kind":"text","text":", q. v. (TA.) ―         -b4-  Said of a wound, (S, Ibn-' Abbád, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":", with fet-h to the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"It had scars remaining after having healed:"},{"kind":"text","text":"(Ibn-' Abbád, K: *) or"},{"kind":"italic_en","text":"it broke open again;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became recrudescent;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Eariba","text_ar":"عَرِبَ"},{"kind":"text","text":"[which has the signification given above on the authority of Ibn-' Abbád as well as what follows it] and"},{"kind":"arabic","text_bw":"nukisa","text_ar":"نُكِسَ"},{"kind":"text","text":". (S.) [See also"},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":"below.]"}],"source_refs":["S","ISd","K","Az","ISk","Z","IAth","L","TA","Msb"]},{"entry_id":"n6936","headword_ar":"حَبَطٌ","root":"HbT","body":[{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"HabiTa","text_ar":"حَبِطَ"},{"kind":"text","text":", q. v.:] A beast's"},{"kind":"italic_en","text":"having the belly swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, so that what is in it does not come forth, in consequence of eating much:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"pain in the belly,"},{"kind":"text","text":"of a camel,"},{"kind":"italic_en","text":"from pasture which he finds unwholesome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from herbage of which he has eaten much, so that he becomes swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, therefrom,"},{"kind":"text","text":"(ISd, K,)"},{"kind":"italic_en","text":"in his belly,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and nothing comes forth from him:"},{"kind":"text","text":"(ISd, K:) or a"},{"kind":"italic_en","text":"swelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflation, of the belly,"},{"kind":"text","text":"(K,) or a beast's"},{"kind":"italic_en","text":"having the belly swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated,"},{"kind":"text","text":"(ISk, S,)"},{"kind":"italic_en","text":"from eating"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the herb called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"*uraq","text_ar":"ذُرَق"},{"kind":"text","text":": (ISk, S, K:) [see 1:] and"},{"kind":"italic_en","text":"a swelling in the udder"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other thing:"},{"kind":"text","text":"(K:) or, accord. to the M, the"},{"kind":"italic_en","text":"slightest swelling in the udder:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"swelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflation, wherever it be, from disease or other cause."},{"kind":"text","text":"(TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a mim~aA yunobitu Alr~abiyEu mDA yaqotulu","text_ar":"اـِنَّ مِمَّا يُنْبِتُ الرَّبِيعُ مضا يَقْتُلُ"},{"kind":"arabic","text_bw":"HabaTFA A^awo yulim~u","text_ar":"حَبَطًا اَوْ يُلِمُّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily, of what the"},{"kind":"text","text":"("},{"kind":"italic_en","text":"rain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season, called"},{"kind":"text","text":")"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"italic_en","text":"causes to grow, is what kills by inflation of the belly, or nearly does so"},{"kind":"text","text":"]. (S, TA.) ―         -b2-  The"},{"kind":"italic_en","text":"scars,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks, of a wound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of whips, upon the body, after healing:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"swollen scars,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks,"},{"kind":"text","text":"("},{"kind":"italic_en","text":"of whips,"},{"kind":"text","text":"TA,)"},{"kind":"italic_en","text":"not lacerated:"},{"kind":"text","text":"when mangled and bleeding, they are termed"},{"kind":"arabic","text_bw":"Euluwb","text_ar":"عُلُوب"},{"kind":"text","text":"[pl. of"},{"kind":"arabic","text_bw":"Ealob","text_ar":"عَلْب"},{"kind":"text","text":"]: (K:) the"},{"kind":"italic_en","text":"excrescent flesh upon the scars of wounds."},{"kind":"text","text":"(Sgh.)"}],"source_refs":["S","ISd","K","TA","ISk"]},{"entry_id":"n6937","headword_ar":"حَبِطٌ","root":"HbT","body":[{"kind":"text","text":"part. n. of"},{"kind":"arabic","text_bw":"HabiTa","text_ar":"حَبِطَ"},{"kind":"text","text":"; A camel [or other beast"},{"kind":"italic_en","text":"having his belly swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, so that what is in it does not come forth, in consequence of eating much:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"having pain in the belly, from pasture which he finds unwholesome,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from herbage of which he has eaten much, so that he is swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, therefrom,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in his belly,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and nothing comes forth from him:"},{"kind":"text","text":"(K:) [see"},{"kind":"arabic","text_bw":"HabaTN","text_ar":"حَبَطٌ"},{"kind":"text","text":":] pl."},{"kind":"arabic","text_bw":"HabaATaY","text_ar":"حَبَاطَى"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"HabaTapN","text_ar":"حَبَطَةٌ"},{"kind":"text","text":". (M, TA.) You say also"},{"kind":"arabic","text_bw":"farasN HabiTu AlquSayoraY","text_ar":"فَرَسٌ حَبِطُ القُصَيْرَى"},{"kind":"italic_en","text":"A horse swollen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inflated, in the flanks."},{"kind":"text","text":"(TA.)"}],"source_refs":["K"]}]}}