{"lemma":"عادَ","slug":"عادَ","root":"ع.#.د","root_slug":"ع-_-د","root_link":"/words/roots/ع-_-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عُدْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عُدْتِ","in_corpus":true,"count":7,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عُدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عُدْتُم","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عُدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عادَ","in_corpus":true,"count":103,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عادَت","in_corpus":true,"count":5,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عادا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عادَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عادُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عُدْنَ","in_corpus":true,"count":17,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعُد","in_corpus":true,"count":32,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَعُود","in_corpus":true,"count":10,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعُودِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعُودِي","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعُودانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعُودا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعُودُونَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعُودُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعُد","in_corpus":true,"count":30,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعُود","in_corpus":true,"count":52,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعُد","in_corpus":true,"count":32,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعُود","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعُودانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعُودا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعُودانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعُودا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعُودُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعُودُوا","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عُدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عُدْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعُود","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعُود","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":333,"cross_references":{"qac":{"found":true,"lemma_key":"عادَ","root":"عود","pos":"V","occurrence_count":18},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["name","noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["","n28397","n30935","n30936"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to return, to go back, to come back"},{"pos":"verb","gloss":"to become","tags":["copulative"],"examples":[{"text":"وذهب التاجر المذكور الى خراسان ثم عاد الى الهند وهنالك تقاضى مني ماله واستفاد بسببي فائدة عظيمة وعاد من كبار التجار"}]},{"pos":"verb","gloss":"to refer to","examples":[{"text":"قَد يَعُودُ ٱلضَّمِيرُ عَلَى ٱلْفاعِلِ أَوِ ٱلْمَفْعُولِ بِه.","english":"The pronominal suffix might refer to the subject or the object."}]},{"pos":"verb","gloss":"to go back to; to have its origins in","examples":[{"text":"هٰذَا التَقْلِيدُ الشَعْبِيُّ يَعُودُ إلَى العَصْرِ العُثْمانِيّ.","english":"This popular tradition goes back to the Ottoman era."}]},{"pos":"verb","gloss":"to come back with something"},{"pos":"verb","gloss":"to visit (a patient)"},{"pos":"noun","gloss":"plural of عَادَة (ʕāda)","tags":["form-of","plural"]},{"pos":"name","gloss":"ʿĀd (an ancient tribe mentioned in the Qur'an)"}]},"etymology":null,"ipa":["/ʕaː.da/","/ʕaːd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28397","headword_ar":"عَادٍ","root":"Edw","body":[{"kind":"text","text":"[act. part. n. of"},{"kind":"arabic","text_bw":"EadaA","text_ar":"عَدَا"},{"kind":"text","text":", q. v. ―         -b2-  As such particularly signifying]"},{"kind":"italic_en","text":"Acting wrongfully, unjustly, injuriously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tyrannically; transgressing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exceeding the proper limit:"},{"kind":"text","text":"(Msb, TA:) pl."},{"kind":"arabic","text_bw":"EaAduwna","text_ar":"عَادُونَ"},{"kind":"text","text":". (Msb.) Hence the saying,"},{"kind":"arabic","text_bw":"laA A^a$omata A@ll~`hu bika EaAdiyaka","text_ar":"لَا اَشْمَتَ ا@للّٰهُ بِكَ عَادِيَكَ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"May God not make to rejoice at thy affliction"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"him who acts wrongfully to thee."},{"kind":"text","text":"(TA.) [And hence the phrase"},{"kind":"arabic","text_bw":"liS~N EaAdiY ZahorK","text_ar":"لِصٌّ عَادِى ظَهْرٍ"},{"kind":"text","text":", expl. in art."},{"kind":"arabic","text_bw":"Zhr","text_ar":"ظهر"},{"kind":"text","text":".] See also"},{"kind":"arabic","text_bw":"EadawaAnN","text_ar":"عَدَوَانٌ"},{"kind":"text","text":". And see"},{"kind":"arabic","text_bw":"Eaduw~N","text_ar":"عَدُوٌّ"},{"kind":"text","text":", with which it is syn. ―         -b3-  Also"},{"kind":"italic_en","text":"Seizing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carrying off, by force;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"snatching at unawares."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlEaAdiY","text_ar":"العَادِى"},{"kind":"text","text":"signifies [particularly]"},{"kind":"italic_en","text":"The lion;"},{"kind":"text","text":"(K, TA;) because of his injuriousness, and his seizing men and making them his prey. (TA.) ―         -b4-  ↓"},{"kind":"arabic","text_bw":"EadiY~N","text_ar":"عَدِىٌّ","orth_type":"arrow"},{"kind":"text","text":"is a pl. of"},{"kind":"arabic","text_bw":"EaAdK","text_ar":"عَادٍ"},{"kind":"text","text":", [or rather a quasi-pl. n.,] like as"},{"kind":"arabic","text_bw":"gaziY~N","text_ar":"غَزِىٌّ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"gaAzK","text_ar":"غَازٍ"},{"kind":"text","text":"; as such signifying"},{"kind":"italic_en","text":"Runners upon their feet:"},{"kind":"text","text":"(S, TA:) or"},{"kind":"italic_en","text":"a company of men,"},{"kind":"text","text":"(K, TA,) in the dial. of Hudheyl, (TA,)"},{"kind":"italic_en","text":"that run to the fight"},{"kind":"text","text":"(K, TA) and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"first, of the footmen,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"foot-soldiers,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that charge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assault;"},{"kind":"text","text":"(K, TA;) because they run quickly: (TA:) like"},{"kind":"arabic","text_bw":"EaAdiyapN","text_ar":"عَادِيَةٌ"},{"kind":"text","text":", (K, TA,) of which the pl. is"},{"kind":"arabic","text_bw":"EawaAdK","text_ar":"عَوَادٍ"},{"kind":"text","text":", (TA,) in both senses: or this signifies the"},{"kind":"italic_en","text":"horsemen;"},{"kind":"text","text":"(K, TA;) i. e. the"},{"kind":"italic_en","text":"first, of the horsemen, that charge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assault, in a hostile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"predatory, incursion,"},{"kind":"text","text":"especially; (TA;) or"},{"kind":"italic_en","text":"horses making a hostile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"predatory, incursion;"},{"kind":"text","text":"and hence [the pl.]"},{"kind":"arabic","text_bw":"AlEaAdiyaAt","text_ar":"العَادِيَات"},{"kind":"text","text":"in the Kur c. 1. (TA in"},{"kind":"page_break","n":1981},{"kind":"text","text":"the supplement to this art.) And accord. to ElKhuwárezmee,"},{"kind":"arabic","text_bw":"EadiY~N","text_ar":"عَدِىٌّ"},{"kind":"text","text":"particularly signifies The"},{"kind":"italic_en","text":"foot-messengers of the sovereign,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of the judge, who are made to run in quest of one against whom an accusation has been made, and to bring him, for the purpose of exacting from him the right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, of his accuser."},{"kind":"text","text":"(De Sacy's Chrest. Arabe, sec. ed., iii. 100.)       -A2-"},{"kind":"arabic","text_bw":"EaAdiY AlEawaAdiY","text_ar":"عَادِى العَوَادِى"},{"kind":"text","text":", a phrase used by a poet, is expl. by IAar as meaning"},{"kind":"italic_en","text":"The hardest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most pressing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most severe, of occupations that turn one away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"back, from a thing."},{"kind":"text","text":"(TA.)       -A3-  See also"},{"kind":"arabic","text_bw":"EaAdK","text_ar":"عَادٍ"},{"kind":"text","text":"and its fem."},{"kind":"arabic","text_bw":"EaAdiyapN","text_ar":"عَادِيَةٌ"},{"kind":"text","text":"voce"},{"kind":"arabic","text_bw":"EudowiY~N","text_ar":"عُدْوِىٌّ"},{"kind":"text","text":".       -A4-"},{"kind":"arabic","text_bw":"EaAdiyaA All~awoHi","text_ar":"عَادِيَا اللَّوْحِ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"TarafaAhu","text_ar":"طَرَفَاهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The two extremities,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"two sides, of the tablet"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"]; (K, TA;) each of them being called"},{"kind":"arabic","text_bw":"EAdY","text_ar":"عادى"},{"kind":"text","text":"[i. e."},{"kind":"arabic","text_bw":"EaAdiY All~awoHi","text_ar":"عَادِى اللَّوْحِ"},{"kind":"text","text":", or a mistranscription for"},{"kind":"arabic","text_bw":"EaAdK","text_ar":"عَادٍ"},{"kind":"text","text":"], like"},{"kind":"arabic","text_bw":"EidY","text_ar":"عِدى"},{"kind":"text","text":"[i. e. ↓"},{"kind":"arabic","text_bw":"EidFY","text_ar":"عِدًى","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"EadFY","text_ar":"عَدًى","orth_type":"arrow"},{"kind":"text","text":", both mentioned above, voce"},{"kind":"arabic","text_bw":"EudowapN","text_ar":"عُدْوَةٌ"},{"kind":"text","text":", as meaning, absolutely,"},{"kind":"italic_en","text":"a side,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lateral part"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["Msb","TA","S","K"]},{"entry_id":"n30935","headword_ar":"عَادٌ","root":"Ewd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EaAdapN","text_ar":"عَادَةٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"maA A^adoriY A^aY~u EaAda huwa","text_ar":"مَا اَدْرِى اَىُّ عَادَ هُوَ"},{"kind":"text","text":", (S, O, K,)"},{"kind":"arabic","text_bw":"EAd","text_ar":"عاد"},{"kind":"text","text":"being in this case imperfectly decl., (S, O, [but in the CK and in my MS. copy of the K it is written"},{"kind":"arabic","text_bw":"EAdK","text_ar":"عادٍ"},{"kind":"text","text":",]) means"},{"kind":"italic_en","text":"I know not what one of mankind he is."},{"kind":"text","text":"(S, O, K.) [Perhaps it is from"},{"kind":"arabic","text_bw":"EaAdN","text_ar":"عَادٌ"},{"kind":"text","text":"the name of an ancient and extinct tribe of the Arabs.]"}],"source_refs":["S","O","K"]},{"entry_id":"n30936","headword_ar":"عَادِ","root":"Ewd","body":[{"kind":"text","text":", indecl., with kesr for its termination, is a particle in the sense of"},{"kind":"arabic","text_bw":"A_in~a","text_ar":"اـِنَّ"},{"kind":"text","text":", governing an accus. case, on the condition of its being preceded by a verbal proposition and a conjunction; as in the saying,"},{"kind":"arabic","text_bw":"raqadotu waEaAdi A^abaAka saAhirN","text_ar":"رَقَدْتُ وَعَادِ اَبَاكَ سَاهِرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I slept, and verily thy father was waking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remaining awake, by night"},{"kind":"text","text":"]: ―         -b2-  it is also an interrogative particle in the sense of"},{"kind":"arabic","text_bw":"halo","text_ar":"هَلْ"},{"kind":"text","text":", indecl., with kesr for its termination, requiring an answer; as in the saying,"},{"kind":"arabic","text_bw":"EaAdi","text_ar":"عَادِ"},{"kind":"arabic","text_bw":"A^abuwka muqiymN","text_ar":"اَبُوكَ مُقِيمٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Is thy father abiding?"},{"kind":"text","text":"]: ―         -b3-  it also denotes an answer, in the sense of a proposition rendered negative by means of"},{"kind":"arabic","text_bw":"lm","text_ar":"لم"},{"kind":"text","text":"or of"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":", only; indecl., with kesr for its termination; and this is when it is conjoined with a pronoun; as when"},{"kind":"page_break","n":2190},{"kind":"text","text":"an interrogator says,"},{"kind":"arabic","text_bw":"halo Sal~ayota","text_ar":"هَلْ صَلَّيْتَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Didst thou perform,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hast thou performed, the act of prayer?"},{"kind":"text","text":"], and thou answerest,"},{"kind":"arabic","text_bw":"EaAdininY","text_ar":"عَادِنِنى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Verily I"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A_in~aniY","text_ar":"اـِنَّنِى"},{"kind":"text","text":")"},{"kind":"italic_en","text":"did not perform,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"have not performed, the act of prayer:"},{"kind":"text","text":"―         -b4-  and some of the people of El-Hijáz suppress the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"EaAdiniY","text_ar":"عَادِنِى"},{"kind":"text","text":": both the modes are chaste when"},{"kind":"arabic","text_bw":"EaAdi","text_ar":"عَادِ"},{"kind":"text","text":"is used in the sense of"},{"kind":"arabic","text_bw":"A_in~a","text_ar":"اـِنَّ"},{"kind":"text","text":": ―         -b5-  sometimes, also, it is used by the interrogator and the answerer; the former saying,"},{"kind":"arabic","text_bw":"EaAdi","text_ar":"عَادِ"},{"kind":"arabic","text_bw":"xaraja zayodN","text_ar":"خَرَجَ زَيْدٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Did Zeyd go forth?"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has Zeyd gone forth?"},{"kind":"text","text":"], and the latter saying,"},{"kind":"arabic","text_bw":"EaAdihi","text_ar":"عَادِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"Verily he did not go forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has not gone forth:"},{"kind":"text","text":"―         -b6-  all this is unmentioned by the leading authors on the Arabic language, those of lengthy compositions as well as the epitomisers. (MF, TA.)"}],"source_refs":[]}]}}