nd":"italic_en","text":"resembling"},{"kind":"arabic","text_bw":"sa*aAb","text_ar":"سَذَاب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rue"},{"kind":"text","text":"], (M, K,)"},{"kind":"italic_en","text":"with which the hair is dyed."},{"kind":"text","text":"(M.) ―         -b8-  And"},{"kind":"italic_en","text":"Senna,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"with which beards are dyed, as with"},{"kind":"arabic","text_bw":"Hin~aA='","text_ar":"حِنَّا=ء"},{"kind":"text","text":". (M.) ―         -b9-  And"},{"kind":"italic_en","text":"A certain thing"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"plant"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"resembling the"},{"kind":"arabic","text_bw":"wasomap","text_ar":"وَسْمَة"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"wasimap","text_ar":"وَسِمَة"},{"kind":"text","text":", q. v.], (M, K, TA,)"},{"kind":"italic_en","text":"with which beards are dyed."},{"kind":"text","text":"(TA.) ―         -b10-  Also"},{"kind":"italic_en","text":"Hoar-frost."},{"kind":"text","text":"(AA, K.) AA cites, as descriptive of the sky,"},{"kind":"quote","text":"walayosa bhaA Al~aA SabFA waSabiybuhaA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And there is not in it aught save east wind and its hoar-frost"},{"kind":"text","text":"]. (TA.) ―         -b11-  And"},{"kind":"italic_en","text":"Good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellent, honey."},{"kind":"text","text":"(K.) ―         -b12-  Also, (K,) or"},{"kind":"arabic","text_bw":"Sabiybu sayofK","text_ar":"صَبِيبُ سَيْفٍ"},{"kind":"text","text":", (TA,) The"},{"kind":"italic_en","text":"extremity of a sword:"},{"kind":"text","text":"(K, TA:) or the"},{"kind":"italic_en","text":"extremity next the"},{"kind":"arabic","text_bw":"siylaAn","text_ar":"سِيلَان"},{"kind":"text","text":"[q. v.]"},{"kind":"italic_en","text":"thereof:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"its"},{"kind":"arabic","text_bw":"sylAn","text_ar":"سيلان"},{"kind":"text","text":"absolutely. (TA.) ―         -b13-  See also"},{"kind":"arabic","text_bw":"SababN","text_ar":"صَبَبٌ"},{"kind":"text","text":"."}],"source_refs":["M","K","S","TA"]}]},"classical_definitions":null}