بُّونَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصَبُّوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْبُبْنَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَصْبَبْنَ","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَصُبّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصُبّ","in_corpus":true,"count":26,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصَبّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَصَبّ","in_corpus":true,"count":26,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"صَبِبْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَبِبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صَبَبْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"صَبَبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":300,"cross_references":{"qac":{"found":true,"lemma_key":"صَبّ","root":"صبب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n23601"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D8%A8%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pour out, to shed","examples":[{"text":"مَنِ ٱسْتَمَعَ إِلَى حَدِيثِ قَوْمٍ وَهُمْ لَهُ كَارِهُونَ أَوْ يَفِرُّونَ مِنْهُ، صُبَّ فِي أُذُنِهِ الآنُكُ يَوْمَ الْقِيَامَةِ.","english":"If somebody eavesdrops on a conversation of a party who disapproves or flees this molten lead will be poured into his ears on the Day of Resurrection."}]},{"pos":"verb","gloss":"to be poured out, to flow","examples":[{"text":"يَصُبُّ نَهْرُ ٱلنِّيلِ فِي ٱلْبَحْرِ ٱلْأَبْيَضِ ٱلْمُتَوَسِّطِ","english":"The river Nile flows into the Mediterranean Sea."}]},{"pos":"verb","gloss":"to descend, to trickle down"},{"pos":"verb","gloss":"to embogue, to flow into, to undergo discharge into","examples":[{"text":"وأشار إلى أنه \"لايستبعد معارضة بعض الأطراف الكردية لهذا المشروع، لأنها تريد إبقاء لقمة عيش الناس بيدها وتستثمرها للابتزاز وكسب الولاء تبعا لمصالحها الحزبية\"، مستبعدا، \"الحل العاجل للأزمة بين بغداد وأربيل، ذلك أن حكومتي بغداد والإقليم غير جادتين في إيجاد حلول للأزمة، فبغداد تبحث عن مختلف الذرائع لكسر إرادة الإقليم، وتعتقد حكومة الإقليم أن حل الأزمة يضرّ بمصالحها الحزبية الضيقة وتريد لها أن تطول لأبعد وقت، لأنها تعتقد أن ذلك يصب في مصلحتها\".","english":"And he [زانا سعيد (Zānā Saʿīd), deputee of the Kurdistan Islamic Group] pointed out that “opposition of a part of the Kurdish parties for this bill is not excluded, because they want to keep the livelihood of the people in their hand, and exploit it for plundering and gaining loyality to their party interests”, excluding ”the needful solution for the crisis between Baġdād and ʾArbīl, this because the two governments of Baġdād and ʾArbīl aren’t big-hearted in finding solutions for the crisis, and Baġdād is seeking various pretexts for crushing the will of the region, and the territorial government believes that a solution of the crisis damages the narrow party interests and wants for it that it peruses a longer lapse of time, because it believes that this slots into their interest.”"}]},{"pos":"verb","gloss":"to be affected by desire, to love heavily and suddenly"},{"pos":"noun","gloss":"remnant, portion, residue in a vessel"},{"pos":"noun","gloss":"verbal noun of صَبَّ (ṣabba) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23601","headword_ar":"صَبَّ","root":"Sb","body":[{"kind":"text","text":", (S, M, Msb, K, &, c.,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Sab~N","text_ar":"صَبٌّ"},{"kind":"text","text":", (M, Msb,)"},{"kind":"italic_en","text":"He poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth"},{"kind":"text","text":"(S, M, Msb, K) water (S, M, Msb) and the like. (M.) One says,"},{"kind":"arabic","text_bw":"Sababotu lifulaAnK maA='F fiY AlqadaHi liya$orabahu","text_ar":"صَبَبْتُ لِفُلَانٍ مَا=ءً فِى القَدَحِ لِيَشْرَبَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I poured out for such a one water into the drinkingcup that he might drink it"},{"kind":"text","text":"]. (TA. [See also 8.]) ―         -b2-  Hence [(assumed tropical:)"},{"kind":"italic_en","text":"He paid down"},{"kind":"text","text":"a price, or sum of money:] it is said in a trad.,"},{"kind":"arabic","text_bw":"A_ino A^aHab~a A^aholuka A^ano","text_ar":"اـِنْ اَحَبَّ اَهْلُكَ اَنْ"},{"kind":"arabic","text_bw":"waAHidapF","text_ar":"وَاحِدَةً"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aSab~a lahumo vamanaka Sub~apF","text_ar":"اَصَبَّ لَهُمْ ثَمَنَكَ صُبَّةً","orth_type":"arrow"},{"kind":"text","text":", meaning [(assumed tropical:)"},{"kind":"italic_en","text":"If thy family like that I should pay down to them thy price"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"at once,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"at one time."},{"kind":"text","text":"(L, TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Sab~a AlHabola fiY Albiy^ori","text_ar":"صَبَّ الحَبْلَ فِى البِيْرِ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"He lowered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"let down, the rope into the well"},{"kind":"text","text":"] on the occasion of drawing water. (M in art."},{"kind":"arabic","text_bw":"tl","text_ar":"تل"},{"kind":"text","text":".) ―         -b4-  And"},{"kind":"arabic","text_bw":"lamo yaSub~a raA^osahu","text_ar":"لَمْ يَصُبَّ رَاْسَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He did not bend down his head:"},{"kind":"text","text":"occurring in a trad. relating to prayer. (T, TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"Sub~a","text_ar":"صُبَّ"},{"kind":"arabic","text_bw":"rijolaA fulaAnK fiY Alqayodi","text_ar":"رِجْلَا فُلَانٍ فِى القَيْدِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The legs of such a one were"},{"kind":"text","text":"["},{"kind":"italic_en","text":"put into the shackles,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"shackled."},{"kind":"text","text":"(Z, L, TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"Sab~a diroEahu","text_ar":"صَبَّ دِرْعَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He put on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clad himself with, his coat of mail:"},{"kind":"text","text":"(A, TA:) and"},{"kind":"arabic","text_bw":"SababotuhaA Ealayohi","text_ar":"صَبَبْتُهَا عَلَيْهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I put it on him"},{"kind":"text","text":"]. (A.) ―         -b7-  And"},{"kind":"arabic","text_bw":"Sab~a Ealayohi nafosahu","text_ar":"صَبَّ عَلَيْهِ نَفْسَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He threw himself upon him"},{"kind":"text","text":"]. (A.) ―         -b8-  And"},{"kind":"arabic","text_bw":"huwa yaSub~u A_ilaY~a Alxayora","text_ar":"هُوَ يَصُبُّ اـِلَىَّ الخَيْرَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He pours forth to me wealth"},{"kind":"text","text":"]. (A, TA.) ―         -b9-  And"},{"kind":"arabic","text_bw":"Sab~a A@ll~`hu Ealayohimo sawoTa","text_ar":"صَبَّ ا@للّٰهُ عَلَيْهِمْ سَوْطَ"},{"kind":"arabic","text_bw":"Ea*aAbK","text_ar":"عَذَابٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"God poured upon them a portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a share,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severity, of punishment;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"God punished them."},{"kind":"text","text":"(A, * TA. [See also"},{"kind":"arabic","text_bw":"sawoTN","text_ar":"سَوْطٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"Sab~a A@ll~`hu Ealayohi SaAEiqapF","text_ar":"صَبَّ ا@للّٰهُ عَلَيْهِ صَاعِقَةً"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"God poured upon him a thunderbolt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a destructive punishment,"},{"kind":"text","text":"&c.]. (A, TA.) See also another ex. voce"},{"kind":"arabic","text_bw":"Sab~N","text_ar":"صَبٌّ"},{"kind":"text","text":". ―         -b10-  And"},{"kind":"arabic","text_bw":"Sub~a","text_ar":"صُبَّ"},{"kind":"text","text":", (K, TA,) in the pass. form, said of a man, and of a thing, (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was annihilated, caused to pass away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"done away with."},{"kind":"text","text":"(K, TA. [See also R. Q. 2.])       -A2-  See also 7, with which it is syn. in the first of the senses assigned to the latter below. ―         -b2-  [Hence, app.,]"},{"kind":"arabic","text_bw":"Sab~a fiY AlwaAdiY","text_ar":"صَبَّ فِى الوَادِى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He descended into the valley."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"qadamaAhu fiY baToni","text_ar":"قَدَمَاهُ فِى بَطْنِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AinoSab~ato","text_ar":"اِنْصَبَّتْ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlwaAdiY","text_ar":"الوَادِى"},{"kind":"text","text":", occurring in a trad., means (assumed tropical:)"},{"kind":"italic_en","text":"His feet descended"},{"kind":"text","text":"["},{"kind":"italic_en","text":"into the interior,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bottom, of the valley"},{"kind":"text","text":"]: (TA:) or"},{"kind":"arabic","text_bw":"AnoSab~ato qadamaAhu fiY AlwaAdiY","text_ar":"انْصَبَّتْ قَدَمَاهُ فِى الوَادِى"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"his feet rested in the valley;"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"AinoSab~a","text_ar":"اِنْصَبَّ"},{"kind":"text","text":"said of water. (Mgh.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Sab~ati AlHay~apu EalaY","text_ar":"صَبَّتِ الحَيَّةُ عَلَى"},{"kind":"arabic","text_bw":"Almaloduwgi","text_ar":"المَلْدُوغِ"},{"kind":"text","text":", (S, * TA,) or ↓"},{"kind":"arabic","text_bw":"AnSb~t","text_ar":"انصبّت","orth_type":"arrow"},{"kind":"text","text":", (A,) (tropical:)  ["},{"kind":"italic_en","text":"The serpent darted down upon the"},{"kind":"text","text":"person"},{"kind":"italic_en","text":"bitten"},{"kind":"text","text":"by it], said of the serpent when it has raised itself desiring to bite. (Ez-Zuhree, S, TA. *) And"},{"kind":"arabic","text_bw":"AlbaAziY EalaY AlS~ayodi","text_ar":"البَازِى عَلَى الصَّيْدِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnSb~","text_ar":"انصبّ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The hawk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falcon, stooped upon the prey,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarry"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"Sab~a *uw^aAlapu EalaY ganami fulaAnK","text_ar":"صَبَّ ذُوَالَةُ عَلَى غَنَمِ فُلَانٍ"},{"kind":"text","text":"(A, * TA) (tropical:)"},{"kind":"italic_en","text":"The wolf"},{"kind":"text","text":"["},{"kind":"italic_en","text":"rushed upon"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"made havock among the sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, of such a one."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"Sab~a","text_ar":"صَبَّ"},{"kind":"text","text":", (IAar, A, TA,) sec. pers."},{"kind":"arabic","text_bw":"Sabibota","text_ar":"صَبِبْتَ"},{"kind":"text","text":", (S, M, * K,) aor."},{"kind":"arabic","text_bw":"yaSab~u","text_ar":"يَصَبُّ"},{"kind":"text","text":", (IAar, TA,) inf. n."},{"kind":"arabic","text_bw":"SabaAbapN","text_ar":"صَبَابَةٌ"},{"kind":"text","text":", (IAar, S, * M, A, K, * TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with excessive love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with attachment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admiring love,"},{"kind":"text","text":"(IAar, S, TA,) and"},{"kind":"italic_en","text":"desire:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"with desire:"},{"kind":"text","text":"(M, A, K:) or"},{"kind":"italic_en","text":"with tenderness of desire,"},{"kind":"text","text":"(S, M, A, K,) and"},{"kind":"italic_en","text":"ardour thereof:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"with tenderness of love."},{"kind":"text","text":"(M, K.) One says,"},{"kind":"arabic","text_bw":"Sabibotu A_ilayohi","text_ar":"صَبِبْتُ اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with excessive love,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for him"},{"kind":"text","text":"]. (M, A, * TA. *) And"},{"kind":"arabic","text_bw":"Sab~a bihaA","text_ar":"صَبَّ بِهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_ilayohaA","text_ar":"اـِلَيْهَا"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehement desire,"},{"kind":"text","text":"[&c.,]"},{"kind":"italic_en","text":"of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, her."},{"kind":"text","text":"(MA.) ―         -b2-  Lh mentions, among what is said by the women of the Arabs of the desert on the occasion of fascinating by means of charms,"},{"kind":"arabic","text_bw":"faA@Sobabo A_ilayohi","text_ar":"فَا@صْبَبْ اـِلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Sab~N","text_ar":"صَبٌّ","orth_type":"arrow"},{"kind":"text","text":", i. e."},{"kind":"arabic","text_bw":"A^ariqN faA^oraqo A_ilayohi","text_ar":"اَرِقٌ فَاْرَقْ اـِلَيْهِ"},{"kind":"text","text":"[as though meaning May he be"},{"kind":"italic_en","text":"sleepless"},{"kind":"text","text":"by reason of love,"},{"kind":"italic_en","text":"and I will be sleepless for him:"},{"kind":"text","text":"but I incline to think that the explanation has been corrupted by a copyist from"},{"kind":"arabic","text_bw":"raq~a faA^ariq~a A_ilayohi","text_ar":"رَقَّ فَاَرِقَّ اـِلَيْهِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"may he be tender-hearted"},{"kind":"text","text":"to me,"},{"kind":"italic_en","text":"and I will be tenderhearted to him"},{"kind":"text","text":"]. (M, L, TA.)"}],"source_refs":["M","Msb","S","K","A","TA","IAar"]}]}}