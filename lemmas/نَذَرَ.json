,"num":"d"},{"role":"present_3fd","form":"تَنْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْذُرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْذُرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْذُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْذُرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْذُرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"نَذَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَذَرْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْذِر","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْذِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَنْذُر","in_corpus":true,"count":4,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْذُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":47,"cross_references":{"qac":{"found":true,"lemma_key":"نَذَرَ","root":"نذر","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":11,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":13},"lanes":{"found":true,"entry_ids":["n39618","n39619","n39620"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%B0%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to vow, to pledge","examples":[{"text":"إِنِّي نَذَرْتُ لِلرَّحْمَٰنِ صَوْمًا فَلَنْ أُكَلِّمَ الْيَوْمَ إِنسِيًّا","english":"Lo! I have vowed a fast unto the Beneficent, and may not speak today to any mortal."}]},{"pos":"verb","gloss":"to devote one's son to the service of God"},{"pos":"verb","gloss":"to place in front of a combat"},{"pos":"verb","gloss":"to see the danger, to see through the intentions of an enemy and be on one's guard"},{"pos":"verb","gloss":"to make a vow to, profess before, profess a belief"},{"pos":"noun","gloss":"a vow; verbal noun of نَذَرَ (naḏara, “to vow, to warn”) (form I)"},{"pos":"noun","gloss":"anything consecrated to God","tags":["broadly"]},{"pos":"noun","gloss":"pious gift; present to superiors","tags":["broadly"]},{"pos":"noun","gloss":"pious gift; mulct for wounds","tags":["broadly"]},{"pos":"noun","gloss":"warning, admonition, threat, irregular verbal noun of أَنْذَرَ (ʔanḏara) (form IV)","examples":[{"text":"وَلَقَدْ جَاءَ آلَ فِرْعَوْنَ النُّذُرُ كَذَّبُوا بِآيَاتِنَا","english":"And warning came to the house of the Pharaoh that they reproved."}]},{"pos":"noun","gloss":"plural of نَذْر (naḏr)","tags":["form-of","plural"]},{"pos":"noun","gloss":"plural of نَذِير (naḏīr)","tags":["form-of","plural"]},{"pos":"noun","gloss":"verbal noun of نَذِرَ (naḏira) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Akin to Aramaic נִדְרָא (niḏrā), Classical Syriac ܢܕܪܐ (neḏrā), Hebrew נֶדֶר (néḏer), Punic 𐤍𐤃𐤓 (ndr) and Ugaritic 𐎐𐎄𐎗 (ndr). It is argued that the sense vow is influenced from Jewish and Christian usage in Aramaic and Hebrew, the sense of “warning” as in أَنْذَرَ (ʔanḏara) and its verbal noun نُذُر (nuḏur) being more particular to Arabic, so the original meaning of the base stem needs to have been “to take heed”.\n\nSee the etymology of the corresponding lemma form."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39618","headword_ar":"نَذْرٌ","root":"n*r","body":[{"kind":"italic_en","text":"A vow, which a man makes to be binding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, on himself;"},{"kind":"text","text":"(T, M, * K, * TA;) [either"},{"kind":"italic_en","text":"absolutely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"conditionally:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"na*ara","text_ar":"نَذَرَ"},{"kind":"text","text":":)] pl."},{"kind":"arabic","text_bw":"nu*uwrN","text_ar":"نُذُورٌ"},{"kind":"text","text":": (S, M, K: *) and in the following verse of Ibn-Ahmar, some say that"},{"kind":"arabic","text_bw":"nu*ur","text_ar":"نُذُر"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"na*orN","text_ar":"نَذْرٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"ruhunN","text_ar":"رُهُنٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"rahonN","text_ar":"رَهْنٌ"},{"kind":"text","text":"; but others say that it is pl. of"},{"kind":"arabic","text_bw":"na*iyrN","text_ar":"نَذِيرٌ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"mano*uwrN","text_ar":"مَنْذُورٌ"},{"kind":"text","text":":"},{"kind":"quote","text":"kamo duwna layolaY mino tanuwfiy~apK\n                      \n                     \n                        lam~aAEapK tuno*aru fiyhaA Aln~u*uro"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How many a waterless desert glistening with the mirage, in which vows,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"things vowed, are vowed, lie in the way to Leylà!"},{"kind":"text","text":"]. (S.) ―         -b2-  Also, (tropical:)  The"},{"kind":"italic_en","text":"mulct for an intentional wound;"},{"kind":"text","text":"used in this sense by Esh-Sháfi'ee, (T, TA,) and of the dial. of El-Hijáz; (TA;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^aro$N","text_ar":"اَرْشٌ"},{"kind":"text","text":", (T, A, K, TA,) which is of the dial. of the people of El-'Irák: (T, TA:) pl."},{"kind":"arabic","text_bw":"nu*uwrN","text_ar":"نُذُورٌ"},{"kind":"text","text":": (T, A, K:) said by Aboo-Nahshal to be"},{"kind":"italic_en","text":"only for wounds, small and great."},{"kind":"text","text":"(T, K. *) You say,"},{"kind":"arabic","text_bw":"liY qibala fulaAnK na*orN","text_ar":"لِى قِبَلَ فُلَانٍ نَذْرٌ"},{"kind":"text","text":", (T, TS, L,) or"},{"kind":"arabic","text_bw":"Einoda fulaAnK","text_ar":"عِنْدَ فُلَانٍ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"A mulct for a wound is owed to me."},{"kind":"text","text":"(T, K, &c.) And"},{"kind":"arabic","text_bw":"A^aEoTayotuhu na*ora juroHihi","text_ar":"اَعْطَيْتُهُ نَذْرَ جُرْحِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I gave him the mulct for his wound."},{"kind":"text","text":"(A.) Aboo-Sa'eed Ed-Dareer says that it is thus called"},{"kind":"arabic","text_bw":"liA^an~ahu nu*ira fiyhi","text_ar":"لِاَنَّهُ نُذِرَ فِيهِ"},{"kind":"text","text":", i. e., because it is made binding, or obligatory, for it; [namely, for the wound;] from the phrase"},{"kind":"arabic","text_bw":"na*arotu ElaY nafosiY","text_ar":"نَذَرْتُ علَى نَفْسِى"},{"kind":"text","text":". (T, TA.) ―         -b3-  ["},{"kind":"italic_en","text":"A votive offering"},{"kind":"text","text":"].       -A2-  See also"},{"kind":"arabic","text_bw":"nu*orN","text_ar":"نُذْرٌ"},{"kind":"text","text":"."}],"source_refs":["T","TA","A","K","TS","L"]},{"entry_id":"n39619","headword_ar":"نُذْرٌ","root":"n*r","body":[{"kind":"text","text":"(M) and ↓"},{"kind":"arabic","text_bw":"nu*urN","text_ar":"نُذُرٌ","orth_type":"arrow"},{"kind":"text","text":"(T, S, K) [and ↓"},{"kind":"arabic","text_bw":"na*orN","text_ar":"نَذْرٌ","orth_type":"arrow"},{"kind":"text","text":"(see 4)] and ↓"},{"kind":"arabic","text_bw":"na*iyrN","text_ar":"نَذِيرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M) and ↓"},{"kind":"arabic","text_bw":"na*iyrapN","text_ar":"نَذِيرَةٌ","orth_type":"arrow"},{"kind":"text","text":"(M) and ↓"},{"kind":"arabic","text_bw":"ni*aArapN","text_ar":"نِذَارَةٌ","orth_type":"arrow"},{"kind":"text","text":"(Esh-Sháfi'ee, K) and ↓"},{"kind":"arabic","text_bw":"nu*oraY","text_ar":"نُذْرَى","orth_type":"arrow"},{"kind":"text","text":"(K) are substs. in the sense of"},{"kind":"arabic","text_bw":"A_ino*aArN","text_ar":"اـِنْذَارٌ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"An informing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"advising, of a thing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a warning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cautioning, and putting one on his guard, against a thing, and putting one in fear of a thing;"},{"kind":"text","text":"&c.: (see 4:)] (T, S, M, K:) or"},{"kind":"italic_en","text":"a putting one in fear in announcing a thing."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"Eu*orFA","text_ar":"عُذْرًا"},{"kind":"arabic","text_bw":"A^awo nu*orFA","text_ar":"اَوْ نُذْرًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Eu*urFA A^awo nu*urFA","text_ar":"عُذُرًا اَوْ نُذُرًا"},{"kind":"text","text":", accord. to different readings, in the Kur, lxxvii. 6, put in the accus. case as causal complements, signify"},{"kind":"arabic","text_bw":"liloA_iEo*aAri","text_ar":"لِلْاـِعْذَارِ"},{"kind":"arabic","text_bw":"waA@loA_ino*aAri","text_ar":"وَا@لْاـِنْذَارِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"For excusing and warning"},{"kind":"text","text":"]. (Zj, T.) [See also art."},{"kind":"arabic","text_bw":"E*r","text_ar":"عذر"},{"kind":"text","text":".] And in like manner, ↓"},{"kind":"arabic","text_bw":"nu*uri","text_ar":"نُذُرِ","orth_type":"arrow"},{"kind":"text","text":", in the Kur, liv. 16, &c., signifies"},{"kind":"arabic","text_bw":"A_ino*aAriY","text_ar":"اـِنْذَارِى"},{"kind":"text","text":". (S, K.) And so ↓"},{"kind":"arabic","text_bw":"na*iyri","text_ar":"نَذِيرِ","orth_type":"arrow"},{"kind":"text","text":", in the Kur, lxvii. 17. (T, M.) Hence also the saying of the Arabs,"},{"kind":"arabic","text_bw":"Eu*oraAka laA","text_ar":"عُذْرَاكَ لَا"},{"kind":"arabic","text_bw":"nu*oraAka","text_ar":"نُذْرَاكَ"},{"kind":"text","text":", meaning,"},{"kind":"arabic","text_bw":"A^aEo*iru walaA tuno*iro","text_ar":"اَعْذِرُ وَلَا تُنْذِرْ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Do thou that for which thou wilt be excused,"},{"kind":"text","text":"by inflicting punishment when it is deserved,"},{"kind":"italic_en","text":"and do not"},{"kind":"text","text":"merely"},{"kind":"italic_en","text":"warn and put in fear"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["M","T","S","K"]},{"entry_id":"n39620","headword_ar":"نُذُرٌ","root":"n*r","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"nu*orN","text_ar":"نُذْرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}