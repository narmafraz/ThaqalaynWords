us":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَطْهُرُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَطْهُرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَطْهُرْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَطْهُر","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَطْهُر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"طَهَرْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَهَرْتُ","in_corpus":true,"count":90,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"طَهُرْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"طَهُرْتُ","in_corpus":true,"count":90,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":983,"cross_references":{"qac":{"found":true,"lemma_key":"طَهَرَ","root":"طهر","pos":"V","occurrence_count":9},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27212"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D9%8E%D9%87%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become pure"},{"pos":"verb","gloss":"to purify"},{"pos":"verb","gloss":"to circumcise"}]},"etymology":{"source":"wiktextract","text":"From the root ط ه ر (ṭ h r). Cognate with Biblical Hebrew טהר (taher, “to be clean, to be pure”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27212","headword_ar":"طَهَرَ","root":"Thr","body":[{"kind":"text","text":", (S, A, Msb, K,) aor. of each"},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"TahaArapN","text_ar":"طَهَارَةٌ"},{"kind":"text","text":", (S, Msb, K,) which is of each verb, (S, Msb,) and"},{"kind":"arabic","text_bw":"TuhorN","text_ar":"طُهْرٌ"},{"kind":"text","text":", (Sb, K,) or the latter is a simple subst., (S, Msb,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, clean, free from dirt"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"filth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pure."},{"kind":"text","text":"(A, * Msb, K. *)"},{"kind":"arabic","text_bw":"ThArp","text_ar":"طهارة"},{"kind":"text","text":"is of two kinds; [properly] corporeal and [tropically] spiritual. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Taharato","text_ar":"طَهَرَتْ"},{"kind":"text","text":", (M, Mgh, K,) or"},{"kind":"arabic","text_bw":"Taharato mina AlHayoDi","text_ar":"طَهَرَتْ مِنَ الحَيْضِ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"Tahurato","text_ar":"طَهُرَتْ"},{"kind":"text","text":", (M, Msb, K,) which is allowable, (IAar,) but of rare occurrence, (Msb,) and"},{"kind":"arabic","text_bw":"Tahirato","text_ar":"طَهِرَتْ"},{"kind":"text","text":", [which is of more rare occurrence;] (M, El-Isnawee;) inf. n."},{"kind":"arabic","text_bw":"TuhorN","text_ar":"طُهْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TahaArapN","text_ar":"طَهَارَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TuhuwrN","text_ar":"طُهُورٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TahuwrN","text_ar":"طَهُورٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"She was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, pure from the menstrual discharge;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"her discharge of blood stopped."},{"kind":"text","text":"(Mgh, K.) See also 5. The saying,"},{"kind":"arabic","text_bw":"A_in~a Al$~aApa taqo*iY Ea$orFA vum~a taTohuru","text_ar":"اـِنَّ الشَّاةَ تَقْذِى عَشْرًا ثُمَّ تَطْهُرُ"},{"kind":"page_break","n":1887},{"kind":"text","text":"["},{"kind":"italic_en","text":"Verily the ewe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"she-goat, emits a white fluid from her womb during ten"},{"kind":"text","text":"nights,"},{"kind":"italic_en","text":"and then becomes pure,"},{"kind":"text","text":"] is mentioned on the authority of Lh: but ISd says, whether he mentioned this as heard from the Arabs, or did so presumptuously, I know not. (TA.)       -A2-"},{"kind":"arabic","text_bw":"Taharahu","text_ar":"طَهَرَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"TahorN","text_ar":"طَهْرٌ"},{"kind":"text","text":",) (TK,) signifies"},{"kind":"italic_en","text":"He made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused it, to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become, distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aboEadahu","text_ar":"اَبْعَدَهُ"},{"kind":"text","text":": (O, K:) and so"},{"kind":"arabic","text_bw":"TaHarahu","text_ar":"طَحَرَهُ"},{"kind":"text","text":"; (O, TA;) the"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":"being substituted for"},{"kind":"arabic","text_bw":"h","text_ar":"ه"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","A","Msb","K","Sb","M","Mgh","IAar","TK","O"]}]}}