=%D9%87%D9%8E%D8%B1%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to flee, to escape"},{"pos":"verb","gloss":"to desert, to run away"},{"pos":"verb","gloss":"to elope"},{"pos":"verb","gloss":"to help escape"},{"pos":"verb","gloss":"to force to flee"},{"pos":"verb","gloss":"to put to flight"},{"pos":"verb","gloss":"to liberate, to free"},{"pos":"verb","gloss":"to rescue"},{"pos":"verb","gloss":"to smuggle, to traffic illicitly","examples":[{"text":"هَرَّبَ ٱلْمُجْرِمُونَ ٱلْمُخَدِّرَاتِ.","english":"The criminals smuggled drugs."}]},{"pos":"noun","gloss":"verbal noun of هَرَبَ (haraba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"flight, escape, getaway"},{"pos":"noun","gloss":"desertion"},{"pos":"noun","gloss":"elopement"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41093","headword_ar":"هَرَبَ","root":"hrb","body":[{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":"; not"},{"kind":"text","text":", as some have imagined on account of the measure of the first of the following inf. ns., imagining thence also that the pret. is"},{"kind":"arabic","text_bw":"hariba","text_ar":"هَرِبَ"},{"kind":"text","text":"; nor"},{"kind":"text","text":"with the pret."},{"kind":"arabic","text_bw":"haraba","text_ar":"هَرَبَ"},{"kind":"text","text":", as some have supposed because of the guttural letter; for a guttural letter, when it is the first, is not reckoned as having any influence on the form of the aor.; nor"},{"kind":"text","text":", as some have thought; (TA;) inf. n."},{"kind":"arabic","text_bw":"harabN","text_ar":"هَرَبٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"mahorabN","text_ar":"مَهْرَبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"harabaAnN","text_ar":"هَرَبَانٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, or any animal, TA)"},{"kind":"italic_en","text":"fled; ran away."},{"kind":"text","text":"(S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"A_ilayoka minoka Almahorabu","text_ar":"اـِلَيْكَ مِنْكَ المَهْرَبُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"To Thee I flee for refuge from Thee;"},{"kind":"text","text":"i. e., from thy punishment: addressed to God]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"haraba mina Alwatadi","text_ar":"هَرَبَ مِنَ الوَتَدِ"},{"kind":"arabic","text_bw":"niSofuhu","text_ar":"نِصْفُهُ"},{"kind":"italic_en","text":"Half of the wooden pin, peg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stake, disappeared"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the ground"},{"kind":"text","text":"]. (K.)       -A2-"},{"kind":"arabic","text_bw":"hariba","text_ar":"هَرِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"He became extremely aged, old and weak,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decrepit; i. q."},{"kind":"arabic","text_bw":"harima","text_ar":"هَرِمَ"},{"kind":"text","text":"; (K;) of which it is a dial. form. (TA.)"}],"source_refs":["S","K"]}]}}