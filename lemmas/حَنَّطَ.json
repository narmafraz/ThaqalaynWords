i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُحَنِّطُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُحَنِّطْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُحَنِّط","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُحَنِّط","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُحَنِّطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُحَنِّطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُحَنِّطانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَنِّطا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَنِّطُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَنِّطُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَنِّطْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حَنَّطْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَنَّطْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَنِّط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَنِّط","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n9311"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%86%D9%8E%D9%91%D8%B7%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to embalm, mummify"}]},"etymology":null,"ipa":["/ħan.na.tˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9311","headword_ar":"حَنَطَ","root":"HnT","body":[{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"HunuwTN","text_ar":"حُنُوطٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(seed-produce)"},{"kind":"italic_en","text":"attained to the time for its being reaped;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHnT","text_ar":"احنط","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a tree of the kind called"},{"kind":"arabic","text_bw":"rimov","text_ar":"رِمْث"},{"kind":"text","text":")"},{"kind":"italic_en","text":"became mature, and its leaves became white;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHnT","text_ar":"احنط","orth_type":"arrow"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"it became white and mature,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and there came forth upon it a dust-coloured fruit, and what resembled pieces of glue appeared upon its tops;"},{"kind":"text","text":"(TA;) as also"},{"kind":"arabic","text_bw":"HaniTa","text_ar":"حَنِطَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (K, TA;) and ↓"},{"kind":"arabic","text_bw":"AHnT","text_ar":"احنط","orth_type":"arrow"},{"kind":"text","text":": (TA:) [the last, though omitted in the K, seems to be the most common:] or"},{"kind":"italic_en","text":"its colour became white inclining to yellowness, and its odour sweet:"},{"kind":"text","text":"(IAth:) Az relates, on the authority of IAar, that one says,"},{"kind":"arabic","text_bw":"A^aworasa Alr~imovu","text_ar":"اَوْرَسَ الرِّمْثُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AHnT","text_ar":"احنط","orth_type":"arrow"},{"kind":"text","text":"; like"},{"kind":"arabic","text_bw":"xaDaba AlEarofaju","text_ar":"خَضَبَ العَرْفَجُ"},{"kind":"text","text":": and one says, of the"},{"kind":"arabic","text_bw":"rimov","text_ar":"رِمْث"},{"kind":"text","text":", when it first breaks out for its leaves to come forth,"},{"kind":"arabic","text_bw":"qado A^aqomala","text_ar":"قَدْ اَقْمَلَ"},{"kind":"text","text":"; and when it has increased little by little,"},{"kind":"arabic","text_bw":"qado A^adobaY","text_ar":"قَدْ اَدْبَى"},{"kind":"text","text":"; and when its greenness has increased,"},{"kind":"arabic","text_bw":"baqala","text_ar":"بَقَلَ"},{"kind":"text","text":": and when it has become white and mature,"},{"kind":"arabic","text_bw":"HanaTa","text_ar":"حَنَطَ"},{"kind":"text","text":": (TA:) or ↓"},{"kind":"arabic","text_bw":"AHnT","text_ar":"احنط","orth_type":"arrow"},{"kind":"text","text":"is said of a tree, and of a herb, meaning"},{"kind":"italic_en","text":"its fruit became mature;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"HanaTa","text_ar":"حَنَطَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HunuwTN","text_ar":"حُنُوطٌ"},{"kind":"text","text":". (AHn.) ―         -b3-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(leather)"},{"kind":"italic_en","text":"became red."},{"kind":"text","text":"(S, K.) [The inf. n. of the verb in this sense is not mentioned.]       -A2-  See also 2."}],"source_refs":["K","TK","S","TA","IAth"]}]}}