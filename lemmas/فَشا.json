","text_bw":"yafo$uw","text_ar":"يَفْشُو"},{"kind":"text","text":", S,) inf. n."},{"kind":"arabic","text_bw":"fu$uw~N","text_ar":"فُشُوٌّ"},{"kind":"text","text":"(S, MA, Msb, K) and"},{"kind":"arabic","text_bw":"fu$iY~N","text_ar":"فُشِىٌّ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"fa$owN","text_ar":"فَشْوٌ"},{"kind":"text","text":", (Msb, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, Msb, or a secret, MA, or information, news, or tidings, S, K, and a man's beneficence, or bounty, K)"},{"kind":"italic_en","text":"became revealed, disclosed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"divulged,"},{"kind":"text","text":"(S, MA, Msb, K, *) and"},{"kind":"italic_en","text":"spread."},{"kind":"text","text":"(S, * Msb, K.) ―         -b2-  ["},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a saying or the like)"},{"kind":"italic_en","text":"became common;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtained extensively."},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"fa$ati AlmaA$iyapu","text_ar":"فَشَتِ المَاشِيَةُ"},{"kind":"italic_en","text":"The cattle pastured"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at large"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"where they pleased."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"fa$ato DayoEatuhu","text_ar":"فَشَتْ ضَيْعَتُهُ"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"DyE","text_ar":"ضيع"},{"kind":"text","text":",) or"},{"kind":"arabic","text_bw":"fa$ato Ealayohi","text_ar":"فَشَتْ عَلَيْهِ"},{"kind":"arabic","text_bw":"DayoEatuhu","text_ar":"ضَيْعَتُهُ"},{"kind":"text","text":", (TA in the present art.,) or"},{"kind":"arabic","text_bw":"fa$ato Ealayohi","text_ar":"فَشَتْ عَلَيْهِ"},{"kind":"arabic","text_bw":"AlD~ayoEapu","text_ar":"الضَّيْعَةُ"},{"kind":"text","text":", (Ham p. 33,) said to mean"},{"kind":"italic_en","text":"His property was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"widespread,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"so that he was unable to collect it together:"},{"kind":"text","text":"and [hence]"},{"kind":"italic_en","text":"his means of attaining his object,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his affairs, became disordered so that he knew not with which of them to begin:"},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"DyE","text_ar":"ضيع"},{"kind":"text","text":"and in the present art.;) or"},{"kind":"italic_en","text":"he took to doing an affair that did not concern him."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"DyE","text_ar":"ضيع"},{"kind":"text","text":", and Ham p. 33.) ―         -b5-  And"},{"kind":"arabic","text_bw":"fa$ato A^umuwru Aln~aAsi","text_ar":"فَشَتْ اُمُورُ النَّاسِ"},{"kind":"italic_en","text":"The affairs of the people became discomposed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Aifotaraqato","text_ar":"اِفْتَرَقَتْ"},{"kind":"text","text":". (Msb.)"}],"source_refs":["S","MA","Msb","K"]}]}}