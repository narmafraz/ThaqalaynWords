}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24739","headword_ar":"صَلْدٌ","root":"Sld","body":[{"kind":"italic_en","text":"Hard and smooth;"},{"kind":"text","text":"(S, M, A, K;) as also ↓"},{"kind":"arabic","text_bw":"SilodN","text_ar":"صِلْدٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"SaluwdN","text_ar":"صَلُودٌ","orth_type":"arrow"},{"kind":"text","text":"(M) and ↓"},{"kind":"arabic","text_bw":"SaliydN","text_ar":"صَلِيدٌ","orth_type":"arrow"},{"kind":"text","text":"(A) and ↓"},{"kind":"arabic","text_bw":"A^aSoladu","text_ar":"اَصْلَدُ","orth_type":"arrow"},{"kind":"text","text":"; (M;) applied to a stone; (S, M, A;) and so the first applied to land or ground ("},{"kind":"arabic","text_bw":"A^aroD","text_ar":"اَرْض"},{"kind":"text","text":"); (S;) and to a solid hoof, as also ↓"},{"kind":"arabic","text_bw":"SilodimN","text_ar":"صِلْدِمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SulaAdimN","text_ar":"صُلَادِمٌ","orth_type":"arrow"},{"kind":"text","text":", which last is of the measure"},{"kind":"arabic","text_bw":"fuEaAlimN","text_ar":"فُعَالِمٌ"},{"kind":"text","text":"accord. to Kh, but"},{"kind":"arabic","text_bw":"fuEaAlilN","text_ar":"فُعَالِلٌ"},{"kind":"text","text":"accord. to others; (M;) and to a side of the forehead, (S, M,) or thus applied meaning"},{"kind":"italic_en","text":"smooth and tough;"},{"kind":"text","text":"(L;) and to a head, as also ↓"},{"kind":"arabic","text_bw":"SulaAdimN","text_ar":"صُلَادِمٌ","orth_type":"arrow"},{"kind":"text","text":", (M,) or thus applied meaning (tropical:)"},{"kind":"italic_en","text":"upon which no hair grows:"},{"kind":"text","text":"(A:) and ↓"},{"kind":"arabic","text_bw":"SalawodadN","text_ar":"صَلَوْدَدٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) which is of an extr. form, (M,) has the first of the significations above, (K,) or signifies [simply]"},{"kind":"italic_en","text":"hard:"},{"kind":"text","text":"(M:) the pl. of"},{"kind":"arabic","text_bw":"SalodN","text_ar":"صَلْدٌ"},{"kind":"text","text":"(M, L) and of ↓"},{"kind":"arabic","text_bw":"SaluwdN","text_ar":"صَلُودٌ","orth_type":"arrow"},{"kind":"text","text":"(M) is"},{"kind":"arabic","text_bw":"A^aSolaAdN","text_ar":"اَصْلَادٌ"},{"kind":"text","text":". (M, L.) ―         -b2-  Also applied to a place, ("},{"kind":"arabic","text_bw":"makaAnN","text_ar":"مَكَانٌ"},{"kind":"text","text":", M,) and"},{"kind":"arabic","text_bw":"SalodapN","text_ar":"صَلْدَةٌ"},{"kind":"text","text":"applied to land, ("},{"kind":"arabic","text_bw":"A^aroDN","text_ar":"اَرْضٌ"},{"kind":"text","text":", A,) (tropical:)"},{"kind":"italic_en","text":"That produces no plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage."},{"kind":"text","text":"(M, A.) And"},{"kind":"arabic","text_bw":"A^aSolaAdu Aljabiyni","text_ar":"اَصْلَادُ الجَبِينِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The part of the side of the forehead upon which is no hair:"},{"kind":"text","text":"likened to smooth stone. (A Heyth.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"HajarN SalodN","text_ar":"حَجَرٌ صَلْدٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SaluwdN","text_ar":"صَلُودٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A stone that will not emit fire:"},{"kind":"text","text":"(L, TA:) and ↓"},{"kind":"arabic","text_bw":"zanodN SaluwdN","text_ar":"زَنْدٌ صَلُودٌ","orth_type":"arrow"},{"kind":"text","text":"(M, A) and ↓"},{"kind":"arabic","text_bw":"SaAlidN","text_ar":"صَالِدٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Sal~aAdN","text_ar":"صَلَّادٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"miSolaAdN","text_ar":"مِصْلَادٌ","orth_type":"arrow"},{"kind":"text","text":"(M) [and ↓"},{"kind":"arabic","text_bw":"muSolidN","text_ar":"مُصْلِدٌ","orth_type":"arrow"},{"kind":"text","text":"] (tropical:)  ["},{"kind":"italic_en","text":"A piece of stick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wood, for producing fire"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that gives a sound,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"not emitting fire:"},{"kind":"text","text":"(M, A:) and ↓"},{"kind":"arabic","text_bw":"EuwdN Sal~aAdN","text_ar":"عُودٌ صَلَّادٌ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a stick, from which fire cannot be produced."},{"kind":"text","text":"(T, L, K. *) ―         -b4-  And"},{"kind":"arabic","text_bw":"farasN SalodN","text_ar":"فَرَسٌ صَلْدٌ"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"SaluwdN","text_ar":"صَلُودٌ","orth_type":"arrow"},{"kind":"text","text":"(S, M, A, K) (tropical:)"},{"kind":"italic_en","text":"A horse that does not sweat:"},{"kind":"text","text":"(S, A, K:) such a horse is discommended: (K:) or"},{"kind":"italic_en","text":"slow to sweat:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"having little seminal fluid:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"slow in impregnating."},{"kind":"text","text":"(M.) ―         -b5-  And"},{"kind":"arabic","text_bw":"rajulN SalodN","text_ar":"رَجُلٌ صَلْدٌ"},{"kind":"text","text":"(M) and ↓"},{"kind":"arabic","text_bw":"SaluwdN","text_ar":"صَلُودٌ","orth_type":"arrow"},{"kind":"text","text":"(M, A) and ↓"},{"kind":"arabic","text_bw":"A^aSoladu","text_ar":"اَصْلَدُ","orth_type":"arrow"},{"kind":"text","text":"(S, M, A, K) (tropical:)"},{"kind":"italic_en","text":"A niggardly, tenacious, penurious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avaricious, man:"},{"kind":"text","text":"(S, M, K:) or"},{"kind":"italic_en","text":"a man very niggardly"},{"kind":"text","text":"&c. (A.) ―         -b6-  And"},{"kind":"arabic","text_bw":"naAqapN SalodapN","text_ar":"نَاقَةٌ صَلْدَةٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A hardy, strong, enduring she-camel."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"xayolN SilaAdN","text_ar":"خَيْلٌ صِلَادٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Hard, hardy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong, horses."},{"kind":"text","text":"(A.) [And ↓"},{"kind":"arabic","text_bw":"SilodaAmN","text_ar":"صِلْدَامٌ","orth_type":"arrow"},{"kind":"text","text":", also, signifies"},{"kind":"italic_en","text":"Robust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong."},{"kind":"text","text":"(Freytag, from Jereer.)]"}],"source_refs":["K","M","A","S","L","TA"]},{"entry_id":"n24740","headword_ar":"صِلْدٌ","root":"Sld","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"SalodN","text_ar":"صَلْدٌ"},{"kind":"text","text":", first sentence."}],"source_refs":[]}]},"classical_definitions":null}