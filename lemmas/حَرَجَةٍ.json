{"lemma":"حَرَجَةٍ","slug":"حَرَجَةٍ","root":"ح.ر.ج","root_slug":"ح-ر-ج","root_link":"/words/roots/ح-ر-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"حَرَج","root":"حرج","pos":"N","occurrence_count":15},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n7563","n7570"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B1%D9%8E%D8%AC%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be in a critical situation"},{"pos":"verb","gloss":"to be forbidden"},{"pos":"verb","gloss":"to commit a sin, an offense"},{"pos":"verb","gloss":"to embarrass, to hinder"},{"pos":"verb","gloss":"to prohibit"},{"pos":"noun","gloss":"tightness, difficulty, critical situation"},{"pos":"noun","gloss":"constraint, limitation, restriction","examples":[{"text":"بِلَا حَرَجٍ","english":"unhesitatingly (lit. without restriction)"}]},{"pos":"adj","gloss":"tight, close; impenetrable due to denseness of trees or other things"},{"pos":"noun","gloss":"woodlands, woods, forestland","tags":["collective"],"examples":[{"text":"المنبت والزراعة الغلطارية المسطّحة موطنها أمريكا الشمالية، وتوجد في الأحراج والمناطق الجبلية المكشوفة.","english":"The place where the checkerberry grows and is planted is Northern America where it is native, and it is found in woodlands and exposed mountainous regions."}]},{"pos":"noun","gloss":"herds of camels","tags":["collective","obsolete"]}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew חרג (ħarág, “deviate”)."},"ipa":["/ħa.ri.d͡ʒa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7563","headword_ar":"حرّجهُ","root":"Hrj","body":[{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"taHoriyjN","text_ar":"تَحْرِيجٌ"},{"kind":"text","text":", (S, K,) (assumed tropical:)"},{"kind":"italic_en","text":"He made it strait,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult;"},{"kind":"text","text":"(S, K, TA;) and"},{"kind":"italic_en","text":"forbade it to be violated;"},{"kind":"text","text":"namely, a right. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Hr~j EalaY Hay~apK","text_ar":"حرّج عَلَى حَيَّةٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He said to a serpent,"},{"kind":"text","text":"[by way of warning, lest it should be a Jinnee,]"},{"kind":"italic_en","text":"Thou wilt be in a strait if thou return to us; therefore blame us not if we reduce thee to a strait by pursuing and driving away and killing."},{"kind":"text","text":"(TA from a trad.)"}],"source_refs":["TA","S","K"]},{"entry_id":"n7570","headword_ar":"حَرَجَةٌ","root":"Hrj","body":[{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A wood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collection of trees;"},{"kind":"text","text":"(S, K, TA;) so called because of their closeness: or"},{"kind":"italic_en","text":"dense and tangled trees:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"a thicket,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collection of dense and tangled trees, of the kind called"},{"kind":"arabic","text_bw":"salam","text_ar":"سَلَم"},{"kind":"text","text":","},{"kind":"italic_en","text":"into which no one can penetrate;"},{"kind":"text","text":"(AHeyth, Az, TA;) or"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"samur","text_ar":"سَمُر"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"TaloH","text_ar":"طَلْح"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"Eawosaj","text_ar":"عَوْسَج"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"salam","text_ar":"سَلَم"},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"sidor","text_ar":"سِدْر"},{"kind":"text","text":"; or"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"sidor","text_ar":"سِدْر"},{"kind":"italic_en","text":"and olive and other trees:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a place in a wood where trees are dense and tangled, extending as far as a stone's throw:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"a tree which the pasturing animals cannot reach:"},{"kind":"text","text":"(TA:) pl. ↓"},{"kind":"arabic","text_bw":"HarajN","text_ar":"حَرَجٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K) [or rather this is a coll. gen. n., of which"},{"kind":"arabic","text_bw":"HarajapN","text_ar":"حَرَجَةٌ"},{"kind":"text","text":"is the n. un.,] and"},{"kind":"arabic","text_bw":"HarajaAtN","text_ar":"حَرَجَاتٌ"},{"kind":"text","text":"(S, A) and"},{"kind":"arabic","text_bw":"HiraAjN","text_ar":"حِرَاجٌ"},{"kind":"text","text":"(S) and [of pauc.]"},{"kind":"arabic","text_bw":"A^aHoraAjN","text_ar":"اَحْرَاجٌ"},{"kind":"text","text":": (A, TA:) or ↓"},{"kind":"arabic","text_bw":"HarajN","text_ar":"حَرَجٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a place in which is a collection of trees, and where they are close together."},{"kind":"text","text":"(A.) ―         -b2-  Also (tropical:)"},{"kind":"italic_en","text":"A collection of camels:"},{"kind":"text","text":"(S, K, TA:)"},{"kind":"italic_en","text":"a hundred camels:"},{"kind":"text","text":"(ISd, TA:) pl. [or rather coll. gen. n.] ↓"},{"kind":"arabic","text_bw":"HarajN","text_ar":"حَرَجٌ","orth_type":"arrow"},{"kind":"text","text":". (K.)"}],"source_refs":["TA","S","K","A","ISd"]}]},"classical_definitions":null}