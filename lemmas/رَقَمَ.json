,"gen":"m","num":"p"},{"role":"present_2mp","form":"تَرْقُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْقُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْقُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْقُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْقُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْقُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْقُما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْقُمانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْقُمُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْقُمُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْقُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"رَقَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رَقَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَرْقُم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرْقُم","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n16395"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%82%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"numeral, number, figure"},{"pos":"noun","gloss":"rate"},{"pos":"noun","gloss":"record"},{"pos":"noun","gloss":"embroidery, variegation on a cloth; and the cloth itself","tags":["archaic"]},{"pos":"noun","gloss":"verbal noun of رَقَمَ (raqama) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to imprint, to mark, to dot","tags":["archaic"]},{"pos":"verb","gloss":"to variegate, to figure, to decorate","tags":["archaic"]},{"pos":"verb","gloss":"to furnish with distinguishing marks, to add interpunction, diacritics or the like","tags":["archaic"]},{"pos":"verb","gloss":"to furnish with numbers, to paginate, to catalogue and the like","tags":["archaic"]}]},"etymology":null,"ipa":["/raqm/","/ra.qam/","/rə.qəm/","/ra.ɡim/","/ra.ɡam/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16395","headword_ar":"رَقَمَ","root":"rqm","body":[{"kind":"text","text":", (Msb, K,) aor."},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"raqomN","text_ar":"رَقْمٌ"},{"kind":"text","text":", (S, Msb, TA,)"},{"kind":"italic_en","text":"He wrote"},{"kind":"text","text":"(S, Msb, K) a writing, book, or letter. (Msb.) And"},{"kind":"italic_en","text":"He sealed, stamped, imprinted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impressed."},{"kind":"text","text":"(S, TA.) And"},{"kind":"arabic","text_bw":"raqama AliktaAba","text_ar":"رَقَمَ الِكتَابَ"},{"kind":"text","text":", (K,) inf. n. as above, (JK,)"},{"kind":"italic_en","text":"He marked the writing with the dots,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"points,"},{"kind":"text","text":"(JK, K, TA,)"},{"kind":"italic_en","text":"and made its letters distinct,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plain."},{"kind":"text","text":"(K, * TA.) One says,"},{"kind":"arabic","text_bw":"huwa yaroqumu AlmaA='a","text_ar":"هُوَ يَرْقُمُ المَا=ءَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"huwa yaroqumu fiY AlmaA='i","text_ar":"هُوَ يَرْقُمُ فِى المَا=ءِ"},{"kind":"text","text":", (JK, TA,) ["},{"kind":"italic_en","text":"He writes,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"upon the water,"},{"kind":"text","text":"] a prov., applied to the skilful and intelligent, (JK, * TA,) meaning he is so skilful that he writes, &c., ("},{"kind":"arabic","text_bw":"yaroqumu","text_ar":"يَرْقُمُ"},{"kind":"text","text":") where the writing, &c., ("},{"kind":"arabic","text_bw":"Alr~aqomu","text_ar":"الرَّقْمُ"},{"kind":"text","text":",) will not remain fixed. (JK, S, TA.) And one says of a skilful workwoman, clever in sewing skins and the like,"},{"kind":"arabic","text_bw":"hiYa taroqumu AlmaA='a","text_ar":"هِىَ تَرْقُمُ المَا=ءَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taroqumu fiY AlmaA='i","text_ar":"تَرْقُمُ فِى المَا=ءِ"},{"kind":"text","text":". (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"raqama Alv~awoba","text_ar":"رَقَمَ الثَّوْبَ"},{"kind":"text","text":", (S, Mgh, Msb, K,) aor. as above, (JK, Msb,) and so the inf. n.; (Msb, TA;) and ↓"},{"kind":"arabic","text_bw":"rq~mhu","text_ar":"رقّمهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"taroqiymN","text_ar":"تَرْقِيمٌ"},{"kind":"text","text":"; (S, TA;)"},{"kind":"italic_en","text":"He figured, variegated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decorated, the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth;"},{"kind":"text","text":"(Mgh, Msb, TA;) and (TA)"},{"kind":"italic_en","text":"made it striped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marked it with stripes:"},{"kind":"text","text":"(K, TA:) or, accord. to IF,"},{"kind":"italic_en","text":"he figured it, variegated it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decorated it, with a certain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"known, figuring"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"variegation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"decoration, such as became a mark"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thereof"},{"kind":"text","text":"]. (Msb.) Also the former phrase, (JK, Mgh, TA,) and ↓ the latter likewise, (TA,) said of a trader, or dealer, (JK, Mgh,)"},{"kind":"italic_en","text":"He marked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put a mark on, the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth,"},{"kind":"text","text":"(JK, Mgh, TA,)"},{"kind":"italic_en","text":"specifying its price; he put a price-mark upon it:"},{"kind":"text","text":"(Mgh:) whence,"},{"kind":"arabic","text_bw":"laA yajuwzu bayoEu Al$~aYo'i biraqomihi","text_ar":"لَا يَجُوزُ بَيْعُ الشَّىْءِ بِرَقْمِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The sale of the thing by the putting a price-mark upon it shall not be allowable,"},{"kind":"text","text":"because the express consent of the seller as well as that of the purchaser is necessary to the ratification of the sale]: (Mgh:) [or]"},{"kind":"arabic","text_bw":"raqamotu Al$~aYo'a","text_ar":"رَقَمْتُ الشَّىْءَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"I marked the thing so as to distinguish it from other things, as, for instance, by writing"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"and hence,"},{"kind":"arabic","text_bw":"laA yubaAEu Alv~awobu","text_ar":"لَا يُبَاعُ الثَّوْبُ"},{"kind":"arabic","text_bw":"biraqomihi walaA bilamosihi","text_ar":"بِرَقْمِهِ وَلَا بِلَمْسِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, shall not be sold by the putting a price-mark upon it,"},{"kind":"text","text":"for the reason explained above,"},{"kind":"italic_en","text":"nor by the feeling it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"touching it:"},{"kind":"text","text":"see 3 in art."},{"kind":"arabic","text_bw":"lms","text_ar":"لمس"},{"kind":"text","text":"]. (Msb.) ―         -b3-  [Hence,]"},{"kind":"arabic","text_bw":"huwa yaziydu fiY Alr~aqomi","text_ar":"هُوَ يَزِيدُ فِى الرَّقْمِ"},{"kind":"text","text":"is a phrase used by the relaters of traditions as meaning (assumed tropical:)"},{"kind":"italic_en","text":"He adds to his tradition, and lies:"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Alr~aqomu","text_ar":"الرَّقْمُ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"the writing"},{"kind":"text","text":"upon a garment, or piece of cloth. (TA.) ―         -b4-  You say also,"},{"kind":"arabic","text_bw":"raqama AlbaEiyra","text_ar":"رَقَمَ البَعِيرَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He cauterized the camel."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"raqama Alfarasa","text_ar":"رَقَمَ الفَرَسَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a farrier)"},{"kind":"italic_en","text":"marked the horse, making lines upon him, with a hot iron:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"maroquwmN","text_ar":"مَرْقُومٌ"},{"kind":"text","text":", and see also"},{"kind":"arabic","text_bw":"jaAEirapN","text_ar":"جَاعِرَةٌ"},{"kind":"text","text":".]"},{"kind":"page_break","n":1139}],"source_refs":["Msb","K","TA","S","JK","Mgh"]}]},"classical_definitions":null}