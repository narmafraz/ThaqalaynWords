{"lemma":"رَغِبَ","slug":"رَغِبَ","root":"ر.غ.ب","root_slug":"ر-غ-ب","root_link":"/words/roots/ر-غ-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"رَغِبْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"رَغِبْتِ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"رَغِبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"رَغِبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"رَغِبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"رَغِبَ","in_corpus":true,"count":11,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"رَغِبَت","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"رَغِبا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"رَغِبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"رَغِبُوا","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"رَغِبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَرْغَب","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَرْغَبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَرْغَبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَرْغَبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَرْغَبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَرْغَبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَرْغَبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَرْغَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَرْغَب","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرْغَب","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرْغَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرْغَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرْغَبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرْغَبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرْغَبُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرْغَبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرْغَبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رَغِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رَغِبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرْغَب","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرْغَب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":45,"cross_references":{"qac":{"found":true,"lemma_key":"رَغِبَ","root":"رغب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n15969"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%BA%D9%90%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to desire, to seek","examples":[{"text":"يَجِبُ أَنْ يَكُونَ لَدَى ٱلْمُشَارِكِينَ حِسَابُ بَرِيدٍ إِلِكْتْرُونِيٍّ نَشِطٍ، إِذَا رَغِبَ ٱلْمُنَظَّمُونَ فِي ٱلاِتِّصَالِ.","english":"Participants must have an active email account, if the organizers wish to contact."}]},{"pos":"verb","gloss":"to have an aversion for, to dislike, not to desire"},{"pos":"verb","gloss":"to be greedy, to be gluttonous"},{"pos":"verb","gloss":"to become wide and filled with water (of a wadi, i.e. dry river or gulch)"},{"pos":"verb","gloss":"to become soft (of the land)"}]},"etymology":{"source":"wiktextract","text":"Related to Hebrew רָעַב (ra'áv, “to be hungry”)."},"ipa":["/ra.ɣi.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15969","headword_ar":"رَغِبَ","root":"rgb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ragobapN","text_ar":"رَغْبَةٌ"},{"kind":"text","text":"(JK, TA) and"},{"kind":"arabic","text_bw":"ragobaY","text_ar":"رَغْبَى"},{"kind":"text","text":"(JK) [and app."},{"kind":"arabic","text_bw":"ragabN","text_ar":"رَغَبٌ"},{"kind":"text","text":"&c. as in the next sentence but one],"},{"kind":"italic_en","text":"He desired a thing"},{"kind":"text","text":"[app. in an absolute sense, agreeably with what follows in the next sentence but one: and also,]"},{"kind":"italic_en","text":"vehemently, eagerly, greedily, very greedily, with avidity, excessively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"culpably; he coveted a thing, longed for it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lusted after it."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"ragabu Aln~afosi","text_ar":"رَغَبُ النَّفْسِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"soul's"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hoping largely, and desiring much."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"ragiba fiyhi","text_ar":"رَغِبَ فِيهِ"},{"kind":"text","text":", (S, A, Mgh, Msb, K, &c.,) and"},{"kind":"arabic","text_bw":"ragibahu","text_ar":"رَغِبَهُ"},{"kind":"text","text":", (Msb, TA,) aor."},{"kind":"text","text":", (K, TA,) inf. n."},{"kind":"arabic","text_bw":"ragobapN","text_ar":"رَغْبَةٌ"},{"kind":"text","text":"(S, A, * Mgh, K) and"},{"kind":"arabic","text_bw":"ragabN","text_ar":"رَغَبٌ"},{"kind":"text","text":"(S, Msb) and"},{"kind":"arabic","text_bw":"ragobN","text_ar":"رَغْبٌ"},{"kind":"text","text":"(Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"rugobaY","text_ar":"رُغْبَى"},{"kind":"text","text":"(A, * Msb) and"},{"kind":"arabic","text_bw":"ragobaY","text_ar":"رَغْبَى"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"ragobaA='u","text_ar":"رَغْبَا=ءُ"},{"kind":"text","text":", (A, * Msb,)"},{"kind":"italic_en","text":"He desired it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wished for it;"},{"kind":"text","text":"(S, A, Mgh, Msb, K;) as also"},{"kind":"arabic","text_bw":"fyh","text_ar":"فيه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Artgb","text_ar":"ارتغب","orth_type":"arrow"},{"kind":"text","text":". (S, K.) You say,"},{"kind":"arabic","text_bw":"maA liY fiyhi ragobapN","text_ar":"مَا لِى فِيهِ رَغْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rugobaY","text_ar":"رُغْبَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ragobaA='u","text_ar":"رَغْبَا=ءُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I have not any desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wish, for it"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"ruhobaAka xayorN mino rugobaAka","text_ar":"رُهْبَاكَ خَيْرٌ مِنْ رُغْبَاكَ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"The fearing thee is better than the loving thee;"},{"kind":"arabic","text_bw":"rhbAk","text_ar":"رهباك"},{"kind":"text","text":"being an inf. n. prefixed to an objective complement; and so"},{"kind":"arabic","text_bw":"rgbAk","text_ar":"رغباك"},{"kind":"text","text":": and said to mean, thy being given a thing through fear of thee is better than through desire: a prov., similar to"},{"kind":"arabic","text_bw":"rahabuwtN xayorN mino raHamuwtK","text_ar":"رَهَبُوتٌ خَيْرٌ مِنْ رَحَمُوتٍ"},{"kind":"text","text":". (Meyd. [Freytag explains it otherwise: see his Arab. Prov. i. 542.]) ―         -b3-"},{"kind":"arabic","text_bw":"ragiba Eanohu","text_ar":"رَغِبَ عَنْهُ"},{"kind":"italic_en","text":"He did not desire it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wish for it;"},{"kind":"text","text":"(S, A, Mgh, Msb, K;)"},{"kind":"italic_en","text":"he shunned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avoided, it; abstained from it;"},{"kind":"text","text":"(S, TA;) or"},{"kind":"italic_en","text":"left it, relinquished it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsook it,"},{"kind":"text","text":"(JK, S, TA,)"},{"kind":"italic_en","text":"intentionally."},{"kind":"text","text":"(JK, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"ragiba","text_ar":"رَغِبَ"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"ragabN","text_ar":"رَغَبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"ragobN","text_ar":"رَغْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"rugobaY","text_ar":"رُغْبَى"},{"kind":"text","text":"(Mgh, * K) and"},{"kind":"arabic","text_bw":"ragobaY","text_ar":"رَغْبَى"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"ragobaA='u","text_ar":"رَغْبَا=ءُ"},{"kind":"text","text":"(A, * K) and"},{"kind":"arabic","text_bw":"ragobapN","text_ar":"رَغْبَةٌ"},{"kind":"text","text":"(Mgh, * TA) and"},{"kind":"arabic","text_bw":"rugobapN","text_ar":"رُغْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ragabapN","text_ar":"رَغَبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ragabuwtN","text_ar":"رَغَبُوتٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"ragabuwtaY","text_ar":"رَغَبُوتَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ragabaAnN","text_ar":"رَغَبَانٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He made petition to him, addressed a petition to him, asked him, petitioned him, sought of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanded of him:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he prayed to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"supplicated him, with humility"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abasement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with sincerity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earnestness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"energy:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he humbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abased, himself, and made petition to him."},{"kind":"text","text":"(K, A, TA.) You say,"},{"kind":"arabic","text_bw":"ragiba A_ilaY fulaAnK fiY ka*aA","text_ar":"رَغِبَ اـِلَى فُلَانٍ فِى كَذَا"},{"kind":"italic_en","text":"He made petition to such a one, petitioned him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asked him, for such a thing."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"arabic","text_bw":"A@ll~`hi A^arogabu","text_ar":"ا@للّٰهِ اَرْغَبُ"},{"kind":"italic_en","text":"To God I humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abase, myself, and make petition;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^aDoraEu","text_ar":"اَضْرَعُ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"A_ilayoh$ A^arofaEu ragobatiY","text_ar":"اـِلَيْهش اَرْفَعُ رَغْبَتِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"To Him I raise my humble petition"},{"kind":"text","text":"]. (A.) And"},{"kind":"arabic","text_bw":"Alr~uhobaY mina A@ll~`hi waAlr~ugobaY A_ilayohi","text_ar":"الرُّهْبَى مِنَ ا@للّٰهِ وَالرُّغْبَى اـِلَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Fear"},{"kind":"text","text":"should be"},{"kind":"italic_en","text":"of God;"},{"kind":"text","text":"(not of a creature;)"},{"kind":"italic_en","text":"and petition,"},{"kind":"text","text":"&c., should be"},{"kind":"italic_en","text":"to Him"},{"kind":"text","text":"]. (Lth, TA in art."},{"kind":"arabic","text_bw":"rhb","text_ar":"رهب"},{"kind":"text","text":".) See also another ex. in a verse cited voce"},{"kind":"arabic","text_bw":"ragiybapN","text_ar":"رَغِيبَةٌ"},{"kind":"text","text":". ―         -b5-"},{"kind":"arabic","text_bw":"ragiba binafosihi Eanohu","text_ar":"رَغِبَ بِنَفْسِهِ عَنْهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"He made himself to be not desirous of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to shun,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abstain from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leave, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":"having the same effect as in"},{"kind":"arabic","text_bw":"*ahaba bihi","text_ar":"ذَهَبَ بِهِ"},{"kind":"text","text":"&c.; and hence,]"},{"kind":"italic_en","text":"he held himself above,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superior to, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"ragibotu","text_ar":"رَغِبْتُ"},{"kind":"arabic","text_bw":"bifulaAnK Eano h`*aA","text_ar":"بِفُلَانٍ عَنْ هٰذَا"},{"kind":"italic_en","text":"I made such a one to shun, abstain from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leave, this, disliking it for him."},{"kind":"text","text":"(MF.)       -A2-"},{"kind":"arabic","text_bw":"raguba","text_ar":"رَغُبَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, wide,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ample."},{"kind":"text","text":"(TA. [See also 6.]) You say,"},{"kind":"arabic","text_bw":"raguba","text_ar":"رَغُبَ"},{"kind":"arabic","text_bw":"AlwaAdiY","text_ar":"الوَادِى"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rugubN","text_ar":"رُغُبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"ragaAbapN","text_ar":"رَغَابَةٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The valley was large and wide, taking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"receiving, much water."},{"kind":"text","text":"(K, * TA.) And"},{"kind":"arabic","text_bw":"ragubati AlA^aroDu","text_ar":"رَغُبَتِ الاَرْضُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":"[&c.], (assumed tropical:)"},{"kind":"italic_en","text":"The land was soft"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"and wide, with even,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sandy, soil:"},{"kind":"text","text":"(TA:) or (S, TA)"},{"kind":"italic_en","text":"took much water;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"was such as would not flow unless in consequence of much rain."},{"kind":"text","text":"(S, TA.) ―         -b2-  And [hence,]"},{"kind":"arabic","text_bw":"raguba","text_ar":"رَغُبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":"(S, K *) and"},{"kind":"arabic","text_bw":"rugubN","text_ar":"رُغُبٌ"},{"kind":"text","text":", (K, * TA,) (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, voracious, a great eater;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"very greedy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gluttonous;"},{"kind":"text","text":"(S, K, TA;)"},{"kind":"italic_en","text":"vehemently, excessively,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"culpably, desirous of worldly goods, and one who made himself to be large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant, therein:"},{"kind":"text","text":"or as some say,"},{"kind":"italic_en","text":"large in his hopes,"},{"kind":"page_break","n":1111},{"kind":"italic_en","text":"and desirous of much."},{"kind":"text","text":"(TA.) Accord. to the T,"},{"kind":"arabic","text_bw":"rugobu AlbaToni","text_ar":"رُغْبُ البَطْنِ"},{"kind":"text","text":"signifies (assumed tropical:)"},{"kind":"italic_en","text":"Voracity:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":", alone, as occurring in a trad., is explained as meaning"},{"kind":"italic_en","text":"capaciousness of the belly, and voracity."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"raguba raA^oyuhu","text_ar":"رَغُبَ رَاْيُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rugobN","text_ar":"رُغْبٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, liberal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bountiful, and large in opinion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"judgment."},{"kind":"text","text":"(A.)"}],"source_refs":["JK","TA","Msb","K","S","Mgh"]}]}}