num":"p"},{"role":"present_2mp","form":"تَخْتِنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْتِنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْتِن","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْتِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْتِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْتِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْتِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْتِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْتِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْتِنُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْتِنَّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"خَتَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خَتَنّا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخْتِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْتِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n10021"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to circumcise"},{"pos":"verb","gloss":"to give a feast or banquet for on account of wedding or circumcision","tags":["obsolete"]},{"pos":"verb","gloss":"to delude, to outwit, to circumvent (as خَدَعَ (ḵadaʕa) and خَتَلَ (ḵatala))","tags":["obsolete"]},{"pos":"verb","gloss":"to truncate, to cut parts off around, to diminish","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of خَتَنَ (ḵatana) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"circumcision"},{"pos":"noun","gloss":"a man being related through marriage (son-in-law or brother-in-law or father-in-law or bridegroom)","tags":["archaic"]}]},"etymology":{"source":"wiktextract","text":"Inherited noun from Proto-Semitic *ḫatan- (“son-in-law”). Thereof the base stem was formed in the sense of a causative “to have a bridegroom”; the active part خَاتِن (ḵātin) being the father-in-law and a circumciser: though we cannot answer at this place the ancient history of circumcision in detail, nor will anyone on the internet without great animosity, apparently from the occasion of taking a wife a man’s prepuce was considered less necessary, hence the making eligible was equated with circumcising. The other meanings given by the lexicographic tradition of “outwitting, circumventing” and “cutting around or truncating” probably don’t point to an original word in meanings of going around or cutting around but are rather vulgarities punning upon the practice of circumcision; see also our explanation of عَرُوب (ʕarūb)."},"ipa":null}