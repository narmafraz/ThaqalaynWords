num":"p"},{"role":"present_2mp","form":"تَخْتِنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْتِنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْتِن","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْتِن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْتِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْتِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْتِنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْتِنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْتِنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْتِنُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْتِنَّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خَتَنّا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَتَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْتِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْتِن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":7,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n10021"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%AA%D9%8E%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to circumcise"},{"pos":"verb","gloss":"to give a feast or banquet for on account of wedding or circumcision","tags":["obsolete"]},{"pos":"verb","gloss":"to delude, to outwit, to circumvent (as خَدَعَ (ḵadaʕa) and خَتَلَ (ḵatala))","tags":["obsolete"]},{"pos":"verb","gloss":"to truncate, to cut parts off around, to diminish","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of خَتَنَ (ḵatana) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"circumcision"},{"pos":"noun","gloss":"a man being related through marriage (son-in-law or brother-in-law or father-in-law or bridegroom)","tags":["archaic"]}]},"etymology":{"source":"wiktextract","text":"Inherited noun from Proto-Semitic *ḫatan- (“son-in-law”). Thereof the base stem was formed in the sense of a causative “to have a bridegroom”; the active part خَاتِن (ḵātin) being the father-in-law and a circumciser: though we cannot answer at this place the ancient history of circumcision in detail, nor will anyone on the internet without great animosity, apparently from the occasion of taking a wife a man’s prepuce was considered less necessary, hence the making eligible was equated with circumcising. The other meanings given by the lexicographic tradition of “outwitting, circumventing” and “cutting around or truncating” probably don’t point to an original word in meanings of going around or cutting around but are rather vulgarities punning upon the practice of circumcision; see also our explanation of عَرُوب (ʕarūb)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10021","headword_ar":"خَتَنَ","root":"xtn","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) aor."},{"kind":"text","text":"(Msb, K) and"},{"kind":"text","text":", (K, TA, but omitted in the CK,) inf. n."},{"kind":"arabic","text_bw":"xatonN","text_ar":"خَتْنٌ"},{"kind":"text","text":", (S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"He circumcised"},{"kind":"text","text":"(K, TA) a boy, (S, Mgh, Msb, K,) and a girl also: or, as some say,"},{"kind":"arabic","text_bw":"xatonN","text_ar":"خَتْنٌ"},{"kind":"text","text":"relates to men [or boys], and"},{"kind":"arabic","text_bw":"xafoDN","text_ar":"خَفْضٌ"},{"kind":"text","text":"to women [or girls]. (TA.)"},{"kind":"arabic","text_bw":"xutina","text_ar":"خُتِنَ"},{"kind":"text","text":": see 8. ―         -b2-  And ↓"},{"kind":"arabic","text_bw":"xitaAnN","text_ar":"خِتَانٌ","orth_type":"arrow"},{"kind":"text","text":"[which see below, app. as an inf. n. of which the verb is as above,] signifies The"},{"kind":"italic_en","text":"making a feast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"banquet, to which people are invited, on account of a wedding,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of a circumcision"},{"kind":"text","text":"also. (KL.) ―         -b3-  [And accord. to Golius, as on the authority of a gloss. in the KL,"},{"kind":"arabic","text_bw":"xatana","text_ar":"خَتَنَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He diminished; he rendered imperfect:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he acted unjustly."},{"kind":"text","text":"]       -A2-"},{"kind":"arabic","text_bw":"xatanahu","text_ar":"خَتَنَهُ"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"xatalahu","text_ar":"خَتَلَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He deceived, deluded, beguiled, circumvented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outwitted, him, unawares"},{"kind":"text","text":"]: and ↓"},{"kind":"arabic","text_bw":"muxaAtanapN","text_ar":"مُخَاتَنَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"muxaAtalapN","text_ar":"مُخَاتَلَةٌ"},{"kind":"text","text":"[which signifies in like manner the act of"},{"kind":"italic_en","text":"deceiving, deluding,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"practising mutual deceit,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"striving, endeavouring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring, to deceive,"},{"kind":"text","text":"&c.]. (TA.)"},{"kind":"page_break","n":704}],"source_refs":["S","Mgh","Msb","K","TA"]}]}}