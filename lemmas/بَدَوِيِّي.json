{"lemma":"بَدَوِيِّي","slug":"بَدَوِيِّي","root":"ب.د.#","root_slug":"ب-د-_","root_link":"/words/roots/ب-د-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n2049"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%AF%D9%8E%D9%88%D9%90%D9%8A%D9%90%D9%91%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"Bedouin (pastoral nomad)"},{"pos":"adj","gloss":"Bedouin (pastoral nomad)"}]},"etymology":null,"ipa":["/ba.da.wijj/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2049","headword_ar":"بَدَوِىٌّ","root":"bdw","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"belonging to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating to, the"},{"kind":"arabic","text_bw":"badow","text_ar":"بَدْو"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"desert:"},{"kind":"text","text":"and, used as a subst.,"},{"kind":"italic_en","text":"a man,"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"an Arab, of the desert:"},{"kind":"text","text":"] a rel. n. from"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":", (S, M, K,) extr. [with respect to rule], (M, K,) for by rule it should be"},{"kind":"arabic","text_bw":"badowiY~N","text_ar":"بَدْوِىٌّ"},{"kind":"text","text":"; (ElTebreezee, TA;) or it is an irregular rel. n. from"},{"kind":"arabic","text_bw":"baAdiyapN","text_ar":"بَادِيَةٌ"},{"kind":"text","text":": (Msb:) and ↓"},{"kind":"arabic","text_bw":"badaAwiY~N","text_ar":"بَدَاوِىٌّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"bidaAwiY~N","text_ar":"بِدَاوِىٌّ","orth_type":"arrow"},{"kind":"text","text":"are similar rel. ns., (M, K,) from"},{"kind":"arabic","text_bw":"badaAwapN","text_ar":"بَدَاوَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bidaAwapN","text_ar":"بِدَاوَةٌ"},{"kind":"text","text":", as syn. with"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baAdiyapN","text_ar":"بَادِيَةٌ"},{"kind":"text","text":", agreeably with rule; or the former of these two may be a rel. n. from"},{"kind":"arabic","text_bw":"badowN","text_ar":"بَدْوٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baAdiyapN","text_ar":"بَادِيَةٌ"},{"kind":"text","text":", and therefore extr. [with respect to rule]; but it is said that when a rel. n. may be regarded as regular or irregular, it is more proper to regard it as regular; (M;) or the former is a rel. n. signifying"},{"kind":"italic_en","text":"of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"belonging to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relating to,"},{"kind":"arabic","text_bw":"AlbadaAwap","text_ar":"البَدَاوَة"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"the dwelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abiding, in the desert,"},{"kind":"text","text":"(S, TA,) accord. to the opinion of AZ; and the latter is a rel. n. from"},{"kind":"arabic","text_bw":"AlbidaAwap","text_ar":"البِدَاوَة"},{"kind":"text","text":"accord. to the opinion of As and others; and is held by Th to be the chaste form: (TA:) but"},{"kind":"arabic","text_bw":"badawiY~N","text_ar":"بَدَوِىٌّ"},{"kind":"text","text":"is the only one of these rel. ns. that is known to the common people: (M:) it is opposed to a townsman or villager. (TA.) [The pl. is"},{"kind":"arabic","text_bw":"badaAwaY","text_ar":"بَدَاوَى"},{"kind":"text","text":", and vulg."},{"kind":"arabic","text_bw":"bidowaAnN","text_ar":"بِدْوَانٌ"},{"kind":"text","text":". See also"},{"kind":"arabic","text_bw":"baAdK","text_ar":"بَادٍ"},{"kind":"text","text":", often applied to a man as syn. with"},{"kind":"arabic","text_bw":"badawiY~N","text_ar":"بَدَوِىٌّ"},{"kind":"text","text":".]"}],"source_refs":["S","M","K","Msb","TA"]}]},"classical_definitions":null}