{"lemma":"بَلْبَلَةٍ","slug":"بَلْبَلَةٍ","root":"ب.ل.ب.ل","root_slug":"ب-ل-ب-ل","root_link":"/words/roots/ب-ل-ب-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n3131","n3132"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%84%D9%92%D8%A8%D9%8E%D9%84%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n3131","headword_ar":"بَلْبَلَةٌ","root":"bl","body":[{"kind":"text","text":"inf. n. of"},{"kind":"arabic","text_bw":"balobala","text_ar":"بَلْبَلَ"},{"kind":"text","text":"[q. v.]. (M, K.)       -A2-"},{"kind":"italic_en","text":"A state of confusion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mixture, of tongues,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languages."},{"kind":"text","text":"(M, K. *) In the copies of the K,"},{"kind":"arabic","text_bw":"AlA^asin~ap","text_ar":"الاَسِنَّة"},{"kind":"text","text":"is here erroneously put for"},{"kind":"arabic","text_bw":"AlA^alosinap","text_ar":"الاَلْسِنَة"},{"kind":"text","text":". (TA.) ―         -b2-  Also, and ↓"},{"kind":"arabic","text_bw":"balobaAlN","text_ar":"بَلْبَالٌ","orth_type":"arrow"},{"kind":"text","text":", The"},{"kind":"italic_en","text":"vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil, suggestion of anxieties in the bosom:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"anxiety, and vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil, suggestion of the mind:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"intense anxiety, and vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unprofitable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil, suggestions"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thoughts;"},{"kind":"text","text":"(M, K;) as also ↓"},{"kind":"arabic","text_bw":"bulaAbilN","text_ar":"بُلَابِلٌ","orth_type":"arrow"},{"kind":"text","text":", (so in the M, accord. to the TT,) or ↓"},{"kind":"arabic","text_bw":"balaAbilu","text_ar":"بَلَابِلُ","orth_type":"arrow"},{"kind":"text","text":": (so in copies of the K:) this last [however] is pl. of ↓"},{"kind":"arabic","text_bw":"balobaAlN","text_ar":"بَلْبَالٌ","orth_type":"arrow"},{"kind":"text","text":"; (T;) which also signifies"},{"kind":"italic_en","text":"vehement distress in the bosom;"},{"kind":"text","text":"(M, K;) and so does ↓"},{"kind":"arabic","text_bw":"balobaAlapN","text_ar":"بَلْبَالَةٌ","orth_type":"arrow"},{"kind":"text","text":": (IJ, M:) or ↓"},{"kind":"arabic","text_bw":"balobaAlN","text_ar":"بَلْبَالٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"anxiety"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"grief:"},{"kind":"text","text":"and, as also"},{"kind":"arabic","text_bw":"balobalapN","text_ar":"بَلْبَلَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"a motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commotion, in the heart, arising from grief"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"love."},{"kind":"text","text":"(Har p. 94.)"}],"source_refs":["T","S","IJ","M"]},{"entry_id":"n3132","headword_ar":"بُلْبُلَةٌ","root":"bl","body":[{"kind":"italic_en","text":"A mug"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"kuwz","text_ar":"كُوز"},{"kind":"text","text":")"},{"kind":"italic_en","text":"having a spout"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"bulobul","text_ar":"بُلْبُل"},{"kind":"text","text":")"},{"kind":"italic_en","text":"by the side of its head,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"from which the water pours forth:"},{"k