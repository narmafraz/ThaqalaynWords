its,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"from milk,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"from hire,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"from the increase of cattle,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like,"},{"kind":"text","text":"(TA,) and"},{"kind":"italic_en","text":"from the rent of a house,"},{"kind":"text","text":"(K, TA,) and"},{"kind":"italic_en","text":"from the hire of a slave,"},{"kind":"text","text":"(Mgh, K, TA,) and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(Mgh, Msb;) [generally meaning"},{"kind":"italic_en","text":"corn,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grain;"},{"kind":"text","text":"i.e.]"},{"kind":"italic_en","text":"wheat"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"barley"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"rice"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(KL;) the"},{"kind":"arabic","text_bw":"gal~ap","text_ar":"غَلَّة"},{"kind":"text","text":"of the slave is the"},{"kind":"italic_en","text":"payment imposed by the master, and made to him:"},{"kind":"text","text":"(TA voce"},{"kind":"arabic","text_bw":"DariybapN","text_ar":"ضَرِيبَةٌ"},{"kind":"text","text":":) pl."},{"kind":"arabic","text_bw":"gal~aAtN","text_ar":"غَلَّاتٌ"},{"kind":"text","text":"(S, O, Msb, TA) and"},{"kind":"arabic","text_bw":"gilaAlN","text_ar":"غِلَالٌ"},{"kind":"text","text":". (Msb, TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Dirhems"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pieces of money"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that are clipped"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"muqaT~aEap","text_ar":"مُقَطَّعَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"in a single piece thereof"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the quantity clipped being"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"qiyraAT","text_ar":"قِيرَاط"},{"kind":"italic_en","text":"or a"},{"kind":"arabic","text_bw":"Tas~uwj","text_ar":"طَسُّوج"},{"kind":"italic_en","text":"or a grain;"},{"kind":"text","text":"of which it is said in the “ Eedáh, ” that one's lending"},{"kind":"arabic","text_bw":"gal~ap","text_ar":"غَلَّة"},{"kind":"text","text":"in order to have such as are free from defect returned to him is disapproved: (Mgh:) or"},{"kind":"italic_en","text":"dirhems"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pieces of money"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that are rejected by the treasury of the state, but taken by the merchants."},{"kind":"text","text":"(KT. [Freytag has given this latter explanation, but has erroneously assigned it to"},{"kind":"arabic","text_bw":"gul~apN","text_ar":"غُلَّةٌ"},{"kind":"text","text":".])"}],"source_refs":["Mgh","Msb","K","TA","S","O"]}]},"classical_definitions":null}