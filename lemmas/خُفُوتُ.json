{"lemma":"خُفُوتُ","slug":"خُفُوتُ","root":"خ.ف.ت","root_slug":"خ-ف-ت","root_link":"/words/roots/خ-ف-ت","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n11093"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D9%81%D9%8F%D9%88%D8%AA%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11093","headword_ar":"خَفُوتٌ","root":"xft","body":[{"kind":"text","text":"(tropical:)  A"},{"kind":"italic_en","text":"lean,"},{"kind":"text","text":"or an"},{"kind":"italic_en","text":"emaciated,"},{"kind":"text","text":"woman: (Lh, K:) or a woman"},{"kind":"italic_en","text":"who is scarcely seen distinctly, by reason of leanness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciation:"},{"kind":"text","text":"(TA:) or a woman"},{"kind":"italic_en","text":"who is deemed goodly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beautiful,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"whom the eye regards as worthy of notice,"},{"kind":"text","text":"(A, TA,)"},{"kind":"italic_en","text":"as long as she is alone, not when she is among other women."},{"kind":"text","text":"(A, K, TA.) You say"},{"kind":"arabic","text_bw":"AimoraA^apN xafowtN lafuwtN","text_ar":"اِمْرَاَةٌ خَفْوتٌ لَفُوتٌ"},{"kind":"text","text":": (Lth, A, TA:)"},{"kind":"arabic","text_bw":"lfwt","text_ar":"لفوت"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"wont to calumniate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slander."},{"kind":"text","text":"(A.) But AM says, I have not heard"},{"kind":"arabic","text_bw":"xfwt","text_ar":"خفوت"},{"kind":"text","text":"as an epithet applied to a woman on any authority but that of Lth. (TA.)"}],"source_refs":["Lh","K","TA","A","Lth"]}]}}