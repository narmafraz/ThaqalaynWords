":"text","text":";)] as also ↓"},{"kind":"arabic","text_bw":"balogN","text_ar":"بَلْغٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"bilogN","text_ar":"بِلْغٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"bilagN","text_ar":"بِلَغٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"balDAgaY","text_ar":"بَلضاغَى","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"sakaAray","text_ar":"سَكَارَي"},{"kind":"text","text":", [in the CK like"},{"kind":"arabic","text_bw":"sukaAray","text_ar":"سُكَارَي"},{"kind":"text","text":",] and ↓"},{"kind":"arabic","text_bw":"bulaAgay","text_ar":"بُلَاغَي","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"HubaAray","text_ar":"حُبَارَي"},{"kind":"text","text":": (K:) or ↓"},{"kind":"arabic","text_bw":"balogN","text_ar":"بَلْغٌ","orth_type":"arrow"},{"kind":"text","text":"signifies a man"},{"kind":"italic_en","text":"who does not commit mistakes often in his speech:"},{"kind":"text","text":"(JK:) the pl. of"},{"kind":"arabic","text_bw":"baliygN","text_ar":"بَلِيغٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"bulagaA='u","text_ar":"بُلَغَا=ءُ"},{"kind":"text","text":". (TA.) Applied to a saying, [&c.,] it also signifies"},{"kind":"italic_en","text":"Effectual,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"producing an effect."},{"kind":"text","text":"(Ksh and Bd and Jel in iv. 66.) ―         -b2-  [Also"},{"kind":"italic_en","text":"Surpassing"},{"kind":"text","text":"in any quality: and"},{"kind":"italic_en","text":"superlative."},{"kind":"text","text":"] It is also applied to a calamity or the like [as meaning"},{"kind":"italic_en","text":"Great, severe, distressing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afflictive"},{"kind":"text","text":"]. (IAth.)"}],"source_refs":["K","JK"]}]}}