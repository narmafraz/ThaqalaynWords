"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجَرِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجَرِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجَرِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجَرِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجَرِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجَرِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجَرِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجَرِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجَرِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"جَرَّبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَرَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n5424","n5429","n5430","n5431"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D8%B1%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be scabby, to be mangy","examples":[{"text":"والكتم قال أبو الخير هو ثلاثة أنواع منها ما له ورق عريض مثل ورق الآس الذي ينبت في الشعرى وهو يعلو كثيرا ويأخذ من التدويح وورقه مشرفة مثل تشريف المنشار ومنه نوع آخر له ورق دون الأول في العرض وتعظم شجرته أيضا وله حب في قدر حب الفلفل والريحان ويعتصر منه دهن يستصبح به ونوع آخر له ورق طويل دقيق مثل ورق المسان وقيل إن مما جرب فصح إنه إن سقى من عصارة ورقه ثمانية دراهم لمن عضه الكلب فإنه يبرئ في ذلك اليوم ويخلص بإذن الله تعالى وأن فزع من الماء فإنه يبرئ والكتم هو شبيه للحناء ويجفف ورقه ويدق نعما ويخلط بالحناء وخضب به الشعر.","english":"About the mock privet says Abū al-Ḵayr that there are three kinds of it: The first has wide leaves similar to the leaves of the myrtle which grows in the maquis and it becomes very high and swollen and its leaves are humped like a saw, the second has leaves of lesser width but its tree is also poddy and its seeds are of the size of the seeds of peppers and myrtles and from them one can press oil for lighting, and another kind has long delicate leaves like sandpaper and it is said if someone is affected by scabies then he will regain health, that if he whom a dog has bitten drinks eight dirhem from the extract of its leaves he will becomes free from the ailment the same day and cleansed of it if God is gracious; so that he will fear water but he will be free of the pest. Mock privet is similar to henna and one dries its leaves and crushes them well and mixes with henna and dyes the hair with it."}]},{"pos":"noun","gloss":"mange, scurvy, scabies, verbal noun of جَرِبَ (jariba) (form I)"},{"pos":"adj","gloss":"mangy, scabby"},{"pos":"adj","gloss":"plural of أَجْرَب (ʔajrab)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to experience"},{"pos":"verb","gloss":"to test, put to the test, probe"},{"pos":"verb","gloss":"to get wise by experience"},{"pos":"noun","gloss":"plural of جِرَاب (jirāb)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *garab-."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n5424","headword_ar":"جَرِبَ","root":"jrb","body":[{"kind":"text","text":", (S, A, Mgh, Msb, K,) aor."},{"kind":"text","text":", (Mgh, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"jarabN","text_ar":"جَرَبٌ"},{"kind":"text","text":", (Msb, TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel, S, A, Msb, K, and a man, S, or other animal, Msb,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with what is termed"},{"kind":"arabic","text_bw":"jarab","text_ar":"جَرَب"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab"},{"kind":"text","text":"]. (S, Msb, K.)"},{"kind":"arabic","text_bw":"maA lahu jariba waHariba","text_ar":"مَا لَهُ جَرِبَ وَحَرِبَ"},{"kind":"text","text":"is a form of imprecation against a man [meaning"},{"kind":"italic_en","text":"What aileth him? may he have the scab, and be despoiled of all his wealth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"property:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may he have his camels affected with the mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab, and be despoiled"},{"kind":"text","text":"&c.: or"},{"kind":"italic_en","text":"may his camels be affected with the mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab,"},{"kind":"text","text":"&c.]: it may express a wish that he may be affected with"},{"kind":"arabic","text_bw":"jarab","text_ar":"جَرَب"},{"kind":"text","text":": or"},{"kind":"arabic","text_bw":"jariba","text_ar":"جَرِبَ"},{"kind":"text","text":"may be put for"},{"kind":"arabic","text_bw":"A^ajoraba","text_ar":"اَجْرَبَ"},{"kind":"text","text":", to assimilate it to"},{"kind":"arabic","text_bw":"Hariba","text_ar":"حَرِبَ"},{"kind":"text","text":": or it may be for"},{"kind":"arabic","text_bw":"jaribato A_ibluhu","text_ar":"جَرِبَتْ اـِبلُهُ"},{"kind":"text","text":". (L.) ―         -b2-  See 4. ―         -b3-  Also (tropical:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"halakato A^aroDuhu","text_ar":"هَلَكَتْ اَرْضُهُ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"His land had its herbage dried up by drought;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became such as is termed"},{"kind":"arabic","text_bw":"jarobaA='","text_ar":"جَرْبَا=ء"},{"kind":"text","text":", fem. of"},{"kind":"arabic","text_bw":"A^ajorabu","text_ar":"اَجْرَبُ"},{"kind":"text","text":", q. v.]. (K.)"}],"source_refs":["S","A","Mgh","Msb","K","TA"]},{"entry_id":"n5429","headword_ar":"جِرْبٌ","root":"jrb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jirobapN","text_ar":"جِرْبَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n5430","headword_ar":"جَرَبٌ","root":"jrb","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain disease,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"well known;"},{"kind":"text","text":"(S, A, K;) accord. to the medical books, (Msb,)"},{"kind":"italic_en","text":"a gross humour, arising beneath the skin, from the mixture of the salt phlegm,"},{"kind":"text","text":"(Msb, MF,) or"},{"kind":"italic_en","text":"the phlegm of the flesh,"},{"kind":"text","text":"(so in a copy of the Msb,)"},{"kind":"italic_en","text":"with the blood, accompanied with pustules, and sometimes with emaciation, in consequence of its abundance;"},{"kind":"text","text":"(Msb, MF;) or ["},{"kind":"italic_en","text":"an eruption consisting of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"pustules upon the bodies of men and camels."},{"kind":"text","text":"(M, TA.) You say,"},{"kind":"arabic","text_bw":"A^EodaY mina Aljarabi Einoda AlEarabi","text_ar":"اعْدَى مِنَ الجَرَبِ عِنْدَ العَرَبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"More transitive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"catching, than the mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab, among the Arabs"},{"kind":"text","text":"]: (A, TA:) a proverb. (TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"Rust upon a sword."},{"kind":"text","text":"(K.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"A resemblance of rust upon the inner side of the"},{"kind":"arabic","text_bw":"jafon","text_ar":"جَفْن"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"eyelid"},{"kind":"text","text":"], (M, K,)"},{"kind":"italic_en","text":"sometimes covering the whole of it, and sometimes part of it."},{"kind":"text","text":"(M.) You say,"},{"kind":"arabic","text_bw":"biA^ajofaAnihi jarabN","text_ar":"بِاَجْفَانِهِ جَرَبٌ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"In his eyelids is"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a resemblance of rust upon their inner sides."},{"kind":"text","text":"(A.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"A vice, a fault, a defect, an imperfection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a blemish."},{"kind":"text","text":"(IAar, K.)"}],"source_refs":["A","Msb","MF","TA","M","K"]},{"entry_id":"n5431","headword_ar":"جَرِبٌ","root":"jrb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^ajorabu","text_ar":"اَجْرَبُ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}