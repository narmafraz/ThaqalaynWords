:"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُجَرِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُجَرِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُجَرِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُجَرِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُجَرِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُجَرِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُجَرِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُجَرِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُجَرِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"جَرَّبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"جَرَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُجَرِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":9,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n5424","n5429","n5430","n5431"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be scabby, to be mangy","examples":[{"text":"والكتم قال أبو الخير هو ثلاثة أنواع منها ما له ورق عريض مثل ورق الآس الذي ينبت في الشعرى وهو يعلو كثيرا ويأخذ من التدويح وورقه مشرفة مثل تشريف المنشار ومنه نوع آخر له ورق دون الأول في العرض وتعظم شجرته أيضا وله حب في قدر حب الفلفل والريحان ويعتصر منه دهن يستصبح به ونوع آخر له ورق طويل دقيق مثل ورق المسان وقيل إن مما جرب فصح إنه إن سقى من عصارة ورقه ثمانية دراهم لمن عضه الكلب فإنه يبرئ في ذلك اليوم ويخلص بإذن الله تعالى وأن فزع من الماء فإنه يبرئ والكتم هو شبيه للحناء ويجفف ورقه ويدق نعما ويخلط بالحناء وخضب به الشعر.","english":"About the mock privet says Abū al-Ḵayr that there are three kinds of it: The first has wide leaves similar to the leaves of the myrtle which grows in the maquis and it becomes very high and swollen and its leaves are humped like a saw, the second has leaves of lesser width but its tree is also poddy and its seeds are of the size of the seeds of peppers and myrtles and from them one can press oil for lighting, and another kind has long delicate leaves like sandpaper and it is said if someone is affected by scabies then he will regain health, that if he whom a dog has bitten drinks eight dirhem from the extract of its leaves he will becomes free from the ailment the same day and cleansed of it if God is gracious; so that he will fear water but he will be free of the pest. Mock privet is similar to henna and one dries its leaves and crushes them well and mixes with henna and dyes the hair with it."}]},{"pos":"noun","gloss":"mange, scurvy, scabies, verbal noun of جَرِبَ (jariba) (form I)"},{"pos":"adj","gloss":"mangy, scabby"},{"pos":"adj","gloss":"plural of أَجْرَب (ʔajrab)","tags":["form-of","plural"]},{"pos":"verb","gloss":"to experience"},{"pos":"verb","gloss":"to test, put to the test, probe"},{"pos":"verb","gloss":"to get wise by experience"},{"pos":"noun","gloss":"plural of جِرَاب (jirāb)","tags":["form-of","plural"]}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *garab-."},"ipa":null}