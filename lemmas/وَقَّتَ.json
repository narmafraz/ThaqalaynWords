":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُوَقِّتُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُوَقِّتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُوَقِّت","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُوَقِّت","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُوَقِّتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُوَقِّتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُوَقِّتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَقِّتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوَقِّتُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوَقِّتُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوَقِّتْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"وَقَّتُّ","in_corpus":true,"count":513,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"وَقَّتْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَقِّت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوَقِّت","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":1575,"cross_references":{"qac":{"found":true,"lemma_key":"وَقَّتَ","root":"وقت","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":[""]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of وَقَتَ (waqata) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"time (as an abstract concept)"},{"pos":"noun","gloss":"period of time, time span"},{"pos":"noun","gloss":"moment, instant"},{"pos":"verb","gloss":"to determine, define, or place a limit on a thing especially time"},{"pos":"verb","gloss":"to fix boundaries of duration, to set or appoint a time for something to occur especially the falling due of an obligation"},{"pos":"verb","gloss":"to set a time, to appoint a time, to fix a time, to schedule"},{"pos":"verb","gloss":"to time"},{"pos":"verb","gloss":"to set a time limit"}]},"etymology":{"source":"wiktextract","text":"Possibly, via dissimilation of emphatic consonants, from the root و ق ط (w q ṭ), akin to rare Classical Arabic وَقْط (waqṭ) & وَقِيطَة (waqīṭa) “hollow in a rock or mountain where rainwater collects”, dialectal Yemeni Arabic وَقَّطَ (waqqaṭa) “to cut down, break off stones”, Minaean 𐩥𐩤𐩷 (wqṭ, “cavity”), Sabaean 𐩥𐩤𐩷 (wqṭ), 𐩺𐩤𐩷 (yqṭ, “to dig up, excavate; to hollow out”), Dadanitic 𐪅𐪄𐪗 (wqṭ, “to inscribe, write”); all of these ultimately from the same biliteral Proto-Semitic root *q-ṭ emblematically represented by Arabic قَطَّ (qaṭṭa) “to cut, to carve”. The “time” sense would develop from a more original meaning of “hollow”, then “gap”, interpreted figuratively as “period or gap of time”—cf. وَقْت (waqt) in the rarely attested sense of “A space, or measure, of local extension”, perhaps a remnant of the would-be original non-temporal meaning. There also exist اِقْتَتَّ (iqtatta, “to dissect”), قَتَّ (qatta, “to reduce, to cut lengthwise”) and all derivatives of the root ق ت ت (q t t) seems to be from the meaning to cut, suggesting this origin.\nAlternatively, suggested to be borrowed from Iranian, from Proto-Indo-Iranian *bʰaktás (“distributed, allotted; lot, share”), although this etymology has some difficulties on phonological, semantic, and geographical grounds. If correct, that makes it a doublet of بَخْت (baḵt, “luck”) which was borrowed later. Compare other supposedly borrowed time terms: زَمَن (zaman), سَاعَة (sāʕa), عَام (ʕām), سَوْفَ (sawfa), أَوَان (ʔawān), إِبَّان (ʔibbān).\n\nDenominal verb of وَقْت (waqt)."},"ipa":["/waqt/","/waʔt/","/wakt/","/waɡt/","/waq.qa.ta/"]}