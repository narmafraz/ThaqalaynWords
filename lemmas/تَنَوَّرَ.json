ا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَنَوَّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَنَوَّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَنَوَّر","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَنَوَّر","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَنَوَّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَنَوَّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَنَوَّرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَنَوَّرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَنَوَّرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَنَوَّرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَنَوَّرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَتَنَوَّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَنَوَّر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تَنَوَّرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَنَوَّرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":true,"lemma_key":"تَنَوَّرَ","root":"","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n4137"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%86%D9%8E%D9%88%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be lit, to be illuminated"},{"pos":"verb","gloss":"to receive enlightenment, to be enlightened"},{"pos":"noun","gloss":"verbal noun of تَنَوَّرَ (tanawwara) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"illumination, enlightenment"},{"pos":"noun","gloss":"tandoor"},{"pos":"noun","gloss":"oven, furnace, kiln"},{"pos":"noun","gloss":"cook stove"}]},"etymology":{"source":"wiktextract","text":"Mediopassive of نَوَّرَ (nawwara, “to light”), from نُور (nūr, “light”).\n\nBorrowed from Aramaic תַּנּוּרַא / ܬܰܢܽܘܪܳܐ (tannūrā), from Middle Persian [script needed] (tnwl /⁠tanūr⁠/, “oven”) from which also Hebrew תַּנּוּר (tanúr, “oven”), from Akkadian 𒋾𒂟 (tinūru)."},"ipa":["/ta.naw.wa.ra/","/ta.naw.wur/","/tan.nuːr/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4137","headword_ar":"تَنُّورٌ","root":"tnr","body":[{"kind":"italic_en","text":"A sort of"},{"kind":"arabic","text_bw":"kaAnuwn","text_ar":"كَانُون"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"fire-place"},{"kind":"text","text":"]; (M;) the"},{"kind":"italic_en","text":"thing,"},{"kind":"text","text":"(S, Msb,) or"},{"kind":"arabic","text_bw":"kAnwn","text_ar":"كانون"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"in which bread is baked;"},{"kind":"text","text":"(S, Msb, K;)"},{"kind":"italic_en","text":"but different from the"},{"kind":"arabic","text_bw":"furon","text_ar":"فُرْن"},{"kind":"text","text":": (S in art."},{"kind":"arabic","text_bw":"frn","text_ar":"فرن"},{"kind":"text","text":":) [it is"},{"kind":"italic_en","text":"a kind of oven, open at the top, in the bottom of which a fire is lighted, and in which the bread, in the form of flat cakes, is generally stuck against the sides; either portable, and made of baked clay, wide at the bottom, and narrow at the top, where it is open; and if so, the bread is sometimes stuck upon the outside, to bake; or fixed, and in this case made of baked clay likewise, or constructed of bricks; or it is a hole made in the ground, and lined with bricks or tiles or the like, against which the bread is stuck, to bake; and sometimes flesh-meat, cut into small pieces, is roasted in it, or upon it, on skewers:"},{"kind":"text","text":"] such, accord. to some, is the meaning in the Kur xi. 42 and xxiii. 27; (T;) and the word is said to have the same meaning in every language; (Lth, T, M;) but this is not correct: (Ham p. 793:) it is an arabicized word; (T, M;) not genuine Arabic; (AHát, Msb;) originally Persian: (M:) [in Hebrew"},{"kind":"arabic","text_bw":"XXX","text_ar":"XXX","orth_type":"plain"},{"kind":"text","text":":] Ahmad Ibn-Yahyà [i. e. Th, as is stated in Ham, ubi suprà,] says that it is of the measure"},{"kind":"arabic","text_bw":"tafoEuwlN","text_ar":"تَفْعُولٌ"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"Aln~aAr","text_ar":"النَّار"},{"kind":"text","text":", (M, and Ham ubi suprà,) or from"},{"kind":"arabic","text_bw":"Aln~uwr","text_ar":"النُّور"},{"kind":"text","text":"; originally"},{"kind":"arabic","text_bw":"tanowuwrN","text_ar":"تَنْوُورٌ"},{"kind":"text","text":"; (Ham;) but this is wrong: (M:) the pl. is"},{"kind":"arabic","text_bw":"tanaAniyru","text_ar":"تَنَانِيرُ"},{"kind":"text","text":". (M, Msb.) Mo- hammad is related to have said to a man wearing a garment dyed with bastard-saffron, “ If thy garment were in the"},{"kind":"arabic","text_bw":"tn~wr","text_ar":"تنّور"},{"kind":"text","text":"of thy family, or beneath"},{"kind":"page_break","n":319},{"kind":"text","text":"their cooking-pot, it were better: ” whereupon he went away, and burned it: but he meant, “ Wert thou to spend its price for flour to make bread, or for fire-wood with which to cook, it were better for thee: ” as though he disliked a garment so dyed. (IAth.) ―         -b2-  The"},{"kind":"italic_en","text":"surface of the ground:"},{"kind":"text","text":"(T, S, M, K:) so in the Kur ubi suprà, (T, S,) accord. to 'Alee (S) and I'Ab. (TA.) ―         -b3-  The"},{"kind":"italic_en","text":"highest part of the earth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground:"},{"kind":"text","text":"so in the same passages of the Kur accord. to Katádeh. (TA.) ―         -b4-"},{"kind":"italic_en","text":"Any place from which water pours forth."},{"kind":"text","text":"(M, K.) ―         -b5-"},{"kind":"italic_en","text":"A place where the water of a valley collects."},{"kind":"text","text":"(M, K.) ―         -b6-  The"},{"kind":"italic_en","text":"shining of the dawn:"},{"kind":"text","text":"so accord. to some in the Kur ubi suprà: (T:) and 'Alee is related to have said that"},{"kind":"arabic","text_bw":"wafaAra Alt~an~uwru","text_ar":"وَفَارَ التَّنُّورُ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"and daybreak rose"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rises:"},{"kind":"text","text":"(TA:) or it relates to the welling forth of water from the place of the mosque of El-Koofeh: (T:) or"},{"kind":"arabic","text_bw":"Alt~n~wr","text_ar":"التّنّور"},{"kind":"text","text":"here signifies a well-known spring of water: (Hr, TA:) or a certain mountain near El-Maseesah; (I'Ab, K, TA;) i. e., (TA,) 'Eyn-el-Ward, in El-Jezeereh; (I'Ab, T, TA;) or 'Eyn-Wardeh. (Bd in xi. 42.)"}],"source_refs":["S","Msb","K","M","T","TA","Hr"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AA%D9%86%D9%88%D8%B1/","headword_ar":"تنور","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=88754#a6a767","body_html":"تنور<br>عن الفارسية بمعنى جسيم وضخم."},{"lexicon_id":"dictionary_40","lexicon_en":"Al-Suyūṭī, al-Muhadhdhib fī-mā Waqaʿa fi l-Qurʾān min al-Muʿarrab (d. 1505 CE)","lexicon_ar":"المهذب فيما وقع في القرآن من المعرب للسيوطي","permalink":"https://arabiclexicon.hawramani.com/?p=88754#fe6e0a","body_html":"<span>(تنور) : ذكر ابن دربد والجوالبقي والثعالبي أنه فارسي معرب.</span>"}]}}