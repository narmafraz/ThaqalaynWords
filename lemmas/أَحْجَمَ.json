"verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n7219"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AD%D9%92%D8%AC%D9%8E%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to swell, to become protuberant"},{"pos":"verb","gloss":"to refrain, to forbear"}]},"etymology":null,"ipa":["/ʔaħ.d͡ʒa.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7219","headword_ar":"احجم","root":"Hjm","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the breast of a woman or girl)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, swelling, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant;"},{"kind":"text","text":"(Mgh, K;) as also ↓"},{"kind":"arabic","text_bw":"Hajama","text_ar":"حَجَمَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HajomN","text_ar":"حَجْمٌ"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, round, and swelling, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Hj~m","text_ar":"حجّم","orth_type":"arrow"},{"kind":"text","text":": (A, TA:) properly,"},{"kind":"italic_en","text":"became such as to have what is termed"},{"kind":"arabic","text_bw":"HajomN","text_ar":"حَجْمٌ"},{"kind":"text","text":", (Mgh, TA,) meaning"},{"kind":"italic_en","text":"projection, protrusion, prominence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberance,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"elevation:"},{"kind":"text","text":"(Mgh:) or, as some say,"},{"kind":"italic_en","text":"became such that the suckling might suck it."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^aHojamato","text_ar":"اَحْجَمَتْ"},{"kind":"arabic","text_bw":"lilomawoluwdi","text_ar":"لِلْمَوْلُودِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"suckled the new-born child for the first time."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"arabic","text_bw":"AHjm Eanohu","text_ar":"احجم عَنْهُ"},{"kind":"italic_en","text":"He refrained, forbore, abstained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desisted, from it;"},{"kind":"text","text":"(S, K;) quasi-pass. of"},{"kind":"arabic","text_bw":"Hjamotuhu","text_ar":"حجَمْتُهُ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"A^akab~a","text_ar":"اَكَبَّ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"kababotuhu","text_ar":"كَبَبْتُهُ"},{"kind":"text","text":"; which are extr. of their kind; (S;) and"},{"kind":"arabic","text_bw":"AjHm Enh","text_ar":"اجحم عنه"},{"kind":"text","text":"signifies the same; (S in art."},{"kind":"arabic","text_bw":"jHm","text_ar":"جحم"},{"kind":"text","text":";) but is a rare dial. var.: (Har p. 95:) or"},{"kind":"italic_en","text":"he drew back from it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him, in awe,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fear:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"he receded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew back, form it;"},{"kind":"text","text":"namely, a thing, or an affair: (Msb:) and"},{"kind":"arabic","text_bw":"A^aHojamotu Eani Alqawomi","text_ar":"اَحْجَمْتُ عَنِ القَوْمِ"},{"kind":"italic_en","text":"I dreaded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feared, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, and returned, and left them, after I had desired to go to them."},{"kind":"text","text":"(AZ, Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"AHjm","text_ar":"احجم"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went forward;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"AjHm","text_ar":"اجحم"},{"kind":"text","text":": both of these verbs thus having two contr. meanings. (MF.)       -A3-  See also 1, last sentence."}],"source_refs":["K","A","TA","Mgh","Msb"]}]},"classical_definitions":null}