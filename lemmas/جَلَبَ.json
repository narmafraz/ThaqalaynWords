{"lemma":"جَلَبَ","slug":"جَلَبَ","root":"ج.ل.ب","root_slug":"ج-ل-ب","root_link":"/words/roots/ج-ل-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"جَلَبْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"جَلَبْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"جَلَبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"جَلَبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"جَلَبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"جَلَبَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"جَلَبَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"جَلَبا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"جَلَبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"جَلَبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"جَلَبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَجْلُب","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَجْلِب","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَجْلُبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْلُبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْلِبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَجْلِبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَجْلُبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْلُبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْلِبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَجْلِبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَجْلُبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْلُبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْلِبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَجْلِبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَجْلُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تَجْلِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَجْلُب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَجْلِب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَجْلُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَجْلِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَجْلُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْلُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْلِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَجْلِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَجْلُبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلُبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلِبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَجْلِبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَجْلُبُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْلُبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْلِبُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَجْلِبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَجْلُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَجْلِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَجْلُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْلُب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَجْلِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَجْلِب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"جَلَبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"جَلَبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n6050"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D9%8E%D9%84%D9%8E%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to bring, to fetch"},{"pos":"verb","gloss":"to bring about"},{"pos":"verb","gloss":"to obtain, to get"},{"pos":"verb","gloss":"to import"},{"pos":"verb","gloss":"to win, to earn"},{"pos":"verb","gloss":"to arraign"},{"pos":"verb","gloss":"to attract (something)"},{"pos":"verb","gloss":"to scar over, to heal forming a scar (of a wound)"},{"pos":"verb","gloss":"to shout"},{"pos":"verb","gloss":"to be noisy, to be rowdy, to be boisterous"},{"pos":"noun","gloss":"merchandise, imported goods","tags":["Classical"]},{"pos":"noun","gloss":"slaves and cattle for selling","tags":["Classical"]}]},"etymology":null,"ipa":["/d͡ʒa.la.ba/","/d͡ʒal.la.ba/","/d͡ʒa.lab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6050","headword_ar":"جَلَبَ","root":"jlb","body":[{"kind":"text","text":", (S, A, Mgh, Msb, K,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"jalobN","text_ar":"جَلْبٌ"},{"kind":"text","text":"(S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"jalabN","text_ar":"جَلَبٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"He drove,"},{"kind":"text","text":"(A, K,) or"},{"kind":"italic_en","text":"brought, conveyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"transported,"},{"kind":"text","text":"(Mgh,) a thing, (S, A, * Mgh, Msb, K, *) or things, such as camels, sheep, goats, horses, captives, or slaves, or any merchandise, (TA,)"},{"kind":"italic_en","text":"from one place to another,"},{"kind":"text","text":"(A, K,) or"},{"kind":"italic_en","text":"from one country or town to another, for the purpose of traffic;"},{"kind":"text","text":"(Mgh;) as also ↓"},{"kind":"arabic","text_bw":"Ajtlb","text_ar":"اجتلب","orth_type":"arrow"},{"kind":"text","text":", (A, K, KL,) and ↓"},{"kind":"arabic","text_bw":"Astjlb","text_ar":"استجلب","orth_type":"arrow"},{"kind":"text","text":". (KL.) And"},{"kind":"arabic","text_bw":"jalabotu","text_ar":"جَلَبْتُ"},{"kind":"arabic","text_bw":"Al$~aYo'a A_ilay nafosiY","text_ar":"الشَّىْءَ اـِلَي نَفْسِى"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Aijotalabotuhu","text_ar":"اِجْتَلَبْتُهُ","orth_type":"arrow"},{"kind":"text","text":"signify the same; (S;) i. e. (assumed tropical:)"},{"kind":"italic_en","text":"I brought, drew, attracted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"procured, the thing to myself."},{"kind":"text","text":"(PS.) [Hence,]"},{"kind":"arabic","text_bw":"*aA","text_ar":"ذَا"},{"kind":"arabic","text_bw":"mim~aA yajolibu AlA_ixowaAna","text_ar":"مِمَّا يَجْلِبُ الاـِخْوَانَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"This is of the things that bring, draw, attract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"procure, brothers,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"friends"},{"kind":"text","text":"]. (A, TA.) And"},{"kind":"arabic","text_bw":"Ald~ahori","text_ar":"الدَّهْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jalabatuhu jawaAlibu","text_ar":"جَلَبَتُهُ جَوَالِبُ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The calamities of time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of fortune,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of fate, brought, drew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attracted, him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (A, TA.)"},{"kind":"page_break","n":439},{"kind":"text","text":"[Hence also, accord. to some,]"},{"kind":"arabic","text_bw":"laA jalaba wa laA janaba","text_ar":"لَا جَلَبَ وَ لَا جَنَبَ"},{"kind":"text","text":", a trad., explained as meaning,"},{"kind":"italic_en","text":"The owner of cattle shall not be required to drive them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bring them, to the town,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"country, in order that the collector may take from them the portion appointed for the poor-rate, but this shall be taken at the waters; and when the cattle are in the yards, they shall be left therein, and not brought forth to the place of pasture, for the collector to take that portion:"},{"kind":"text","text":"or, as some say,"},{"kind":"arabic","text_bw":"wlA jnb","text_ar":"ولا جنب"},{"kind":"text","text":"means,"},{"kind":"italic_en","text":"nor shall one have a horse led by his side, in a race, in order that, when he draws near to the goal, he may tranfser himself to it, and so outstrip his fellow:"},{"kind":"text","text":"and other explanations have been given: (Msb:) [accord. to some,]"},{"kind":"arabic","text_bw":"lA jlb","text_ar":"لا جلب"},{"kind":"text","text":"here means,"},{"kind":"italic_en","text":"they shall not drive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bring, their cattle to the collector of the portions appointed for the poor-rate in the place where he alights, but he shall himself come to their yards and take those portions:"},{"kind":"text","text":"or ["},{"kind":"arabic","text_bw":"jlb","text_ar":"جلب"},{"kind":"text","text":"here is from the verb"},{"kind":"arabic","text_bw":"jalaba","text_ar":"جَلَبَ"},{"kind":"text","text":"in a sense which will be explained below, and] the trad. relates to horse-racing, and means,"},{"kind":"italic_en","text":"one shall not cause his horse to be followed by a man crying out at it and chiding it; nor shall he have a horse without a rider led by his own horse, in order that, when he draws near to the goal, he may transfer himself to it, and outstrip upon it:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"arabic","text_bw":"Aljalabu","text_ar":"الجَلَبُ"},{"kind":"text","text":", which is forbidden, means"},{"kind":"italic_en","text":"the collector's not coming to the people at their waters to take the portions appointed for the poor-rate, but ordering them to drive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bring, their cattle to him:"},{"kind":"text","text":"or it relates to contending for a stake, or wager, and means"},{"kind":"italic_en","text":"the mounting a man upon one's horse, and, when he has drawn near to the goal, following his horse and crying out at it, in order that it may outstrip;"},{"kind":"text","text":"which is a kind of fraud: (S:) or it is used in both these cases: (A 'Obeyd: [his explanations are virtually the same as those in the S:]) or the meaning of the trad. [so far as the former clause of it is concerned] is, that"},{"kind":"italic_en","text":"the contributions to the poor-rate shall not be driven,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought, to the waters nor to the great towns, but shall be given in their places of pasture:"},{"kind":"text","text":"or it means, [or rather"},{"kind":"arabic","text_bw":"Aljlb","text_ar":"الجلب"},{"kind":"text","text":"means,]"},{"kind":"italic_en","text":"the collector's alighting in a place, and then sending a person,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persons, to drive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bring, to him the cattle from their places, that he may take the portion thereof appointed for the poor-rate:"},{"kind":"text","text":"or it [relates to horse-racing, and] means"},{"kind":"italic_en","text":"the sending forth a horse in the racecourse, and a number of persons' congregating, and crying out at it, in order that it may be turned from its course:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a man's following his horse, and spurring on behind it, and chiding it, and crying out at it:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"the shaking a thing behind a horse that is backward in a race, that it may be urged on thereby, and outstrip:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one's riding a horse, and leading behind him another, to urge it on, in contending for a stake,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wager:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the crying out at a horse from behind, and urging it to outstrip."},{"kind":"text","text":"(TA. See also 1 in art."},{"kind":"arabic","text_bw":"jnb","text_ar":"جنب"},{"kind":"text","text":".) ―         -b2-"},{"kind":"arabic","text_bw":"jalaba lA^aholihi","text_ar":"جَلَبَ لاَهْلِهِ"},{"kind":"italic_en","text":"He gained"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earned; sought"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought after"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought to gain"},{"kind":"text","text":"[provisions &c.; generally meaning"},{"kind":"italic_en","text":"he purveyed"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"and exercised art"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cunning"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill, in the management of his affairs; for his family;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":". (Lh, K.)       -A2-"},{"kind":"arabic","text_bw":"jalabuwA","text_ar":"جَلَبُوا"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (K,) [inf. n."},{"kind":"arabic","text_bw":"jalabN","text_ar":"جَلَبٌ"},{"kind":"text","text":", and perhaps"},{"kind":"arabic","text_bw":"jalabapN","text_ar":"جَلَبَةٌ"},{"kind":"text","text":"also;] and ↓"},{"kind":"arabic","text_bw":"jl~bwA","text_ar":"جلّبوا","orth_type":"arrow"},{"kind":"text","text":"; (S, K;) and ↓"},{"kind":"arabic","text_bw":"AjlbwA","text_ar":"اجلبوا","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A_ijolaAbN","text_ar":"اـِجْلَابٌ"},{"kind":"text","text":"; (Mgh;) [the second of which is the most common;]"},{"kind":"italic_en","text":"They raised cries, shouts, noises, a clamour,"},{"kind":"text","text":"(S, Mgh, TA,) or"},{"kind":"italic_en","text":"confused cries"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shouts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"noises."},{"kind":"text","text":"(Mgh, K. *) And"},{"kind":"arabic","text_bw":"jalaba Ealay farasihi","text_ar":"جَلَبَ عَلَي فَرَسِهِ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"jalabN","text_ar":"جَلَبٌ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"jalobN","text_ar":"جَلْبٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He chid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urged on, his horse;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jl~b","text_ar":"جلّب","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":"; (K;) the first, rare; the second and third, usual: (TA:)"},{"kind":"italic_en","text":"he cried out at his horse,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"from behind him, and urged him to outstrip"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in a race"},{"kind":"text","text":"], (S,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":"; (K; but this explanation is erased in the copy of the K in its author's handwriting, as being a repetition; and rightly, accord. to MF; though this requires consideration; TA;) as also ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":": (S:)"},{"kind":"italic_en","text":"he urged his horse to run, by striking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goading,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by crying out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":": or, as some say,"},{"kind":"italic_en","text":"he led behind his horse that he was riding another horse to urge on the former,"},{"kind":"text","text":"in contending [in a race] for a stake, or wager; as is shown in an explanation of the tradition cited above,"},{"kind":"arabic","text_bw":"laA jalaba walaA janaba","text_ar":"لَا جَلَبَ وَلَا جَنَبَ"},{"kind":"text","text":". (TA.) It is said in the Kur [xvii. 66],"},{"kind":"arabic","text_bw":"Ealayohimo bixayolika warajolika","text_ar":"عَلَيْهِمْ بِخَيْلِكَ وَرَجْلِكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"waA^ajolibo","text_ar":"وَاَجْلِبْ","orth_type":"arrow"},{"kind":"italic_en","text":"And raise thou confused cries against them,"},{"kind":"text","text":"(Mgh,) or"},{"kind":"italic_en","text":"cry out against them, with thy forces riding and on foot."},{"kind":"text","text":"(Bd. But see another explanation in what follows.) And it is said in a wellknown prov.,"},{"kind":"arabic","text_bw":"jalabato jalobapF vum~a A^amosakato","text_ar":"جَلَبَتْ جَلْبَةً ثُمَّ اَمْسَكَتْ"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"i. e. a cloud ("},{"kind":"arabic","text_bw":"saHaAbap","text_ar":"سَحَابَة"},{"kind":"text","text":"),"},{"kind":"italic_en","text":"thundered, then refrained from raining:"},{"kind":"text","text":"applied to a coward, who threatens, and then is silent: but accord. to some, it is with"},{"kind":"arabic","text_bw":"H","text_ar":"ح"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"j","text_ar":"ج"},{"kind":"text","text":"(MF. See art."},{"kind":"arabic","text_bw":"Hlb","text_ar":"حلب"},{"kind":"text","text":".) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"jalaba","text_ar":"جَلَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He threatened with evil;"},{"kind":"text","text":"(K, TA;) followed by an accus. (TA) [or, app., by"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":"before the object]: or (so in the TA, but in some copies of the K “ and, ”)"},{"kind":"italic_en","text":"he collected a company, a troop,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an army."},{"kind":"text","text":"(K, TA.) [It is said that]"},{"kind":"arabic","text_bw":"Ealayohimo","text_ar":"عَلَيْهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"waA^ajolibo","text_ar":"وَاَجْلِبْ","orth_type":"arrow"},{"kind":"text","text":", in the Kur [xvii. 66], means"},{"kind":"italic_en","text":"And collect thou against them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thy forces"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and threaten them with evil."},{"kind":"text","text":"(TA. But see another explanation above.) And"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Ajlbw","text_ar":"اجلبو","orth_type":"arrow"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"They collected themselves together against him,"},{"kind":"text","text":"(S, K, *)"},{"kind":"italic_en","text":"and aided one another;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"AHlbwA","text_ar":"احلبوا"},{"kind":"text","text":". (S.) ―         -b3-"},{"kind":"arabic","text_bw":"jalaba","text_ar":"جَلَبَ"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jalobN","text_ar":"جَلْبٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He committed a crime against him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an offence for which he should be punished."},{"kind":"text","text":"(K, * TA.)       -A3-"},{"kind":"arabic","text_bw":"jalaba","text_ar":"جَلَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a wound)"},{"kind":"italic_en","text":"healed:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(an ulcer, As, or a wound, S)"},{"kind":"italic_en","text":"became covered with a skin in healing:"},{"kind":"text","text":"(As, S:) as also ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":". (S, L.) ―         -b2-  And"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(blood)"},{"kind":"italic_en","text":"dried; became dry;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Ajlb","text_ar":"اجلب","orth_type":"arrow"},{"kind":"text","text":". (Lh, K.)       -A4-"},{"kind":"arabic","text_bw":"jaliba","text_ar":"جَلِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[app. a company or troop]"},{"kind":"italic_en","text":"assembled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became collected together."},{"kind":"text","text":"(K.)"}],"source_refs":["S","A","Mgh","Msb","K","TA","KL","As"]}]}}