":"p"},{"role":"present_2mp","form":"تَخْفِضُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْفِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْفِض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْفِض","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْفِضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْفِضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْفِضانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْفِضا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْفِضُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْفِضُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْفِضْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"خَفَضْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَفَضْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْفِض","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْفِض","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":20},"lanes":{"found":true,"entry_ids":["","n11115"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%81%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to remain, abide, stay"},{"pos":"verb","gloss":"to lower, sink, let down, place lower","tags":["transitive"]},{"pos":"verb","gloss":"to humble, humiliate"},{"pos":"verb","gloss":"to lower (voice)","examples":[{"text":"اِخْفِضْ صَوْتَكَ!","english":"Lower your voice!"}]},{"pos":"verb","gloss":"to bend wood"},{"pos":"verb","gloss":"to walk slowly"},{"pos":"verb","gloss":"to put a word in the oblique case"},{"pos":"verb","gloss":"to be easy and comfortable"},{"pos":"verb","gloss":"to get circumcised (of a girl)"},{"pos":"verb","gloss":"to lower, to sink","tags":["transitive"]},{"pos":"verb","gloss":"to do or say anything gently or with moderation"},{"pos":"verb","gloss":"to lower the voice"},{"pos":"noun","gloss":"verbal noun of خَفَضَ (ḵafaḍa, “to lower”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of خَفُضَ (ḵafuḍa, “to be easy and comfortable, get circumcised”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"quiet, comfortable life"},{"pos":"noun","gloss":"ease and comfort, affluence"},{"pos":"noun","gloss":"humiliation"},{"pos":"noun","gloss":"low tone or voice"},{"pos":"noun","gloss":"measured walk"},{"pos":"noun","gloss":"oblique case"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11115","headword_ar":"خَفْضٌ","root":"xfD","body":[{"kind":"text","text":": [see"},{"kind":"arabic","text_bw":"xafaDa","text_ar":"خَفَضَ"},{"kind":"text","text":", (of which it is the inf. n.,) throughout. ―         -b2- ]"},{"kind":"italic_en","text":"A state of abatement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remissness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(A, TA:) (assumed tropical:)"},{"kind":"italic_en","text":"ease; repose; freedom from trouble or inconvenience, and toil or fatigue; tranquillity; quietness; quietude; stillness;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daEapN","text_ar":"دَعَةٌ"},{"kind":"text","text":"; (S, A, K;) and"},{"kind":"arabic","text_bw":"raAHapN","text_ar":"رَاحَةٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"sukuwnN","text_ar":"سُكُونٌ"},{"kind":"text","text":"; (TA;) of life: (Msb:) or"},{"kind":"italic_en","text":"ampleness of the circumstances"},{"kind":"text","text":"of life; (El-Marzookee, Msb;)"},{"kind":"italic_en","text":"plentifulness and pleasantness"},{"kind":"text","text":"thereof: (El-Marzookee:)"},{"kind":"italic_en","text":"softness, delicateness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easiness:"},{"kind":"text","text":"(A, TA:)"},{"kind":"italic_en","text":"pleasant life:"},{"kind":"text","text":"(L:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"xafiyDapN","text_ar":"خَفِيضَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"softness, delicateness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"easiness, of life; and ampleness of the circumstances thereof:"},{"kind":"text","text":"(TA:) and the former, (assumed tropical:)"},{"kind":"italic_en","text":"gentleness and easiness"},{"kind":"text","text":"of voice. (TA.) You say,"},{"kind":"arabic","text_bw":"humo fiY xafoDK","text_ar":"هُمْ فِى خَفْضٍ"},{"kind":"arabic","text_bw":"mina AlEayo$i","text_ar":"مِنَ العَيْشِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They are in an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a tranquil,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"a plentiful and pleasant,"},{"kind":"text","text":"or a"},{"kind":"italic_en","text":"soft"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"state of life."},{"kind":"text","text":"(S.) [This phrase is said in the A to be tropical; but why, I do not see; since"},{"kind":"arabic","text_bw":"xafoDN","text_ar":"خَفْضٌ"},{"kind":"text","text":"in the sense of"},{"kind":"arabic","text_bw":"daEapN","text_ar":"دَعَةٌ"},{"kind":"text","text":"is proper accord. to the same authority.] And"},{"kind":"arabic","text_bw":"huwa fiY xafoDi AlEayo$i","text_ar":"هُوَ فِى خَفْضِ العَيْشِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He is in an ample, and an easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a tranquil, state of life."},{"kind":"text","text":"(Msb.) And a poet says,"},{"kind":"quote","text":"laA yamonaEan~aka xafoDa AlEayo$i fiYdaEapK\n                      \n                     \n                        nuzuwEu nafosK A_ilaY A^aholK waA^awoTaAni\n                      \n                     \n                        taloqaY bikul~i bilaAdK A_ino Halalota bihaA\n                      \n                     \n                        A^aholFA biA^aholK wajiyraAnFA bijiyraAni"},{"kind":"text","text":"(Ham p. 137, and Sgh;) i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"Let not yearning of soul for family and homes prevent thee from enjoying"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"ampleness of the circumstances of life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"plentifulness and pleasantness thereof, in ease and tranquillity:"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thou wilt find in every country, if thou take up thine abode in it, a family for a family, and neighbours for neighbours:"},{"kind":"text","text":"] (ElMarzookee, MF:) another reading, which is"},{"kind":"page_break","n":774},{"kind":"text","text":"preferable, though each is allowable, is"},{"kind":"arabic","text_bw":"nizaAEu","text_ar":"نِزَاعُ"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"nuzuwEu","text_ar":"نُزُوعُ"},{"kind":"text","text":". (Ham ubi suprà.) ―         -b3-  [It is also used as an epithet; app. for"},{"kind":"arabic","text_bw":"*uw xfoDK","text_ar":"ذُو خفْضٍ"},{"kind":"text","text":".] You say,"},{"kind":"arabic","text_bw":"Eayo$N xafoDN","text_ar":"عَيْشٌ خَفْضٌ"},{"kind":"text","text":", (JK, TA,) and ↓"},{"kind":"arabic","text_bw":"xaAfiDN","text_ar":"خَافِضٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,) and ↓"},{"kind":"arabic","text_bw":"xafiyDN","text_ar":"خَفِيضٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"maxofuwDN","text_ar":"مَخْفُوضٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"An easy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a tranquil,"},{"kind":"text","text":"(JK, S, K, TA,)"},{"kind":"italic_en","text":"and plentiful,"},{"kind":"text","text":"(JK, TA,)"},{"kind":"italic_en","text":"and soft,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"delicate,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"life:"},{"kind":"text","text":"(JK, S, &c.:) and ↓"},{"kind":"arabic","text_bw":"maxofiDN","text_ar":"مَخْفِضٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"xafoDN","text_ar":"خَفْضٌ"},{"kind":"text","text":". (TA: there mentioned in the same place as here.) [It is said in the A, that"},{"kind":"arabic","text_bw":"Ey$","text_ar":"عيش"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"xAfD","text_ar":"خافض","orth_type":"arrow"},{"kind":"text","text":"is like"},{"kind":"arabic","text_bw":"Eiy$apN raADiyapN","text_ar":"عِيشَةٌ رَاضِيَةٌ"},{"kind":"text","text":", (meaning that it is for"},{"kind":"arabic","text_bw":"Eayo$N maxofuwDN","text_ar":"عَيْشٌ مَخْفُوضٌ"},{"kind":"text","text":",) and that it is tropical.] ―         -b4-  Also (tropical:)"},{"kind":"italic_en","text":"A gentle pace; contr. of"},{"kind":"arabic","text_bw":"rafoEN","text_ar":"رَفْعٌ"},{"kind":"text","text":"; (S, A, * K;) and so ↓"},{"kind":"arabic","text_bw":"maxofuwDN","text_ar":"مَخْفُوضٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, * A;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"marofuwEN","text_ar":"مَرْفُوعٌ"},{"kind":"text","text":". (A, TA.) [See"},{"kind":"arabic","text_bw":"xafaDati AlA_ibilu","text_ar":"خَفَضَتِ الاـِبِلُ"},{"kind":"text","text":".] ―         -b5-  Also"},{"kind":"italic_en","text":"Low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed,"},{"kind":"text","text":"land: (TA:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"xaAfiDapN","text_ar":"خَافِضَةٌ","orth_type":"arrow"},{"kind":"italic_en","text":"a low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, tract"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taloEapN muTomay^in~apN","text_ar":"تَلْعَةٌ مُطْمَيِنَّةٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of land:"},{"kind":"text","text":"(ISh, K:)"},{"kind":"arabic","text_bw":"raAfiEapN","text_ar":"رَافِعَةٌ"},{"kind":"text","text":"signifying [the contr., i. e.] a hard and elevated tract of land. (ISh.)"}],"source_refs":["A","TA","Msb","L","JK","S","K","ISh"]}]}}