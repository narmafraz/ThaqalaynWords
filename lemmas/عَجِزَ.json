{"lemma":"عَجِزَ","slug":"عَجِزَ","root":"ع.ج.ز","root_slug":"ع-ج-ز","root_link":"/words/roots/ع-ج-ز","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَجِزْتَ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَجِزْتِ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَجِزْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَجِزْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَجِزْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَجِزَ","in_corpus":true,"count":25,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَجِزَت","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَجِزا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَجِزَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَجِزُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَجِزْنَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْجَز","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْجَزِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْجَزِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْجَزا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْجَزانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْجَزُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْجَزُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْجَزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْجَز","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْجَز","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْجَزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْجَزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْجَزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْجَزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْجَزُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْجَزُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْجَزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَجِزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَجِزْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْجَز","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْجَز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":55,"cross_references":{"qac":{"found":true,"lemma_key":"عَجِزَ","root":"عجز","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":15},"lanes":{"found":true,"entry_ids":["n28142","n28143","n28144","n28145","n28146","n28147"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D8%AC%D9%90%D8%B2%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become behindhand, to lag","tags":["archaic"]},{"pos":"verb","gloss":"to fall short, to be incapable of, cannot","tags":["figuratively"]},{"pos":"verb","gloss":"to be weak","tags":["figuratively"]},{"pos":"noun","gloss":"verbal noun of عَجِزَ (ʕajiza)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"weakness"},{"pos":"verb","gloss":"to age"},{"pos":"verb","gloss":"to age","tags":["transitive"]},{"pos":"verb","gloss":"to withhold, to divert; to weaken, to make someone incapable of","tags":["transitive"]},{"pos":"verb","gloss":"to ascribe inability to someone","tags":["transitive"]},{"pos":"verb","gloss":"to utter the ending of (the verse)","tags":["transitive"]},{"pos":"noun","gloss":"sacrum","tags":["transitive"]},{"pos":"noun","gloss":"croup, hinder parts, posteriors, the body part between the two hips of man or beast","tags":["transitive"],"examples":[{"text":"ويقولون لما يجعل على عَجُز الفَرَس متّصلا بالسّرج شِلَال. والصّواب شَلِيلٌ.","english":"They say for what is applied upon the croup of a horse and connected with the saddle šilāl. But the correct is šalīl."}]},{"pos":"noun","gloss":"trunk of a palm-tree","tags":["transitive"]},{"pos":"noun","gloss":"the latter or last foot or word or hemistich of a verse, ending","tags":["transitive"]},{"pos":"noun","gloss":"plural of عَجُوز (ʕajūz)","tags":["form-of","plural","transitive"]}]},"etymology":null,"ipa":["/ʕa.d͡ʒa.za/","/ʕa.d͡ʒi.za/","/ʕad͡ʒz/","/ʕad͡ʒ.d͡ʒa.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28142","headword_ar":"عَجْزٌ","root":"Ejz","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":". ―         -b2-  Also, [said in the TA to be written by Sgh"},{"kind":"arabic","text_bw":"Eajaz","text_ar":"عَجَز"},{"kind":"text","text":", but it is written"},{"kind":"arabic","text_bw":"Eajoz","text_ar":"عَجْز"},{"kind":"text","text":"in the O, and is thus accord. to the K,]"},{"kind":"italic_en","text":"A disease in the hinder part of a horse"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, rendering him heavy."},{"kind":"text","text":"(O, K.)"}],"source_refs":[]},{"entry_id":"n28143","headword_ar":"عُجْزٌ","root":"Ejz","body":[{"kind":"italic_en","text":"Old age"},{"kind":"text","text":"of a woman: a simple subst. (TA.) You say,"},{"kind":"arabic","text_bw":"Ait~aqiY A@ll~`ha fiY $abiybatiki waEujoziki","text_ar":"اِتَّقِى ا@للّٰهَ فِى شَبِيبَتِكِ وَعُجْزِكِ"},{"kind":"italic_en","text":"Fear thou God in thy youth and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"thine old age,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"when thou becomest an old woman."},{"kind":"text","text":"(TA. [But"},{"kind":"arabic","text_bw":"At~q","text_ar":"اتّق"},{"kind":"text","text":"is there put for"},{"kind":"arabic","text_bw":"Ait~aqiY","text_ar":"اِتَّقِى"},{"kind":"text","text":": and in the explanation,"},{"kind":"arabic","text_bw":"taSiyru","text_ar":"تَصِيرُ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"taSiyriyna","text_ar":"تَصِيرِينَ"},{"kind":"text","text":". See"},{"kind":"arabic","text_bw":"Eajazato","text_ar":"عَجَزَتْ"},{"kind":"text","text":".])       -A2-  See also"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":". ―         -b2-  [And see"},{"kind":"arabic","text_bw":"Eajizato","text_ar":"عَجِزَتْ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n28144","headword_ar":"عِجْزٌ","root":"Ejz","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]},{"entry_id":"n28145","headword_ar":"عَجُزٌ","root":"Ejz","body":[{"kind":"text","text":"(S, A, O, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EajozN","text_ar":"عَجْزٌ","orth_type":"arrow"},{"kind":"text","text":"(O, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EujuzN","text_ar":"عُجُزٌ","orth_type":"arrow"},{"kind":"text","text":"(L, Msb) and ↓"},{"kind":"arabic","text_bw":"EujozN","text_ar":"عُجْزٌ","orth_type":"arrow"},{"kind":"text","text":"(O, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"EajizN","text_ar":"عَجِزٌ","orth_type":"arrow"},{"kind":"text","text":"(O, L, K) and ↓"},{"kind":"arabic","text_bw":"EijozN","text_ar":"عِجْزٌ","orth_type":"arrow"},{"kind":"text","text":", (K,) but the first form is the most chaste, (Msb,) fem. and masc., (S, O, Msb, K,) in the first of the following senses, i. e., in the general application; and in the second, or restricted application, fem., but made masc. by the Benoo- Temeem, (Msb,) or, accord. to El-Heythemee, fem. only, (TA,) The"},{"kind":"italic_en","text":"hinder part"},{"kind":"text","text":"of a thing; (S, A, O, L, Msb, K;) i. e., of anything: (Msb:) and particularly the"},{"kind":"italic_en","text":"hinder parts, posteriors, buttock,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buttocks, rump,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"croup,"},{"kind":"text","text":"(S, * O, *) or"},{"kind":"italic_en","text":"what is between the two hips,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"what is after the back,"},{"kind":"text","text":"(TA,) of a man, and of a woman; (S, Mgh, O, Msb, TA;) [and of a camel, &c.;] and ↓"},{"kind":"arabic","text_bw":"EajiyzapN","text_ar":"عَجِيزَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same, but of a woman only, (S, O, Msb, K,) in its proper application, though sometimes of a man also by way of comparison: (IAth, Mgh, TA:) pl. of"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":", (S, Msb, K,) and of its variants, (Msb, K,)"},{"kind":"arabic","text_bw":"A^aEojaAzN","text_ar":"اَعْجَازٌ"},{"kind":"text","text":", (S, Msb, K,) the only pl. form: (TA:) and of ↓"},{"kind":"arabic","text_bw":"EajiyzapN","text_ar":"عَجِيزَةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"EajiyzaAtN","text_ar":"عَجِيزَاتٌ"},{"kind":"text","text":": they do not say"},{"kind":"arabic","text_bw":"EajaAy^izu","text_ar":"عَجَايِزُ"},{"kind":"text","text":", [the regular form of pl. of"},{"kind":"arabic","text_bw":"Ejyzp","text_ar":"عجيزة"},{"kind":"text","text":",] for fear of confusion [as it is pl. of"},{"kind":"arabic","text_bw":"EajuwzN","text_ar":"عَجُوزٌ"},{"kind":"text","text":"or of"},{"kind":"arabic","text_bw":"EajuwzapN","text_ar":"عَجُوزَةٌ"},{"kind":"text","text":"]. (TA.) One says also,"},{"kind":"arabic","text_bw":"A_in~ahaA laEaZyimapu AlA^aEojaAzi","text_ar":"اـِنَّهَا لَعَظيِمَةُ الاَعْجَازِ"},{"kind":"italic_en","text":"Verily she is large in the hinder parts:"},{"kind":"text","text":"as though the term"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":"were applicable to every portion thereof. (Lh, TA.) And"},{"kind":"arabic","text_bw":"rakiba fiY AlT~alabi A^aEojaAza AlA_ibili","text_ar":"رَكِبَ فِى الطَّلَبِ اَعْجَازَ الاـِبِلِ"},{"kind":"italic_en","text":"He exposed himself, in seeking"},{"kind":"text","text":"[a thing],"},{"kind":"italic_en","text":"to abasement and difficulty and patient endurance, and exerted unsparingly his power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"not caring for undergoing long night-journeying."},{"kind":"text","text":"(TA.) Thus expl. in a saying of 'Alee:"},{"kind":"arabic","text_bw":"lanaA Haq~N A_ino nuEoTahu","text_ar":"لَنَا حَقٌّ اـِنْ نُعْطَهُ"},{"kind":"arabic","text_bw":"naA^oxu*ohu waA_ino numonaEohu narokabo A^aEojaAza AlA_ibili waA_ino TaAla","text_ar":"نَاْخُذْهُ وَاـِنْ نُمْنَعْهُ نَرْكَبْ اَعْجَازَ الاـِبِلِ وَاـِنْ طَالَ"},{"kind":"arabic","text_bw":"Als~uraY","text_ar":"السُّرَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is a right belonging to us: if we be given it, we take it: and if we be refused it, we expose ourselves to abasement,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"though the night-journeying be long"},{"kind":"text","text":"]: (O, * TA:) or, accord. to Az, he does not mean this, but alludes to others' having precedence in respect of his right, and his being himself kept back from it. (TA.) One also says,"},{"kind":"arabic","text_bw":"banuw fulaAnK yarokabuwna A^aEojaAza AlA_ibili","text_ar":"بَنُو فُلَانٍ يَرْكَبُونَ اَعْجَازَ الاـِبِلِ"},{"kind":"italic_en","text":"The sons of such a one are in a state of abasement, dependents of others:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"experience difficulties;"},{"kind":"text","text":"because the rump, or croup, of the camel is a difficult place to ride upon. (A.) And it is said by one of the wise, (Aktham Ibn-Seyfee, T, in TA, art."},{"kind":"arabic","text_bw":"dbr","text_ar":"دبر"},{"kind":"text","text":",)"},{"kind":"arabic","text_bw":"laA tadab~aruwA A^aEojaAza A^umuwrK qado wal~ato","text_ar":"لَا تَدَبَّرُوا اَعْجَازَ اُمُورٍ قَدْ وَلَّتْ"},{"kind":"arabic","text_bw":"SuduwruhaA","text_ar":"صُدُورُهَا"},{"kind":"text","text":", (TA, in this art., and O,) or"},{"kind":"arabic","text_bw":"laA tatadab~aruwA","text_ar":"لَا تَتَدَبَّرُوا"},{"kind":"text","text":", (T, in TA, art."},{"kind":"arabic","text_bw":"dbr","text_ar":"دبر"},{"kind":"text","text":",) (tropical:)  ["},{"kind":"italic_en","text":"Think ye not upon the ends of things whereof the beginnings have passed:"},{"kind":"text","text":"] meaning, when a thing has passed, make not your minds, or desires, to follow after it, regretting what has passed, but be consoled for it, placing your reliance upon God: (O, TA:) and, as IAth says, it is intended to incite to the consideration of the results, or issues, of affairs before the entering upon them. (TA.) [See also"},{"kind":"arabic","text_bw":"dab~ara","text_ar":"دَبَّرَ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"A^aEojaAzu naxolK","text_ar":"اَعْجَازُ نَخْلٍ"},{"kind":"text","text":"The"},{"kind":"italic_en","text":"trunks of palm-trees."},{"kind":"text","text":"(S, O, K.) [See Kur liv. 20 and lxix. 7.) And"},{"kind":"arabic","text_bw":"A^aEojaAzu AlS~il~iyaAni","text_ar":"اَعْجَازُ الصِّلِّيَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The stems of the"},{"kind":"arabic","text_bw":"Sil~iyaAn","text_ar":"صِلِّيَان"},{"kind":"text","text":"]. (AHn, M in art."},{"kind":"arabic","text_bw":"Sl","text_ar":"صل"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"last foot"},{"kind":"text","text":"of a verse; contr. of"},{"kind":"arabic","text_bw":"SadorN","text_ar":"صَدْرٌ"},{"kind":"text","text":". (TA.) And The"},{"kind":"italic_en","text":"latter hemistich"},{"kind":"text","text":"of a verse: the former hemistich is termed"},{"kind":"arabic","text_bw":"SadorN","text_ar":"صَدْرٌ"},{"kind":"text","text":". (O.) [And The"},{"kind":"italic_en","text":"last word"},{"kind":"text","text":"of a clause of rhyming"},{"kind":"page_break","n":1961},{"kind":"text","text":"prose. And the"},{"kind":"italic_en","text":"latter part"},{"kind":"text","text":"of a word.]       -A2-  See also"},{"kind":"arabic","text_bw":"EaAjizN","text_ar":"عَاجِزٌ"},{"kind":"text","text":".       -A3-"},{"kind":"arabic","text_bw":"A^ay~aAmu AlEajuzi","text_ar":"اَيَّامُ العَجُزِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajuwzN","text_ar":"عَجُوزٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","O","L","Msb","K","TA","Mgh","IAth"]},{"entry_id":"n28146","headword_ar":"عَجِزٌ","root":"Ejz","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"EaAjizN","text_ar":"عَاجِزٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n28147","headword_ar":"عُجُزٌ","root":"Ejz","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"EajuzN","text_ar":"عَجُزٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}