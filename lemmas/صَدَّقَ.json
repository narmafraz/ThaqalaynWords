ranslations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be truthful, to speak the truth","tags":["intransitive"],"examples":[{"text":"قَالَ سَنَنْظُرُ أَصَدَقْتَ أَمْ كُنْتَ مِنَ الْكَاذِبِينَ","english":"[Solomon] said, \"We will see whether you were truthful or were of the liars."}]},{"pos":"verb","gloss":"to tell (someone) the truth","tags":["ditransitive","transitive"],"examples":[{"text":"صَدِيقُكَ مَنْ صَدَقَكَ لَا مَنْ صَدَّقَكَ","english":"Your friend is he who is trustworthy, not he who trusts you."},{"text":"صَدَقَنِي القَوْلَ.","english":"He told me the truth in his speech."}]},{"pos":"verb","gloss":"to be sincere","tags":["ditransitive"],"examples":[{"text":"صَدَقَنِي النَّصِيحَة"}]},{"pos":"verb","gloss":"to prove true"},{"pos":"verb","gloss":"to become aware of"},{"pos":"verb","gloss":"to believe, to accept that (someone) is telling the truth"},{"pos":"verb","gloss":"to believe, to accept as true","examples":[{"text":"هل تقدر أن تصدِّق الكتاب المقدس؟","english":"Can you believe the Bible?"}]},{"pos":"verb","gloss":"to believe in","examples":[{"text":"وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ"},{"text":"إِنَّ سَعْيَكُمْ لَشَتَّى\n فَأَمَّا مَنْ أَعْطَى وَٱتَّقَى\n وَصَدَّقَ بِٱلْحُسْنَى\n فَسَنُيَسِّرُهُ لِلْيُسْرَى\n وَأَمَّا مَن بَخِلَ وَٱسْتَغْنَى\n وَكَذَّبَ بِٱلْحُسْنَى\n فَسَنُيَسِّرُهُ لِلْعُسْرَى","english":"Lo! your effort is dispersed (toward divers ends).\nAs for him who giveth and is dutiful (toward Allah)\nAnd believeth in goodness;\nSurely We will ease his way unto the state of ease.\nBut as for him who hoardeth and deemeth himself independent,\nAnd disbelieveth in goodness;\nSurely We will ease his way unto adversity."}]},{"pos":"verb","gloss":"to approve, to ratify"},{"pos":"noun","gloss":"verbal noun of صَدَقَ (ṣadaqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"truthfulness, sincerity, honesty"},{"pos":"adj","gloss":"true, truthful, sincere"},{"pos":"adj","gloss":"complete"}