alse,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَرَدَّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَرَدَّدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَرَدَّد","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَرَدَّد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَرَدَّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَرَدَّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَرَدَّدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَرَدَّدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَرَدَّدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَرَدَّدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَرَدَّدْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَتَرَدَّد","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَرَدَّد","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"تَرَدَّدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"تَرَدَّدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":12,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n15184"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B1%D9%8E%D8%AF%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be made to go back"},{"pos":"verb","gloss":"to return or come back again and again to"},{"pos":"verb","gloss":"to frequent"},{"pos":"verb","gloss":"to alternate, to move to and fro"},{"pos":"verb","gloss":"to hesitate, to be reluctant"},{"pos":"verb","gloss":"to waver, to vacillate"},{"pos":"verb","gloss":"to make repeated efforts"},{"pos":"verb","gloss":"to reiterate, to do repeatedly"},{"pos":"verb","gloss":"to be repeated frequently, to be reiterated"},{"pos":"verb","gloss":"to be frequently refused or repelled"},{"pos":"verb","gloss":"to remember or remind frequently"},{"pos":"noun","gloss":"verbal noun of تَرَدَّدَ (taraddada) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"reluctance, indecision, hesitation, wavering"},{"pos":"noun","gloss":"frequency"}]},"etymology":{"source":"wiktextract","text":"Compare رَدَّ (radda, “to return”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15184","headword_ar":"تردّد","root":"rd","body":[{"kind":"text","text":"quasi-pass. of 2; (S, L;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused, to return, go back, come back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"revert;"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, returned, went back, came back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reverted; much, frequently, again and again,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"time after time."},{"kind":"text","text":"(L.) You say,"},{"kind":"arabic","text_bw":"tarad~adotu A_ilaY fulaAnK","text_ar":"تَرَدَّدْتُ اـِلَى فُلَانٍ"},{"kind":"italic_en","text":"I returned time after time to such a one"},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"huwa yatarad~adu A_ilaY majaAlisi AlEilomi","text_ar":"هُوَ يَتَرَدَّدُ اـِلَى مَجَالِسِ العِلْمِ"},{"kind":"italic_en","text":"He repairs frequently to, or frequents, the assemblies of science;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"yaxotalifu","text_ar":"يَخْتَلِفُ"},{"kind":"text","text":". (A.) See also 6. ―         -b2-  [And as the returning repeatedly involves the going repeatedly, it signifies also, like"},{"kind":"arabic","text_bw":"Axtlf","text_ar":"اختلف"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, went,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moved, repeatedly, to and fro; so went and came;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reciprocated."},{"kind":"text","text":"Thus,]"},{"kind":"arabic","text_bw":"tarad~udu Al$~aYo'i AlmuEal~aqi fiY AlhawaA='i","text_ar":"تَرَدُّدُ الشَّىْءِ المُعَلَّقِ فِى الهَوَا=ءِ"},{"kind":"text","text":"[means"},{"kind":"italic_en","text":"The moving to and fro of a thing suspended in the air"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"*b","text_ar":"ذب"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"trd~dt Alr~uwHu","text_ar":"تردّدت الرُّوحُ"},{"kind":"italic_en","text":"The soul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spirit, went and came."},{"kind":"text","text":"(W p. 5.) ―         -b3-  [Hence,] (assumed tropical:)"},{"kind":"italic_en","text":"He wavered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vacillated,"},{"kind":"arabic","text_bw":"fiY Alr~aA^oYi","text_ar":"فِى الرَّاْىِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in opinion"},{"kind":"text","text":"]: (MA:) and"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the affair"},{"kind":"text","text":"], (S and K in art."},{"kind":"arabic","text_bw":"lv","text_ar":"لث"},{"kind":"text","text":", &c.,) and"},{"kind":"arabic","text_bw":"bayona A^amorayoni","text_ar":"بَيْنَ اَمْرَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"between two things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affairs"},{"kind":"text","text":"]. (S and K in art."},{"kind":"arabic","text_bw":"*b","text_ar":"ذب"},{"kind":"text","text":", &c.) And"},{"kind":"arabic","text_bw":"trd~d fiY SadoriY ka*aA","text_ar":"تردّد فِى صَدْرِى كَذَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Such a thing became agitated to and fro in my mind, or bosom"},{"kind":"text","text":"]. (TA in art."},{"kind":"arabic","text_bw":"rjE","text_ar":"رجع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"trd~d","text_ar":"تردّد"},{"kind":"text","text":"said of a man, (assumed tropical:)"},{"kind":"italic_en","text":"He was, or became, confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, so that he was unable to see his right course."},{"kind":"text","text":"(Bd and Jel in ix. 45.) [And (assumed tropical:)"},{"kind":"italic_en","text":"He laboured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exerted himself, as though going to and fro,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making repeated efforts,"},{"kind":"text","text":"in an affair: a meaning well known.] ―         -b4-  [And"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, repeated time after time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reiterated: it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, reproduced: it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, renewed."},{"kind":"text","text":"] You say,"},{"kind":"arabic","text_bw":"trd~d Sawotuhu fiY Haloqihi","text_ar":"تردّد صَوْتُهُ فِى حَلْقِهِ"},{"kind":"italic_en","text":"His voice was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, reiterated in his throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces."},{"kind":"text","text":"(The Lexicons passim.) And"},{"kind":"arabic","text_bw":"trd~dfiY AlfaA='i","text_ar":"تردّدفِى الفَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He reiterated in uttering the letter"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"; or, as the meaning is shown to be in the K in art."},{"kind":"arabic","text_bw":"fA^","text_ar":"فا"},{"kind":"text","text":","},{"kind":"italic_en","text":"he reiterated the letter"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"rad~ada AlfaA='a","text_ar":"رَدَّدَ الفَا=ءَ"},{"kind":"text","text":")]. (S in art."},{"kind":"arabic","text_bw":"fA^","text_ar":"فا"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"trd~A_","text_ar":"تردّاـ"},{"kind":"arabic","text_bw":"fiY AljawaAbi wataEav~ara lisaAnuhu","text_ar":"فِى الجَوَابِ وَتَعَثَّرَ لِسَانُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He reiterated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stam-"},{"kind":"italic_en","text":"mered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stuttered, in uttering the reply, and his tongue halted, faltered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hesitated"},{"kind":"text","text":"]. (A.)"}],"source_refs":["MA"]}]},"classical_definitions":null}