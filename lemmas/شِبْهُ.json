{"lemma":"شِبْهُ","slug":"شِبْهُ","root":"ش.ب.ه","root_slug":"ش-ب-ه","root_link":"/words/roots/ش-ب-ه","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"شِبْهُ","root":"شبه","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n21527","n21641","n21642"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%90%D8%A8%D9%92%D9%87%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"piece of alum","tags":["singulative"]},{"pos":"noun","gloss":"lass, kweng (i. q. شَابَّة (šābba))","tags":["rare"]},{"pos":"noun","gloss":"prance, a single act of the legs being lifted","tags":["rare"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21527","headword_ar":"شَبَّةٌ","root":"$b","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"burning, burning up, burning brightly"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fiercely, blazing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flaming,"},{"kind":"text","text":"of fire. (TA.)"}],"source_refs":[]},{"entry_id":"n21641","headword_ar":"شِبْهٌ","root":"$bh","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$abahN","text_ar":"شَبَهٌ","orth_type":"arrow"},{"kind":"text","text":"are syn., (S, Msb, K,) like"},{"kind":"arabic","text_bw":"mivolN","text_ar":"مِثْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mavalN","text_ar":"مَثَلٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bidolN","text_ar":"بِدْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"badalN","text_ar":"بَدَلٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"nikolN","text_ar":"نِكْلٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nakalN","text_ar":"نَكَلٌ"},{"kind":"text","text":", the only other instances of the kind, i. e. of words of both these measures, that have been heard, having the same meaning, (S and TA in art."},{"kind":"arabic","text_bw":"bdl","text_ar":"بدل"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"i. q."},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"$abiyhN","text_ar":"شَبِيهٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) syn."},{"kind":"arabic","text_bw":"mivolN","text_ar":"مِثْلٌ"},{"kind":"text","text":", (K,) [i. e.]"},{"kind":"italic_en","text":"A like; a similar person"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing;"},{"kind":"text","text":"(MA; Msb;) ["},{"kind":"italic_en","text":"an analogue; a match;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a fellow:"},{"kind":"text","text":"(MA:) pl. (of all, TA)"},{"kind":"arabic","text_bw":"A^a$obaAhN","text_ar":"اَشْبَاهٌ"},{"kind":"text","text":". (K, TA.) One says,"},{"kind":"arabic","text_bw":"h`*aA","text_ar":"هٰذَا"},{"kind":"arabic","text_bw":"$ibohuhu","text_ar":"شِبْهُهُ"},{"kind":"text","text":"[and ↓"},{"kind":"arabic","text_bw":"$abahuhu","text_ar":"شَبَهُهُ","orth_type":"arrow"},{"kind":"text","text":"], i. e. ↓"},{"kind":"arabic","text_bw":"$abiyhuhu","text_ar":"شَبِيهُهُ","orth_type":"arrow"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"This is the like,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"fulaAnN $ibohuka","text_ar":"فُلَانٌ شِبْهُكَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$abahuka","text_ar":"شَبَهُكَ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$abiyhuka","text_ar":"شَبِيهُكَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one is the like,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of thee"},{"kind":"text","text":"]. (JK.) [And ↓"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ","orth_type":"arrow"},{"kind":"italic_en","text":"This is like him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"And hence, in lexicology,"},{"kind":"arabic","text_bw":"AlA^a$obaAhu waAln~aZaAy^iru","text_ar":"الاَشْبَاهُ وَالنَّظَايِرُ"},{"kind":"italic_en","text":"The words that are alike in form:"},{"kind":"text","text":"generally applied to rare instances.] ―         -b2-  See also the next paragraph, in two places."}],"source_refs":["S","Msb","K","MA"]},{"entry_id":"n21642","headword_ar":"شَبَهٌ","root":"$bh","body":[{"kind":"text","text":": see the next preceding paragraph, in three places. ―         -b2-  [Hence,]"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"$akolN","text_ar":"شَكْلٌ"},{"kind":"text","text":"[signifying"},{"kind":"italic_en","text":"A likeness, resemblance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"semblance,"},{"kind":"text","text":"as meaning"},{"kind":"italic_en","text":"something resembling"},{"kind":"text","text":"]; (AA, K and TA in art."},{"kind":"arabic","text_bw":"$kl","text_ar":"شكل"},{"kind":"text","text":";) and ↓"},{"kind":"arabic","text_bw":"$ubohapN","text_ar":"شُبْهَةٌ","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"mivolN","text_ar":"مِثْلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the same sense"},{"kind":"text","text":"]: (K in the present art.: [see exs. of the latter voce"},{"kind":"arabic","text_bw":"EuqorN","text_ar":"عُقْرٌ"},{"kind":"text","text":":]) pl. of the former [in this sense, as is indicated in the S,] ↓"},{"kind":"arabic","text_bw":"ma$aAbihu","text_ar":"مَشَابِهُ","orth_type":"arrow"},{"kind":"text","text":", contr. to rule, like"},{"kind":"arabic","text_bw":"maHaAsinu","text_ar":"مَحَاسِنُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ma*aAkiyru","text_ar":"مَذَاكِيرُ"},{"kind":"text","text":"; (S, TA;) or this is a pl. having no proper sing. (TA.) One says,"},{"kind":"arabic","text_bw":"bayonahumaA $abahN","text_ar":"بَيْنَهُمَا شَبَهٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Between them two is a likeness,"},{"kind":"text","text":"&c.]. (S,) And"},{"kind":"arabic","text_bw":"nazaEa A_ilaY A^abiyhi fiY Al$~abahi","text_ar":"نَزَعَ اـِلَى اَبِيهِ فِى الشَّبَهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He inclined to his father in likeness"},{"kind":"text","text":"]. (S, in art."},{"kind":"arabic","text_bw":"nzE","text_ar":"نزع"},{"kind":"text","text":".) And a poet cited by IAar says,"},{"kind":"quote","text":"A^aSobaHa fiyhi $abahN mino A^um~ihi\n                      \n                     \n                        mino EiZami Alr~aA^osi wamino xuroTum~ihi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He became so that there was in him a resemblance of his mother, in respect of bigness of the head, and of his nose"},{"kind":"text","text":"]. (TA.) And one says also,"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"bihi $ubohapN","text_ar":"بِهِ شُبْهَةٌ","orth_type":"arrow"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"mivolN","text_ar":"مِثْلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"In him is a likeness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"something having a likeness, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (TK.) ―         -b3-  Also, (JK, S, Msb, K, &c.,) and ↓"},{"kind":"arabic","text_bw":"$ibohN","text_ar":"شِبْهٌ","orth_type":"arrow"},{"kind":"text","text":", (JK, S, K,) and ↓"},{"kind":"arabic","text_bw":"$abahaAnN","text_ar":"شَبَهَانٌ","orth_type":"arrow"},{"kind":"text","text":", (K, TA, but not in the CK,) ["},{"kind":"italic_en","text":"A sort of fine brass;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a metal resembling gold in its colour,"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"highest in quality of"},{"kind":"arabic","text_bw":"Sufor","text_ar":"صُفْر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"brass"},{"kind":"text","text":"]; (Msb;)"},{"kind":"italic_en","text":"yellow"},{"kind":"arabic","text_bw":"nuHaAs","text_ar":"نُحَاس"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"a sort of"},{"kind":"arabic","text_bw":"nuHaAs","text_ar":"نُحَاس"},{"kind":"text","text":"(JK, T, S, M *)"},{"kind":"italic_en","text":"rendered yellow by the addition of an alloy"},{"kind":"text","text":"(lit."},{"kind":"italic_en","text":"a medicament"},{"kind":"text","text":"): (T, M, * TA:) so called because resembling gold in its colour: (M, TA:) pl."},{"kind":"arabic","text_bw":"A^a$obaAhu","text_ar":"اَشْبَاهُ"},{"kind":"text","text":". (K.) One says"},{"kind":"arabic","text_bw":"kuwzu","text_ar":"كُوزُ"},{"kind":"arabic","text_bw":"$abahK","text_ar":"شَبَهٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$ibohK","text_ar":"شِبْهٍ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A mug of"},{"kind":"arabic","text_bw":"$bh","text_ar":"شبه"},{"kind":"text","text":"]. (S.)       -A2-  See also"},{"kind":"arabic","text_bw":"$abahaAnN","text_ar":"شَبَهَانٌ"},{"kind":"text","text":"."}],"source_refs":["S","JK","K","M","TA"]}]}}