rm":"خَشِيْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَشِيْتُ","in_corpus":true,"count":6,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":71,"cross_references":{"qac":{"found":true,"lemma_key":"خَشِيَ","root":"خشي","pos":"V","occurrence_count":40},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n10724","n10729"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B4%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to fear","examples":[{"text":"خَشِيَ الطَّالِبُ الامْتِحَانَ.","english":"The student feared the exam."},{"text":"مَّنْ خَشِيَ الرَّحْمَٰنَ بِالْغَيْبِ وَجَاءَ بِقَلْبٍ مُّنِيبٍ","english":"who were in awe of the Most Compassionate without seeing ˹Him˺, and have come with a heart turning ˹only to Him˺."}]}]},"etymology":null,"ipa":["/xa.ʃi.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10724","headword_ar":"خَشِىَ","root":"x$Y","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxo$aY","text_ar":"يَخْشَى"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xa$oyapN","text_ar":"خَشْيَةٌ"},{"kind":"text","text":"(JK, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"xa$oYN","text_ar":"خَشْىٌ"},{"kind":"text","text":"(JK, M, K) and"},{"kind":"arabic","text_bw":"xi$oYN","text_ar":"خِشْىٌ"},{"kind":"text","text":"(Sgh, K) [the second and third erroneously written in the CK"},{"kind":"arabic","text_bw":"xa$FA","text_ar":"خَشًا"},{"kind":"text","text":"and (by indication)"},{"kind":"arabic","text_bw":"xi$FA","text_ar":"خِشًا"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"xa$aApN","text_ar":"خَشَاةٌ"},{"kind":"text","text":"(M, K) and"},{"kind":"arabic","text_bw":"xa$oyaAnN","text_ar":"خَشْيَانٌ"},{"kind":"text","text":", (JK, M, K,) though it has been said that the only instances of this kind are"},{"kind":"arabic","text_bw":"$anoA=nN","text_ar":"شَنْا=نٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lay~aAnN","text_ar":"لَيَّانٌ"},{"kind":"text","text":", [see the former of these two,] but in one copy of the M found written"},{"kind":"arabic","text_bw":"xi$oyaAnN","text_ar":"خِشْيَانٌ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"maxo$aApN","text_ar":"مَخْشَاةٌ"},{"kind":"text","text":"(JK, M, K) and"},{"kind":"arabic","text_bw":"maxo$iyapN","text_ar":"مَخْشِيَةٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He feared;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"xaAfa","text_ar":"خَافَ"},{"kind":"text","text":": (JK, S, M, Msb, K:) or, accord. to Er-Rághib and others,"},{"kind":"italic_en","text":"he dreaded;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feared with reverence, veneration, respect, honour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"awe."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"xa$iyahu","text_ar":"خَشِيَهُ"},{"kind":"italic_en","text":"He feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he dreaded him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"feared him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, with reverence,"},{"kind":"text","text":"&c.;] as also ↓"},{"kind":"arabic","text_bw":"tx$~Ahu","text_ar":"تخشّاهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) [And"},{"kind":"arabic","text_bw":"xa$iYa minohu","text_ar":"خَشِىَ مِنْهُ"},{"kind":"text","text":", meaning the same: or"},{"kind":"italic_en","text":"He feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dreaded, what might happen to him from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"xa$iYa Ealayohi $ayoy^FA","text_ar":"خَشِىَ عَلَيْهِ شَيْيًا"},{"kind":"italic_en","text":"He feared,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dreaded, for him a thing."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"faEalotu *`lika xa$aApa A^ano yakuwna ka*aA","text_ar":"فَعَلْتُ ذٰلِكَ خَشَاةَ اَنْ يَكُونَ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I did that in fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dread, that such a thing might happen"},{"kind":"text","text":"]. (IAar, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xa$ayotuhu","text_ar":"خَشَيْتُهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"Hope."},{"kind":"text","text":"(Er-Rághib, TA.) And the saying of Ibn-'Abbás to 'Omar,"},{"kind":"arabic","text_bw":"laqado A^akovarota mina Ald~uEaA='i","text_ar":"لَقَدْ اَكْثَرْتَ مِنَ الدُّعَا=ءِ"},{"kind":"arabic","text_bw":"biAlmawoti Hat~aY xa$iytu A^ano yakuwna *`lika A^asohala laka Einoda","text_ar":"بِالمَوْتِ حَتَّى خَشِيتُ اَنْ يَكُونَ ذٰلِكَ اَسْهَلَ لَكَ عِنْدَ"},{"kind":"arabic","text_bw":"nuzuwlihi","text_ar":"نُزُولِهِ"},{"kind":"text","text":", is explained as meaning ["},{"kind":"italic_en","text":"Verily thou hast prayed much for death, so that"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I hope [that it may be easier to thee when it happens]."},{"kind":"text","text":"(TA.) ―         -b3-  And sometimes"},{"kind":"arabic","text_bw":"xa$iytu","text_ar":"خَشِيتُ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"Ealimotu","text_ar":"عَلِمْتُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I knew,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"know"},{"kind":"text","text":"]. (Msb.) So it is said to mean in the saying of the poet."},{"kind":"quote","text":"walaqado xa$iytu biA^a mano tabiEa AlhudaY\n                      \n                     \n                        skana AljinaAna maEa Aln~abiY~i muHam~adi"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And I know assuredly that he who follows the right direction shall dwell in the gardens"},{"kind":"text","text":"of Paradise"},{"kind":"italic_en","text":"with the Prophet Mohammad"},{"kind":"text","text":"]: (S, TA:) or the meaning may be,"},{"kind":"italic_en","text":"I hope."},{"kind":"text","text":"(TA.) ―         -b4-  In the saying in the Kur [xviii. 79],"},{"kind":"arabic","text_bw":"faxa$iynaA","text_ar":"فَخَشِينَا"},{"kind":"arabic","text_bw":"A^ano yurohiqahumaA TugoyaAnFA wakuforFA","text_ar":"اَنْ يُرْهِقَهُمَا طُغْيَانًا وَكُفْرًا"},{"kind":"text","text":", the meaning is said, by Akh, to be"},{"kind":"italic_en","text":"And we disapproved [that he should make excessive disobedience, and ingratitude, to come upon them twain];"},{"kind":"text","text":"(S;) and so says Zj, explaining it as the saying of El-Khidr: or, accord. to Fr, the meaning is,"},{"kind":"italic_en","text":"and we knew."},{"kind":"text","text":"(TA. [See also"},{"kind":"arabic","text_bw":"A^azohaqa","text_ar":"اَزْهَقَ"},{"kind":"text","text":".])       -A2-"},{"kind":"arabic","text_bw":"xaA$aAniY faxa$ayotuhu","text_ar":"خَاشَانِى فَخَشَيْتُهُ"},{"kind":"text","text":": see 3."}],"source_refs":["JK","S","M","Msb","K","Sgh","TA"]},{"entry_id":"n10729","headword_ar":"خَشِىٌّ","root":"x$Y","body":[{"kind":"italic_en","text":"Dry;"},{"kind":"text","text":"(As, JK, S, K;) like"},{"kind":"arabic","text_bw":"Ha$iY~N","text_ar":"حَشِىٌّ"},{"kind":"text","text":"; (As, S;) applied to herbage; (As, S;) or to herbs and trees: (JK:) or"},{"kind":"italic_en","text":"dry and rotten."},{"kind":"text","text":"(IAar, TA.) A rájiz says, (S,) namely, Sakhr, (TA,)"},{"kind":"quote","text":"sam~u *araAriyHa riTaAbK waxa$iYo"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Poison of moist cantharides, and dry"},{"kind":"text","text":"]; (S, TA;) meaning"},{"kind":"arabic","text_bw":"waxa$iY~K","text_ar":"وَخَشِىٍّ"},{"kind":"text","text":", suppressing one of the two"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"s by poetic license. (IB, TA.)"}],"source_refs":["JK","S","TA"]}]}}