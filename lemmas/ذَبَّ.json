],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n13654"],"search_url":"https://lanelexicon.com/?s=%D8%B0%D9%8E%D8%A8%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"plural of ذُبَابَة (ḏubāba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13654","headword_ar":"ذَبٌّ","root":"*b","body":[{"kind":"italic_en","text":"Repelling:"},{"kind":"text","text":"fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": hence"},{"kind":"arabic","text_bw":"*ab~aAtu","text_ar":"ذَبَّاتُ"},{"kind":"arabic","text_bw":"Als~abiybi","text_ar":"السَّبِيبِ"},{"kind":"text","text":", a phrase used by Dhu-r-Rummeh, meaning"},{"kind":"italic_en","text":"repelling with their tails:"},{"kind":"text","text":"or this may be from the signification next following. (Ham p. 510.)       -A2-"},{"kind":"italic_en","text":"Much in motion."},{"kind":"text","text":"(Ham ubi suprà.)"},{"kind":"arabic","text_bw":"*ab~N","text_ar":"ذَبٌّ"},{"kind":"text","text":", (M, L,) or ↓"},{"kind":"arabic","text_bw":"*aAb~N","text_ar":"ذَابٌّ","orth_type":"arrow"},{"kind":"text","text":", (K,) [the former correct, and perhaps the latter also,] applied to a camel,"},{"kind":"italic_en","text":"That does not,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will not, remain still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless, in a place."},{"kind":"text","text":"(M, L, K.) A poet says,"},{"kind":"quote","text":"fakaA^an~anaA fiyhimo jimaAlN *ab~apN"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And it was as though we were, among them, camels that would not remain still in a place"},{"kind":"text","text":"]: which shows that"},{"kind":"arabic","text_bw":"*ab~N","text_ar":"ذَبٌّ"},{"kind":"text","text":"is not an inf. n. used as an epithet; for, were it so, he had said"},{"kind":"arabic","text_bw":"jimaAlN *ab~N","text_ar":"جِمَالٌ ذَبٌّ"},{"kind":"text","text":". (M, L.) ―         -b2-"},{"kind":"arabic","text_bw":"Al*~ab~u","text_ar":"الذَّبُّ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The wild bull;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a species of bovine antelope;"},{"kind":"text","text":"] also called"},{"kind":"arabic","text_bw":"*ab~u Alr~iyaAdi","text_ar":"ذَبُّ الرِّيَادِ"},{"kind":"text","text":"; (T, S, M, K;) so called because he goes to and fro, not remaining in one place; (M;) or because he pastures going to and fro; (T, S, * M;) or because his females pasture with him, going to and fro: (T:) and called also ↓"},{"kind":"arabic","text_bw":"AlA^a*ab~u","text_ar":"الاَذَبُّ","orth_type":"arrow"},{"kind":"text","text":", (T, K,) by poetic license, for"},{"kind":"arabic","text_bw":"Al*~ab~u","text_ar":"الذَّبُّ"},{"kind":"text","text":"; (T;) and ↓"},{"kind":"arabic","text_bw":"Al*~unobubu","text_ar":"الذُّنْبُبُ","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b3-"},{"kind":"arabic","text_bw":"*ab~u Alr~iyaAdi","text_ar":"ذَبُّ الرِّيَادِ"},{"kind":"text","text":"is also applied to (tropical:)  A man"},{"kind":"italic_en","text":"who goes and comes."},{"kind":"text","text":"(Kr, M, TA.) And (tropical:)  A man"},{"kind":"italic_en","text":"who is in the habit of visiting women."},{"kind":"text","text":"(AA, T, K.)"}],"source_refs":["M","L","K","T"]}]},"classical_definitions":null}