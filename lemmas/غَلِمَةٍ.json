{"lemma":"غَلِمَةٍ","slug":"غَلِمَةٍ","root":"غ.ل.م","root_slug":"غ-ل-م","root_link":"/words/roots/غ-ل-م","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n32305"],"search_url":"https://lanelexicon.com/?s=%D8%BA%D9%8E%D9%84%D9%90%D9%85%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be gripped with lust, to be sexually excited"},{"pos":"adj","gloss":"sexually excited, lustful, aroused"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n32305","headword_ar":"غُلْمَةٌ","root":"glm","body":[{"kind":"text","text":", (S, Msb, K, TA, &c.,) written by some"},{"kind":"arabic","text_bw":"gilomapN","text_ar":"غِلْمَةٌ"},{"kind":"text","text":", [like a pl. of"},{"kind":"arabic","text_bw":"gulaAmN","text_ar":"غُلَامٌ"},{"kind":"text","text":",] is expl. by a number of authors as signifying"},{"kind":"italic_en","text":"Lust, appetence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carnal desire:"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eager desire, of"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"experienced by"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"gilomaAn","text_ar":"غِلْمَان"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"young men"},{"kind":"text","text":"]: (TA:) or it signifies"},{"kind":"italic_en","text":"vehement lust"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appetence:"},{"kind":"text","text":"(Msb:) it is also of women, (K and TA in art."},{"kind":"arabic","text_bw":"trj","text_ar":"ترج"},{"kind":"text","text":",) meaning their"},{"kind":"italic_en","text":"lust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appetence:"},{"kind":"text","text":"(TA ibid.:) [and] it is used [also] in relation to a camel, signifying his"},{"kind":"italic_en","text":"lust to cover."},{"kind":"text","text":"(S, K, TA.) [See also 1, where it is mentioned as an inf. n. In the K, voce"},{"kind":"arabic","text_bw":"qaEirapN","text_ar":"قَعِرَةٌ"},{"kind":"text","text":", it is used as meaning The"},{"kind":"italic_en","text":"gratification of venereal lust."},{"kind":"text","text":"]"}],"source_refs":["TA","Msb"]}]},"classical_definitions":null}