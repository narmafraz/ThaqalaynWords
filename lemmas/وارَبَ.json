nes_definition":{"source":"lanes","entries":[{"entry_id":"n41821","headword_ar":"وارب","root":"wrb","body":[{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"muwaArabapN","text_ar":"مُوَارَبَةٌ"},{"kind":"italic_en","text":"He strove to outwit, deceive, beguile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumvent"},{"kind":"text","text":"[another]: syn."},{"kind":"arabic","text_bw":"daAhaY","text_ar":"دَاهَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xaAtala","text_ar":"خَاتَلَ"},{"kind":"text","text":". (K.) Accord. to IAth, it is from"},{"kind":"arabic","text_bw":"Alwarabu","text_ar":"الوَرَبُ"},{"kind":"text","text":"“ the being corrupt: ” or it may be from"},{"kind":"arabic","text_bw":"AlArb","text_ar":"الارب"},{"kind":"text","text":"“ intelligence, &c.; ” the"},{"kind":"arabic","text_bw":"A^","text_ar":"ا"},{"kind":"text","text":"being changed into"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":". The latter is the opinion of AM. (L.) ―         -b2-  One of the sages says,"},{"kind":"arabic","text_bw":"muwaArabapu","text_ar":"مُوَارَبَةُ"},{"kind":"arabic","text_bw":"AlA^ariybi jaholN waEanaA'N","text_ar":"الاَرِيبِ جَهْلٌ وَعَنَاءٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The striving to outwit the cunning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intelligent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sagacious, is ignorance and labour without profit"},{"kind":"text","text":"]. (TA.) [See art."},{"kind":"arabic","text_bw":"A^rb","text_ar":"ارب"},{"kind":"text","text":", where this saying, but with"},{"kind":"arabic","text_bw":"mw^Arbp","text_ar":"مواربة"},{"kind":"text","text":"in the place of"},{"kind":"arabic","text_bw":"mwArbp","text_ar":"مواربة"},{"kind":"text","text":", is given as a trad.] ―         -b3-  It is said in a trad.,"},{"kind":"arabic","text_bw":"A_ino baAyaEotahumo waArabuwka","text_ar":"اـِنْ بَايَعْتَهُمْ وَارَبُوكَ"},{"kind":"text","text":", i. e.,"},{"kind":"arabic","text_bw":"xaAdaEuwka","text_ar":"خَادَعُوكَ"},{"kind":"text","text":","},{"kind":"italic_en","text":"If thou buy and sell with them, they will deceive thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavour to deceive the."},{"kind":"text","text":"(IAth.)"}],"source_refs":[]}]},"classical_definitions":null}