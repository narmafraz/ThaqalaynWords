{"lemma":"حَدِّ","slug":"حَدِّ","root":"ح.د.د","root_slug":"ح-د-د","root_link":"/words/roots/ح-د-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":7,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":39},"lanes":{"found":true,"entry_ids":["n7265","n7270","n7271","n7272"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AF%D9%90%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to prevent, to restrain, to check, to hinder","examples":[{"text":"حَدَّ اللَّهُ عَنَّا الشَّرَّ","english":"God protected us from evil"}]},{"pos":"verb","gloss":"to restrict, to limit, to confine"},{"pos":"verb","gloss":"to stop, to halt"},{"pos":"verb","gloss":"to delineate, to delimit (esp. land)"},{"pos":"verb","gloss":"to define (a word)"},{"pos":"verb","gloss":"to sharpen (a knife, etc.)"},{"pos":"verb","gloss":"to punish, to chastise"},{"pos":"verb","gloss":"to fix (one's gaze)"},{"pos":"verb","gloss":"to separate"},{"pos":"verb","gloss":"to deprive (someone) of their livelihood"},{"pos":"verb","gloss":"to remove all ornaments and wear mourning apparel"},{"pos":"verb","gloss":"to mourn"},{"pos":"verb","gloss":"to be sharp, to be cutting (of a knife)"},{"pos":"verb","gloss":"to be strong (of a smell)"},{"pos":"verb","gloss":"to be strong, to be active (of a person)"},{"pos":"verb","gloss":"to be sharp, to be intelligent (of a person)"},{"pos":"verb","gloss":"to be quick to anger (of a person)"},{"pos":"verb","gloss":"to fly into a rage against, to be angry or furious with"},{"pos":"noun","gloss":"verbal noun of حَدَّ (ḥadda) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"limit"},{"pos":"noun","gloss":"boundary, border"},{"pos":"noun","gloss":"frontier"},{"pos":"noun","gloss":"term"},{"pos":"noun","gloss":"end, goal, aim"},{"pos":"noun","gloss":"district"},{"pos":"noun","gloss":"reach, sphere of action"},{"pos":"noun","gloss":"difference"},{"pos":"noun","gloss":"definition"},{"pos":"noun","gloss":"rule"},{"pos":"noun","gloss":"punishment"},{"pos":"noun","gloss":"edge, point"},{"pos":"noun","gloss":"passion"},{"pos":"noun","gloss":"intoxicating strength of liquors"},{"pos":"noun","gloss":"strength, bravery"},{"pos":"noun","gloss":"energy"},{"pos":"noun","gloss":"manner, way"},{"pos":"noun","gloss":"hindrance"},{"pos":"noun","gloss":"side","tags":["Arabic","Modern","Standard"]},{"pos":"adj","gloss":"violent, passionate"}]},"etymology":null,"ipa":["/ħad.da/","/ħadd/","/ħid/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7265","headword_ar":"حَدَّ","root":"Hd","body":[{"kind":"text","text":", (A, Mgh, Msb,) aor."},{"kind":"text","text":", (Mgh, TA,) inf. n."},{"kind":"arabic","text_bw":"Had~q","text_ar":"حَدّق"},{"kind":"text","text":", (S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, prevented, hindered, impeded, withheld, restrained, debarred, inhibited, forbade, prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interdicted"},{"kind":"text","text":": (S, A, Mgh, Msb, K, TA:) this is the primary signification: (Mgh:) and"},{"kind":"italic_en","text":"he repelled, turned away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"averted,"},{"kind":"text","text":"(L, K, TA,) evil [or the like], and also a person from a thing, good or evil. (L.) You say,"},{"kind":"arabic","text_bw":"Had~a Alr~ajula Eani AlA^amori","text_ar":"حَدَّ الرَّجُلَ عَنِ الاَمْرِ"},{"kind":"italic_en","text":"He prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hindered,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"restrained, the man from the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Hadadotu fulAnFA Eani Al$~ar~i","text_ar":"حَدَدْتُ فُلانًا عَنِ الشَّرِّ"},{"kind":"italic_en","text":"I prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hindered, such a one from"},{"kind":"text","text":"["},{"kind":"italic_en","text":"falling into"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"preserved him from, evil."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"qado Had~a A@ll~`hu *`lika","text_ar":"قَدْ حَدَّ ا@للّٰهُ ذٰلِكَ"},{"kind":"arabic","text_bw":"Ean~aA","text_ar":"عَنَّا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"God hath forbidden us that"},{"kind":"text","text":"]. (S.) And"},{"kind":"arabic","text_bw":"Aall~`hum~a A@Hoduwdohu","text_ar":"اَللّٰهُمَّ ا@حْدُودْهُ"},{"kind":"text","text":"(T, A, L)"},{"kind":"italic_en","text":"O God, prevent him from hitting the mark"},{"kind":"text","text":": said with reference to a man shooting, or casting a missile weapon, or the like. (T, L.) And"},{"kind":"arabic","text_bw":"Hud~a","text_ar":"حُدَّ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withheld, from obtaining good fortune, success,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what he desired"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sought."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Had~a A@ll~`hu Ean~aA","text_ar":"حَدَّ ا@للّٰهُ عَنَّا"},{"kind":"arabic","text_bw":"$ar~a fulaAnK","text_ar":"شَرَّ فُلَانٍ"},{"kind":"italic_en","text":"May God repel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avert, from us, the evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief, of such a one."},{"kind":"text","text":"(L.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Had~ahu","text_ar":"حَدَّهُ"},{"kind":"text","text":", (S, L, Msb,) aor."},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":", (L, Msb, K,)"},{"kind":"italic_en","text":"He inflicted upon him the castigation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punishment, termed"},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":"; (S, L;)"},{"kind":"italic_en","text":"he inflicted upon him"},{"kind":"text","text":"(namely, a criminal or an offender [against the law],)"},{"kind":"italic_en","text":"a castigation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punishment, that should prevent him from returning to his crime"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence, and that should prevent others from committing such a crime"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such an offence"},{"kind":"text","text":": (K, * TA:)"},{"kind":"italic_en","text":"he inflicted upon him a flogging."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"Had~a $ayoy^FA mino gayorihi","text_ar":"حَدَّ شَيْيًا مِنْ غَيْرِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"Hd~dhu","text_ar":"حدّدهُ","orth_type":"arrow"},{"kind":"text","text":"; (L;)"},{"kind":"italic_en","text":"He distinguished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"separated by some mark"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"note,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"notes, a thing from another thing."},{"kind":"text","text":"(L, K. *) And"},{"kind":"arabic","text_bw":"Had~a Ald~aAra","text_ar":"حَدَّ الدَّارَ"},{"kind":"text","text":", aor. and inf. n. as above; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"H~ddhA","text_ar":"حّددها","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHodiydN","text_ar":"تَحْدِيدٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He distinguished the house from the parts adjoining it, by mentioning"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"defining"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its limits."},{"kind":"text","text":"Msb.)       -A2-  [And hence,"},{"kind":"arabic","text_bw":"Had~a","text_ar":"حَدَّ"},{"kind":"text","text":"in logic, inf. n."},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"He defined"},{"kind":"text","text":"a word; as also ↓"},{"kind":"arabic","text_bw":"Hd~d","text_ar":"حدّد","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHodiydN","text_ar":"تَحْدِيدٌ"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"Had~a","text_ar":"حَدَّ"},{"kind":"text","text":", (L, Msb, K,) aor."},{"kind":"text","text":", (L, Msb,) inf. n."},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":"; (L;) and ↓"},{"kind":"arabic","text_bw":"Hd~d","text_ar":"حدّد","orth_type":"arrow"},{"kind":"text","text":", (S, L, Msb, K,) [which is more common,] inf. n."},{"kind":"arabic","text_bw":"taHodiydN","text_ar":"تَحْدِيدٌ"},{"kind":"text","text":"; (S;) and ↓"},{"kind":"arabic","text_bw":"AHd~","text_ar":"احدّ","orth_type":"arrow"},{"kind":"text","text":", (S, L, K,) which is the form preferred by Lh, (L,) inf. n."},{"kind":"arabic","text_bw":"A_iHodaAdN","text_ar":"اـِحْدَادٌ"},{"kind":"text","text":"; (S;) and ↓"},{"kind":"arabic","text_bw":"AstHd~","text_ar":"استحدّ","orth_type":"arrow"},{"kind":"text","text":"; (As, S, L;)"},{"kind":"italic_en","text":"He edged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sharpened,"},{"kind":"text","text":"a knife, (L, K,) a blade, (S,) a sword, (L, Msb,) or anything blunt, (L,) [and"},{"kind":"italic_en","text":"pointed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made sharp-pointed,"},{"kind":"text","text":"an arrow-head or the like,]"},{"kind":"italic_en","text":"with a stone"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"file."},{"kind":"text","text":"(L, K.) ―         -b3-  [And hence,]"},{"kind":"arabic","text_bw":"Had~a baSarahu A_ilayohi","text_ar":"حَدَّ بَصَرَهُ اـِلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (Lh, L;) and ↓"},{"kind":"arabic","text_bw":"AHd~hu","text_ar":"احدّهُ","orth_type":"arrow"},{"kind":"text","text":", (L,) or"},{"kind":"arabic","text_bw":"AHd~ Aln~aZara Alyh","text_ar":"احدّ النَّظَرَ اليه"},{"kind":"text","text":"; (S, Msb;) and ↓"},{"kind":"arabic","text_bw":"Hd~dhu","text_ar":"حدّدهُ","orth_type":"arrow"},{"kind":"text","text":"; (K in art."},{"kind":"arabic","text_bw":"ltA^","text_ar":"لتا"},{"kind":"text","text":", &c.;) (tropical:)"},{"kind":"italic_en","text":"He looked sharply at him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(L;) or"},{"kind":"italic_en","text":"intently,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"attentively."},{"kind":"text","text":"(Msb.)       -A3-"},{"kind":"arabic","text_bw":"Had~ato","text_ar":"حَدَّتْ"},{"kind":"text","text":", (S, Mgh, L, K,) or"},{"kind":"arabic","text_bw":"Had~ato EalaY zawojihaA","text_ar":"حَدَّتْ عَلَى زَوْجِهَا"},{"kind":"text","text":", (Msb,) aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HidaAdN","text_ar":"حِدَادٌ"},{"kind":"text","text":"(S, Mgh, L, Msb, K) and"},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"AHd~t","text_ar":"احدّت","orth_type":"arrow"},{"kind":"text","text":", (As, S, A, Mgh, L, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_iHodaAdN","text_ar":"اـِحْدَادٌ"},{"kind":"text","text":"; (Mgh, Msb;) the former the more common in the language of the Arabs, but the latter preferred by the early grammarians, (Fr, TA,) and the only form known to As, (S,) who rejected the former; (Msb;)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"abstained from the wearing of ornaments,"},{"kind":"text","text":"(A 'Obeyd, S, A, Mgh, L, Msb, K,)"},{"kind":"italic_en","text":"and the use of perfumes,"},{"kind":"text","text":"(L,)"},{"kind":"italic_en","text":"and dye for the hands"},{"kind":"text","text":"&c., (S, Mgh,)"},{"kind":"italic_en","text":"because forbidden such things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"because she forbade herself,"},{"kind":"text","text":"(Mgh,)"},{"kind":"italic_en","text":"and put on the garments of mourning,"},{"kind":"text","text":"(A,)"},{"kind":"italic_en","text":"after the death of her husband,"},{"kind":"text","text":"(S, Mgh,) or"},{"kind":"italic_en","text":"on account of the death of her husband,"},{"kind":"text","text":"(A 'Obeyd, A, Msb,)"},{"kind":"italic_en","text":"for the period called"},{"kind":"arabic","text_bw":"AlEid~ap","text_ar":"العِدَّة"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"she mourned for her husband, and put on the garments of mourning, and abstained from the wearing of ornaments, and the use dye for the hands"},{"kind":"text","text":"&c. (L.) The epithets applied to a woman in this case are ↓"},{"kind":"arabic","text_bw":"HaAd~N","text_ar":"حَادٌّ","orth_type":"arrow"},{"kind":"text","text":"(S, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"muHid~N","text_ar":"مُحِدٌّ","orth_type":"arrow"},{"kind":"text","text":"(S, A, Mgh, L, Msb, K) and ↓"},{"kind":"arabic","text_bw":"muHid~apN","text_ar":"مُحِدَّةٌ","orth_type":"arrow"},{"kind":"text","text":"also, but the first [always] without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":", (Msb,) or both more chaste without"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (TA.)       -A4-"},{"kind":"arabic","text_bw":"Had~a","text_ar":"حَدَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Hid~apN","text_ar":"حِدَّةٌ"},{"kind":"text","text":"; (S, L, Msb, K;) and ↓"},{"kind":"arabic","text_bw":"AHtd~","text_ar":"احتدّ","orth_type":"arrow"},{"kind":"text","text":"; (L, K;) [and app. ↓"},{"kind":"arabic","text_bw":"AnHd~","text_ar":"انحدّ","orth_type":"arrow"},{"kind":"text","text":", q. v.;]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a sword, S Msb, and a knife, L, K, [or the like,] and a canine tooth, L)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"edged,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"sharp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pointed."},{"kind":"text","text":"(S, L, Msb, K.) ―         -b2-  [And hence,]"},{"kind":"arabic","text_bw":"Had~a","text_ar":"حَدَّ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Hid~apN","text_ar":"حِدَّةٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sharp"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"effective"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in respect of eloquence,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of intellect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"of anger."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Had~a Ealayohi","text_ar":"حَدَّ عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (S, L, K,) inf. n."},{"kind":"arabic","text_bw":"Hid~apN","text_ar":"حِدَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":", (S, L,) (tropical:)"},{"kind":"italic_en","text":"He became excited against him by sharpness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hastiness, of temper; by irascibility, passionateness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"angriness;"},{"kind":"text","text":"(Ks, S, L, K;) as also"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AHtd~","text_ar":"احتدّ","orth_type":"arrow"},{"kind":"text","text":": (TA:) and"},{"kind":"arabic","text_bw":"Had~a Ealayohi","text_ar":"حَدَّ عَلَيْهِ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"HadadN","text_ar":"حَدَدٌ"},{"kind":"text","text":"; (L, K;) and ↓"},{"kind":"arabic","text_bw":"Hd~d","text_ar":"حدّد","orth_type":"arrow"},{"kind":"text","text":", (accord. to some copies of the K,) and ↓"},{"kind":"arabic","text_bw":"AHtd~","text_ar":"احتدّ","orth_type":"arrow"},{"kind":"text","text":", (S, [in which it is not followed by"},{"kind":"arabic","text_bw":"Elyh","text_ar":"عليه"},{"kind":"text","text":",] A, L, K,) and ↓"},{"kind":"arabic","text_bw":"AstHd~","text_ar":"استحدّ","orth_type":"arrow"},{"kind":"text","text":"; (L, K;) (tropical:)"},{"kind":"italic_en","text":"he was angry with him;"},{"kind":"text","text":"(S, * A, L, K;) but Az remarks upon the last of these verbs as not heard from the Arabs of classical times in this sense: (L:) and"},{"kind":"arabic","text_bw":"bihimo","text_ar":"بِهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHd~d","text_ar":"تحدّد","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he became exasperated by them:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tHr~$","text_ar":"تحرّش"},{"kind":"text","text":". (AZ, L.)"}],"source_refs":["A","Mgh","Msb","TA","S","K","L","T","As","Fr"]},{"entry_id":"n7270","headword_ar":"حَدْ","root":"Hd","body":[{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"A^aHadN","text_ar":"اَحَدٌ"},{"kind":"text","text":", in the phrase"},{"kind":"arabic","text_bw":"yaA Hado raA=haA","text_ar":"يَا حَدْ رَا=هَا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^aHadN","text_ar":"اَحَدٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"AHd","text_ar":"احد"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n7271","headword_ar":"حَدٌّ","root":"Hd","body":[{"kind":"italic_en","text":"Prevention, hinderance, an impediment, a withholding, restraint, a debarring, inhibition, forbiddance, prohibition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interdiction;"},{"kind":"text","text":"(S, Mgh, L, Msb, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"HadadN","text_ar":"حَدَدٌ","orth_type":"arrow"},{"kind":"text","text":": (S, L, K:) and, both words,"},{"kind":"italic_en","text":"a repelling,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an averting."},{"kind":"text","text":"(K. [See 1.]) A poet says, (S,) namely, Zeyd Ibn-' Amr Ibn-Nufeyl, (TA,)"},{"kind":"quote","text":"laA taEobudan~a A_il`hFA gayora xaAliqikumo\n                      \n                     ↓ \n      waA_ino duEiytumo faquwluwA duwnahu Hadadu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Ye shall by no means worship any deity except your Creator; and if ye be invited"},{"kind":"text","text":"to do so,"},{"kind":"italic_en","text":"say ye, There is an impediment in the way of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a prohibition against it"},{"kind":"text","text":"]. (S, TA.) And one says, ↓"},{"kind":"arabic","text_bw":"duwna maA saA^alota Eanohu HadadN","text_ar":"دُونَ مَا سَاَلْتَ عَنْهُ حَدَدٌ","orth_type":"arrow"},{"kind":"text","text":"(A, * L)"},{"kind":"italic_en","text":"There is an impediment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a prohibition, in the way of that respecting which thou hast asked."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"laAHadada","text_ar":"لَاحَدَدَ","orth_type":"arrow"},{"kind":"italic_en","text":"There is nothing to prevent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hinder, one from it."},{"kind":"text","text":"(L. [But this admits of another meaning, as will be seen, under the word"},{"kind":"arabic","text_bw":"HadadN","text_ar":"حَدَدٌ"},{"kind":"text","text":", below.]) ―         -b2-  [Hence,]"},{"kind":"italic_en","text":"A restrictive ordinance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"statute,"},{"kind":"text","text":"of God,"},{"kind":"italic_en","text":"respecting things lawful and things unlawful:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"HuduwdN","text_ar":"حُدُودٌ"},{"kind":"text","text":". (L.) The"},{"kind":"arabic","text_bw":"Huduwd","text_ar":"حُدُود"},{"kind":"text","text":"of God are of two kinds: first, those"},{"kind":"italic_en","text":"ordinances prescribed to men"},{"kind":"text","text":"(T, Mgh, L)"},{"kind":"italic_en","text":"respecting eatables and drinkables and marriages"},{"kind":"text","text":"&c.;"},{"kind":"italic_en","text":"what are lawful thereof and what are unlawful:"},{"kind":"text","text":"(T, L:) the second kind,"},{"kind":"italic_en","text":"castigations,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punishments, prescribed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, to be inflicted upon him who does that which he has been forbidden to do;"},{"kind":"text","text":"(T, Mgh, L;) as the"},{"kind":"arabic","text_bw":"Hd~","text_ar":"حدّ"},{"kind":"text","text":"of the thief, which is the cutting off of his right hand for stealing a thing of the value of a quarter of a deenár or more; and that of the fornicator or fornicatress, which is flogging with a hundred stripes and banishment for a year; and that of the adulterer or adulteress, which is stoning; and that of the person who [falsely] charges an honest or a married woman with adultery, which is flogging with eighty stripes [as is also that of the person who has committed the crime of drunkenness]: (T, L:) the first kind are called"},{"kind":"arabic","text_bw":"Hdwd","text_ar":"حدود"},{"kind":"text","text":"because they denote limits which God has forbidden to transgress: the second, because they prevent one's committing again those acts for which they are appointed as punishments; (T, Mgh, L;) or because the limits thereof are determined: (Mgh:) the latter kind of"},{"kind":"arabic","text_bw":"Hd~","text_ar":"حدّ"},{"kind":"text","text":"is also explained as being"},{"kind":"italic_en","text":"that"},{"kind":"text","text":"["},{"kind":"italic_en","text":"castigation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punishment,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"which prevents the criminal from returning to his crime, and prevents others from committing his crime."},{"kind":"text","text":"(L, K. *)"},{"kind":"arabic","text_bw":"lawo raA^ayotahu EalaY Had~K","text_ar":"لَوْ رَاَيْتَهُ عَلَى حَدٍّ"},{"kind":"text","text":", in a saying of ' Omar, means"},{"kind":"italic_en","text":"Hadst thou seen him engaged in an affair requiring the infliction of the"},{"kind":"arabic","text_bw":"Hd~","text_ar":"حدّ"},{"kind":"text","text":". (Mgh.) ―         -b3-"},{"kind":"italic_en","text":"A bar, an obstruction, a partition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a separation,"},{"kind":"text","text":"(S, A, Mgh, L, Msb, * K,)"},{"kind":"italic_en","text":"between two things,"},{"kind":"text","text":"(S, A, L, K,) or"},{"kind":"italic_en","text":"between two places,"},{"kind":"text","text":"(Mgh,) [or"},{"kind":"italic_en","text":"between two persons,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"to prevent their commixture,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confusion, or the encroachment of one upon the other:"},{"kind":"text","text":"(L:) an inf. n. used as a subst.: (Mgh:) pl."},{"kind":"arabic","text_bw":"HuduwdN","text_ar":"حُدُودٌ"},{"kind":"text","text":". (L.) ―         -b4-"},{"kind":"italic_en","text":"A limit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boundary,"},{"kind":"text","text":"of a land or territory: pl. as above. (L.) [Hence,"},{"kind":"arabic","text_bw":"jaAwaza AlHad~a","text_ar":"جَاوَزَ الحَدَّ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, exceeded the proper, due,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"common, limit; was excessive, immoderate, beyond measure, enormous, inordinate,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exorbitant."},{"kind":"text","text":"] ―         -b5-  [And hence, in logic, (assumed tropical:)"},{"kind":"italic_en","text":"A definition."},{"kind":"text","text":"] It is applied by the learned to the"},{"kind":"arabic","text_bw":"Haqiyqap","text_ar":"حَقِيقَة"},{"kind":"text","text":"of a thing, [or"},{"kind":"italic_en","text":"that by being which a thing is what it is,"},{"kind":"text","text":"] because it is [a term] collective and restrictive. (Mgh.) ―         -b6-  The"},{"kind":"italic_en","text":"end, extremity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"utmost point,"},{"kind":"text","text":"of a thing: (S, L, K:) pl. as above. (L.) ―         -b7-  [(assumed tropical:)  The"},{"kind":"italic_en","text":"point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verge,"},{"kind":"text","text":"of an event.] The saying"},{"kind":"arabic","text_bw":"musolimapN mawoquwfapN EalaY Had~i maHoramK","text_ar":"مُسْلِمَةٌ مَوْقُوفَةٌ عَلَى حَدِّ مَحْرَمٍ"},{"kind":"text","text":"means (assumed tropical:)"},{"kind":"italic_en","text":"A Muslimeh brought to the point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verge, of being subjected to an infidel's lying with her:"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"musolimN mawoquwfN EalaY Had~i kuforK","text_ar":"مُسْلِمٌ مَوْقُوفٌ عَلَى حَدِّ كُفْرٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A Muslim brought,"},{"kind":"text","text":"by beating or slaughter,"},{"kind":"italic_en","text":"to"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the point,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verge, of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"denying God."},{"kind":"text","text":"(Mgh.) ―         -b8-  The"},{"kind":"italic_en","text":"edge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"extremity of the edge,"},{"kind":"text","text":"(S, L,) and"},{"kind":"italic_en","text":"point,"},{"kind":"text","text":"(L,) of anything, (S, L,) as of a sword, a knife, a spear-head, and an arrow: (L:) the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"of a sword [&c.]"},{"kind":"italic_en","text":"with which one cuts:"},{"kind":"text","text":"(MF:) pl. as above. (L.) ―         -b9-  See also"},{"kind":"arabic","text_bw":"Hid~apN","text_ar":"حِدَّةٌ"},{"kind":"text","text":", in four places. ―         -b10-  [And hence, app.,]"},{"kind":"italic_en","text":"Arms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weapons;"},{"kind":"text","text":"as in the phrase"},{"kind":"arabic","text_bw":"*awuw Had~K","text_ar":"ذَوُو حَدٍّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Possessors of arms"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weapons:"},{"kind":"text","text":"or this may mean (tropical:)"},{"kind":"italic_en","text":"persons endowed with valour"},{"kind":"text","text":"]. (Ham p. 143.) ―         -b11-"},{"kind":"italic_en","text":"A side, region, quarter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tract."},{"kind":"text","text":"(L.) ―         -b12-  (assumed tropical:)"},{"kind":"italic_en","text":"Station, standing, rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"marotabapN","text_ar":"مَرْتَبَةٌ"},{"kind":"text","text":". (KL.) ―         -b13-  [(assumed tropical:)"},{"kind":"italic_en","text":"A case:"},{"kind":"text","text":"as when a noun is said to be"},{"kind":"arabic","text_bw":"fiY Had~i Alr~afoEi","text_ar":"فِى حَدِّ الرَّفْعِ"},{"kind":"italic_en","text":"in the nominative case."},{"kind":"text","text":"―         -b14-  And (assumed tropical:)"},{"kind":"italic_en","text":"A class,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"category:"},{"kind":"text","text":"as when a verb is said to be"},{"kind":"arabic","text_bw":"mino Had~i Daraba","text_ar":"مِنْ حَدِّ ضَرَبَ"},{"kind":"italic_en","text":"of the class,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"category, of"},{"kind":"arabic","text_bw":"Daraba","text_ar":"ضَرَبَ"},{"kind":"text","text":".] ―         -b15-  [(tropical:)"},{"kind":"italic_en","text":"A quarter"},{"kind":"text","text":"of the year.] You say,"},{"kind":"arabic","text_bw":"A^aqaAma Had~a Alr~abiyEi","text_ar":"اَقَامَ حَدَّ الرَّبِيعِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He remained, stayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, during the quarter of the"},{"kind":"arabic","text_bw":"rbyE","text_ar":"ربيع"},{"kind":"text","text":". (A.)       -A2-  See also"},{"kind":"arabic","text_bw":"maHoduwdN","text_ar":"مَحْدُودٌ"},{"kind":"text","text":"."}],"source_refs":["S","L","K","TA","T","Mgh","A","MF"]},{"entry_id":"n7272","headword_ar":"حُدٌّ","root":"Hd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"maHoduwdN","text_ar":"مَحْدُودٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}