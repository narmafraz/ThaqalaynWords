{"lemma":"شَمْسٌ","slug":"شَمْسٌ","root":"ش.م.س","root_slug":"ش-م-س","root_link":"/words/roots/ش-م-س","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"شَمْس","root":"شمس","pos":"N","occurrence_count":33},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":8},"lanes":{"found":true,"entry_ids":["n22994","n22995"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D9%85%D9%92%D8%B3%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"sun","examples":[{"text":"تُشْرِقُ ٱلشَّمْسُ كُلَّ صَبَاحٍ وَتُنِيرُ ٱلْعَالَمَ بِنُورِهَا.","english":"The sun rises every morning and illuminates the world with its light."}]},{"pos":"verb","gloss":"to be headstrong, to be restive"},{"pos":"verb","gloss":"to be sunny"},{"pos":"verb","gloss":"to expose to the sun, to sun-dry"},{"pos":"verb","gloss":"to worship the sun"},{"pos":"verb","gloss":"to perform the office of deacon"},{"pos":"verb","gloss":"to frighten"},{"pos":"noun","gloss":"verbal noun of شَمِسَ (šamisa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Inherited from Proto-Semitic *śamš-."},"ipa":["/ʃams/","/ʃa.ma.sa/","/ʃa.mi.sa/","/ʃam.ma.sa/","/ʃa.mas/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22994","headword_ar":"شَمَسَ","root":"$ms","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"$umuwsN","text_ar":"شُمُوسٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"$amisa","text_ar":"شَمِسَ"},{"kind":"text","text":", aor"},{"kind":"text","text":"(K) and"},{"kind":"text","text":"also, like"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafoDulu","text_ar":"يَفْضُلُ"},{"kind":"text","text":", accord. to the lexicologists, as ISd says, but he holds the aor. of"},{"kind":"arabic","text_bw":"$amisa","text_ar":"شَمِسَ"},{"kind":"text","text":"to be"},{"kind":"text","text":"[only]; (TA;) and ↓"},{"kind":"arabic","text_bw":"A$ms","text_ar":"اشمس","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a day)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, sunny,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sunshiny; it had sun,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sunshine:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"it had sun,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sunshine, all the daytime:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, clear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unobscured:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"its sun was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vehement."},{"kind":"text","text":"(IF, Msb.)       -A2-"},{"kind":"arabic","text_bw":"$amasa","text_ar":"شَمَسَ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":"(Msb, TA) and"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"$umuwsN","text_ar":"شُمُوسٌ"},{"kind":"page_break","n":1597},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$imaAsN","text_ar":"شِمَاسٌ"},{"kind":"text","text":", (S, Msb, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"refused to be ridden"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"took fright and broke loose and ran away, refusing to be ridden, by reason of the vehemence of his force of resistance,"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"li$id~api mtEbh","text_ar":"لِشِدَّةِ متعبه"},{"kind":"text","text":"in the TA, I read"},{"kind":"arabic","text_bw":"l$d~p","text_ar":"لشدّة"},{"kind":"arabic","text_bw":"manaEatihi","text_ar":"مَنَعَتِهِ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"and his sharpness of temper, so that he would not remain still:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"became rebellious against his rider."},{"kind":"text","text":"(Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"$amasati","text_ar":"شَمَسَتِ"},{"kind":"arabic","text_bw":"AlmaroA^apu","text_ar":"المَرْاَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The woman abstained from looking at men, and from exciting their desire."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"$amasa liY fulaAnN","text_ar":"شَمَسَ لِى فُلَانٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such a one showed enmity to me:"},{"kind":"text","text":"(K: *) or"},{"kind":"italic_en","text":"showed his enmity to me,"},{"kind":"text","text":"(T, S, A,)"},{"kind":"italic_en","text":"and almost made it to take effect,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"as though he purposed to act:"},{"kind":"text","text":"(T, TA:) or"},{"kind":"arabic","text_bw":"$amasa","text_ar":"شَمَسَ"},{"kind":"arabic","text_bw":"fiY fulaAnK","text_ar":"فِى فُلَانٍ"},{"kind":"text","text":"signifies, [unless"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"text","text":"be a mistake for"},{"kind":"arabic","text_bw":"liY","text_ar":"لِى"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fulaAnK","text_ar":"فُلَانٍ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"he showed his enmity"},{"kind":"text","text":"["},{"kind":"italic_en","text":"towards such a one"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"and could not conceal it."},{"kind":"text","text":"(M in TA.) [See also 3.] ―         -b4-  And"},{"kind":"arabic","text_bw":"Alxamoru ta$omusu","text_ar":"الخَمْرُ تَشْمُسُ"},{"kind":"arabic","text_bw":"biSaAHibihaA","text_ar":"بِصَاحِبِهَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Wine overcomes, and runs away with, its drinker."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA","T","A"]},{"entry_id":"n22995","headword_ar":"شمّس","root":"$ms","body":[{"kind":"text","text":", (TK,) inf. n."},{"kind":"arabic","text_bw":"ta$omiysN","text_ar":"تَشْمِيسٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He worshipped the sun."},{"kind":"text","text":"(K, TK.)       -A2-  And"},{"kind":"italic_en","text":"He spread"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"in the sun,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sunshine,"},{"kind":"text","text":"(K, TK,)"},{"kind":"italic_en","text":"in order that it might dry."},{"kind":"text","text":"(TA.)"}],"source_refs":["TK","K"]}]},"classical_definitions":null}