يَّلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخَيَّلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخَيِّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُخَيَّلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُخَيِّل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخَيِّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خُيِّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خُيِّلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخَيَّل","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخَيَّل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خَيَّلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَيَّلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":true,"lemma_key":"خُيِّلَ","root":"خيل","pos":"N","occurrence_count":5},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n11873","n11874"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D9%8A%D9%90%D9%91%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"horses","tags":["collective"]},{"pos":"noun","gloss":"verbal noun of خَالَ (ḵāla) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to make believe, to pretend, to suggest"},{"pos":"verb","gloss":"to imagine, to fancy, to think","examples":[{"text":"خُيِّلَ إِلَيْهِ أَنْ","english":"he imagined, fancied, thought that; it seemed, it appeared to him that …"},{"text":"ومن ذلك قولهم: يخال لي أن الأمر كذا بفتح الياء أو ضمها على أن الفعل مجرَّد أو من باب أفعل مبنيًّا للمجهول، وكلاهما غير صواب؛ لأن خال المجرَّد لا يكون إلا متعديًا؛ تقول: خلت الأمر كذا ولا تقول خال لي الأمر، وأخال لا يكون إلا لازمًا؛ تقول: أخال الأمرُ إخالةً: إذا اشتبه والتبس، وهو أمرٌ مُخيل. والصواب: يُخيَّل إليَّ أن الأمر كذا، من باب التفعيل، وقد خُيِّل إليَّ أنه كذا بالبناء فيهما للمجهول."}]}]},"etymology":null,"ipa":["/xajl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11873","headword_ar":"خَيْلٌ","root":"xyl","body":[{"kind":"italic_en","text":"Horses,"},{"kind":"text","text":"(JK, S, K,)"},{"kind":"italic_en","text":"collectively;"},{"kind":"text","text":"(JK, K;) as some say, (Msb,) applied to"},{"kind":"italic_en","text":"Arabian horses and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"such as are of inferior breed, termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"baraA*iyn","text_ar":"بَرَاذِين"},{"kind":"text","text":"; (Mgh, Msb;) the"},{"kind":"italic_en","text":"males thereof"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"females:"},{"kind":"text","text":"(Mgh, TA: *) but of the fem. gender: (Msb, TA:) a quasi-pl. n., (Mgh,) having no sing. (Msb, K) formed of the same radical letters: (Msb:) or the sing. is ↓"},{"kind":"arabic","text_bw":"xaAy^ilN","text_ar":"خَايِلٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) so called because of their"},{"kind":"arabic","text_bw":"AixotiyaAl","text_ar":"اِخْتِيَال"},{"kind":"text","text":", (Msb, K, * TA, *) i. e. pride and self-conceit, (Msb,) in their gait: so says AO; but ISd says that this is not well known: (TA:) or because no one rides a horse without experiencing a feeling of pride: (Er-Rághib, TA:) pl., (Msb, CK,) or pl. pl., (so in copies of the K and in the TA,) [of mult.,]"},{"kind":"arabic","text_bw":"xuyuwlN","text_ar":"خُيُولٌ"},{"kind":"text","text":"(S, * Msb, K) and"},{"kind":"arabic","text_bw":"xiyuwlN","text_ar":"خِيُولٌ"},{"kind":"text","text":"and [pl. of pauc.]"},{"kind":"arabic","text_bw":"A^axoyaAlN","text_ar":"اَخْيَالٌ"},{"kind":"text","text":". (K.) And the dual form is used, [although"},{"kind":"arabic","text_bw":"xayolN","text_ar":"خَيْلٌ"},{"kind":"text","text":"has a pl. signification,] like as are [the duals"},{"kind":"arabic","text_bw":"A_ibilaAni","text_ar":"اـِبِلَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ganamaAni","text_ar":"غَنَمَانِ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"liqaAHaAni","text_ar":"لِقَاحَانِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jimaAlaAni","text_ar":"جِمَالَانِ"},{"kind":"text","text":". (ISd, TA.) One says,"},{"kind":"arabic","text_bw":"fulaAnN laAtusaAyaru xayolaAhu","text_ar":"فُلَانٌ لَاتُسَايَرُ خَيْلَاهُ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"laAtuwaAqafu","text_ar":"لَاتُوَاقَفُ"},{"kind":"text","text":", (K, TA,) and"},{"kind":"arabic","text_bw":"laAtusaAyaru xayolaAhu walaA tuwaAqafu","text_ar":"لَاتُسَايَرُ خَيْلَاهُ وَلَا تُوَاقَفُ"},{"kind":"text","text":", (TA, and so in the CK,) ["},{"kind":"italic_en","text":"Such a one, his two troops of horses will not be competed with in going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"running, nor in standing still,"},{"kind":"text","text":"] meaning (tropical:)"},{"kind":"italic_en","text":"he is not to be endured in respect of calumny and lying:"},{"kind":"text","text":"(K, TA:) it is said of a great, or frequent, liar. (TA in art."},{"kind":"arabic","text_bw":"syr","text_ar":"سير"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"Alxayolu A^aEolamu mino furosaAnihaA","text_ar":"الخَيْلُ اَعْلَمُ مِنْ فُرْسَانِهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The horses are more knowing than their riders"},{"kind":"text","text":"]; (Meyd, K;) a prov., (Meyd,) applied in relation to him of whom thou formest an opinion (Meyd, K, TA) that he possesses, or possesses not, what suffices, (TA,) and whom thou findest to be as thou thoughtest, (Meyd, K, TA,) or the contrary. (Meyd.) And"},{"kind":"arabic","text_bw":"Alxayolu A^aEolamu bafurosaAnihaA","text_ar":"الخَيْلُ اَعْلَمُ بَفُرْسَانِهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The horses are possessed of most knowledge of their riders"},{"kind":"text","text":"]; a prov., meaning (assumed tropical:)  seek thou aid of him who knows the case, or affair. (Meyd.) And"},{"kind":"arabic","text_bw":"Alxayolu","text_ar":"الخَيْلُ"},{"kind":"arabic","text_bw":"tajoriY EalaY masaAwiyhaA","text_ar":"تَجْرِى عَلَى مَسَاوِيهَا"},{"kind":"text","text":", another prov. [explained in art."},{"kind":"arabic","text_bw":"swA^","text_ar":"سوا"},{"kind":"text","text":"]. (Meyd.) ―         -b2-  Also"},{"kind":"italic_en","text":"Horsemen,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"riders on horses."},{"kind":"text","text":"(S, Msb, K.) Thus in the Kur [xvii. 66],"},{"kind":"arabic","text_bw":"waA^ajolibo Ealayohimo bixayolika wa rajolika","text_ar":"وَاَجْلِبْ عَلَيْهِمْ بِخَيْلِكَ وَ رَجْلِكَ"},{"kind":"text","text":". (S. [See 1 in art."},{"kind":"arabic","text_bw":"jlb","text_ar":"جلب"},{"kind":"text","text":".])       -A2-  See also"},{"kind":"arabic","text_bw":"xuyalaA='u","text_ar":"خُيَلَا=ءُ"},{"kind":"text","text":"."}],"source_refs":["JK","S","K","Msb","TA","Mgh","CK","Meyd"]},{"entry_id":"n11874","headword_ar":"خَيَلٌ","root":"xyl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xuyalaA='u","text_ar":"خُيَلَا=ءُ"},{"kind":"text","text":"."}],"source_refs":[]}]}}