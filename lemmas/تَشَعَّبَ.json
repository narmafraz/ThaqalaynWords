s":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَتَشَعَّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَتَشَعَّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَتَشَعَّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَتَشَعَّب","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَتَشَعَّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَتَشَعَّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَتَشَعَّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَتَشَعَّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَتَشَعَّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَتَشَعَّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَتَشَعَّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَتَشَعَّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَشَعَّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"تَشَعَّبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"تَشَعَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":8,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n22428"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B4%D9%8E%D8%B9%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to diverge, to branch, to fork"},{"pos":"noun","gloss":"verbal noun of تَشَعَّبَ (tašaʕʕaba) (form V)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ta.ʃaʕ.ʕa.ba/","/ta.ʃaʕ.ʕub/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22428","headword_ar":"تشعّب","root":"$Eb","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"An$Eb","text_ar":"انشعب","orth_type":"arrow"},{"kind":"text","text":"are quasi-pass. verbs, the former of"},{"kind":"arabic","text_bw":"$aE~aba","text_ar":"شَعَّبَ"},{"kind":"text","text":"and the latter of"},{"kind":"arabic","text_bw":"$aEaba","text_ar":"شَعَبَ"},{"kind":"text","text":": (TA:) [the former, therefore, is most correctly to be regarded and used as intensive in its significations, or as relating to several things or persons: but it is said that] both signify alike: [app."},{"kind":"italic_en","text":"It became collected; it became brought, gathered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drawn, together;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became united:"},{"kind":"text","text":"and also]"},{"kind":"italic_en","text":"it became separated, put apart"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"asunder, divided, disunited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scattered:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, became distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"ta$aE~abuwA fiY Talabi AlmiyaAhi","text_ar":"تَشَعَّبُوا فِى طَلَبِ المِيَاهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They became separated,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"they separated themselves,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in search of the waters"},{"kind":"text","text":"], and"},{"kind":"arabic","text_bw":"fiY AlgaAraAti","text_ar":"فِى الغَارَاتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in predatory excursions"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"An$Eb","text_ar":"انشعب","orth_type":"arrow"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"italic_en","text":"Such a one became distant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remote, from me;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"withdrew to a distance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for away, from me."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"AlT~ariyqu","text_ar":"الطَّرِيقُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"An$Eb","text_ar":"انشعب","orth_type":"arrow"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"t$E~b","text_ar":"تشعّب"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"The road separated."},{"kind":"text","text":"(S, A, Msb.) And ↓"},{"kind":"arabic","text_bw":"An$Eb","text_ar":"انشعب","orth_type":"arrow"},{"kind":"arabic","text_bw":"Aln~ahoru","text_ar":"النَّهْرُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"t$E~b","text_ar":"تشعّب"},{"kind":"italic_en","text":"The river separated"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"branched forth"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"into other rivers."},{"kind":"text","text":"(TA.) And ↓"},{"kind":"arabic","text_bw":"An$Ebt","text_ar":"انشعبت","orth_type":"arrow"},{"kind":"arabic","text_bw":"A^agoSaAnu Al$~ajarapi","text_ar":"اَغْصَانُ الشَّجَرَةِ"},{"kind":"text","text":"(S, Msb, TA) and"},{"kind":"arabic","text_bw":"t$E~bt","text_ar":"تشعّبت"},{"kind":"text","text":"(TA)"},{"kind":"italic_en","text":"The branches of the tree separated, divided,"},{"kind":"page_break","n":1556},{"kind":"italic_en","text":"straggled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread out dispersedly;"},{"kind":"text","text":"(S, TA;) or"},{"kind":"italic_en","text":"branched forth from the stem, and separated, divided,"},{"kind":"text","text":"&c. (Msb.) See also 2. One says also,"},{"kind":"arabic","text_bw":"t$E~b A^amoru Alr~ajuli","text_ar":"تشعّب اَمْرُ الرَّجُلِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The state of affairs of the man became broken up, discomposed, deranged, disorganized,"},{"kind":"text","text":"or (agreeably with another explanation of the verb in what follows)"},{"kind":"italic_en","text":"rendered unsound, impaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred"},{"kind":"text","text":"]. (A.) ―         -b2-  Also ↓ the latter verb, [or each,]"},{"kind":"italic_en","text":"It became closed up;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"repaired by having a crack"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cracks closed up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by being pieced;"},{"kind":"text","text":"] said of a cracked thing: (TA:) and ↓ both verbs,"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"AinoSalaHa","text_ar":"اِنْصَلَحَ"},{"kind":"text","text":"[which means, in a general sense,"},{"kind":"italic_en","text":"it became rectified, repaired, mended, amended, adjusted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put into a right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper, state;"},{"kind":"text","text":"&c.; but I have not found this verb ("},{"kind":"arabic","text_bw":"AnSlH","text_ar":"انصلح"},{"kind":"text","text":") in its proper art. in any of the Lexicons]: (K, TA:) and ↓ the latter signifies also"},{"kind":"italic_en","text":"it became cracked;"},{"kind":"text","text":"(A;) [and in like manner the former, said of a number of things; or"},{"kind":"italic_en","text":"it became cracked in several places"},{"kind":"text","text":"when said of a single thing: and hence ↓ both signify, in a general sense,"},{"kind":"italic_en","text":"it became corrupted, rendered unsound, impaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred;"},{"kind":"text","text":"a meaning which may justly be assigned to the former verb in the phrase mentioned in the next preceding sentence.]"}],"source_refs":["TA","S","K","Msb"]}]},"classical_definitions":null}