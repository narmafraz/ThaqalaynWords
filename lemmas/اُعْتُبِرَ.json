: true, "count": 2, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَعْتَبِر", "in_corpus": true, "count": 1, "asp": "i", "per": "1", "gen": "m", "num": "p"}, {"role": "present_1ms", "form": "أُعْتَبَر", "in_corpus": true, "count": 2, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نُعْتَبَر", "in_corpus": true, "count": 1, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 34, "cross_references": {"qac": {"found": true, "lemma_key": "اُعْتُبِرَ", "root": "عبر", "pos": "V", "occurrence_count": 1}, "wiktextract": {"found": true, "entry_count": 1, "pos_tags": ["verb"], "has_etymology": false, "sense_count": 4}, "lanes": {"found": true, "entry_ids": ["n27824"], "search_url": "https://lanelexicon.com/?s=%D8%A7%D9%8F%D8%B9%D9%92%D8%AA%D9%8F%D8%A8%D9%90%D8%B1%D9%8E"}}, "translations": {"en": "to take warning", "fa": "عبرت گرفتن", "ur": "عبرت لینا", "tr": "ibret almak", "id": "mengambil ibrah", "bn": "ইবরত নেওয়া", "es": "tomar ejemplo", "fr": "prendre exemple", "de": "Lektion lernen", "ru": "брать урок", "zh": "吸取教训"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to take example, to take warning, to learn a lesson", "tags": ["intransitive"], "examples": [{"text": "اِعْتَبِرْ بِمَنْ قَبَلَكَ وَلَا تَكُنْ عِبْرَةً لِمَنْ يَأْتِي بَعْدَكَ", "english": "Consider those who came before you and do not be an example for those who come after you"}]}, {"pos": "verb", "gloss": "to acknowledge, value, respect"}, {"pos": "verb", "gloss": "to consider, to regard as", "tags": ["ditransitive"], "examples": [{"text": "اِعْتَبَرَ وَزِيرُ ٱلْأَمْنِ ٱلْإِسْرَائِيلِيُّ وَزَعِيمُ حِزْبِ «يِسْرَائِيل بِيتِينُو»، أَفِغْدُور لِيبِرْمَان، أَنَّ «كْلَايْن تَجَاوَزَ كُلَّ ٱلْخُطُوطِ ٱلْحُمْرِ» […]", "english": "The Defense Minister of Israel and the leader of Yisrael Beiteinu Party, Avigdor Lieberman, considered that “[Yossi] Klein has crossed all the red lines” […]"}]}, {"pos": "verb", "gloss": "to examine, to investigate, to put to test"}]}, "etymology": null, "ipa": ["/iʕ.ta.ba.ra/"], "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n27824", "headword_ar": "اعتبر", "root": "Ebr", "body": [{"kind": "italic_en", "text": "He became admonished,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "reminded; he took warning,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "example:"}, {"kind": "text", "text": "in this sense the verb is used in the Kur lix. 2: and you say,"}, {"kind": "arabic", "text_bw": "AiEotabara bimaA maDaY", "text_ar": "اِعْتَبَرَ بِمَا مَضَى"}, {"kind": "italic_en", "text": "He became admonished"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "reminded,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "he took warning"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "example, by what passed:"}, {"kind": "text", "text": "(Msb:) and"}, {"kind": "arabic", "text_bw": "Als~aEiydu mina A@Eotabara bigayorihi", "text_ar": "السَّعِيدُ مِنَ ا@عْتَبَرَ بِغَيْرِهِ"}, {"kind": "arabic", "text_bw": "waAl$~aqiY~u mani A@Eotabara bihi gayoruhu", "text_ar": "وَالشَّقِىُّ مَنِ ا@عْتَبَرَ بِهِ غَيْرُهُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The fortunate is he who takes warning by others, and the unfortunate is he by whom others take warning"}, {"kind": "text", "text": "]. (Kull p. 60.) And"}, {"kind": "arabic", "text_bw": "EabarN", "text_ar": "عَبَرٌ"}, {"kind": "text", "text": "[as inf. n. of ↓"}, {"kind": "arabic", "text_bw": "Eabira", "text_ar": "عَبِرَ", "orth_type": "arrow"}, {"kind": "text", "text": ", aor."}, {"kind": "text", "text": ",] signifies the same as"}, {"kind": "arabic", "text_bw": "AiEotibaArN", "text_ar": "اِعْتِبَارٌ"}, {"kind": "text", "text": "[as inf. n. of"}, {"kind": "arabic", "text_bw": "AiEotabara", "text_ar": "اِعْتَبَرَ"}, {"kind": "text", "text": "in the sense expl. above]: (Fr, O, L, K, TA:) whence the saying of the Arabs,"}, {"kind": "arabic", "text_bw": "Aall~`hum~a A@joEalonaA mim~ano yaEobaru Ald~unoyaA walaA", "text_ar": "اَللّٰهُمَّ ا@جْعَلْنَا مِمَّنْ يَعْبَرُ الدُّنْيَا وَلَا"}, {"kind": "arabic", "text_bw": "yaEoburuhaA", "text_ar": "يَعْبُرُهَا"}, {"kind": "text", "text": ", (Fr, O, L, TA,) with fet-h to the"}, {"kind": "arabic", "text_bw": "b", "text_ar": "ب"}, {"kind": "text", "text": "of"}, {"kind": "arabic", "text_bw": "yEbr", "text_ar": "يعبر"}, {"kind": "text", "text": "in the first case, and with damm to it in the second case, (TA,) meaning"}, {"kind": "italic_en", "text": "O God, make us to be of those who take warning,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "example, by the present world, and do not"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "pass through it"}, {"kind": "text", "text": "or]"}, {"kind": "italic_en", "text": "die quickly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "soon,"}, {"kind": "text", "text": "until they content Thee by obedience: (Fr, O, L, TA:) in the copies of the K,"}, {"kind": "arabic", "text_bw": "mim~ano yaEoburu Ald~unoyaA walaA yaEomuruhaA", "text_ar": "مِمَّنْ يَعْبُرُ الدُّنْيَا وَلَا يَعْمُرُهَا"}, {"kind": "text", "text": ", the former verb with"}, {"kind": "arabic", "text_bw": "b", "text_ar": "ب"}, {"kind": "text", "text": "[and damm], and the latter with"}, {"kind": "arabic", "text_bw": "m", "text_ar": "م"}, {"kind": "text", "text": "[and damm]: and in the A is given, as a trad.,"}, {"kind": "arabic", "text_bw": "AuEoburuwA", "text_ar": "اُعْبُرُوا"}, {"kind": "arabic", "text_bw": "Ald~unoyaA walaA taEomuruwhaA", "text_ar": "الدُّنْيَا وَلَا تَعْمُرُوهَا"}, {"kind": "text", "text": ": but the reading given by Sgh and in the L is pronounced by MF to be the right. (TA.) See also"}, {"kind": "arabic", "text_bw": "EiborapN", "text_ar": "عِبْرَةٌ"}, {"kind": "text", "text": ". [And see 10, last sentence.] ―         -b2-  Also"}, {"kind": "italic_en", "text": "He took,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regarded, what he witnessed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "saw,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "beheld, as an indication,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "evidence, of what was concealed from him:"}, {"kind": "text", "text": "(O:)"}, {"kind": "italic_en", "text": "he compared what was unapparent with what was apparent"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "and so judged of the former from analogy"}, {"kind": "text", "text": "]: or"}, {"kind": "italic_en", "text": "he considered the essential properties of things, and their modes of indication, in order that, by the consideration thereof, another thing, of their kind, might become known."}, {"kind": "text", "text": "(Kull p. 60.) See, again,"}, {"kind": "arabic", "text_bw": "EiborapN", "text_ar": "عِبْرَةٌ"}, {"kind": "text", "text": ". Ibn-Seereen used to say,"}, {"kind": "arabic", "text_bw": "A^aEotabiru AlHadiyva", "text_ar": "اَعْتَبِرُ الحَدِيثَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "I judge by comparison with what has been transmitted by tradition"}, {"kind": "text", "text": "from the Prophet]; meaning I interpret a dream according to what has been transmitted by tradition, like as I do according to the Kur-án; as when a crow is interpreted as meaning an unrighteous man, and a rib as meaning a woman, in imitation of forms of speech used by the Prophet. (O, * TA.) ―         -b3-  See also 1, latter half, in two places. ―         -b4-  Also"}, {"kind": "italic_en", "text": "He accounted,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "esteemed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regarded,"}, {"kind": "text", "text": "a thing,"}, {"kind": "italic_en", "text": "in respect of predicamental order."}, {"kind": "text", "text": "(Msb.) See, again,"}, {"kind": "arabic", "text_bw": "EiborapN", "text_ar": "عِبْرَةٌ"}, {"kind": "text", "text": ". ―         -b5-  [And"}, {"kind": "italic_en", "text": "He esteemed"}, {"kind": "text", "text": "a person, or thing;"}, {"kind": "italic_en", "text": "held"}, {"kind": "text", "text": "him, or it,"}, {"kind": "italic_en", "text": "in high estimation"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "regard."}, {"kind": "text", "text": "―         -b6-  And"}, {"kind": "italic_en", "text": "He took"}, {"kind": "text", "text": "a thing"}, {"kind": "italic_en", "text": "into account, regarded"}, {"kind": "text", "text": "it, or"}, {"kind": "italic_en", "text": "included"}, {"kind": "text", "text": "it"}, {"kind": "italic_en", "text": "in a mental view"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "an examination."}, {"kind": "text", "text": "Hence the phrase"}, {"kind": "arabic", "text_bw": "biA@EotibaAri ka*aA", "text_ar": "بِا@عْتِبَارِ كَذَا"}, {"kind": "italic_en", "text": "With regard,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "respect,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "with regard had, to such a thing; in consideration of such a thing,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "of the implication thereof;"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "having regard,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "respect, to such a thing;"}, {"kind": "text", "text": "as also"}, {"kind": "arabic", "text_bw": "AiEotibaArFA lika*aA", "text_ar": "اِعْتِبَارًا لِكَذَا"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "bika*aA", "text_ar": "بِكَذَا"}, {"kind": "text", "text": ". And"}, {"kind": "arabic", "text_bw": "biA@EotibaArK waAHidK", "text_ar": "بِا@عْتِبَارٍ وَاحِدٍ"}, {"kind": "italic_en", "text": "Considered in one respect; in one and the same light."}, {"kind": "text", "text": "Hence also the phrase,]"}, {"kind": "arabic", "text_bw": "yuEotabaru ka*aA liSiH~api", "text_ar": "يُعْتَبَرُ كَذَا لِصِحَّةِ"}, {"kind": "arabic", "text_bw": "AlEaqodi", "text_ar": "العَقْدِ"}, {"kind": "italic_en", "text": "Such a thing is made a condition"}, {"kind": "text", "text": "[or"}, {"kind": "italic_en", "text": "is taken into account"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "for the soundness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "validity, of the contract."}, {"kind": "text", "text": "(Msb.) ―         -b7-"}, {"kind": "arabic", "text_bw": "AEtbr minohu", "text_ar": "اعتبر مِنْهُ"}, {"kind": "text", "text": "means"}, {"kind": "italic_en", "text": "He wondered at him,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it."}, {"kind": "text", "text": "(K, TA. In the CK,"}, {"kind": "arabic", "text_bw": "mnh", "text_ar": "منه"}, {"kind": "text", "text": "is omitted.)"}], "source_refs": ["Msb", "Fr", "O", "L", "K", "TA"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}