num":"d"},{"role":"present_2mp","form":"تَحْفَُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحْفَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحْفَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحْفَى","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحْفَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحْفَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحْفَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحْفَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحْفَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحْفَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحْفَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَحْفَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْفَ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَفِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَفِيْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحْفَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحْفَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":true,"lemma_key":"حَفِيَ","root":"حفو","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n8538","n8552"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%81%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to go barefoot"},{"pos":"verb","gloss":"to have sore feet"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8538","headword_ar":"حَفِىَ","root":"Hfw and HfY","body":[{"kind":"text","text":", (S, Mgh, Msb,) aor."},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"HafaA='N","text_ar":"حَفَا=ءٌ"},{"kind":"text","text":", (ISk, Zj, IB, Mgh, Msb,) like"},{"kind":"arabic","text_bw":"salaAmN","text_ar":"سَلَامٌ"},{"kind":"text","text":", (Msb,) with fet-h, not"},{"kind":"arabic","text_bw":"HifaA='N","text_ar":"حِفَا=ءٌ"},{"kind":"text","text":", as in the S, (IB,) [for] this latter is a simple subst., (Msb,)"},{"kind":"italic_en","text":"He walked barefoot, without sandal and without boot;"},{"kind":"text","text":"(ISk, Zj, S, IB, Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"AHtfY","text_ar":"احتفى","orth_type":"arrow"},{"kind":"text","text":": (K:) [but Mtr says,] this latter, occurring in the sense of the former in a trad. of 'Omar, I have not found [elsewhere]. (Mgh.) And"},{"kind":"arabic","text_bw":"HafiYa mino naEolayohi","text_ar":"حَفِىَ مِنْ نَعْلَيْهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xuf~ahi","text_ar":"خُفَّهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HifowapN","text_ar":"حِفْوَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HifoyapN","text_ar":"حِفْيَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HifaAyapN","text_ar":"حِفَايَةٌ"},{"kind":"text","text":", [or all these are simple substs.,"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bare of his sandals"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his boot."},{"kind":"text","text":"] (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"HafiYa","text_ar":"حَفِىَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HafFA","text_ar":"حَفًا"},{"kind":"text","text":", (S, Mgh, Msb, K, &c.,)"},{"kind":"italic_en","text":"His foot,"},{"kind":"text","text":"i. e. a man's, (S, Msb, K,) and a camel's, (K,) or"},{"kind":"italic_en","text":"his solid hoof,"},{"kind":"text","text":"(S, Ham p. 476,) or this also, (K,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, attenuated"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the sole"},{"kind":"text","text":"], (S, Msb, K,) or"},{"kind":"italic_en","text":"chafed, abraded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"worn,"},{"kind":"text","text":"(Ham ubi suprà, and PS,) by much walking or treading or travel: (S, Msb, Ham:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the foot of a man [and the hoof of a horse or the like])"},{"kind":"italic_en","text":"became attenuated"},{"kind":"text","text":"[&c.]"},{"kind":"italic_en","text":"by much walking"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"treading"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"travel:"},{"kind":"text","text":"(Mgh:) and"},{"kind":"arabic","text_bw":"HafiYa","text_ar":"حَفِىَ"},{"kind":"text","text":"said of a horse,"},{"kind":"italic_en","text":"his hoof became abraded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grazed."},{"kind":"text","text":"(S.)       -A2-"},{"kind":"arabic","text_bw":"HafiYa bihi","text_ar":"حَفِىَ بِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HafaAwapN","text_ar":"حَفَاوَةٌ"},{"kind":"text","text":"(S, Mgh, K) and"},{"kind":"arabic","text_bw":"HifaAwapN","text_ar":"حِفَاوَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HifaAyapN","text_ar":"حِفَايَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"tiHofaAyapN","text_ar":"تِحْفَايَةٌ"},{"kind":"text","text":", (K, TA,) with kesr; (TA; [in the CK"},{"kind":"arabic","text_bw":"taHofaAyap","text_ar":"تَحْفَايَة"},{"kind":"text","text":"; both extr.;]) and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHf~Y","text_ar":"تحفّى","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"AHtfY","text_ar":"احتفى","orth_type":"arrow"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He showed him much honour,"},{"kind":"text","text":"(S, Mgh, K,)"},{"kind":"italic_en","text":"and kindness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodness and affection and gentleness, and regard for his circumstances;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"regarded him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"behaved towards him, with affection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benevolence and solicitude;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"and manifested joy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasure;"},{"kind":"text","text":"(K;) and"},{"kind":"italic_en","text":"asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquired, much respecting his state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"(S, K;) and"},{"kind":"italic_en","text":"was careful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"solicitous, respecting his case:"},{"kind":"text","text":"(S:) or"},{"kind":"arabic","text_bw":"HafiYa Eanohu","text_ar":"حَفِىَ عَنْهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he asked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquired, much respecting him:"},{"kind":"text","text":"(Har p. 284:) and ↓"},{"kind":"arabic","text_bw":"AHfY","text_ar":"احفى","orth_type":"arrow"},{"kind":"italic_en","text":"he exceeded the usual bounds in making much inquiry respecting another, and in carefulness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"solicitude, respecting his case:"},{"kind":"text","text":"(Har p. 348:) and ↓"},{"kind":"arabic","text_bw":"taHaf~K","text_ar":"تَحَفٍّ","orth_type":"arrow"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"speaking and meeting in a good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasing, manner;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"exceeding the usual bounds in returning a salutation,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in asking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquiring:"},{"kind":"text","text":"accord. to Zj,"},{"kind":"arabic","text_bw":"HafiYabihi","text_ar":"حَفِىَبِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HifowapN","text_ar":"حِفْوَةٌ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"he acted towards him with kindness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodness and affection and gentleness, and regard for his circumstances:"},{"kind":"text","text":"accord. to As,"},{"kind":"arabic","text_bw":"HafiYa bihi","text_ar":"حَفِىَ بِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HafaAwapN","text_ar":"حَفَاوَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"he employed himself in the accomplishment of that which he needed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"required, and made his abode pleasant:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"HafaAwapN","text_ar":"حَفَاوَةٌ"},{"kind":"text","text":"signifies also the"},{"kind":"italic_en","text":"being importunate, pressing, urgent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"persevering,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"in asking."},{"kind":"text","text":"(TA.) Hence the prov.,"},{"kind":"arabic","text_bw":"maA^orubapN laA HafaAwapN","text_ar":"مَاْرُبَةٌ لَا حَفَاوَةٌ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"maA^orabapN","text_ar":"مَاْرَبَةٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maA^orabN","text_ar":"مَاْرَبٌ"},{"kind":"text","text":", explained in art."},{"kind":"arabic","text_bw":"Arb","text_ar":"ارب"},{"kind":"text","text":"]. (S, K.) ―         -b2-"},{"kind":"arabic","text_bw":"Hafiytu","text_ar":"حَفِيتُ"},{"kind":"arabic","text_bw":"A_ilayohi biAlwaSiy~api","text_ar":"اـِلَيْهِ بِالوَصِيَّةِ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"Hafayotu","text_ar":"حَفَيْتُ"},{"kind":"text","text":", (accord. to different copies of the S,)"},{"kind":"italic_en","text":"I exceeded the usual bounds to him in the injunction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charge:"},{"kind":"text","text":"mentioned by A'Obeyd: (S:) and"},{"kind":"arabic","text_bw":"Alyh","text_ar":"اليه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tHf~Y","text_ar":"تحفّى","orth_type":"arrow"},{"kind":"italic_en","text":"he exceeded the usual bounds to him in the injunction,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charge."},{"kind":"text","text":"(TA.)       -A3-"},{"kind":"arabic","text_bw":"HafaA bihi","text_ar":"حَفَا بِهِ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"HafaAhu","text_ar":"حَفَاهُ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"HafowN","text_ar":"حَفْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"honoured him."},{"kind":"text","text":"(K, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"HafaAhu","text_ar":"حَفَاهُ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"gave to him."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"italic_en","text":"He denied him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refused to give him;"},{"kind":"text","text":"(IAar, K;) inf. n."},{"kind":"arabic","text_bw":"HafowN","text_ar":"حَفْوٌ"},{"kind":"text","text":". (IAar.) Thus it bears two contr. significations. (K.) You say,"},{"kind":"arabic","text_bw":"A^ataAniY","text_ar":"اَتَانِى"},{"kind":"arabic","text_bw":"faHafawotuhu","text_ar":"فَحَفَوْتُهُ"},{"kind":"italic_en","text":"He came to me and I denied him,"},{"kind":"text","text":"&c. (IAar.) And"},{"kind":"arabic","text_bw":"Hafawotuhu mino kul~i xayorK","text_ar":"حَفَوْتُهُ مِنْ كُلِّ خَيْرٍ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HafowN","text_ar":"حَفْوٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"I debarred him from,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prevented him from obtaining, all good."},{"kind":"text","text":"(As, S.)       -A4-"},{"kind":"arabic","text_bw":"HafaA $aAribahu","text_ar":"حَفَا شَارِبَهُ"},{"kind":"text","text":": see 4."},{"kind":"page_break","n":605}],"source_refs":["S","Mgh","Msb","ISk","Zj","IB","K","Ham","TA","God"]},{"entry_id":"n8552","headword_ar":"حَفىٌّ","root":"Hfw and HfY","body":[{"kind":"italic_en","text":"Showing much honour,"},{"kind":"text","text":"(Mgh, K,)"},{"kind":"italic_en","text":"and manifesting joy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasure"},{"kind":"text","text":"["},{"kind":"italic_en","text":"at meeting another"},{"kind":"text","text":"]; as also ↓"},{"kind":"arabic","text_bw":"HaAfK","text_ar":"حَافٍ","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"and behaving with affection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benevolence and solicitude;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"showing kindness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodness and affection and gentleness, and regard for the circumstances of another:"},{"kind":"text","text":"(Lth, TA:) and"},{"kind":"italic_en","text":"asking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquiring, much respecting another's state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HaAfK","text_ar":"حَافٍ","orth_type":"arrow"},{"kind":"text","text":": (K:)"},{"kind":"italic_en","text":"going to the utmost length in asking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquiring:"},{"kind":"text","text":"(S:) and [hence, perhaps,]"},{"kind":"italic_en","text":"knowing in the utmost degree:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"importunate, pressing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"urgent, in asking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inquiring:"},{"kind":"text","text":"(K:) pl."},{"kind":"arabic","text_bw":"HufawaA='u","text_ar":"حُفَوَا=ءُ"},{"kind":"text","text":". (Fr, K.) You say,"},{"kind":"arabic","text_bw":"huwa HafiY~N bihi","text_ar":"هُوَ حَفِىٌّ بِهِ"},{"kind":"italic_en","text":"He is one who behaves with affection,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"benevolence and solicitude, to him; who shows him much honour"},{"kind":"text","text":"[&c.]. (Mgh.)"},{"kind":"arabic","text_bw":"A_in~ahu kaAna biY","text_ar":"اـِنَّهُ كَانَ بِى"},{"kind":"arabic","text_bw":"Hafiy~FA","text_ar":"حَفِيًّا"},{"kind":"text","text":", in the Kur [xix. 48], means"},{"kind":"italic_en","text":"Verily He is gracious"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to me"},{"kind":"text","text":"]: (Zj:) or"},{"kind":"italic_en","text":"knowing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with respect to me"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and gracious"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to me"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"answering my prayer when I pray to him:"},{"kind":"text","text":"(Fr:) or"},{"kind":"italic_en","text":"mindful, regardful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"considerate, of me."},{"kind":"text","text":"(TA.)"}],"source_refs":["Mgh","K","Lth","TA","S","Zj","Fr"]}]},"classical_definitions":null}