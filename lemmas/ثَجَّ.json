","num":"s"}],"frequency_in_corpus":5,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n4348"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D8%AC%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4348","headword_ar":"ثَجَّ","root":"vj","body":[{"kind":"text","text":", (A, L, Msb, K,) aor."},{"kind":"text","text":", (A, Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"vaj~N","text_ar":"ثَجٌّ"},{"kind":"text","text":", (L, Msb, TA,) or"},{"kind":"arabic","text_bw":"vajiyjN","text_ar":"ثَجِيجٌ"},{"kind":"text","text":", (A, TA,) or"},{"kind":"arabic","text_bw":"vujuwjN","text_ar":"ثُجُوجٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"flowed:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"poured forth vehemently,"},{"kind":"text","text":"(A, Msb, TA,) or"},{"kind":"italic_en","text":"much:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(much water)"},{"kind":"italic_en","text":"poured forth:"},{"kind":"text","text":"(L, TA:) and ↓"},{"kind":"arabic","text_bw":"Anvj~","text_ar":"انثجّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"tavajovaja","text_ar":"تَثَجْثَجَ","orth_type":"arrow"},{"kind":"text","text":"signify the same. (K.)"},{"kind":"arabic","text_bw":"vaj~N","text_ar":"ثَجٌّ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"flowing"},{"kind":"text","text":"of the blood of a victim brought for sacrifice to the sacred territory of Mekkeh. (S, K, TA.)       -A2-"},{"kind":"arabic","text_bw":"vaj~ahu","text_ar":"ثَجَّهُ"},{"kind":"text","text":", (S, A, Mgh, Msb, K,) aor."},{"kind":"text","text":", (S, A, Mgh, Msb,) inf. n."},{"kind":"arabic","text_bw":"vaj~N","text_ar":"ثَجٌّ"},{"kind":"text","text":", (S, Mgh, Msb,)"},{"kind":"italic_en","text":"He made it to flow;"},{"kind":"text","text":"(S, A, Mgh, Msb K;)"},{"kind":"italic_en","text":"poured it forth;"},{"kind":"text","text":"(Msb;) namely, water, (S, A, Mgh, Msb, K,) and blood (S, A, Mgh, Msb) of a victim for sacrifice; (Mgh, Msb;) as also ↓"},{"kind":"arabic","text_bw":"vajovajahu","text_ar":"ثَجْثَجَهُ","orth_type":"arrow"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"Avj~hu","text_ar":"اثجّهُ","orth_type":"arrow"},{"kind":"text","text":"may also be used in the same sense. (TA.) Hence, (Mgh, Msb,)"},{"kind":"arabic","text_bw":"A^afoDalu AlHaj~i AlEaj~u wAlv~aj~u","text_ar":"اَفْضَلُ الحَجِّ العَجُّ والثَّجُّ"},{"kind":"text","text":", (S, Mgh, Msb,) a saying of Mohammad, (TA,) meaning"},{"kind":"italic_en","text":"The most excellent of the actions of the pilgrimage are"},{"kind":"text","text":"(Mgh)"},{"kind":"italic_en","text":"the raising of the voice in the"},{"kind":"arabic","text_bw":"talobiyap","text_ar":"تَلْبِيَة"},{"kind":"text","text":"[see 2 in art."},{"kind":"arabic","text_bw":"lbY","text_ar":"لبى"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the shedding of the blood of the victims brought for sacrifice to the sacred territory."},{"kind":"text","text":"(Mgh, Msb.)"}],"source_refs":["A","L","Msb","K","TA","S","Mgh"]}]},"classical_definitions":null}