"form":"تَعِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعِيب","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعِب","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعِيب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعِيبانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعِيبُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عِبْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعِيب","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n31147","n31151"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be faulty, to be defective"},{"pos":"verb","gloss":"to spoil, to mar"},{"pos":"verb","gloss":"to blame, to decry"},{"pos":"verb","gloss":"to shame, to humiliate, to disgrace","examples":[{"text":"عَابَ مَجْدَكَ بِالمَذَلَّةِ وَالهَزَائِمِ\nحِينَمَا هَبَّ الجَنُوبُ لِكَيْ يُقَاوِم","english":"You glory was shamed with humility and defeats\n When the South stood up to resist"}]},{"pos":"verb","gloss":"to render defective","examples":[{"text":"أَمَّا السَّفِينَةُ فَكَانَتْ لِمَسَاكِينَ يَعْمَلُونَ فِي الْبَحْرِ فَأَرَدْتُ أَنْ أَعِيبَهَا وَكَانَ وَرَاءَهُم مَلِكٌ يَأْخُذُ كُلَّ سَفِينَةٍ غَصْبًا","english":"“As for the ship, it belonged to some poor people, working at sea. So I intended to damage it, for there was a ˹tyrant˺ king ahead of them who seizes every ˹good˺ ship by force."}]}]},"etymology":{"source":"wiktextract","text":"Possibly related to Egyptian ꜥb (“to make dirty, to pollute”)."},"ipa":["/ʕaː.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31147","headword_ar":"عَابَ","root":"Eyb","body":[{"kind":"text","text":", (S, A, O, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaEiybu","text_ar":"يَعِيبُ"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":", (Msb, TA,) and"},{"kind":"arabic","text_bw":"maEaAbN","text_ar":"مَعَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEiybN","text_ar":"مَعِيبٌ"},{"kind":"text","text":"are allowable as inf. ns., (S, O, TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, A, TA, or an article of merchandise, S, O, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, faulty, unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had a fault, an unsoundness, a defect, an imperfection, a blemish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"something amiss."},{"kind":"text","text":"(S, A, O, Msb, * K.) [See also 5.]       -A2-"},{"kind":"arabic","text_bw":"EaAbahu","text_ar":"عَابَهُ"},{"kind":"text","text":", (S, O, Msb, K,) [aor. as above,] inf. n."},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaAbN","text_ar":"عَابٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Ey~bhu","text_ar":"عيّبهُ","orth_type":"arrow"},{"kind":"text","text":", (S, A, O,) or this has an intensive signification; (Msb;) and ↓"},{"kind":"arabic","text_bw":"tEy~bhu","text_ar":"تعيّبهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, O;)"},{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused, it"},{"kind":"text","text":"(a thing, TA in relation to the first, and A in relation to the second and third, or an article of merchandise, S and O in relation to the first,)"},{"kind":"italic_en","text":"to be faulty, unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to have a fault, an unsoundness, a defect, an imperfection, a blemish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"something amiss."},{"kind":"text","text":"(S, A, O, Msb, * K.)"},{"kind":"arabic","text_bw":"A^aradotu A^ano A^uEiybahaA","text_ar":"اَرَدْتُ اَنْ اُعِيبَهَا"},{"kind":"text","text":", in the Kur [xviii. 78], means"},{"kind":"italic_en","text":"I desired to render it faulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound."},{"kind":"text","text":"(AHeyth, TA.) ―         -b2-  [The same verbs are also often used in relation to a human being as the object.] ―         -b3-  And one says"},{"kind":"arabic","text_bw":"EaAbahu","text_ar":"عَابَهُ"},{"kind":"text","text":", [aor. as above,] inf. n."},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EaAbN","text_ar":"عَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEaAbN","text_ar":"مَعَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEiybN","text_ar":"مَعِيبٌ"},{"kind":"text","text":"; (MA;) and ↓"},{"kind":"arabic","text_bw":"Ey~bhu","text_ar":"عيّبهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, O, Msb;) and ↓"},{"kind":"arabic","text_bw":"tEy~bhu","text_ar":"تعيّبهُ","orth_type":"arrow"},{"kind":"text","text":"; (TA;) meaning"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"["},{"kind":"italic_en","text":"found fault with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it; blamed, upbraided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reproached, him;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"attributed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imputed to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charged him with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accused him of, a vice, fault,"},{"kind":"text","text":"&c. (S, A, MA, * O, Msb, TA.) [The first of these verbs is of very frequent occurrence as meaning thus: one ex. of it occurs in the saying of a poet cited in the S and O in this art.,"},{"kind":"quote","text":"A^anaA Alr~ajulu Al~a*iY qado Eibotumuwhu"},{"kind":"italic_en","text":"I am the man whom ye have charged with a vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault,"},{"kind":"text","text":"&c. And one says,"},{"kind":"arabic","text_bw":"EAb Ealayohi fiEolahu","text_ar":"عاب عَلَيْهِ فِعْلَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He blamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discommended, to him his deed."},{"kind":"text","text":"-A3-"},{"kind":"arabic","text_bw":"EAb Als~iqaA='u","text_ar":"عاب السِّقَا=ءُ"},{"kind":"italic_en","text":"The skin had milk that had become thick in it"},{"kind":"text","text":"(O, K, TA.)"}],"source_refs":["S","A","O","Msb","K","TA"]},{"entry_id":"n31151","headword_ar":"عَابٌ","root":"Eyb","body":[{"kind":"text","text":": see the next paragraph."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B9%D8%A7%D8%A8/","headword_ar":"عاب","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61787#58882f","body_html":"<span class=\"title1\">عاب</span><br><span>العَيْبُ والعَابُ: الأمر الذي يصير به الشيء عَيْبَةً. أي: مقرّا للنّقص، وعِبْتُهُ جعلته مَعِيباً إما بالفعل كما قال: فَأَرَدْتُ أَنْ أَعِيبَها</span><br><span>[الكهف/ 79] ، وإما بالقول، وذلك إذا ذممته نحو قولك: عِبْتُ فلانا، والْعَيْبَةُ: ما يستر فيه الشيء، ومنه قوله عليه الصلاة والسلام:</span><br><span>«الأنصار كرشي وعَيْبَتِي» أي: موضع سرّي.</span>"}]}}