"},{"role":"present_2mp","form":"تَشْبَعُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْبَعْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْبَع","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْبَع","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْبَعانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْبَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْبَعانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْبَعا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْبَعُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْبَعُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْبَعْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَبِعْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَبِعْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْبَع","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْبَع","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":19,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n21584"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%A8%D9%90%D8%B9%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be full, to be satiated","tags":["intransitive"],"examples":[{"text":"لَيْسَ الْمُؤْمِنُ الَّذِي يَشْبَعُ وَجَارُهُ جَائِعٌ","english":"He is not a believer who eats his fill while his neighbor goes hungry."}]},{"pos":"verb","gloss":"to be fed up, to have had it"},{"pos":"noun","gloss":"fullness, satiety (with food)"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew שָׂבַע (savá', “to be sated, to be satisfied”) and Assyrian Neo-Aramaic ܣܵܒ݂ܹܥ (sāḇēˁ, “to be satiated from food”).\n\nVerbal noun of شَبِعَ (šabiʕa)."},"ipa":["/ʃa.bi.ʕa/","/ʃi.baʕ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21584","headword_ar":"شَبِعَ","root":"$bE","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"$ibaEN","text_ar":"شِبَعٌ"},{"kind":"text","text":"(IDrd, S, Msb, K) and"},{"kind":"arabic","text_bw":"$iboEN","text_ar":"شِبْعٌ"},{"kind":"text","text":", (IDrd, Msb, TA,) which is a contraction of the former, or accord. to some it is a subst., having the signification assigned to it below, (Msb,) or it is both, (TA,) and"},{"kind":"arabic","text_bw":"$aboEN","text_ar":"شَبْعٌ"},{"kind":"text","text":", (Ibn- 'Abbád, K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, satiated, sated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied in stomach;"},{"kind":"arabic","text_bw":"$ibaEN","text_ar":"شِبَعٌ"},{"kind":"text","text":"being the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"juwEN","text_ar":"جُوعٌ"},{"kind":"text","text":", (S, K,) and one of those inf. ns. [which are of a measure often] denoting natural affections or qualities [such as"},{"kind":"arabic","text_bw":"riwFY","text_ar":"رِوًى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"simanN","text_ar":"سِمَنٌ"},{"kind":"text","text":"&c.]. (S.) You say"},{"kind":"arabic","text_bw":"baladN qado $abiEato ganamuhu","text_ar":"بَلَدٌ قَدْ شَبِعَتْ غَنَمُهُ"},{"kind":"italic_en","text":"A country of which the sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats, have become completely satiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied, by abundance of herbage."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"$abiEotu","text_ar":"شَبِعْتُ"},{"kind":"arabic","text_bw":"xubozFA","text_ar":"خُبْزًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"laHomFA","text_ar":"لَحْمًا"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"mino xubozK","text_ar":"مِنْ خُبْزٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mn laHomK","text_ar":"من لَحْمٍ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, satiated, sated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied, with bread,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"with flesh-meat."},{"kind":"text","text":"(S, K.) ―         -b2-  Hence, metaphorically,"},{"kind":"arabic","text_bw":"$abiEotu","text_ar":"شَبِعْتُ"},{"kind":"arabic","text_bw":"mino h`*aA AlA^amoi warawiytu","text_ar":"مِنْ هٰذَا الاَمِْ وَرَوِيتُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I have become,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I became, disgusted"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"satiated to loathing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"with this thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(S, * TA.) ―         -b3-  [See also another metaphorical usage of this verb voce"},{"kind":"arabic","text_bw":"HuzaAnapN","text_ar":"حُزَانَةٌ"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"$abuEa Eaqoluhu","text_ar":"شَبُعَ عَقْلُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"His intellect was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, full, perfect,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"solid."},{"kind":"text","text":"(TA.)"}],"source_refs":["IDrd","S","Msb","K","TA"]}]}}