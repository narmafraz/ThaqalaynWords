esent_1ms","form":"أَنْشَقّ","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":14,"cross_references":{"qac":{"found":true,"lemma_key":"اِنْشَقَّ","root":"شقق","pos":"V","occurrence_count":5},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n22695"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%B4%D9%8E%D9%82%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to split, to part, to be divided, to break"},{"pos":"verb","gloss":"to split off, to part; to defect, to secede"},{"pos":"verb","gloss":"to be laid open, to be undone, to split open so as to reveal, to be opened to view, to be exposed, to be manifested, to be broken forth, to breakthrough"}]},"etymology":null,"ipa":["/in.ʃaq.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22695","headword_ar":"انشقّ","root":"$q","body":[{"kind":"text","text":"quasi-pass. of"},{"kind":"arabic","text_bw":"$aq~ahu","text_ar":"شَقَّهُ"},{"kind":"text","text":"as expl. in the first sentence of this art.: [i. e. it signifies"},{"kind":"italic_en","text":"It became divided lengthwise, cloven, split, riven"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rifted, slit, rent, ripped, torn, broken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burst, asunder;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became cracked, chapped, incided"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incised, gashed, slashed, furrowed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trenched;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cloven,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"split,"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"cut, open:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it clave, split,"},{"kind":"text","text":"&c.:] (S, M:) and in like manner, ↓"},{"kind":"arabic","text_bw":"t$q~q","text_ar":"تشقّق","orth_type":"arrow"},{"kind":"text","text":"is quasi-pass. of"},{"kind":"arabic","text_bw":"$aq~aqahu","text_ar":"شَقَّقَهُ"},{"kind":"text","text":": [i. e. it signifies"},{"kind":"italic_en","text":"it became cloven"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"split"},{"kind":"text","text":"&c., or"},{"kind":"italic_en","text":"it clave"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"split &c., much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in pieces,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in several"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many places:"},{"kind":"text","text":"] (M:) or the former signifies [sometimes]"},{"kind":"italic_en","text":"it opened so as to have in it an interstice."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"waA@no$aq~a Alqamaru","text_ar":"وَا@نْشَقَّ القَمَرُ"},{"kind":"text","text":", in the Kur liv. I, means"},{"kind":"italic_en","text":"And the moon hath been cloven"},{"kind":"text","text":"(Bd, Jel)"},{"kind":"italic_en","text":"in twain,"},{"kind":"text","text":"(Jel,) as a sign to the"},{"kind":"page_break","n":1577},{"kind":"text","text":"Prophet: (Bd, Jel:) or"},{"kind":"italic_en","text":"shall be cloven"},{"kind":"text","text":"on the day of resurrection: but the former is confirmed by another reading,"},{"kind":"arabic","text_bw":"waqadi A^ono$aq~a Alqamaru","text_ar":"وَقَدِ اْنْشَقَّ القَمَرُ"},{"kind":"text","text":": (Bd:) or, accord. to Er-Rághib, the meaning is, (assumed tropical:)"},{"kind":"italic_en","text":"the case hath become manifest."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"An$q~","text_ar":"انشقّ"},{"kind":"arabic","text_bw":"Al$~aYo'u biniSofayoni","text_ar":"الشَّىْءُ بِنِصْفَيْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The thing became cloven,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in halves"},{"kind":"text","text":"]. (S.) [And"},{"kind":"arabic","text_bw":"An$q~ minohu","text_ar":"انشقّ مِنْهُ"},{"kind":"italic_en","text":"It became cloven,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from it:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it branched off from it;"},{"kind":"text","text":"as a river from another river, and the like. And"},{"kind":"arabic","text_bw":"An$q~ Eanohu","text_ar":"انشقّ عَنْهُ"},{"kind":"italic_en","text":"It clave asunder from over it, so as to disclose it:"},{"kind":"text","text":"see also 8.] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"An$q~ flaAnN","text_ar":"انشقّ فلَانٌ"},{"kind":"arabic","text_bw":"mina AlgaDabi","text_ar":"مِنَ الغَضَبِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one was as though his interior were filled with anger so that he split."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Aino$aq~ati AlEaSaA","text_ar":"اِنْشَقَّتِ العَصَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state of affairs, became discomposed, deranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered:"},{"kind":"text","text":"(S, K, TA:) and"},{"kind":"arabic","text_bw":"An$q~t AlEaSaA biAlbayoni","text_ar":"انشقّت العَصَا بِالبَيْنِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"t$q~qt","text_ar":"تشقّقت","orth_type":"arrow"},{"kind":"text","text":", (Lth, M, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state of affairs, became discomposed, deranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorganized, by separation:"},{"kind":"text","text":"(Lth, TA:) and"},{"kind":"arabic","text_bw":"An$q~","text_ar":"انشقّ"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state of affairs, became discomposed, deranged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorganized, being incongruous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsistent."},{"kind":"text","text":"(M, TA.) And"},{"kind":"arabic","text_bw":"An$q~t EaSaA AlT~aAEapi","text_ar":"انشقّت عَصَا الطَّاعَةِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The compact of allegiance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obedience, became broken"},{"kind":"text","text":"]. (M.) ―         -b4-"},{"kind":"arabic","text_bw":"An$q~","text_ar":"انشقّ"},{"kind":"text","text":"said of lightning: see 1, in the latter half of the paragraph."}],"source_refs":["S","M","Bd","Jel","K","TA","Lth"]}]},"classical_definitions":null}