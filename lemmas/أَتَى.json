{"lemma":"أَتَى","slug":"أَتَى","root":"#.ت.#","root_slug":"_-ت-_","root_link":"/words/roots/_-ت-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَتَيْتَ","in_corpus":true,"count":26,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَتَيْتِ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَتَيْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَتَيْتُم","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَتَيْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَتَى","in_corpus":true,"count":197,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَتَت","in_corpus":true,"count":34,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَتَيا","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَتَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَتَوْا","in_corpus":true,"count":14,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَتَيْنَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَأْتِي","in_corpus":true,"count":16,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَأْت","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَأْتِينَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَأْتِي","in_corpus":true,"count":16,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَأْتِيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَأْتِيانِ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَأْتُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَأْتُونَ","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَأْتِيْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَأْتِي","in_corpus":true,"count":94,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَأْت","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَأْتِي","in_corpus":true,"count":16,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَأْت","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَأْتِيا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَأْتِيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَأْتِيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْتِيانِ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَأْتُوا","in_corpus":true,"count":11,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْتُونَ","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَأْتِيْنَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَأْتِي","in_corpus":true,"count":5,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَتَيْنا","in_corpus":true,"count":22,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَتَيْتُ","in_corpus":true,"count":45,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَأْت","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":545,"cross_references":{"qac":{"found":true,"lemma_key":"أَتَى","root":"أتي","pos":"V","occurrence_count":264},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n156","n170","n159","n165","n172"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AA%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n156","headword_ar":"اَتِىٌّ","root":"Atw","body":[{"kind":"text","text":"(S, M, Sgh, K) and"},{"kind":"arabic","text_bw":"A^utiY~N","text_ar":"اُتِىٌّ"},{"kind":"text","text":"[respecting which see what follows] and"},{"kind":"arabic","text_bw":"A_itiY~N","text_ar":"اـِتِىٌّ"},{"kind":"text","text":", (Sgh, K,) of all which, the first is said by A'Obeyd to be the form used by the Arabs, (TA,) [and all belong to art."},{"kind":"arabic","text_bw":"AtY","text_ar":"اتى"},{"kind":"text","text":", as well as to the present art.,] and ↓"},{"kind":"arabic","text_bw":"A^ataAwiY~N","text_ar":"اَتَاوِىٌّ","orth_type":"arrow"},{"kind":"text","text":"(M, Sgh, K) and"},{"kind":"arabic","text_bw":"A^utaAwiY~N","text_ar":"اُتَاوِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_itaAwiY~N","text_ar":"اـِتَاوِىٌّ"},{"kind":"text","text":", (Sgh, K,) all these, and the three preceding them, mentioned by Sgh on the authority of AA, but the last of all said by him to be strange, (TA,)"},{"kind":"italic_en","text":"A rivulet for which a man makes a way"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"channel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an easy course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passage, to his land:"},{"kind":"text","text":"(S, M, K:) or a"},{"kind":"italic_en","text":"torrent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flow of water, from another region"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quarter:"},{"kind":"text","text":"(M, K: [both these meanings mentioned in the M in art."},{"kind":"arabic","text_bw":"Atw","text_ar":"اتو"},{"kind":"text","text":", and the former in art."},{"kind":"arabic","text_bw":"Aty","text_ar":"اتي"},{"kind":"text","text":"also, of that work:]) or"},{"kind":"arabic","text_bw":"A^atiY~N","text_ar":"اَتِىٌّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a conduit of water;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"any channel in which water is made to have an easy course;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"A^utiY~N","text_ar":"اُتِىٌّ"},{"kind":"text","text":", mentioned by Sb; or, as some say, this is a pl.: (M:) or"},{"kind":"italic_en","text":"any rivulet:"},{"kind":"text","text":"(As, T:) or"},{"kind":"italic_en","text":"a rivulet less than the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"trench called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"nuw^oY","text_ar":"نُوْى"},{"kind":"text","text":": (IB:) and"},{"kind":"arabic","text_bw":"sayolN A^atY~N","text_ar":"سَيْلٌ اَتىٌّ"},{"kind":"text","text":"(Lh, T, S, M) and"},{"kind":"arabic","text_bw":"A^ataAwiY~N","text_ar":"اَتَاوِىٌّ"},{"kind":"text","text":", (Lh, S, M,)"},{"kind":"italic_en","text":"a torrent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flow of water, that comes one knows not whence:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"that comes when the rain that has produced it has not fallen upon the people to whom it comes:"},{"kind":"text","text":"(Lh, S, M:) or"},{"kind":"italic_en","text":"that comes from a land upon which rain has fallen to a land upon which rain has not fallen."},{"kind":"text","text":"(T, Msb.) ―         -b2-  Hence, (T, M,) or the reverse is the case, (T, M, Msb,) all the words above, (AA, T, K,) or"},{"kind":"arabic","text_bw":"A^atiYa","text_ar":"اَتِىَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^ataAwiY~u","text_ar":"اَتَاوِىُّ"},{"kind":"text","text":", (S, M, Mgh, Msb, [the last said in the T to be the most approved,])"},{"kind":"italic_en","text":"A stranger;"},{"kind":"text","text":"or a man"},{"kind":"italic_en","text":"not of one's own people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not of one's own kindred:"},{"kind":"text","text":"(AA, T, S, M, Mgh:) or a man"},{"kind":"italic_en","text":"who asserts his relation to a people of whom he is not:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"A^atiY~N","text_ar":"اَتِىٌّ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"one who is among a people of whom he is not:"},{"kind":"text","text":"(As, T:) and"},{"kind":"arabic","text_bw":"A^ataAwiY~N","text_ar":"اَتَاوِىٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"a stranger, who is not in his own country;"},{"kind":"text","text":"or, accord. to Ks,"},{"kind":"italic_en","text":"a stranger, who is not in his own home:"},{"kind":"text","text":"(T:) the pl. of this last is"},{"kind":"arabic","text_bw":"A^ataAwiy~uwna","text_ar":"اَتَاوِيُّونَ"},{"kind":"text","text":": (S:) [the fem. sing. is"},{"kind":"arabic","text_bw":"A^ataAwy~apN","text_ar":"اَتَاويَّةٌ"},{"kind":"text","text":":] and the pl. fem."},{"kind":"arabic","text_bw":"A^ataAwy~aAtN","text_ar":"اَتَاويَّاتٌ"},{"kind":"text","text":". (T, S, M.)"}],"source_refs":["S","M","Sgh","K","TA","As","T","IB","Lh","Msb","AA","Mgh"]},{"entry_id":"n170","headword_ar":"اَتِىٌّ","root":"AtY","body":[{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"A^taAwiY~N","text_ar":"اتَاوِىٌّ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Atw","text_ar":"اتو"},{"kind":"text","text":". ―         -b2-  Also, (M, and so in some copies of the K, where it is said to be like"},{"kind":"arabic","text_bw":"raDiY~N","text_ar":"رَضِىٌّ"},{"kind":"text","text":",) or ↓"},{"kind":"arabic","text_bw":"A_itFY","text_ar":"اـِتًى","orth_type":"arrow"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"riDFY","text_ar":"رِضًى"},{"kind":"text","text":", (so in other copies of the K,) and ↓"},{"kind":"arabic","text_bw":"A^ataA='N","text_ar":"اَتَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) written by some"},{"kind":"arabic","text_bw":"A_itaA='N","text_ar":"اـِتَا=ءٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"What falls, of wood"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leaves, into a river:"},{"kind":"text","text":"(M, K:) from"},{"kind":"arabic","text_bw":"AlA_itoyaAnu","text_ar":"الاـِتْيَانُ"},{"kind":"text","text":": (M:) pl."},{"kind":"arabic","text_bw":"A=taA='N","text_ar":"ا=تَا=ءٌ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"AitA'","text_ar":"اِتاء"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"A^utiY~N","text_ar":"اُتِىٌّ"},{"kind":"text","text":". (M, K.) ―         -b3-"},{"kind":"arabic","text_bw":"rajulN A^atiY~N","text_ar":"رَجُلٌ اَتِىٌّ"},{"kind":"italic_en","text":"A man who is sharp, energetic, vigorous, and effective, in affairs; who applies himself to them with gentleness, and enters into them,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performs them, by the way,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"manner, proper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suitable, to them."},{"kind":"text","text":"(M.) ―         -b4-"},{"kind":"arabic","text_bw":"farasN A^atiY~N","text_ar":"فَرَسٌ اَتِىٌّ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"musotaA^otK","text_ar":"مُسْتَاْتٍ"},{"kind":"text","text":"."}],"source_refs":["M","K","TA"]},{"entry_id":"n159","headword_ar":"اَتَى","root":"AtY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^otiY","text_ar":"يَاْتِى"},{"kind":"text","text":", (Msb,) and, in the dial. of Hudheyl,"},{"kind":"arabic","text_bw":"yaA^ot","text_ar":"يَاْت"},{"kind":"text","text":", without"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"; (S;) and"},{"kind":"arabic","text_bw":"A^atayotuhu","text_ar":"اَتَيْتُهُ"},{"kind":"text","text":", (T, S, M, Msb, K,) [aor."},{"kind":"arabic","text_bw":"A=tiyhi","text_ar":"ا=تِيهِ"},{"kind":"text","text":";] and in the imperative, some of the Arabs say,"},{"kind":"arabic","text_bw":"ti","text_ar":"تِ"},{"kind":"text","text":", suppressing the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":", like as is done in"},{"kind":"arabic","text_bw":"xu*o","text_ar":"خُذْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"kulo","text_ar":"كُلْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muro","text_ar":"مُرْ"},{"kind":"text","text":"; (IJ, M;) inf. n."},{"kind":"arabic","text_bw":"A_itoyaAnN","text_ar":"اـِتْيَانٌ"},{"kind":"text","text":", (T, S, * M, Mgh, Msb, K,) or this is a simple subst., (Msb.) and"},{"kind":"arabic","text_bw":"A_itoyaAnapN","text_ar":"اـِتْيَانَةٌ"},{"kind":"text","text":", (M, K,) which should not be used as an inf. n. of un., unless by a bad poetic licence, (Lth, T,) and"},{"kind":"arabic","text_bw":"A^atoYN","text_ar":"اَتْىٌ"},{"kind":"text","text":"(T, S, M, Msb, K) and"},{"kind":"arabic","text_bw":"A^utiYN","text_ar":"اُتِىٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A_itiYN","text_ar":"اـِتِىٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maA^otaApN","text_ar":"مَاْتَاةٌ"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"came;"},{"kind":"text","text":"(Msb;) and"},{"kind":"italic_en","text":"I came to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"(S, M, Mgh, * Msb, K;) or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, present at it,"},{"kind":"text","text":"namely, a place: (Mgh:) as also"},{"kind":"arabic","text_bw":"A^ataA","text_ar":"اَتَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^otuw","text_ar":"يَاْتُو"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"A^atawotuhu","text_ar":"اَتَوْتُهُ"},{"kind":"text","text":", (T, S, M, K), aor."},{"kind":"arabic","text_bw":"A=tuwhu","text_ar":"ا=تُوهُ"},{"kind":"text","text":": (S:) for which reason, we assign the generality of the words mentioned in art."},{"kind":"arabic","text_bw":"Atw","text_ar":"اتو"},{"kind":"text","text":"to the present art. also. (M.) [Accord. to the authorities here indicated for the signification of"},{"kind":"arabic","text_bw":"A^ataY","text_ar":"اَتَى"},{"kind":"text","text":", this verb and"},{"kind":"arabic","text_bw":"jaA='a","text_ar":"جَا=ءَ"},{"kind":"text","text":"are syn.: some attempt to distinguish them; but contradict one another in so doing: the slight distinctions that exist between them will be best seen by a comparison of the exs. in this art. with those in art."},{"kind":"arabic","text_bw":"jyA^","text_ar":"جيا"},{"kind":"text","text":":] accord. to Er-Rághib, the proper [or primary] signification of"},{"kind":"arabic","text_bw":"AlA_itoyaAnu","text_ar":"الاـِتْيَانُ"},{"kind":"text","text":"is"},{"kind":"italic_en","text":"The coming with ease."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A^ataAhaA","text_ar":"اَتَاهَا"},{"kind":"text","text":", (Mgh, Msb,) inf. n."},{"kind":"arabic","text_bw":"A_itoyaAnN","text_ar":"اـِتْيَانٌ"},{"kind":"text","text":", (Msb,) [lit."},{"kind":"italic_en","text":"He came to her,"},{"kind":"text","text":"] means (assumed tropical:)"},{"kind":"italic_en","text":"he lay with her;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jaAmaEahaA","text_ar":"جَامَعَهَا"},{"kind":"text","text":"; (Mgh, Msb;) namely, a woman, (Mgh,) or his wife. (Msb.) Hence an expression in the Kur xxvi. 165. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"A^ataY Alqawoma","text_ar":"اَتَى القَوْمَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He came to the people:"},{"kind":"text","text":"and hence,]"},{"kind":"italic_en","text":"he asserted his relationship to the people, not being of them."},{"kind":"text","text":"(Msb.) [See"},{"kind":"arabic","text_bw":"A^atiY~u","text_ar":"اَتِىُّ"},{"kind":"text","text":"in art."},{"kind":"arabic","text_bw":"Atw","text_ar":"اتو"},{"kind":"text","text":".] ―         -b4-"},{"kind":"arabic","text_bw":"A^atay bihi","text_ar":"اَتَي بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He came with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brought, him,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he made him"},{"kind":"text","text":"(a man), and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing, such, for instance, as property),"},{"kind":"italic_en","text":"to come."},{"kind":"text","text":"(Kull.) [See also 4: and see, in what follows, other significations of"},{"kind":"arabic","text_bw":"A^ataY","text_ar":"اَتَى"},{"kind":"text","text":"trans. by means of"},{"kind":"arabic","text_bw":"bi","text_ar":"بِ"},{"kind":"text","text":". Hence,"},{"kind":"arabic","text_bw":"A^ataY biwaladK","text_ar":"اَتَى بِوَلَدٍ"},{"kind":"italic_en","text":"He begot a child,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"children."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"A^atato bihi","text_ar":"اَتَتْ بِهِ"},{"kind":"italic_en","text":"She brought him forth; gave birth to him."},{"kind":"text","text":"] Accord. to Aboo-Is-hák, the meaning of the words in the Kur [ii. 143]"},{"kind":"arabic","text_bw":"A^ayonamaA takuwnuwA yaA^oti bikumu All~`hu jamiyEFA","text_ar":"اَيْنَمَا تَكُونُوا يَاْتِ بِكُمُ اللّٰهُ جَمِيعًا"},{"kind":"text","text":"is,"},{"kind":"italic_en","text":"Wherever ye be, God will bring you all back unto Himself."},{"kind":"text","text":"(M.) [You say also,"},{"kind":"arabic","text_bw":"A^ataY bibay~inapK","text_ar":"اَتَى بِبَيِّنَةٍ"},{"kind":"italic_en","text":"He adduced a proof."},{"kind":"text","text":"] See also 3. ―         -b5-"},{"kind":"arabic","text_bw":"A^ataY AlA^amora","text_ar":"اَتَى الاَمْرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He entered into, engaged in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupied himself with, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair:"},{"kind":"text","text":"and, as also"},{"kind":"arabic","text_bw":"A^ataY bihi","text_ar":"اَتَى بِهِ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"he did, executed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performed, the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"(M. K;) and in like manner,"},{"kind":"arabic","text_bw":"Al*~anoba","text_ar":"الذَّنْبَ"},{"kind":"text","text":", [and"},{"kind":"arabic","text_bw":"baAl*~anobi","text_ar":"بَالذَّنْبِ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"the crime, sin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offence."},{"kind":"text","text":"(M.) It is said in the Kur [ix. 54],"},{"kind":"arabic","text_bw":"walaA yaA^otuwna AlS~alaApa A_il~aA wahumo kusaAlaY","text_ar":"وَلَا يَاْتُونَ الصَّلَاةَ اـِلَّا وَهُمْ كُسَالَى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"And they do not enter into,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"engage in, prayer, unless when they are heavy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sluggish."},{"kind":"text","text":"(TA.) And you say,"},{"kind":"arabic","text_bw":"A^ataY AlfaAHi$aha","text_ar":"اَتَى الفَاحِشَهَ"},{"kind":"text","text":", [and"},{"kind":"arabic","text_bw":"biAlfaAHi$api","text_ar":"بِالفَاحِشَةِ"},{"kind":"text","text":","},{"kind":"page_break","n":16},{"kind":"text","text":"(see Kur iv. 23 and lxv. 1,)]"},{"kind":"italic_en","text":"He entered into, engaged in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupied himself with,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committed,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that which was excessively foul"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^ataY biAljay~idi mino qawolK A^awo fiEolK","text_ar":"اَتَى بِالجَيِّدِ مِنْ قَوْلٍ اَوْ فِعْلٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He said, gave utterance to, uttered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he brought to pass, did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effected, what was good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excellent; he said,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did, well,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excel-lently"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"jwd","text_ar":"جود"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"A^ataY bijaroYi baEoda","text_ar":"اَتَى بِجَرْىِ بَعْدَ"},{"kind":"arabic","text_bw":"jaroYK","text_ar":"جَرْىٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"performed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fetched, run after run"},{"kind":"text","text":"]. (S in art."},{"kind":"arabic","text_bw":"tA^m","text_ar":"تام"},{"kind":"text","text":", &c.) ―         -b6-"},{"kind":"arabic","text_bw":"walaA yufoliHu Als~aAHiru","text_ar":"وَلَا يُفْلِحُ السَّاحِرُ"},{"kind":"arabic","text_bw":"Hayovu A^ataY","text_ar":"حَيْثُ اَتَى"},{"kind":"text","text":"[in the Kur xx. 72] means"},{"kind":"arabic","text_bw":"Hayovu kaAna","text_ar":"حَيْثُ كَانَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And the enchanter shall not prosper where he is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wherever he may be"},{"kind":"text","text":"]; (M, Bd, K;) and"},{"kind":"italic_en","text":"where he cometh:"},{"kind":"text","text":"(Bd:) or"},{"kind":"arabic","text_bw":"Hayovu A^ataY bisiHorihi","text_ar":"حَيْثُ اَتَى بِسِحْرِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"where he cometh with his enchantment;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"where he performeth his enchantment"},{"kind":"text","text":"]: (Jel:) and it is said to mean that where the enchanter is, he must be slain: such is the doctrine of the lawyers. (M.) ―         -b7-  Z mentions that"},{"kind":"arabic","text_bw":"A^ataY","text_ar":"اَتَى"},{"kind":"text","text":"occurs in the sense of"},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, became;"},{"kind":"text","text":"like as we sometimes say,"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to be"},{"kind":"text","text":"]; like"},{"kind":"arabic","text_bw":"jaA='a","text_ar":"جَا=ءَ"},{"kind":"text","text":"in the saying,"},{"kind":"arabic","text_bw":"jaA='a AlbinaA='u muHokamFA","text_ar":"جَا=ءَ البِنَا=ءُ مُحْكَمًا"},{"kind":"text","text":". (Kull.) [So you say,"},{"kind":"arabic","text_bw":"AlbinaA='u muHokamFA","text_ar":"البِنَا=ءُ مُحْكَمًا"},{"kind":"italic_en","text":"The building became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to be, firm, strong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"compact."},{"kind":"text","text":"] ―         -b8-  The saying, in the Kur [xvi. 1],"},{"kind":"arabic","text_bw":"A^ataY A^amoru A=ll~`hi falaA tasotaEojiluwhu","text_ar":"اَتَى اَمْرُ ا=للّٰهِ فَلَا تَسْتَعْجِلُوهُ"},{"kind":"text","text":"means ["},{"kind":"italic_en","text":"The threatened punishment ordained of God hath approached: therefore desire not ye to hasten it:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its coming hath approached."},{"kind":"text","text":"(TA.) [And in like manner,]"},{"kind":"arabic","text_bw":"A^utiYa fulaAnN","text_ar":"اُتِىَ فُلَانٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"Such a one was approached by the enemy come in sight of him."},{"kind":"text","text":"(K.)"},{"kind":"arabic","text_bw":"A^utiyta yaA fulaAnN","text_ar":"اُتِيتَ يَا فُلَانٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thou art approached"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"O such a one,"},{"kind":"text","text":"] is said when one is warned of an enemy that has come in sight of him. (Sgh, TA.) And"},{"kind":"arabic","text_bw":"A^ataY Ealayohimu AlEaduw~u","text_ar":"اَتَى عَلَيْهِمُ العَدُوُّ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The enemy came to them,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"came down upon them,"},{"kind":"text","text":"for, as MF observes,"},{"kind":"arabic","text_bw":"A^ataY","text_ar":"اَتَى"},{"kind":"text","text":"when trans. by means of"},{"kind":"arabic","text_bw":"EalaY","text_ar":"عَلَى"},{"kind":"text","text":"seems to imply the meaning of"},{"kind":"arabic","text_bw":"nazala","text_ar":"نَزَلَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"overcoming,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overpowering, them."},{"kind":"text","text":"(Bd in xviii. 40.) ―         -b9-  Hence,"},{"kind":"arabic","text_bw":"A^ataY Ealayohi","text_ar":"اَتَى عَلَيْهِ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"A^ataAhu","text_ar":"اَتَاهُ"},{"kind":"text","text":", as will be seen by what follows,] (assumed tropical:)"},{"kind":"italic_en","text":"He destroyed him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(Bd ubi suprà.) And hence, from"},{"kind":"arabic","text_bw":"A_itoyaAnu AlEaduw~i","text_ar":"اـِتْيَانُ العَدُوِّ"},{"kind":"text","text":", (Mgh,)"},{"kind":"arabic","text_bw":"A^ataY Ealayohi","text_ar":"اَتَى عَلَيْهِ"},{"kind":"arabic","text_bw":"Ald~ahoru","text_ar":"الدَّهْرُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, destroyed him."},{"kind":"text","text":"(M, Mgh, Msb, K.) Destruction is meant in the Kur [lix. 2], where it is said,"},{"kind":"arabic","text_bw":"fA^atAhumu All~`hu mino Hyovu lamo","text_ar":"فاَتاهُمُ اللّٰهُ مِنْ حيْثُ لَمْ"},{"kind":"arabic","text_bw":"yaHotasibuwA","text_ar":"يَحْتَسِبُوا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"But God brought destruction upon them whence they did not reckon,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"expect"},{"kind":"text","text":"]. (EsSemeen, TA.) And it is said in the Kur [xvi. 28],"},{"kind":"arabic","text_bw":"faA^ataY All~`hu bunoyaAnahumo mina AlqawaAEidi","text_ar":"فَاَتَى اللّٰهُ بُنْيَانَهُمْ مِنَ القَوَاعِدِ"},{"kind":"text","text":", i. e. (assumed tropical:)"},{"kind":"italic_en","text":"But God removed their building from the foundations, and demolished it"},{"kind":"text","text":"upon them, so that He destroyed them. (TA.)"},{"kind":"arabic","text_bw":"A^ataY Ealayohi","text_ar":"اَتَى عَلَيْهِ"},{"kind":"text","text":"also signifies (assumed tropical:)"},{"kind":"italic_en","text":"He caused it to come to an end; made an end of it; consumed it;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"devoured it;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"exhausted it; came to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reached, the end of it;"},{"kind":"text","text":"namely, a thing; (Kull;) as, for instance, what was in a bowl; (K in art."},{"kind":"arabic","text_bw":"jrdm","text_ar":"جردم"},{"kind":"text","text":";) and what was in a vessel; (K in art."},{"kind":"arabic","text_bw":"jrjb","text_ar":"جرجب"},{"kind":"text","text":";) like"},{"kind":"arabic","text_bw":"faraga minohu","text_ar":"فَرَغَ مِنْهُ"},{"kind":"text","text":": (ISd cited in the TA in art."},{"kind":"arabic","text_bw":"nk$","text_ar":"نكش"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"mar~a bihi","text_ar":"مَرَّ بِهِ"},{"kind":"text","text":"[which may be rendered"},{"kind":"italic_en","text":"he went away with it;"},{"kind":"text","text":"but this, as an explanation of"},{"kind":"arabic","text_bw":"A^ataY Ealayohi","text_ar":"اَتَى عَلَيْهِ"},{"kind":"text","text":", has another meaning, which see in what follows]. (Kull.) And one says,"},{"kind":"arabic","text_bw":"A^utiYa fulaAnN","text_ar":"اُتِىَ فُلَانٌ"},{"kind":"arabic","text_bw":"mino maA^omanihi","text_ar":"مِنْ مَاْمَنِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Destruction came to such a one from the quarter whence he felt secure."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^utiYa Ealay yadi fulaAnK","text_ar":"اُتِىَ عَلَي يَدِ فُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Property belonging to such a one perished."},{"kind":"text","text":"(T.) And"},{"kind":"arabic","text_bw":"yuw^otaY duwnahu","text_ar":"يُوْتَى دُونَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He is taken away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carried off, and overcome."},{"kind":"text","text":"(TA.) A poet says,"},{"kind":"quote","text":"A^ataY duwna HulowiAlEayo$i Hat~aY A^amar~ahu\n                      \n                     \n                        nukuwbN Ealay A=vaArihin~a nukuwbu"},{"kind":"text","text":"meaning (assumed tropical:)  ["},{"kind":"italic_en","text":"Misfortunes, in the footsteps of which were misfortunes,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"took away"},{"kind":"text","text":"["},{"kind":"italic_en","text":"what was sweet, of life, and rendered it bitter"},{"kind":"text","text":"]. (TA.) One says also,"},{"kind":"arabic","text_bw":"mino h`hunaA A^utiyato","text_ar":"مِنْ هٰهُنَا اُتِيَتْ"},{"kind":"text","text":", [so I find it written, but I think that the last word should be"},{"kind":"arabic","text_bw":"A^utiyta","text_ar":"اُتِيتَ"},{"kind":"text","text":", agreeably with a preceding phrase from the T,] (assumed tropical:)"},{"kind":"italic_en","text":"Hence the trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affliction, came in upon thee."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"A^utiYa mino jihapi ka*aA","text_ar":"اُتِىَ مِنْ جِهَةِ كَذَا"},{"kind":"text","text":", with the verb in the passive form, (assumed tropical:)"},{"kind":"italic_en","text":"He missed"},{"kind":"text","text":"["},{"kind":"italic_en","text":"his object in respect of such a thing"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by laying hold upon it when it was not fit to be laid hold upon."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"A^utiYa Alr~ajulu","text_ar":"اُتِىَ الرَّجُلُ"},{"kind":"text","text":", [also] like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The man was deceived,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deluded, and his faculty of sense became altered to him, so that he imagined that to be true which was not true."},{"kind":"text","text":"(TA.) ―         -b10-"},{"kind":"arabic","text_bw":"A^ataY Ealayohi","text_ar":"اَتَى عَلَيْهِ"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"mar~a bihi","text_ar":"مَرَّ بِهِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"(as, for instance, a period of time,)"},{"kind":"italic_en","text":"passed by him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"over him"},{"kind":"text","text":"]. (Msb.) You say,"},{"kind":"arabic","text_bw":"A^ata Ealayohi HawolN","text_ar":"اَتَ عَلَيْهِ حَوْلٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A year passed over him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became a year old"},{"kind":"text","text":"]. (S, K, Msb, in art."},{"kind":"arabic","text_bw":"Hwl","text_ar":"حول"},{"kind":"text","text":"; &c.) ―         -b11-"},{"kind":"arabic","text_bw":"A^atati Aln~aAqahu","text_ar":"اَتَتِ النَّاقَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maA A^aHosana A^atoYa yadaY h*ihi Aln~Aqapi","text_ar":"مَا اَحْسَنَ اَتْىَ يَدَى هذِهِ النّاقَةِ"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"Atw","text_ar":"اتو"},{"kind":"text","text":"."}],"source_refs":["Msb","T","S","M","K","Lth","Mgh","Bd","Jel"]},{"entry_id":"n165","headword_ar":"اـِتَّى","root":"AtY","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^atiY~N","text_ar":"اَتِىٌّ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n172","headword_ar":"اَتَّى","root":"AtY","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Hat~aY","text_ar":"حَتَّى"},{"kind":"text","text":"; (K;) a dial. var. of the latter. (TA.)"}],"source_refs":[]}]}}