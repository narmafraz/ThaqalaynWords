lanes":{"found":true,"entry_ids":["n11294"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AE%D9%92%D8%AA%D9%8E%D9%84%D9%8E%D8%B7%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11294","headword_ar":"اختلط","root":"xlT","body":[{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, mixed, mingled, commingled, incorporated"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blended together,"},{"kind":"text","text":"(S, * Msb, K,) or"},{"kind":"italic_en","text":"put together."},{"kind":"text","text":"(Msb.) [And hence, (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confused, confounded, indiscriminate, promiscuous, without order, disordered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"AxtlT All~ayolu biAlt~uraAbi","text_ar":"اختلط اللَّيْلُ بِالتُّرَابِ"},{"kind":"text","text":"(assumed tropical:) ["},{"kind":"italic_en","text":"The night became confused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confounded, with the dust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth"},{"kind":"text","text":"]: (AZ, K:) and"},{"kind":"arabic","text_bw":"AlHaAbilu","text_ar":"الحَابِلُ"},{"kind":"arabic","text_bw":"biAln~aAbili","text_ar":"بِالنَّابِلِ"},{"kind":"text","text":"(K) (assumed tropical:)"},{"kind":"italic_en","text":"the setter of the snare with the shooter of arrows;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the warp with the woof:"},{"kind":"text","text":"(TA:) and"},{"kind":"arabic","text_bw":"AlmaroEaY biAlhamali","text_ar":"المَرْعَى بِالهَمَلِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"the place of pasturage with the camels left to pasture by themselves"},{"kind":"text","text":"]: (AZ, K:) and"},{"kind":"arabic","text_bw":"AlxaAviru biAlz~ubaAdi","text_ar":"الخَاثِرُ بِالزُّبَادِ"},{"kind":"text","text":"(as in some copies of the K and in the TA) (assumed tropical:)"},{"kind":"italic_en","text":"the thick milk with the butter that had become bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spoiled, in the churning;"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"with the thin milk;"},{"kind":"text","text":"(TA;) or"},{"kind":"arabic","text_bw":"biAlz~ab~aAdi","text_ar":"بِالزَّبَّادِ"},{"kind":"text","text":"(as in other copies of the K and in the TA)"},{"kind":"italic_en","text":"with the herb"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so called"},{"kind":"text","text":"], which, when it falls into the"},{"kind":"arabic","text_bw":"raAy^ib","text_ar":"رَايِب"},{"kind":"text","text":"[or milk that is thick, and fit for churning, &c.], is with difficulty separated from it: (TA:) [but see art."},{"kind":"arabic","text_bw":"zbd","text_ar":"زبد"},{"kind":"text","text":":] proverbs, alluding to the dubiousness and confusedness of an affair or a case: (K:) or the first, to the dubiousness of an affair or case; and the second, to its confusedness; and the third is applied when a people's affair or case is confused or perplexed to them; and the last relates to the confusedness of truth with falsity; and to a people whose affair or case is dubious to them, so that they do not decide upon anything. (TA.) ―         -b3-  ["},{"kind":"arabic","text_bw":"AxtlT AlZ~alaAmu","text_ar":"اختلط الظَّلَامُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The darkness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the beginning of night, became confused,"},{"kind":"text","text":"is a phrase of frequent occurrence. And so"},{"kind":"arabic","text_bw":"AixotilaATu AlZ~alaAmi","text_ar":"اِخْتِلَاطُ الظَّلَامِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The confusedness of the darkness,"},{"kind":"text","text":"&c.] ―         -b4-"},{"kind":"arabic","text_bw":"AxtlT Ealayohimo","text_ar":"اختلط عَلَيْهِمْ"},{"kind":"arabic","text_bw":"A^amoruhumo","text_ar":"اَمْرُهُمْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Their affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became confused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, to them"},{"kind":"text","text":"]. (S.) ―         -b5-  See also 3, in four places, near the end of the paragraph: and see 6. ―         -b6-  Said of a camel, (tropical:)"},{"kind":"italic_en","text":"He became fat;"},{"kind":"text","text":"(ISh, K;)"},{"kind":"italic_en","text":"his fat and flesh becoming mixed together."},{"kind":"text","text":"(ISh.) ―         -b7-  Said of a horse: see 4, last sentence."}],"source_refs":["AZ","K","TA"]}]},"classical_definitions":null}