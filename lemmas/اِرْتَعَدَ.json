https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B1%D9%92%D8%AA%D9%8E%D8%B9%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15876","headword_ar":"ارتعد","root":"rEd","body":[{"kind":"italic_en","text":"He trembled, quivered, quaked, shivered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became in a state of commotion,"},{"kind":"text","text":"(S, A, L, Msb, K,) by reason of fear, (A, L,) or cold, (A,) &c.; (L;) as also"},{"kind":"arabic","text_bw":"rEd","text_ar":"رعد"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yrEd","text_ar":"يرعد"},{"kind":"text","text":": (Msb: [written in my copy without any syll. signs; but it seems to be indicated that it is ↓"},{"kind":"arabic","text_bw":"raEada","text_ar":"رَعَدَ","orth_type":"arrow"},{"kind":"text","text":"aor."},{"kind":"arabic","text_bw":"yaroEudu","text_ar":"يَرْعُدُ"},{"kind":"text","text":": I believe, however, that ↓"},{"kind":"arabic","text_bw":"ruEida","text_ar":"رُعِدَ","orth_type":"arrow"},{"kind":"text","text":"is also used in this sense, and in the sense here following:])"},{"kind":"italic_en","text":"he was affected with a tremour, quivering, quaking, shivering,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commotion;"},{"kind":"text","text":"(A, L;) as also ↓"},{"kind":"arabic","text_bw":"A^uroEida","text_ar":"اُرْعِدَ","orth_type":"arrow"},{"kind":"text","text":", (S, A, L, K,) and ↓"},{"kind":"arabic","text_bw":"taraEodada","text_ar":"تَرَعْدَدَ","orth_type":"arrow"},{"kind":"text","text":", (L,) and ↓"},{"kind":"arabic","text_bw":"trE~d","text_ar":"ترعّد","orth_type":"arrow"},{"kind":"text","text":"; (TA;) by fear, (A, L,) or cold, (A,) &c. (L.) You say,"},{"kind":"arabic","text_bw":"faraAy^iSuhu Einoda","text_ar":"فَرَايِصُهُ عِنْدَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^uroEidato","text_ar":"اُرْعِدَتْ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlfazaEi","text_ar":"الفَزَعِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"His muscles called the"},{"kind":"arabic","text_bw":"frAy^Sa","text_ar":"فرايصَ"},{"kind":"text","text":"(pl. of"},{"kind":"arabic","text_bw":"fariySapN","text_ar":"فَرِيصَةٌ"},{"kind":"text","text":"q. v.)"},{"kind":"italic_en","text":"quivered on the occasion of fright"},{"kind":"text","text":"]. (S, A, * L.) And"},{"kind":"arabic","text_bw":"AlA^aloyapu","text_ar":"الاَلْيَةُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taraE~adati","text_ar":"تَرَعَّدَتِ","orth_type":"arrow"},{"kind":"text","text":", (K,) or, as in some of the Lexicons, ↓"},{"kind":"arabic","text_bw":"taraEodadat","text_ar":"تَرَعْدَدَت","orth_type":"arrow"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"Alyp","text_ar":"الية"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"buttock,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"buttocks,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"quivered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moved to and fro:"},{"kind":"text","text":"(K, TA:) and in like manner one says of anything subject to such motion; as [the kinds of food called]"},{"kind":"arabic","text_bw":"qariys","text_ar":"قَرِيس"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"faAluw*","text_ar":"فَالُوذ"},{"kind":"text","text":", and a hill or heap of sand, and the like. (TA.)"}],"source_refs":["S","A","L","Msb","K","TA"]}]}}