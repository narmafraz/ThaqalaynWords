,"form":"تَأْبَُوا","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَأْبَُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَأْبَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَأْبَ","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَأْبَى","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَأْبَ","in_corpus":true,"count":58,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَأْبَى","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَأْبَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَأْبَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَأْبَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَأْبَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَأْبَُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَأْبَُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَأْبَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَأْبَ","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَأْبَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَبَيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَبَيْنا","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":238,"cross_references":{"qac":{"found":true,"lemma_key":"أَبَى","root":"أبي","pos":"V","occurrence_count":13},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n120","n122","n129"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%A8%D9%8E%D9%89"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n120","headword_ar":"اَبَىٌّ","root":"Abw","body":[{"kind":"text","text":"dim, of"},{"kind":"arabic","text_bw":"A^abN","text_ar":"اَبٌ"},{"kind":"text","text":", q. v. (Msb.)"}],"source_refs":[]},{"entry_id":"n122","headword_ar":"اَبَى","root":"AbY","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaA^obaY","text_ar":"يَاْبَى"},{"kind":"text","text":", (S, M, Msb, K,) which is anomalous, (S, M, Msb,) because it has no faucial letter (S, Msb) for its second or third radical, (Msb,) and"},{"kind":"arabic","text_bw":"yaA^obiY","text_ar":"يَاْبِى"},{"kind":"text","text":", (M, Msb, K,) mentioned by IJ as sometimes said, (M,) agreeably with analogy, (TA,) and"},{"kind":"arabic","text_bw":"yiy^obaY","text_ar":"يِيْبَى"},{"kind":"text","text":", which is doubly anomalous, first because the pret. is of the measure"},{"kind":"arabic","text_bw":"faEala","text_ar":"فَعَلَ"},{"kind":"text","text":", and this pronunciation of the"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"of the aor. is [regularly allowable only] in the case of a verb of the measure"},{"kind":"arabic","text_bw":"faEila","text_ar":"فَعِلَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafoEalu","text_ar":"يَفْعَلُ"},{"kind":"text","text":", and secondly because it is only in an aor. like"},{"kind":"arabic","text_bw":"yiyojalu","text_ar":"يِيْجَلُ"},{"kind":"text","text":", (Sb, M,) i. e., of a verb of which the first radical letter is"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", (TA in art."},{"kind":"arabic","text_bw":"wjl","text_ar":"وجل"},{"kind":"text","text":",) and"},{"kind":"arabic","text_bw":"yiy^obiY","text_ar":"يِيْبِى"},{"kind":"text","text":", (IB, [who cites as an ex. a verse ending with the phrase"},{"kind":"arabic","text_bw":"Hat~aY tiy^obiyaho","text_ar":"حَتَّى تِيْبِيَهْ"},{"kind":"text","text":",]) inf. n."},{"kind":"arabic","text_bw":"A_ibaA='N","text_ar":"اـِبَا=ءٌ"},{"kind":"text","text":"(S, M, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"A_ibaA='a pN","text_ar":"اـِبَا=ءَ ةٌ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"A_ibaApN","text_ar":"اـِبَاةٌ"},{"kind":"text","text":", (so in a copy of the M,) or"},{"kind":"arabic","text_bw":"A_ibaAyapN","text_ar":"اـِبَايَةٌ"},{"kind":"text","text":", (so in the Msb,)"},{"kind":"italic_en","text":"He refused;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrained, forbore, abstained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AimotanaEa","text_ar":"اِمْتَنَعَ"},{"kind":"text","text":"; (S, Msb, MF, Bd in ii. 32, Kull p. 8,)"},{"kind":"italic_en","text":"voluntarily,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of his own free will"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choice:"},{"kind":"text","text":"(Bd ubi suprà, Kull:) [thus when used intransitively: and it is also used transitively:] you say,"},{"kind":"arabic","text_bw":"A^abaY AlA^amora","text_ar":"اَبَى الاَمْرَ"},{"kind":"italic_en","text":"he refused assent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consent, to the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair; disagreed to it;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"did not desire"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to do"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(Mtr in Har p. 483:)"},{"kind":"italic_en","text":"he did not assent to, consent to, approve,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choose, it; he disallowed it; rejected it:"},{"kind":"text","text":"(Mgh:) and"},{"kind":"arabic","text_bw":"A^abay Al$~aYo 'a","text_ar":"اَبَي الشَّىْ ءَ"},{"kind":"italic_en","text":"he disliked, was displeased with, disapproved of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hated, the thing."},{"kind":"text","text":"(M, K.) Fr says that there is no verb with fet-h to its medial radical letter in the pret. and fut. [or aor.] unless its second or third radical is a faucial letter, except"},{"kind":"arabic","text_bw":"A^abaY","text_ar":"اَبَى"},{"kind":"text","text":": that AA adds"},{"kind":"arabic","text_bw":"rakana","text_ar":"رَكَنَ"},{"kind":"text","text":": but that one says"},{"kind":"arabic","text_bw":"rakana","text_ar":"رَكَنَ"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"yarokunu","text_ar":"يَرْكُنُ"},{"kind":"text","text":"for its fut., and"},{"kind":"arabic","text_bw":"rakina","text_ar":"رَكِنَ"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"yarokanu","text_ar":"يَرْكَنُ"},{"kind":"text","text":"for its fut.: (T:) so that the instance mentioned by AA is one of an intermixture of two dial. vars.: (TA:) Th adds"},{"kind":"arabic","text_bw":"qalaY","text_ar":"قَلَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"gasaA","text_ar":"غَسَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ajaA","text_ar":"شَجَا"},{"kind":"text","text":"; and Mbr adds"},{"kind":"arabic","text_bw":"jabaA","text_ar":"جَبَا"},{"kind":"text","text":": but most of the Arabs say"},{"kind":"arabic","text_bw":"yaqoliY","text_ar":"يَقْلِى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yagosuw","text_ar":"يَغْسُو"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ya$ojuw","text_ar":"يَشْجُو"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yajobiY","text_ar":"يَجْبِى"},{"kind":"text","text":". (T.) [Some other instances are mentioned by other authors; but these are verbs of which the aors. are rarely with fet-h, or are instances of the intermixture of two dial. vars.]"},{"kind":"arabic","text_bw":"A^abayota All~aEona","text_ar":"اَبَيْتَ اللَّعْنَ"},{"kind":"text","text":"is a greeting which was addressed to kings in the time of ignorance; meaning"},{"kind":"italic_en","text":"Mayest thou refuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dislike,"},{"kind":"text","text":"(ISk, * S, * M, * Har p. 491,) to do a thing that would occasion thy"},{"kind":"italic_en","text":"being cursed!"},{"kind":"text","text":"(ISk, S, M;) or, to do that for which thou wouldst deserve"},{"kind":"italic_en","text":"the being cursed!"},{"kind":"text","text":"for it implies the meaning of a prayer; i. e., may God make thee to be of those who dislike the being cursed! and hence it occurs parenthetically. (Har ubi suprà.) You say also,"},{"kind":"arabic","text_bw":"A^abaY A^ano yuDaAma","text_ar":"اَبَى اَنْ يُضَامَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He refused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did not submit, to be harmed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"injured"},{"kind":"text","text":"]. (T.) [And sometimes"},{"kind":"arabic","text_bw":"laA","text_ar":"لَا"},{"kind":"text","text":"is inserted after"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"text","text":", and is either redundant, or corroborative of the meaning of the verb, as in the case of"},{"kind":"arabic","text_bw":"A^ana laA","text_ar":"اَنَ لَا"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"A^al~aA","text_ar":"اَلَّا"},{"kind":"text","text":"after"},{"kind":"arabic","text_bw":"manaEa","text_ar":"مَنَعَ"},{"kind":"text","text":".] It is said in the Kur ix. 32,"},{"kind":"arabic","text_bw":"wayaA^obaY All~hu A_il~aA A^ano yutim~a nawrahu","text_ar":"وَيَاْبَى اللّهُ اـِلَّا اَنْ يُتِمَّ نَورَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"But God will not consent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choose"},{"kind":"text","text":"["},{"kind":"italic_en","text":"save to complete,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perfect, his light"},{"kind":"text","text":"]. (Bd.) And in the same xvii. 91,"},{"kind":"arabic","text_bw":"faA^abay A^akovaru AlnaAsa A_il~aA kufuwrFA","text_ar":"فَاَبَي اَكْثَرُ النَاسَ اـِلَّا كُفُورًا"},{"kind":"text","text":", i. e. ["},{"kind":"italic_en","text":"But the greater number of men have not consented to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chosen,"},{"kind":"text","text":"aught]"},{"kind":"italic_en","text":"save denying"},{"kind":"text","text":"[its truth, or"},{"kind":"italic_en","text":"disbelieving"},{"kind":"text","text":"it]; this phrase with"},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":"being allowable because it is rendered by means of a negative. (Bd.) You also say,"},{"kind":"arabic","text_bw":"kaAna yaA^obaY All~aHoma","text_ar":"كَانَ يَاْبَى اللَّحْمَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He used to refuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dislike, flesh-meat"},{"kind":"text","text":"], (K,) or"},{"kind":"arabic","text_bw":"A^akola All~aHomi","text_ar":"اَكْلَ اللَّحْمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the eating of flesh-meat"},{"kind":"text","text":"]. (Mgh.) And"},{"kind":"arabic","text_bw":"A^abaY falaAnN AlmaA='i","text_ar":"اَبَى فَلَانٌ المَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one refused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disliked, water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the water"},{"kind":"text","text":"]: (S:) or"},{"kind":"arabic","text_bw":"A^abaY mino $urobi","text_ar":"اَبَى مِنْ شُرْبِ"},{"kind":"arabic","text_bw":"AlmaA='i","text_ar":"المَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"he refused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voluntarily refrained from, the drinking of water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the water"},{"kind":"text","text":"]. (AAF, M.) And"},{"kind":"arabic","text_bw":"A^abaY Ealayohi AlA^amara","text_ar":"اَبَى عَلَيْهِ الاَمَرَ"},{"kind":"text","text":", (Mgh, and Mtr. [author of the Mgh] in Har p. 483,) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taA^ab~aAhu","text_ar":"تَاَبَّاهُ","orth_type":"arrow"},{"kind":"text","text":", both signify"},{"kind":"italic_en","text":"He refused him his assent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"consent, to the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(Mtr ubi suprà, in Har.) Hence, (Mtr ubi suprà,)"},{"kind":"arabic","text_bw":"A^abaY Ealayohi","text_ar":"اَبَى عَلَيْهِ"},{"kind":"text","text":", (Mgh, and Mtr ubi suprà,) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"taA^ab~aY","text_ar":"تَاَبَّى","orth_type":"arrow"},{"kind":"text","text":", (T, S, and Mtr ubi suprà,)"},{"kind":"italic_en","text":"He was incompliant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unyielding, to him; he resisted him, withstood him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"repugned him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AimotanaEa","text_ar":"اِمْتَنَعَ"},{"kind":"text","text":"(T, S, Mgh, and Mtr ubi suprà)"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":": (T:) thus explained because the objective complement ("},{"kind":"arabic","text_bw":"AlA^amora","text_ar":"الاَمْرَ"},{"kind":"text","text":") is suppressed. (Mtr ubi suprà.)       -A2-"},{"kind":"arabic","text_bw":"A^abiyotu AlT~aEaAma","text_ar":"اَبِيْتُ الطَّعَامَ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"mina AlT~aEaAmi","text_ar":"مِنَ الطَّعَامِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"All~abani","text_ar":"اللَّبَنِ"},{"kind":"text","text":", (M, TA, [in a copy of the former of which the verb is written"},{"kind":"arabic","text_bw":"Abayotu","text_ar":"ابَيْتُ"},{"kind":"text","text":", but this I suppose to be a mistranscription, on account of what here follows,]) like"},{"kind":"arabic","text_bw":"raDiyotu","text_ar":"رَضِيْتُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A^ab~aY","text_ar":"اَبَّى"},{"kind":"text","text":", (M, and so in some copies of the K,) or"},{"kind":"arabic","text_bw":"A_ib~aY","text_ar":"اـِبَّى"},{"kind":"text","text":", (so in some copies of the K,) with kesr, and with the short final alif, (TA, [i.e. like"},{"kind":"arabic","text_bw":"riD~aY","text_ar":"رِضَّى"},{"kind":"text","text":", but perhaps this may have been supposed to be the right reading only because the verb is likened to"},{"kind":"arabic","text_bw":"raDiytu","text_ar":"رَضِيتُ"},{"kind":"text","text":", of which"},{"kind":"arabic","text_bw":"riD~aY","text_ar":"رِضَّى"},{"kind":"text","text":"is the most common inf. n.,])"},{"kind":"italic_en","text":"I left,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"relinquished, the food,"},{"kind":"text","text":"(M, K,) and"},{"kind":"italic_en","text":"the milk,"},{"kind":"text","text":"(M, TA,)"},{"kind":"italic_en","text":"without being satiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"satisfied."},{"kind":"text","text":"(M, K.) ―         -b2-"},{"kind":"arabic","text_bw":"A^abiYa AlfaSiylu","text_ar":"اَبِىَ الفَصِيلُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^ubiYa","text_ar":"اُبِىَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A^ab~aY","text_ar":"اَبَّى"},{"kind":"text","text":","},{"kind":"italic_en","text":"The young camel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young weaned camel, suffered indigestion from the milk, and became affected with a dislike of food."},{"kind":"text","text":"(M, K.)       -A3-"},{"kind":"arabic","text_bw":"A^abayotu","text_ar":"اَبَيْتُ"},{"kind":"text","text":"as"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"A^abawotu","text_ar":"اَبَوْتُ"},{"kind":"text","text":": see the latter."}],"source_refs":["S","M","Msb","K","TA","Sb","Mgh","T"]},{"entry_id":"n129","headword_ar":"اَبِىٌّ","root":"AbY","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^abiyapN","text_ar":"اَبِيَةٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A=bK","text_ar":"ا=بٍ"},{"kind":"text","text":", in three places. ―         -b2-  Also, the former ("},{"kind":"arabic","text_bw":"A^abiY~N","text_ar":"اَبِىٌّ"},{"kind":"text","text":"), She [app. a camel, or any beast,]"},{"kind":"italic_en","text":"that refuses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrains from, fodder, by reason of her suffering from indigestion:"},{"kind":"text","text":"and she"},{"kind":"italic_en","text":"that refuses,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"refrains from, the stallion, by reason of her having little appetency."},{"kind":"text","text":"(AA.) [See also"},{"kind":"arabic","text_bw":"A^awaAbK","text_ar":"اَوَابٍ"},{"kind":"text","text":", voce"},{"kind":"arabic","text_bw":"A=bK","text_ar":"ا=بٍ"},{"kind":"text","text":".]"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A3%D8%A8%D9%89/","headword_ar":"أبى","entries":[{"lexicon_id":"dictionary_9","lexicon_en":"Al-Zamakhsharī, Asās al-Balāgha (d. 1143 CE)","lexicon_ar":"أساس البلاغة للزمخشري","permalink":"https://arabiclexicon.hawramani.com/?p=17510#4e7433","body_html":"<span class=\"title1\">أب ى</span><br><br><span>أبى الله إلا أن يكون كذا. وأبى عليَّ وتأبى: امتنع. وهو أبيُّ الضيم وآبي الضيم: له نفس أبية وفيه عبية. ونوق أواب: يأبين الفحل. وأصابه أباء بالضم إذا كان يأبى الطعام. تقول: فلانٌ إن شهد الطعان فالحمية والإباء، وإن حضر الطعام فالحمية والأباء.</span><br><br><span>ومن المجاز: لا أبا لك، ولا أبا لغيرك، ولا أبا لشانئك، يقولونه في الحث، حتى أمر بعضهم لجفائه بقوله: أمطر علينا الغيث لا أبا لكا ويقال: لعمر أبيك ولعمر أبي سواك. قال الكميتُ:</span><br><br><span>إني لعمر أبي سوا </span><span class=\"red\">...</span><span> ك من الصنائع والذخائر</span><br><br><span>وهو أبو الأضياف. ومن أبو مثواك؟ وهو أبو الرؤيس وأبو العمامة: للكبير الرأس والعمامة.</span>"},{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=17510#4e12c9","body_html":"<span class=\"title1\">أبى</span><span>: مصدرها اباية في معجم فوك. ويقال: أبى منه. ففي كوزج مختار ص113: ((فان كنت راغبا في الخلافة أبيت أنا منها)) أي رغبت عنها وعفتها. وفي رياض النفوس (102و): فأبى عليه من ذلك، أي امتنع عليه أن يقبل ذلك منه. - ويقال: أبى عنه (فوك، بوشر) بمعنى امتنع عنه.</span><br><span>وأَبِيَ: راجع ديوان الهذليين 251 لمعرفة المعنى الأخير الذي ذكره فريتاج ومن هنا يقال: تيس أأبى وشاة أبواء.</span><br><span>آبى: أن العبارة التي نقلها فريتاج من ديوان الهذليين هي في ص251 منه.</span><br><span>إباة: انكار، جحود الشيء المستحق (بوشر).</span><br><span>إباية: اباء، كبر، عظمة (معيار 18).</span><br><span>أبَّاء: فخور، متكبر (الكامل 352).</span><br><span>أابى وابواء: راجع أبى.</span><br><span>مأباة: امتناع، انكار، جحود (بوشر).</span>"},{"lexicon_id":"dictionary_21","lexicon_en":"Muḥammad al-Fattinī, Majmaʿ Biḥār al-Anwār fī Gharāʾib al-Tanzīl wa Laṭāʾif al-Akhbār (d. 1578 CE)","lexicon_ar":"مجمع بحار الأنوار للفَتِّنيّ","permalink":"https://arabiclexicon.hawramani.com/?p=17510#808d76","body_html":"<span class=\"title1\">[أبى]</span><span> ن- فيه: كلكم في الجنة إلا من \"أبى\"- أي من ترك طاعة الله، لأن من ترك التسبب إلى شيء لا يوجد بغيره فقد أباه، والإباء أشد الامتناع. ط: كل أمتي- أي أمة الدعوة، والأبى الكافر؛ أو أمة الإجابة، والأبى العاصي، واستثناه زجراً وتغليظاً، وحق الجواب: إلا من عصى، وعدل إلى المذكور تنبيهاً على أنهم ما عرفوا هذا ولا ذاك؛ وفيه: قال: أربعون يوماً، قال: \"أبيت\"- أي أمتنع عن الكذب على الرسول صلى الله عليه وسلم والإخبار بما لا أعلم، ولا أدري أن الأربعين أيام أو أشهر. ن: أي أبيت عن الجزم بالمراد وإنما أجزم أربعين مجملة. ك: م</span><span>النفختين أربعون سنة، قال: \"أبيت\"- أي امتنعت عن التصديق بمعين من السنة أو الشهر، أو عن الإخبار بما لا أعلم. نه- وفيه: يبقى المهدى أربعين، فقيل: سنة، قال: \"أبيت\" أن تعرفه فإنه غيب، وإن روى: أبيت- بالرفع فمعناه أبيت أن أقول ما لم أسمعه، وقد جاء مثله في غير هذا الحديث، و\"أبيت\" اللعن- من تحية الملوك في الجاهلية أي أبيت أن تفعل ما تلعن بسببه وتذم. ج: و\"يأبى\" الله ذلك والمؤمنون، فيه نوع دلالة على خلافة الصديق، لأنه لا يريد به نفي الصلاة خلف عمر وهي جائز خلف أحاد الأمة، وإنما أراد الإمامة والخلافة، على أنه يجوز أن يراد أن الله يأبى والمسلمون أن يتقدم في الصلاة أحد على جماعة فيهم أبو بكر وهو أكبرهم قدراً وعلماً، فإن التقدم عليه في مثل الصلاة التي هي أكبر الأعمال وأشرفها مما يأباه الله تعالى والمسلمون؛ والأول مفهوم وهذا صريح. ن: الملأ \"أبوا\" علينا- أي امتنعوا من إجابتنا إلى الإسلام. ك: فلما \"أبوا\" إنما أبوا عن حكمه صلى الله عليه وسلم ونهيه فهماً منهم أنه للتنزيه. نه- وفيه: ذكر \"أبا\"- بفتح همزة وتشديد باء: بئر لبني قريظة نزلها النبي صلى الله عليه وسلم لما أتاهم؛ وفيه ذكر \"الأبواء\"- بفتح همزة وسكون موحدة ومد: جبل بين الحرمين، وعنده بلد ينسب إليه. </span>"},{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=17510#f55c75","body_html":"<span class=\"title1\">أبى</span><br><span>الإباء: شدة الامتناع، فكل إباء امتناع وليس كل امتناع إباءا.</span><br><span>قوله تعالى: وَيَأْبَى اللَّهُ إِلَّا أَنْ يُتِمَّ نُورَهُ [التوبة/ 32] ، وقال: وَتَأْبى قُلُوبُهُمْ [التوبة/ 8] ، وقوله تعالى: أَبى وَاسْتَكْبَرَ [البقرة/ 34] ، وقوله تعالى: إِلَّا إِبْلِيسَ أَبى [طه/ 116] وروي: «كلّكم في الجنّة إلا من أبى» ، ومنه: رجل أَبِيٌّ: ممتنع من تحمّل الضيم، وأبيت الضير تأبى، وتيس آبَى، وعنز أَبْوَاء: إذا أخذه من شرب ماءٍ فيه بول الأروى داء يمنعه من شرب الماء . </span>"}]}}