{"lemma":"حَشَمٌ","slug":"حَشَمٌ","root":"ح.ش.م","root_slug":"ح-ش-م","root_link":"/words/roots/ح-ش-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n8122"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B4%D9%8E%D9%85%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tell unpleasant things"},{"pos":"verb","gloss":"to make angry, to irritate"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8122","headword_ar":"حَشَمٌ","root":"H$m","body":[{"kind":"text","text":"A man's"},{"kind":"italic_en","text":"special dependents, consisting of his family and slaves"},{"kind":"text","text":"[and"},{"kind":"italic_en","text":"others"},{"kind":"text","text":"], or"},{"kind":"italic_en","text":"his neighbours, who are angry on his account"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"when an event befalls him;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"Hu$omapN","text_ar":"حُشْمَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (Yoo, TA;) in the K, erroneously,"},{"kind":"arabic","text_bw":"Ha$amapN","text_ar":"حَشَمَةٌ"},{"kind":"text","text":"; (TA;) and"},{"kind":"arabic","text_bw":"A^aHo$aAmN","text_ar":"اَحْشَامٌ"},{"kind":"text","text":"; (K;) which IAar thinks to be pl. of"},{"kind":"arabic","text_bw":"Ha$amN","text_ar":"حَشَمٌ"},{"kind":"text","text":"used in a sing. sense; (TA;) [for] this word is applied to"},{"kind":"italic_en","text":"one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of such persons"},{"kind":"text","text":"] as well as to a pl. number: (K:) you say,"},{"kind":"arabic","text_bw":"h`*aA AlgulaAmu","text_ar":"هٰذَا الغُلَامُ"},{"kind":"arabic","text_bw":"Ha$amN liY","text_ar":"حَشَمٌ لِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This young man,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slave, is a dependent of mine"},{"kind":"text","text":"]: (IAar, TA:) or"},{"kind":"arabic","text_bw":"Ha$amN","text_ar":"حَشَمٌ"},{"kind":"text","text":"signifies, (ISk, Mgh, Msb,) or signifies also, (K,) a man's"},{"kind":"italic_en","text":"relations and household;"},{"kind":"text","text":"(ISk, Mgh, Msb, K;) or his"},{"kind":"italic_en","text":"servants;"},{"kind":"text","text":"(S, Msb;) and"},{"kind":"italic_en","text":"those who are angry on his account"},{"kind":"text","text":"(ISk, S, Mgh, Msb)"},{"kind":"italic_en","text":"when an event befalls him;"},{"kind":"text","text":"(Mgh, Msb;) for which reason they are thus called: (S:) or a man's"},{"kind":"italic_en","text":"followers;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"those on whose account he should be angry:"},{"kind":"text","text":"(Ham p. 614:) or the"},{"kind":"arabic","text_bw":"Ha$am","text_ar":"حَشَم"},{"kind":"text","text":"of a man are"},{"kind":"italic_en","text":"those who are angry on his account;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"those on whose account he is angry:"},{"kind":"text","text":"(Har p. 164:) accord. to ISk, (Msb,) it is a word having a pl. signification, and having no proper sing.: (Mgh, Msb:) but some say that it has for its pl."},{"kind":"arabic","text_bw":"A^aHo$aAmN","text_ar":"اَحْشَامٌ"},{"kind":"text","text":": (Mgh:) and accord. to the K, ↓"},{"kind":"arabic","text_bw":"Hu$amaA='u","text_ar":"حُشَمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"Ha$omaA'","text_ar":"حَشْمَاء"},{"kind":"text","text":"] signifies"},{"kind":"italic_en","text":"neighbours"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"guests;"},{"kind":"text","text":"as though it were pl. of"},{"kind":"arabic","text_bw":"Ha$iymN","text_ar":"حَشِيمٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"kuramaA='u","text_ar":"كُرَمَا=ءُ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"kariymN","text_ar":"كَرِيمٌ"},{"kind":"text","text":": but [perhaps this should be"},{"kind":"arabic","text_bw":"A^aHo$aAmN","text_ar":"اَحْشَامٌ"},{"kind":"text","text":"; for] we find in the M,"},{"kind":"arabic","text_bw":"h`w^ulaA='i A^aHo$aAmiY","text_ar":"هٰوُلَا=ءِ اَحْشَامِى"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"These are my neighbours,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"my guests:"},{"kind":"text","text":"(TA:) and ↓"},{"kind":"arabic","text_bw":"Hu$umN","text_ar":"حُشُمٌ","orth_type":"arrow"},{"kind":"text","text":", with two dammehs, signifies"},{"kind":"italic_en","text":"slaves;"},{"kind":"text","text":"(IAar, TA;) or, as some say,"},{"kind":"italic_en","text":"followers, whether slaves or free persons."},{"kind":"text","text":"(TA.)       -A2-  Also"},{"kind":"italic_en","text":"An object of desire"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quest;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TalabapN","text_ar":"طَلَبَةٌ"},{"kind":"text","text":"[in the CK"},{"kind":"arabic","text_bw":"Talabap","text_ar":"طَلَبَة"},{"kind":"text","text":"]; and so ↓"},{"kind":"arabic","text_bw":"Hu$uwmN","text_ar":"حُشُومٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"huwa Ha$amuhu","text_ar":"هُوَ حَشَمُهُ"},{"kind":"italic_en","text":"It is his object of desire"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quest."},{"kind":"text","text":"(TK.)"}],"source_refs":["K","TA","IAar","ISk","Mgh","Msb","S"]}]},"classical_definitions":null}