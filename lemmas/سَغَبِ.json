{"lemma":"سَغَبِ","slug":"سَغَبِ","root":"س.غ.ب","root_slug":"س-غ-ب","root_link":"/words/roots/س-غ-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n19878","n19880","n19881"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%BA%D9%8E%D8%A8%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19878","headword_ar":"سَغِبَ","root":"sgb","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (S A, Msb, K;) and"},{"kind":"arabic","text_bw":"sagaba","text_ar":"سَغَبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (A, K;) inf. n."},{"kind":"arabic","text_bw":"sagabN","text_ar":"سَغَبٌ"},{"kind":"text","text":", (S, A, * Msb, K,) which is of the former, (Sudot;, Msb, TA,) and"},{"kind":"arabic","text_bw":"sagobN","text_ar":"سَغْبٌ"},{"kind":"text","text":", (K,) which is of the latter, (TA,) and"},{"kind":"arabic","text_bw":"suguwbN","text_ar":"سُغُوبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"sagaAbapN","text_ar":"سَغَابَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"masogabapN","text_ar":"مَسْغَبَةٌ"},{"kind":"text","text":", (A, * K,) the last syn. with"},{"kind":"arabic","text_bw":"majaAEapN","text_ar":"مَجَاعَةٌ"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hungry:"},{"kind":"text","text":"(S, A, Msb, K:) or"},{"kind":"italic_en","text":"suffered hunger together with fatigue."},{"kind":"text","text":"(A, Msb, K.) You say,"},{"kind":"arabic","text_bw":"bihi sagabN","text_ar":"بِهِ سَغَبٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"masogabapN","text_ar":"مَسْغَبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sagaAbapN","text_ar":"سَغَابَةٌ"},{"kind":"text","text":", [using these ns. as simple substs.,]"},{"kind":"italic_en","text":"In him is hunger:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hunger together with fatigue."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"yatiymN *uw masogabapK","text_ar":"يَتِيمٌ ذُو مَسْغَبَةٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"An orphan"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"having hunger."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"fiY yawomK *iY","text_ar":"فِى يَوْمٍ ذِى"},{"kind":"arabic","text_bw":"masogabapK","text_ar":"مَسْغَبَةٍ"},{"kind":"text","text":", in the Kur [xc. 14], means"},{"kind":"italic_en","text":"In a day of hunger."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"sagobapN","text_ar":"سَغْبَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"sagabN","text_ar":"سَغَبٌ"},{"kind":"text","text":"below.]"}],"source_refs":["K","TA","S","A","Msb"]},{"entry_id":"n19880","headword_ar":"سَغَبٌ","root":"sgb","body":[{"kind":"text","text":"an inf. n. of"},{"kind":"arabic","text_bw":"sagiba","text_ar":"سَغِبَ"},{"kind":"text","text":"[q. v.]. (S, &c.) ―         -b2-  It also signifies"},{"kind":"italic_en","text":"Thirst:"},{"kind":"text","text":"but is unused: (K:) [or] thirst is sometimes thus termed. (Msb.)"}],"source_refs":["K"]},{"entry_id":"n19881","headword_ar":"سَغِبٌ","root":"sgb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saAgibN","text_ar":"سَاغِبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}