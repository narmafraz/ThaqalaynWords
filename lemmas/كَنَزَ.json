m":"p"},{"role":"present_2mp","form":"تَكْنِزُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَكْنِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَكْنِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَكْنِز","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَكْنِزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَكْنِزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَكْنِزانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَكْنِزا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَكْنِزُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَكْنِزُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَكْنِزْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَكْنِز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَكْنِز","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"كَنَزْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كَنَزْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":15,"cross_references":{"qac":{"found":true,"lemma_key":"كَنَزَ","root":"كنز","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n37290","n37291"],"search_url":"https://lanelexicon.com/?s=%D9%83%D9%8E%D9%86%D9%8E%D8%B2%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"treasure"},{"pos":"verb","gloss":"to bury in the ground (treasure)"},{"pos":"verb","gloss":"to pile up; to amass"},{"pos":"adj","gloss":"of a firm texture, carnous"}]},"etymology":{"source":"wiktextract","text":"From Old Median *ganǰam (“treasure”), a word spread by the Achaemenid administration, perhaps mediated already then by Imperial Aramaic 𐡂𐡍𐡆𐡀 (gnzʾ /⁠*ganzā⁠/, “treasure”).\n\nDenominal verb of كَنْز (kanz).\n\nDenominal from كَنْز (kanz)."},"ipa":["/kanz/","/ka.na.za/","/ka.niz/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n37290","headword_ar":"كَنْزٌ","root":"knz","body":[{"kind":"italic_en","text":"Treasure; property buried"},{"kind":"text","text":"(S, A, Mgh, Msb, K)"},{"kind":"italic_en","text":"in the earth:"},{"kind":"text","text":"(TA:) an inf. n. used as a subst.: pl."},{"kind":"arabic","text_bw":"kunuwzN","text_ar":"كُنُوزٌ"},{"kind":"text","text":". (Mgh, Msb.) ―         -b2-  Hence, (TA,) it is applied in a trad. to (tropical:)"},{"kind":"italic_en","text":"Any property whereof the portion that should be given in alms is not given."},{"kind":"text","text":"(S, TA.) ―         -b3-"},{"kind":"italic_en","text":"Property that is preserved in a receptacle."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"italic_en","text":"Anything abundant, collected together, that is desired with emulation."},{"kind":"text","text":"(Sh, TA.) ―         -b5-"},{"kind":"italic_en","text":"Gold:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"silver."},{"kind":"text","text":"(K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A^uEoTiytu Alkanozayoni mina AlA^aHomari","text_ar":"اُعْطِيتُ الكَنْزَيْنِ مِنَ الاَحْمَرِ"},{"kind":"arabic","text_bw":"waAlA^aboyaDi","text_ar":"وَالاَبْيَضِ"},{"kind":"italic_en","text":"I have been given gold and silver."},{"kind":"text","text":"(TA.) ―         -b6-  (tropical:)  ["},{"kind":"italic_en","text":"A treasure of knowledge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science"},{"kind":"text","text":"]. You say,"},{"kind":"arabic","text_bw":"maEahu kanozN mino kunuwzi AlEilomi","text_ar":"مَعَهُ كَنْزٌ مِنْ كُنُوزِ العِلْمِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"With him is a treasure of the treasures of knowledge"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"science"},{"kind":"text","text":"]. (A, TA.) In the Kur, xviii. 81, it is said to be used in a similar manner, as signifying not gold nor silver, but (tropical:)"},{"kind":"italic_en","text":"Science"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"books."},{"kind":"text","text":"(TA.) And it is said in like manner in a trad.,"},{"kind":"arabic","text_bw":"A^alaA A^uEal~imuka","text_ar":"اَلَا اُعَلِّمُكَ"},{"kind":"arabic","text_bw":"kanozFA mino kunuwzi Aljan~api laA Hawola walaA quw~apa A_il~aA biA@ll~`hi","text_ar":"كَنْزًا مِنْ كُنُوزِ الجَنَّةِ لَا حَوْلَ وَلَا قُوَّةَ اـِلَّا بِا@للّٰهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Ho! I will teach thee a treasure of the treasures of paradise: There is no power nor strength but in God"},{"kind":"text","text":"]: meaning, that a reward is stored up [in paradise] for him who says this, and who describes himself thereby, like as a treasure is stored up. (TA.) ―         -b7-  Aboo-'Alee El-Kálee says, that it is used in a verse of 'Alkamah, which he does not quote, as signifying (tropical:)"},{"kind":"italic_en","text":"Fat;"},{"kind":"text","text":"as a subst.; and adds, that it is the only instance known to him of its being thus used. (TA.)       -A2-  Also,"},{"kind":"italic_en","text":"That in which property is preserved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"guarded:"},{"kind":"text","text":"(K, * TA:) and ↓"},{"kind":"arabic","text_bw":"makonizN","text_ar":"مَكْنِزٌ","orth_type":"arrow"},{"kind":"text","text":"[or rather both]"},{"kind":"italic_en","text":"that in which property is buried, treasured, hoarded, laid up, reposited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stored, in secret:"},{"kind":"text","text":"pl. of the latter,"},{"kind":"arabic","text_bw":"makaAnizu","text_ar":"مَكَانِزُ"},{"kind":"text","text":". (A, TA.)"}],"source_refs":["S","A","Mgh","Msb","K","TA"]},{"entry_id":"n37291","headword_ar":"كَنِزٌ","root":"knz","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"mukotanizN","text_ar":"مُكْتَنِزٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}