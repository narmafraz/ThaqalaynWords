{"lemma":"ضَبْعٌ","slug":"ضَبْعٌ","root":"ض.ب.ع","root_slug":"ض-ب-ع","root_link":"/words/roots/ض-ب-ع","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n25509"],"search_url":"https://lanelexicon.com/?s=%D8%B6%D9%8E%D8%A8%D9%92%D8%B9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"hyena"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ṣ́abuʕ-. Cognate with Biblical Hebrew צָבוֹעַ (ṣɔḇóaʿ)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25509","headword_ar":"ضَبْعٌ","root":"DbE","body":[{"kind":"text","text":"The"},{"kind":"arabic","text_bw":"EaDud","text_ar":"عَضُد"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"upper arm"},{"kind":"text","text":"of a human being, and"},{"kind":"italic_en","text":"arm"},{"kind":"text","text":"of a quadruped], (S, Mgh, O, Msb, K,)"},{"kind":"italic_en","text":"altogether:"},{"kind":"text","text":"(K:) or the"},{"kind":"italic_en","text":"middle thereof,"},{"kind":"text","text":"(Lth, Mgh, O, K,)"},{"kind":"italic_en","text":"with its flesh:"},{"kind":"text","text":"(O, K:) and the"},{"kind":"italic_en","text":"inner side thereof:"},{"kind":"text","text":"(Mgh:) or (so in some copies of the K, but in others “ and, ”) the"},{"kind":"italic_en","text":"armpit:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"portion, of the upper part of the"},{"kind":"arabic","text_bw":"EaDud","text_ar":"عَضُد"},{"kind":"text","text":","},{"kind":"italic_en","text":"that is between the armpit and the half of the former:"},{"kind":"text","text":"(K:) it is of man and of other than man: (TA:) pl."},{"kind":"arabic","text_bw":"A^aDobaAEN","text_ar":"اَضْبَاعٌ"},{"kind":"text","text":". (S, Msb, K.) One says,"},{"kind":"arabic","text_bw":"A^abad~a DabEayohi","text_ar":"اَبَدَّ ضَبعَيْهِ"},{"kind":"text","text":", [expl. in art."},{"kind":"arabic","text_bw":"bd","text_ar":"بد"},{"kind":"text","text":",] speaking of a man praying. (O, TA.) And"},{"kind":"arabic","text_bw":"A^axa*otu biDaboEaYo fulaAnK falamo A^ufaAriqohu","text_ar":"اَخَذْتُ بِضَبْعَىْ فُلَانٍ فَلَمْ اُفَارِقْهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"madadotu biDaboEayohi","text_ar":"مَدَدْتُ بِضَبْعَيْهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"I seized the middle of the upper arms of such a one"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and did not relinquish him"},{"kind":"text","text":"]. (Lth, O, TA.) And"},{"kind":"arabic","text_bw":"ja*abahu biDaboEayohi","text_ar":"جَذَبَهُ بِضَبْعَيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He raised him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"set him up, and rendered his name famous:"},{"kind":"text","text":"and in like manner,"},{"kind":"arabic","text_bw":"A^axa*a biDaboEayohi","text_ar":"اَخَذَ بِضَبْعَيْهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"mad~a biDaboEayohi","text_ar":"مَدَّ بِضَبْعَيْهِ"},{"kind":"text","text":". (TA.)       -A2-  Also"},{"kind":"italic_en","text":"Any"},{"kind":"text","text":"["},{"kind":"italic_en","text":"hill such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"A^akamap","text_ar":"اَكَمَة"},{"kind":"italic_en","text":"that is black and somewhat oblong."},{"kind":"text","text":"(IAar, K.)       -A3-"},{"kind":"arabic","text_bw":"*ahaba bihi DaboEFA laboEFA","text_ar":"ذَهَبَ بِهِ ضَبْعًا لَبْعًا"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"baATilFA","text_ar":"بَاطِلًا"},{"kind":"text","text":"[i. e., app.,"},{"kind":"italic_en","text":"He took it away with a false pretence;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in play,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sport"},{"kind":"text","text":"]; (Ibn-'Abbád, O, K, TA;) namely, a thing; (O, TA;)"},{"kind":"arabic","text_bw":"laboEFA","text_ar":"لَبْعًا"},{"kind":"text","text":"being an imitative sequent. (TA.)       -A4-  See also"},{"kind":"arabic","text_bw":"DabuEN","text_ar":"ضَبُعٌ"},{"kind":"text","text":".       -A5-  And see what here next follows."}],"source_refs":["S","Mgh","O","Msb","K","Lth","TA"]}]},"classical_definitions":null}