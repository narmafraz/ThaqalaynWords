ch_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D9%85%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to have a chat or conversation at night"},{"pos":"adj","gloss":"who passes the night in chat and amusement"},{"pos":"name","gloss":"a male given name"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of سَمَرَ (samara, “to speak at night”)."},"ipa":["/saː.ma.ra/","/saː.mir/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20687","headword_ar":"سَامِرٌ","root":"smr","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"holding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who holds, a conversation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse, by night:"},{"kind":"text","text":"(S:) pl."},{"kind":"arabic","text_bw":"sum~aArN","text_ar":"سُمَّارٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"sum~arN","text_ar":"سُمَّرٌ"},{"kind":"text","text":". (TA.) It is also a quasi-pl. n., (M, K,) [as such occurring in a verse cited voce"},{"kind":"arabic","text_bw":"murim~N","text_ar":"مُرِمٌّ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"rm","text_ar":"رم"},{"kind":"text","text":",] and is syn. [as such] with"},{"kind":"arabic","text_bw":"sum~aArN","text_ar":"سُمَّارٌ"},{"kind":"text","text":", signifying persons"},{"kind":"italic_en","text":"holding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who hold, conversation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse, by night:"},{"kind":"text","text":"(S, M:) or persons"},{"kind":"italic_en","text":"waking, continuing awake, not sleeping;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"saAmirapN","text_ar":"سَامِرَةٌ","orth_type":"arrow"},{"kind":"text","text":"[a fem. sing., and therefore applicable as an epithet to a broken pl. and to a quasi-pl. n. and to a coll. gen. n.]: (M, K:)"},{"kind":"arabic","text_bw":"saAmirN","text_ar":"سَامِرٌ"},{"kind":"text","text":"is a pl. [or rather quasi-pl. n.] applicable to males and to females: (T, TA:) or it is a sing., and, like other sings., is used as a qualificative of a pl. only when the latter is determinate; as in the phrase"},{"kind":"arabic","text_bw":"tarakotuhumo saAmirFA","text_ar":"تَرَكْتُهُمْ سَامِرًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I left them holding a conversation"},{"kind":"text","text":"& c.]. (Lh, M.) ―         -b2-  Also A camel"},{"kind":"italic_en","text":"pasturing by night."},{"kind":"text","text":"(TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"samarN","text_ar":"سَمَرٌ"},{"kind":"text","text":"."}],"source_refs":["S","M","K","T","TA"]}]},"classical_definitions":null}