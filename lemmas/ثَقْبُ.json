{"lemma":"ثَقْبُ","slug":"ثَقْبُ","root":"ث.ق.ب","root_slug":"ث-ق-ب","root_link":"/words/roots/ث-ق-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":12},"lanes":{"found":true,"entry_ids":["n4524","n4525","n4527"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D9%82%D9%92%D8%A8%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to pierce; to penetrate"},{"pos":"verb","gloss":"to tear, to rip"},{"pos":"verb","gloss":"to permeate"},{"pos":"verb","gloss":"to pierce into"},{"pos":"verb","gloss":"to bore holes into"},{"pos":"verb","gloss":"to puncture"},{"pos":"noun","gloss":"verbal noun of ثَقَبَ (ṯaqaba) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"hole"},{"pos":"noun","gloss":"hollow"},{"pos":"noun","gloss":"perforation, bore"},{"pos":"noun","gloss":"puncture"},{"pos":"noun","gloss":"plural of ثُقْبَة (ṯuqba)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4524","headword_ar":"ثَقَبَ","root":"vqb","body":[{"kind":"text","text":", (S, A, K, &c.,) aor."},{"kind":"text","text":", (JK, Msb,) inf. n."},{"kind":"arabic","text_bw":"vaqobN","text_ar":"ثَقْبٌ"},{"kind":"text","text":", (JK, S, Msb,)"},{"kind":"italic_en","text":"He made a hole in"},{"kind":"text","text":"a thing (JK, * S, * A, Mgh, Msb, K) with a"},{"kind":"arabic","text_bw":"mivoqab","text_ar":"مِثْقَب"},{"kind":"text","text":"; (A, Msb;) meaning,"},{"kind":"italic_en","text":"a hole of small size;"},{"kind":"text","text":"(Mgh;)"},{"kind":"italic_en","text":"such as passed through; he perforated, bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced,"},{"kind":"text","text":"it: (A, Mgh, K:) and in like manner, ↓"},{"kind":"arabic","text_bw":"vq~b","text_ar":"ثقّب","orth_type":"arrow"},{"kind":"text","text":", (K,) but this signifies he did so"},{"kind":"italic_en","text":"much,"},{"kind":"text","text":"or to several, or many, things; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"tvq~b","text_ar":"تثقّب","orth_type":"arrow"},{"kind":"text","text":". (K, TA) You say,"},{"kind":"arabic","text_bw":"vaqaba Ald~ur~a","text_ar":"ثَقَبَ الدُّرَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He bored,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pierced, the pearls"},{"kind":"text","text":"]; (A, TA;) and"},{"kind":"arabic","text_bw":"AlA~u*una","text_ar":"الاُّذُنَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the ear"},{"kind":"text","text":"]. (Mgh.) And"},{"kind":"arabic","text_bw":"vaqaba","text_ar":"ثَقَبَ"},{"kind":"arabic","text_bw":"AlqaroHa","text_ar":"القَرْحَ"},{"kind":"italic_en","text":"He pierced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"punctured, the purulent pustule, in order that the fluid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"water, in process of excretion, might issue."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"vaqaba AlHalamu Aljiloda","text_ar":"ثَقَبَ الحَلَمُ الجِلْدَ"},{"kind":"italic_en","text":"The"},{"kind":"text","text":"["},{"kind":"italic_en","text":"ticks called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Halam","text_ar":"حَلَم"},{"kind":"italic_en","text":"pierced holes in the skin."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"AlbaraAqiEa","text_ar":"البَرَاقِعَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"vaq~abona","text_ar":"ثَقَّبْنَ","orth_type":"arrow"},{"kind":"text","text":"(A, Mgh)"},{"kind":"italic_en","text":"They made holes in the face-veils,"},{"kind":"text","text":"(Mgh,)"},{"kind":"arabic","text_bw":"liEuyuwnihin~a","text_ar":"لِعُيُونِهِنَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for their eyes"},{"kind":"text","text":"]: (A:) said of women. (Mgh.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"vaqaba Alkawokabu","text_ar":"ثَقَبَ الكَوْكَبُ"},{"kind":"text","text":", (K, and Ham p. 701,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (JK, Ham,) (tropical:)"},{"kind":"italic_en","text":"The star shone brightly"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though it pierced through the darkness:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"vaAqibN","text_ar":"ثَاقِبٌ"},{"kind":"text","text":"]: (K:) or"},{"kind":"italic_en","text":"shone and glistened intensely."},{"kind":"text","text":"(Ham ubi suprà.) And"},{"kind":"arabic","text_bw":"vaqabati Aln~aAru","text_ar":"ثَقَبَتِ النَّارُ"},{"kind":"text","text":", (S, L, K,) aor."},{"kind":"text","text":", (S, L,) inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"vaqaAbapN","text_ar":"ثَقَابَةٌ"},{"kind":"text","text":", (S, L,) (tropical:)"},{"kind":"italic_en","text":"The fire burned brightly; burned, blazed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flamed, up."},{"kind":"text","text":"(S, L, K.) And"},{"kind":"arabic","text_bw":"vaqaba Alz~anodu","text_ar":"ثَقَبَ الزَّنْدُ"},{"kind":"text","text":", (JK, TA,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)  ["},{"kind":"italic_en","text":"The"},{"kind":"arabic","text_bw":"znd","text_ar":"زند"},{"kind":"italic_en","text":"emitted fire"},{"kind":"text","text":"]: said when the spark falls (JK, TA) upon [or from] the"},{"kind":"arabic","text_bw":"znd","text_ar":"زند"},{"kind":"text","text":"[or wooden instrument for producing fire]. (JK.) ―         -b3-"},{"kind":"arabic","text_bw":"vaqabati Alr~aAy^iHapu","text_ar":"ثَقَبَتِ الرَّايِحَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The odour diffused itself, and rose."},{"kind":"text","text":"(K, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"vaqaba raA^oyuhu","text_ar":"ثَقَبَ رَاْيُهُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"His judgment was penetrating;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"nafa*a","text_ar":"نَفَذَ"},{"kind":"text","text":". (K.) ―         -b5-"},{"kind":"arabic","text_bw":"vaqabati Aln~aAqapu","text_ar":"ثَقَبَتِ النَّاقَةُ"},{"kind":"text","text":", (JK, S, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":", (JK, TA,) (tropical:)"},{"kind":"italic_en","text":"The she-camel had"},{"kind":"page_break","n":342},{"kind":"italic_en","text":"much milk; abounded with milk."},{"kind":"text","text":"(JK, S, K.)       -A2-"},{"kind":"arabic","text_bw":"vaquba","text_ar":"ثَقُبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"vaqaAbapN","text_ar":"ثَقَابَةٌ"},{"kind":"text","text":", (JK, A, K,) (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, JK, A)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, very red;"},{"kind":"text","text":"(JK, A, K;)"},{"kind":"italic_en","text":"so as to be likened to the flame of fire."},{"kind":"text","text":"(A, TA.)"}],"source_refs":["JK","Msb","S","A","Mgh","K","TA","Ham","L"]},{"entry_id":"n4525","headword_ar":"ثقّب","root":"vqb","body":[{"kind":"text","text":": see 1, in two places. ―         -b2-  [Hence,] (tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a bird)"},{"kind":"italic_en","text":"soared high, piercing the region of the air next to the clouds:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"italic_en","text":"reached,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ascended to, the midst of the sky."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"vq~bhu Al$~ayobu","text_ar":"ثقّبهُ الشَّيْبُ"},{"kind":"text","text":", (JK, A, K,) inf. n."},{"kind":"arabic","text_bw":"tavoqiybN","text_ar":"تَثْقِيبٌ"},{"kind":"text","text":"; (JK, K;) and"},{"kind":"arabic","text_bw":"vq~b fiyhi","text_ar":"ثقّب فِيهِ"},{"kind":"text","text":"; (IAar, K;) (tropical:)"},{"kind":"italic_en","text":"Hoariness appeared upon him:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"began to appear upon him:"},{"kind":"text","text":"(A, TA:) or"},{"kind":"italic_en","text":"became intermixed in his hair;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appeared and spread upon him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his blackness and whiteness of hair became equal."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"vq~b Al$~ayobu biAll~iHoyapi","text_ar":"ثقّب الشَّيْبُ بِاللِّحْيَةِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Hoariness commenced in the sides of the beard."},{"kind":"text","text":"(A.) ―         -b4-"},{"kind":"arabic","text_bw":"vq~b","text_ar":"ثقّب"},{"kind":"arabic","text_bw":"Euwdu AlEarofaji","text_ar":"عُودُ العَرْفَجِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The stalk of the"},{"kind":"arabic","text_bw":"Erfj","text_ar":"عرفج"},{"kind":"text","text":"[q. v.],"},{"kind":"italic_en","text":"the plant being rained upon, became soft:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"the sap ran in it, and it put forth leaves."},{"kind":"text","text":"(JK, A.) When it has become blackish, one says of it,"},{"kind":"arabic","text_bw":"qabila","text_ar":"قَبِلَ"},{"kind":"text","text":": when it has increased a little,"},{"kind":"arabic","text_bw":"A^adobaY","text_ar":"اَدْبَى"},{"kind":"text","text":"; in which state it is fit to be eaten: and when its"},{"kind":"arabic","text_bw":"xuwS","text_ar":"خُوص"},{"kind":"text","text":"are perfect,"},{"kind":"arabic","text_bw":"A^axowaSa","text_ar":"اَخْوَصَ"},{"kind":"text","text":". (S.)       -A2-"},{"kind":"arabic","text_bw":"vq~b","text_ar":"ثقّب"},{"kind":"text","text":", (A, K,) inf. n."},{"kind":"arabic","text_bw":"tavoqiybN","text_ar":"تَثْقِيبٌ"},{"kind":"text","text":", (S, K,) also signifies (tropical:)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"a lamp, and a fire,"},{"kind":"italic_en","text":"to burn, shine, glisten,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gleam, very brightly, as though piercing through the darkness, and dispelling it;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"Avqb","text_ar":"اثقب","orth_type":"arrow"},{"kind":"text","text":"; (A, TA;) and the latter,"},{"kind":"italic_en","text":"he kindled"},{"kind":"text","text":"a fire (TA) with tinder, (A, TA,) or camel's dung, or the like: (A:) or both signify"},{"kind":"italic_en","text":"he made"},{"kind":"text","text":"a fire"},{"kind":"italic_en","text":"to burn brightly; to burn, blaze,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flame, up;"},{"kind":"text","text":"(S, K;) and so ↓"},{"kind":"arabic","text_bw":"tvq~b","text_ar":"تثقّب","orth_type":"arrow"},{"kind":"text","text":": (K:) or, accord. to AZ,"},{"kind":"arabic","text_bw":"Aln~aAra","text_ar":"النَّارَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Avqb","text_ar":"اثقب","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ivoqaAbN","text_ar":"اـِثْقَابٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he scraped a hole for the fire, in the ground, then put upon it,"},{"kind":"text","text":"[i. e. the fire]"},{"kind":"italic_en","text":"dung, such as is called"},{"kind":"arabic","text_bw":"baEor","text_ar":"بَعْر"},{"kind":"text","text":","},{"kind":"italic_en","text":"and small pieces of fire-wood"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"similar fuel, and then buried it in the dust;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"Aln~aAra","text_ar":"النَّارَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tvq~b","text_ar":"تثقّب","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tvq~b","text_ar":"تثقّب","orth_type":"arrow"},{"kind":"text","text":"; as also"},{"kind":"arabic","text_bw":"ms~k biAln~aAri","text_ar":"مسّك بِالنَّارِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tamosibkN","text_ar":"تَمْسِبكٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"Aln~aAra","text_ar":"النَّارَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tvq~b","text_ar":"تثقّب","orth_type":"arrow"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"he struck fire:"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Avqb","text_ar":"اثقب","orth_type":"arrow"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"he made"},{"kind":"text","text":"a spark"},{"kind":"italic_en","text":"to fall"},{"kind":"text","text":"from a"},{"kind":"arabic","text_bw":"zanod","text_ar":"زَنْد"},{"kind":"text","text":", q. v. (TA.)"}],"source_refs":["A","TA","JK","K","S"]},{"entry_id":"n4527","headword_ar":"ثَقْبٌ","root":"vqb","body":[{"kind":"text","text":"(S, A, Mgh, Msb. K) and ↓"},{"kind":"arabic","text_bw":"vuqobN","text_ar":"ثُقْبٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb) and ↓"},{"kind":"arabic","text_bw":"vaqobapN","text_ar":"ثَقْبَةٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, Mgh, Msb)"},{"kind":"italic_en","text":"A hole, perforation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bore, that penetrates,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passes through, a thing;"},{"kind":"text","text":"(A, Mgh, K;) accord. to Mtr, (Msb,) only"},{"kind":"italic_en","text":"such as is small;"},{"kind":"text","text":"(Mgh, Msb;) such as is large being termed"},{"kind":"arabic","text_bw":"naqobN","text_ar":"نَقْبٌ"},{"kind":"text","text":", with"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":": (Mgh:) or"},{"kind":"italic_en","text":"a hole that is not deep:"},{"kind":"text","text":"or, as some say,"},{"kind":"italic_en","text":"a hole descending into the earth:"},{"kind":"text","text":"(Msb: [but this last explanation is not of general application:]) said to be opposed to"},{"kind":"arabic","text_bw":"$aq~N","text_ar":"شَقٌّ"},{"kind":"text","text":": (TA:) pl. [of mult.] (of the first word, S, Msb, K)"},{"kind":"arabic","text_bw":"vuquwbN","text_ar":"ثُقُوبٌ"},{"kind":"text","text":"(S, A, Msb, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^avoqubN","text_ar":"اَثْقُبٌ"},{"kind":"text","text":"(K) and (of"},{"kind":"arabic","text_bw":"vuqobapN","text_ar":"ثُقْبَةٌ"},{"kind":"text","text":", S, Msb)"},{"kind":"arabic","text_bw":"vuqabN","text_ar":"ثُقَبٌ"},{"kind":"text","text":"(S, A, Msb) and"},{"kind":"arabic","text_bw":"vuqubN","text_ar":"ثُقُبٌ"},{"kind":"text","text":". (S [in which this last is said to be with damm, meaning, to the"},{"kind":"arabic","text_bw":"q","text_ar":"ق"},{"kind":"text","text":", not (as some have supposed) to the"},{"kind":"arabic","text_bw":"v","text_ar":"ث"},{"kind":"text","text":"only,] and A.)"},{"kind":"quote","text":"vuqobN: see vaqobN. \n                     \n                        vuqobapN: see vaqobN."}],"source_refs":["Msb","S","A","Mgh","TA","K"]}]}}