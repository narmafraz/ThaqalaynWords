orpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسِير","in_corpus":true,"count":12,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":247,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n751","n18569"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B3%D8%A7%D8%B1%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n751","headword_ar":"اـِسَارٌ","root":"Asr","body":[{"kind":"italic_en","text":"A thing with which one binds;"},{"kind":"text","text":"(M, K;)"},{"kind":"italic_en","text":"a thong of untanned hide,"},{"kind":"text","text":"(S, A, Msb,)"},{"kind":"italic_en","text":"with which one binds a camel's saddle,"},{"kind":"text","text":"(As, S,) [as also"},{"kind":"arabic","text_bw":"A_iSaArN","text_ar":"اـِصَارٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"and a captive;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"A^asorN","text_ar":"اَسْرٌ"},{"kind":"text","text":", q. v.: (S:) and"},{"kind":"italic_en","text":"a rope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cord, with which a captive is bound:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a pair of shackles:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^usurN","text_ar":"اُسُرٌ"},{"kind":"text","text":". (M, K.) [See also 1.] You say,"},{"kind":"arabic","text_bw":"Hal~a A_isaArahu","text_ar":"حَلَّ اـِسَارَهُ"},{"kind":"arabic","text_bw":"faA^aTolaqahu","text_ar":"فَاَطْلَقَهُ"},{"kind":"italic_en","text":"He untied his thong of untanned hide wherewith he was bound, and released him."},{"kind":"text","text":"(A.)       -A2-  See also"},{"kind":"arabic","text_bw":"A^asiyrN","text_ar":"اَسِيرٌ"},{"kind":"text","text":"."}],"source_refs":["S","A","Msb","As","TA"]},{"entry_id":"n18569","headword_ar":"اسار","root":"sA^r","body":[{"kind":"italic_en","text":"He left a remainder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"somewhat remaining;"},{"kind":"text","text":"(IAar, M, K;) as also ↓"},{"kind":"arabic","text_bw":"saA^ara","text_ar":"سَاَرَ","orth_type":"arrow"},{"kind":"text","text":", (IAar, K,) or"},{"kind":"arabic","text_bw":"saA^ara suw^orFA","text_ar":"سَاَرَ سُوْرًا"},{"kind":"text","text":", (A,) inf. n."},{"kind":"arabic","text_bw":"saA^orN","text_ar":"سَاْرٌ"},{"kind":"text","text":": (TK:) or"},{"kind":"italic_en","text":"he left somewhat of the beverage in the bottom of the vessel from which he had drunk;"},{"kind":"text","text":"(S, TA;) as also"},{"kind":"arabic","text_bw":"AsA^r fiY AlA_inaA='i suw^orFA","text_ar":"اسار فِى الاـِنَا=ءِ سُوْرًا"},{"kind":"text","text":": (A:) the doing of which is prescribed in a trad. (TA.) You say also"},{"kind":"arabic","text_bw":"AsA^rhu","text_ar":"اسارهُ"},{"kind":"italic_en","text":"He left it remaining."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AsA^r suw^orFA","text_ar":"اسار سُوْرًا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suw^orapF","text_ar":"سُوْرَةً"},{"kind":"italic_en","text":"He left a remainder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"residue."},{"kind":"text","text":"(T, TA.) And"},{"kind":"arabic","text_bw":"AsA^r minohu $ayoy^FA","text_ar":"اسار مِنْهُ شَيْيًا"},{"kind":"italic_en","text":"He left somewhat of it remaining."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"A^asoA^arati AlA_ibilu fiY AlHawoDi","text_ar":"اَسْاَرَتِ الاـِبِلُ فِى الحَوْضِ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"suw^orFA","text_ar":"سُوْرًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"saA^arato","text_ar":"سَاَرَتْ","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"The camels left some water remaining in the trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank."},{"kind":"text","text":"(A.) Also"},{"kind":"arabic","text_bw":"AsA^r","text_ar":"اسار"},{"kind":"arabic","text_bw":"mina AlT~aEaAmi suw^orapF","text_ar":"مِنَ الطَّعَامِ سُوْرَةً"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He left somewhat remaining of the food."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"AsA^r mino HisaAbihi","text_ar":"اسار مِنْ حِسَابِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He left somewhat of his calculation unreckoned."},{"kind":"text","text":"(M, * TA.)"}],"source_refs":["IAar","K","A","TK"]}]}}