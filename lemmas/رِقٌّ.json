{"lemma":"رِقٌّ","slug":"رِقٌّ","root":"ر.ق.ق","root_slug":"ر-ق-ق","root_link":"/words/roots/ر-ق-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"رِقٌّ","root":"رقق","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":5,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":12},"lanes":{"found":true,"entry_ids":["n16274"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%90%D9%82%D9%8C%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be thin, fine"},{"pos":"verb","gloss":"to be soft, tender"},{"pos":"verb","gloss":"to pity, to sympathize, to have compassion (for)"},{"pos":"verb","gloss":"to rap (on a door)"},{"pos":"verb","gloss":"to crush, to grind, to pulverize, to beat into a powder"},{"pos":"verb","gloss":"to batter, to ram"},{"pos":"verb","gloss":"to soften, to weaken, to relent"},{"pos":"verb","gloss":"to be or become a slave"},{"pos":"noun","gloss":"turtle"},{"pos":"noun","gloss":"parchment"},{"pos":"noun","gloss":"riq, an Arabian tambourine"},{"pos":"noun","gloss":"bondage, slavery, servitude"}]},"etymology":{"source":"wiktextract","text":"Compare Classical Syriac ܪܩܐ (raqqā, “tortoise”) and Akkadian raqqum (“turtle, tortoise”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16274","headword_ar":"رِقٌّ","root":"rq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"raq~N","text_ar":"رَقٌّ"},{"kind":"text","text":". [It is indicated in the K that it is syn. with the latter word in all of its (the latter's) senses: but I do not find it to be so in any other lexicon.] ―         -b2-"},{"kind":"italic_en","text":"A thin thing."},{"kind":"text","text":"(S. [There expl. as signifying"},{"kind":"arabic","text_bw":"$aYo'N raqiyqN","text_ar":"شَىْءٌ رَقِيقٌ"},{"kind":"text","text":"; but perhaps by this may be meant that it is an epithet"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"raqiyqN","text_ar":"رَقِيقٌ"},{"kind":"text","text":", as it is said to be in the K.]) See"},{"kind":"arabic","text_bw":"raqiyqN","text_ar":"رَقِيقٌ"},{"kind":"text","text":". ―         -b3-  The"},{"kind":"italic_en","text":"leaves of trees:"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"branches that are easy for the cattle"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to eat"},{"kind":"text","text":"]. (K.) ―         -b4-  And"},{"kind":"italic_en","text":"A certain thorny plant."},{"kind":"text","text":"(K.) ―         -b5-  See also"},{"kind":"arabic","text_bw":"raqaAqN","text_ar":"رَقَاقٌ"},{"kind":"text","text":".       -A2-  Also The"},{"kind":"italic_en","text":"state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, of a slave; slavery; servitude;"},{"kind":"text","text":"(JK, S, Msb, K;) and so ↓"},{"kind":"arabic","text_bw":"riq~iy~apN","text_ar":"رِقِّيَّةٌ","orth_type":"arrow"},{"kind":"text","text":". (KL.)"}],"source_refs":[]}]},"classical_definitions":null}