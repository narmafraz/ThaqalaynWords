t_1mp","form":"فَنِيْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَنِيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":45,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":9},"lanes":{"found":true,"entry_ids":["n34692"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D9%86%D9%90%D9%8A%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to perish, to pass away","examples":[{"text":"فَٱفْنَ إِنْ شِئْتَ فَنَاءً سَرْمَدًا – فَٱلْفَنَا يُدْنِي إِلَى ذَاكَ ٱلْغِنَى"}]},{"pos":"verb","gloss":"to cease, to wane, to vanish"},{"pos":"verb","gloss":"to do one's best"},{"pos":"adj","gloss":"specialized"},{"pos":"adj","gloss":"technical"},{"pos":"adj","gloss":"artistic"},{"pos":"adj","gloss":"tactical, strategic"},{"pos":"noun","gloss":"technician"},{"pos":"noun","gloss":"artist"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *pan-. Compare Biblical Hebrew פָּנִים (pānîm, “face”).\n\nفَنّ (fann, “specialty, art”) + ـِيّ (-iyy)."},"ipa":["/fa.ni.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34692","headword_ar":"فَنِىَ","root":"fnY","body":[{"kind":"text","text":", (T, S, M, Msb, K, &c.,) aor."},{"kind":"arabic","text_bw":"yafonaY","text_ar":"يَفْنَى"},{"kind":"text","text":"; (T, M, Msb, K;) and"},{"kind":"arabic","text_bw":"fanaY","text_ar":"فَنَى"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yafonaY","text_ar":"يَفْنَى"},{"kind":"text","text":", (M, K,) which is extr., mentioned by Kr, and said by him to be of the dial. of Belhárith Ibn-Kaab; (M;) the former of the two verbs being that which is commonly known; (TA;) inf. n."},{"kind":"arabic","text_bw":"fanaA='N","text_ar":"فَنَا=ءٌ"},{"kind":"text","text":", (T, S, M, Msb, K, &c.,) which is of both of the verbs; (TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(i. e. a thing, S, Msb, TA)"},{"kind":"italic_en","text":"passed away and came to an end; vanished away; became spent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exhausted; failed entirely; ceased, perished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to nought;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, transitory, evanescent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"non-existent;"},{"kind":"text","text":"the inf. n. being"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"nafaAdN","text_ar":"نَفَادٌ"},{"kind":"text","text":"; (Aboo-'Alee El- Kálee, TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"baqaA='N","text_ar":"بَقَا=ءٌ"},{"kind":"text","text":"; (M, TA;) and the pret. being"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"Eudima","text_ar":"عُدِمَ"},{"kind":"text","text":": (K, TA:) it is said of every created thing that it is subject to"},{"kind":"arabic","text_bw":"AlfanaA='","text_ar":"الفَنَا=ء"},{"kind":"text","text":". (Msb.) [Hence]"},{"kind":"arabic","text_bw":"daAru AlfanaA='i","text_ar":"دَارُ الفَنَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The abode of transitoriness, evanescence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perishableness,"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"the present world."},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"dwr","text_ar":"دور"},{"kind":"text","text":".) ―         -b2-  And, said of a man, (T, M, K,) i. e."},{"kind":"arabic","text_bw":"faniYa","text_ar":"فَنِىَ"},{"kind":"text","text":", aor. and inf. n. as above, (M,) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, extremely aged;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"old and infirm;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"harima","text_ar":"هَرِمَ"},{"kind":"text","text":": (M, K:) or"},{"kind":"italic_en","text":"he became on the verge of death by reason of extreme age"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of age and infirmity."},{"kind":"text","text":"(T.) Lebeed says,"},{"kind":"quote","text":"HabaAy^iluhu mabovuwvapN bisabiylhi\n                      \n                     \n                        wayafonaY A_i*aA maA A^axoTaA^atohu AlHabaAy^ilu"},{"kind":"text","text":"(T, M,) meaning ["},{"kind":"italic_en","text":"His snares are spread in his way, and when the snares fail to catch him"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he becomes old and infirm and so dies:"},{"kind":"text","text":"(T:) or it means,"},{"kind":"italic_en","text":"when death misses him he becomes old and infirm."},{"kind":"text","text":"(M.)"}],"source_refs":["M","K","TA","T"]}]}}