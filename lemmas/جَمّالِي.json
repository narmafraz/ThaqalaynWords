xt_bw":"p","text_ar":"ة"},{"kind":"text","text":"applied to a she-camel, (S, K,)"},{"kind":"italic_en","text":"Resembling a he-camel in greatness of make:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"firm"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in make,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"like a he-camel"},{"kind":"text","text":"(K, TA)"},{"kind":"italic_en","text":"in greatness of make and in strength."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}