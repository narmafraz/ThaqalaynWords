{"lemma":"تَصْنِيفٌ","slug":"تَصْنِيفٌ","root":"ص.ن.ف","root_slug":"ص-ن-ف","root_link":"/words/roots/ص-ن-ف","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n25038"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B5%D9%92%D9%86%D9%90%D9%8A%D9%81%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of صَنَّفَ (ṣannafa) (form II)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"rating"},{"pos":"noun","gloss":"classification"},{"pos":"noun","gloss":"a work or composition","examples":[{"text":"قال الذهبي: إمام متقن متبحر في العلم، له تصانيف مفيدة، تدل على إمامته وكثرة اطلاعه ووفور فضله، كان مستقرا بمنية بني خصيب من الصعيد الأدنى، وبها توفى في ليلة الاثنين التاسع من شوال سنة إحدى وسبعين وستمائة."},{"text":"كان الإمام أحمد رضي الله عنه لا يرى وضع الكتاب، وينهي أن يُكتب عنه كلامه ومسائله، ولو رأى ذلك لكانت له تصانيف كثيرة ولنقلت عنه كتب، فكانت تصانيفه المنقولات"}]}]},"etymology":null,"ipa":["/tasˤ.niːf/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25038","headword_ar":"تَصْنِيفٌ","root":"Snf","body":[{"kind":"text","text":"inf. n. of 2 [q. v.]. ―         -b2-  [As a subst.,"},{"kind":"italic_en","text":"A literary composition;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"muSan~afN","text_ar":"مُصَنَّفٌ","orth_type":"arrow"},{"kind":"text","text":": pl. of the former"},{"kind":"arabic","text_bw":"taSaAniyfu","text_ar":"تَصَانِيفُ"},{"kind":"text","text":"; and of the latter"},{"kind":"arabic","text_bw":"muSan~afaAtN","text_ar":"مُصَنَّفَاتٌ"},{"kind":"text","text":".]"}],"source_refs":[]}]},"classical_definitions":null}