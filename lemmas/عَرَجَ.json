"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ascend, to climb"},{"pos":"verb","gloss":"to be lame, to hobble, to limp"},{"pos":"verb","gloss":"to swerve, to turn"},{"pos":"verb","gloss":"to make lame, to make zigzag"},{"pos":"noun","gloss":"verbal noun of عَرِجَ (ʕarija)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"plural of أَعْرَج (ʔaʕraj)","tags":["form-of","plural"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28588","headword_ar":"عَرَجَ","root":"Erj","body":[{"kind":"text","text":", (S, A, O, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"EuruwjN","text_ar":"عُرُوجٌ"},{"kind":"text","text":"(S, O, K) and"},{"kind":"arabic","text_bw":"maEorajN","text_ar":"مَعْرَجٌ"},{"kind":"text","text":", (O, K,)"},{"kind":"italic_en","text":"He ascended,"},{"kind":"text","text":"or"},{"kind":"page_break","n":1996},{"kind":"italic_en","text":"mounted."},{"kind":"text","text":"(S, A, O, K.) So in the saying"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"arabic","text_bw":"fiY Ald~arajapi","text_ar":"فِى الدَّرَجَةِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fY Als~ul~ami","text_ar":"فى السُّلَّمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He ascended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted, the stair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the series of steps,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the ladder"},{"kind":"text","text":"]. (S, O.) And"},{"kind":"arabic","text_bw":"Earaja fiY Al$~aYo'K","text_ar":"عَرَجَ فِى الشَّىْءٍ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EuruwjN","text_ar":"عُرُوجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He ascended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mounted, upon the thing"},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Eurija bihi","text_ar":"عُرِجَ بِهِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"He was taken up"},{"kind":"text","text":"to a high place; as, for instance,"},{"kind":"arabic","text_bw":"A_ilaY EanaAni Als~amaA='i","text_ar":"اـِلَى عَنَانِ السَّمَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to the clouds of Heaven"},{"kind":"text","text":"]. (Ham p. 87.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Earaja Al$~aYo'u","text_ar":"عَرَجَ الشَّىْءُ"},{"kind":"italic_en","text":"The thing became high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"text","text":", (S, O, Msb, K,) with fet-h to the"},{"kind":"arabic","text_bw":"r","text_ar":"ر"},{"kind":"text","text":", (O,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EarojN","text_ar":"عَرْجٌ"},{"kind":"text","text":"; (Msb; [accord. to the O"},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":";]) or"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earuja","text_ar":"عَرُجَ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He limped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had a slight lameness,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"and walked like the lame,"},{"kind":"text","text":"(S, O,)"},{"kind":"italic_en","text":"by reason of some accident that had befallen him"},{"kind":"text","text":"(S, O, Msb, K)"},{"kind":"italic_en","text":"in his leg"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"foot,"},{"kind":"text","text":"(S, O, K.)"},{"kind":"italic_en","text":"not naturally,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"not by reason of a chronic ailment:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"Earaja","text_ar":"عَرَجَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Earuja","text_ar":"عَرُجَ"},{"kind":"text","text":"; inf. n."},{"kind":"arabic","text_bw":"EarajaAnN","text_ar":"عَرَجَانٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"he walked like the lame, with a limping gait, by reason of some accident."},{"kind":"text","text":"(L.) ―         -b2-  And"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":", (S, O, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":"(S, * O, * Msb, K, * TA) and"},{"kind":"arabic","text_bw":"EurojapN","text_ar":"عُرْجَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was lame, walked lamely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"limped,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"naturally,"},{"kind":"text","text":"(S, O, K,) or"},{"kind":"italic_en","text":"by reason of a chronic ailment:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"he became lame."},{"kind":"text","text":"(TA.) [See also"},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":"below.] ―         -b3-"},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"setting"},{"kind":"text","text":"of the sun: or its"},{"kind":"italic_en","text":"inclining towards the place of setting:"},{"kind":"text","text":"(S, O, K:) inf. n. of"},{"kind":"arabic","text_bw":"Earijato","text_ar":"عَرِجَتْ"},{"kind":"text","text":". (TK.) ―         -b4-  And"},{"kind":"arabic","text_bw":"Earija","text_ar":"عَرِجَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EarajN","text_ar":"عَرَجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a camel)"},{"kind":"italic_en","text":"emitted his urine indirectly:"},{"kind":"text","text":"said of the male only, when the hind girth is bound upon him [so as to press upon his sheath]: like"},{"kind":"arabic","text_bw":"Hqiba","text_ar":"حقِبَ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","A","O","K","Msb","TA"]}]}}