{"lemma":"رَعِيَّةٌ","slug":"رَعِيَّةٌ","root":"ر.ع.#","root_slug":"ر-ع-_","root_link":"/words/roots/ر-ع-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n15952"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%B9%D9%90%D9%8A%D9%8E%D9%91%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"herd, flock"},{"pos":"noun","gloss":"subjects (of a ruler), the ruled","examples":[{"text":"Hadith\nكُلُّكُمْ رَاعٍ وَكُلُّكُمْ مَسْؤُولٌ عَنْ رَعِيَّتِهِ\nkullukum rāʕin wakullukum masʔūlun ʕan raʕiyyatihi","english":"(please add an English translation of this quotation) (\"the ruler is the guardian of his subjects\")"}]},{"pos":"noun","gloss":"subject (of a ruler)"},{"pos":"noun","gloss":"parish"}]},"etymology":{"source":"wiktextract","text":"Compare رَعَى (raʕā, “to guard”)."},"ipa":["/ra.ʕij.ja/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15952","headword_ar":"رَعِيَّةٌ","root":"rEY","body":[{"kind":"text","text":"[with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":"affixed"},{"kind":"arabic","text_bw":"liln~aqoli","text_ar":"لِلنَّقْلِ"},{"kind":"text","text":", i. e., to transfer the word from the category of epithets to that of substantives,]"},{"kind":"italic_en","text":"Cattle pasturing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pasturing by themselves:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"cattle kept, tended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pastured:"},{"kind":"text","text":"(K, TA:) pl."},{"kind":"arabic","text_bw":"raEaAyaA","text_ar":"رَعَايَا"},{"kind":"text","text":": (TA:) this latter (the pl.) signifies"},{"kind":"italic_en","text":"cattle kept, tended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pastured, for any one;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"for the subjects"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"for the Sultán;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"raEaAwiy~apN","text_ar":"رَعَاوِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA: in some copies of the K"},{"kind":"arabic","text_bw":"raEaAwiyap","text_ar":"رَعَاوِيَة"},{"kind":"text","text":", without teshdeed:) and ↓"},{"kind":"arabic","text_bw":"A^aroEaAwiy~apN","text_ar":"اَرْعَاوِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"cattle kept, tended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pastured, for the Sultán,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"especially, and upon which are his brands and marks."},{"kind":"text","text":"(TA.) Hence the trad.,"},{"kind":"arabic","text_bw":"kul~u raAEK masow^uwlN Eino raEiy~atihi","text_ar":"كُلُّ رَاعٍ مَسْوُولٌ عِنْ رَعِيَّتِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Every pastor shall be questioned respecting his pastured cattle:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"every ruler shall be questioned respecting his subjects;"},{"kind":"text","text":"agreeably with what follows]. (TA.) ―         -b2-  The"},{"kind":"italic_en","text":"people ruled"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"governed;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"subjects of a ruler or governor:"},{"kind":"text","text":"(Msb, K:) the"},{"kind":"italic_en","text":"community;"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"people in common"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in general;"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"common people:"},{"kind":"text","text":"(S:) [any"},{"kind":"italic_en","text":"persons"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"person,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"things"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing, in the keeping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"under the guardianship"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rule"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"government,"},{"kind":"text","text":"of a man or woman:] see"},{"kind":"arabic","text_bw":"raAEK","text_ar":"رَاعٍ"},{"kind":"text","text":", in the latter half of the paragraph: pl. as above. (TA.)"}],"source_refs":["K","TA","Msb","S"]}]},"classical_definitions":null}