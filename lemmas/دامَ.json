{"lemma":"دامَ","slug":"دامَ","root":"د.#.م","root_slug":"د-_-م","root_link":"/words/roots/د-_-م","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"دُمْتَ","in_corpus":true,"count":4,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"دُمْتِ","in_corpus":true,"count":9,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"دُمْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"دُمْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"دُمْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"دامَ","in_corpus":true,"count":51,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"دامَت","in_corpus":true,"count":18,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"داما","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"دامَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"دامُوا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"دُمْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَدُم","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَدُوم","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَدُومِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَدُومِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَدُوما","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَدُومانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَدُومُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَدُومُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَدُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَدُم","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَدُوم","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَدُم","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَدُوم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَدُوما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَدُومانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَدُوما","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَدُومانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَدُومُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَدُومُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَدُمْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"دُمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"دُمْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَدُوم","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَدُوم","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":99,"cross_references":{"qac":{"found":true,"lemma_key":"دامَ","root":"دوم","pos":"V","occurrence_count":7},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n13170","n13465","n13470"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D8%A7%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to last, to endure","examples":[{"text":"مَا دَامَ ٱلنَّجَاحُ مُهِمًّا فَيَجِبُ أَنْ أَنْجَحَ.","english":"As long as success is important, I have to succeed."},{"text":"وَأَمَّا الَّذِينَ سُعِدُوا فَفِي الْجَنَّةِ خَالِدِينَ فِيهَا مَا دَامَتِ السَّمَاوَاتُ وَالْأَرْضُ إِلَّا مَا شَاءَ رَبُّكَ ۖ عَطَاءً غَيْرَ مَجْذُوذٍ"}]},{"pos":"adj","gloss":"bleeding"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13170","headword_ar":"دَامٍ","root":"(dmw or dmY)","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"damK","text_ar":"دَمٍ"},{"kind":"text","text":". [And see the next paragraph.] ―         -b2-"},{"kind":"arabic","text_bw":"daAmiY Al$~afapi","text_ar":"دَامِى الشَّفَةِ"},{"kind":"text","text":", (M, K,) applied to a man, (M,) [lit."},{"kind":"italic_en","text":"Having a bleeding lip,"},{"kind":"text","text":"] means (tropical:)"},{"kind":"italic_en","text":"poor."},{"kind":"text","text":"(M, K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"$ajarapN daAmiyapN","text_ar":"شَجَرَةٌ دَامِيَةٌ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"A beautiful tree."},{"kind":"text","text":"(TA.)"}],"source_refs":["M","K"]},{"entry_id":"n13465","headword_ar":"دَامَ","root":"dwm","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaduwmu","text_ar":"يَدُومُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yadaAmu","text_ar":"يَدَامُ"},{"kind":"text","text":"; (S, M, Msb, K;) the see. pers. of the pret. when the aor. is"},{"kind":"arabic","text_bw":"yaduwmu","text_ar":"يَدُومُ"},{"kind":"text","text":"being"},{"kind":"arabic","text_bw":"dumota","text_ar":"دُمْتَ"},{"kind":"text","text":"; and when the aor. is"},{"kind":"arabic","text_bw":"yadaAm","text_ar":"يَدَام"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"dimota","text_ar":"دِمْتَ"},{"kind":"text","text":"; (M;) and accord. to Kr, (M,) you say also"},{"kind":"arabic","text_bw":"dimota","text_ar":"دِمْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"taduwmu","text_ar":"تَدُومُ"},{"kind":"text","text":", which is extr., (M, K,) and not of valid authority, held by the lexicologists [in general] to be anomalous like"},{"kind":"arabic","text_bw":"mit~a","text_ar":"مِتَّ"},{"kind":"text","text":"having for its aor."},{"kind":"arabic","text_bw":"tamuwtu","text_ar":"تَمُوتُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"faDila","text_ar":"فَضِلَ"},{"kind":"text","text":"of which the aor. is"},{"kind":"arabic","text_bw":"yafoDulu","text_ar":"يَفْضُلُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HaDira","text_ar":"حَضِرَ"},{"kind":"text","text":"of which the aor. is"},{"kind":"arabic","text_bw":"yaHoDuru","text_ar":"يَحْضُرُ"},{"kind":"text","text":", and said by Aboo-Bekr to be a compound of the pret. of which the aor. is"},{"kind":"arabic","text_bw":"tadaAmu","text_ar":"تَدَامُ"},{"kind":"text","text":"with the aor. of which the pret. is"},{"kind":"arabic","text_bw":"dumota","text_ar":"دُمْتَ"},{"kind":"text","text":"; (M;) inf. n."},{"kind":"arabic","text_bw":"dawomN","text_ar":"دَوْمٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"dawaAmN","text_ar":"دَوَامٌ"},{"kind":"text","text":"[which is the most common form] and"},{"kind":"arabic","text_bw":"dayomuwmapN","text_ar":"دَيْمُومَةٌ"},{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"dayowamuwmapN","text_ar":"دَيْوَمُومَةٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qayoduwdapN","text_ar":"قَيْدُودَةٌ"},{"kind":"text","text":"originally"},{"kind":"arabic","text_bw":"qayowaduwdapN","text_ar":"قَيْوَدُودَةٌ"},{"kind":"text","text":", &c.]; (S, M, Msb, K;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, Msb)"},{"kind":"italic_en","text":"continued, lasted, endured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remained"},{"kind":"text","text":"]: (Msb, TK:) and"},{"kind":"italic_en","text":"it became extended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prolonged;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Aimotad~a","text_ar":"اِمْتَدَّ"},{"kind":"text","text":": (TK:) and ["},{"kind":"italic_en","text":"it continued, lasted, endured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remained, long;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its time was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"baqiYa","text_ar":"بَقِىَ"},{"kind":"text","text":"[as syn. with"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"(explained above) and as meaning"},{"kind":"italic_en","text":"it continued, lasted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"existed, incessantly, always, endlessly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for ever; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, permanent, perpetual,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"everlasting"},{"kind":"text","text":"]: (Msb in art."},{"kind":"arabic","text_bw":"bqY","text_ar":"بقى"},{"kind":"text","text":":) and ↓"},{"kind":"arabic","text_bw":"AstdAm","text_ar":"استدام","orth_type":"arrow"},{"kind":"text","text":"signifies the same as"},{"kind":"arabic","text_bw":"dAm","text_ar":"دام"},{"kind":"text","text":"[in all of these senses]: (TA:) [but Mtr says,]"},{"kind":"arabic","text_bw":"AstdAm Als~afaru","text_ar":"استدام السَّفَرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The journey continued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continued long,"},{"kind":"text","text":"] is not of established authority. (Mgh.) [Hence,"},{"kind":"arabic","text_bw":"daAma mulokuhu","text_ar":"دَامَ مُلْكُهُ"},{"kind":"italic_en","text":"May his dominion be of long continuance."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"dAm EalaY AlA^amori","text_ar":"دام عَلَى الاَمْرِ"},{"kind":"text","text":"; (MA;) and"},{"kind":"arabic","text_bw":"Ealayohi","text_ar":"عَلَيْهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"dAwm","text_ar":"داوم","orth_type":"arrow"},{"kind":"text","text":", [and ↓"},{"kind":"arabic","text_bw":"dAwmhu","text_ar":"داومهُ","orth_type":"arrow"},{"kind":"text","text":", as is shown by a usage of the act. part. n. in art."},{"kind":"arabic","text_bw":"dmn","text_ar":"دمن"},{"kind":"text","text":"in the S, &c.,] (S, * MA,) inf. n."},{"kind":"arabic","text_bw":"mudaAwamapN","text_ar":"مُدَاوَمَةٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He kept continually,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly, to the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(S, MA.)"},{"kind":"arabic","text_bw":"maA daAma","text_ar":"مَا دَامَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Continuance;"},{"kind":"text","text":"because"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":"is a conjunct noun to"},{"kind":"arabic","text_bw":"dAm","text_ar":"دام"},{"kind":"text","text":"; and it is not used otherwise than adverbially, like as inf. ns. are used adverbially: you say,"},{"kind":"arabic","text_bw":"laA A^ajolisu maA dumota qaAy^imFA","text_ar":"لَا اَجْلِسُ مَا دُمْتَ قَايِمًا"},{"kind":"text","text":", i. e.,"},{"kind":"arabic","text_bw":"dawaAma qiyaAmika","text_ar":"دَوَامَ قِيَامِكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will not sit during the continuance of thy standing"},{"kind":"text","text":"]; (S, TA;) [or"},{"kind":"italic_en","text":"as long as thou standest;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"while thou standest;"},{"kind":"text","text":"for]"},{"kind":"arabic","text_bw":"mA","text_ar":"ما"},{"kind":"text","text":"denotes"},{"kind":"italic_en","text":"time;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qumo maA daAma zayodN qaAy^imFA","text_ar":"قُمْ مَا دَامَ زَيْدٌ قَايِمًا"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"mud~apa qiyaAmi zayodK","text_ar":"مُدَّةَ قِيَامِ زَيْدٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Stand thou during the period of Zeyd's standing"},{"kind":"text","text":"]. (Ibn-Keysán, TA.) [And"},{"kind":"arabic","text_bw":"EalaYAld~awaAmi","text_ar":"عَلَىالدَّوَامِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"Continually,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"daAy^imFA","text_ar":"دَايِمًا"},{"kind":"text","text":".] ―         -b2-  Said of rain, it means"},{"kind":"italic_en","text":"It fell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"descended, consecutively, continuously,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly."},{"kind":"text","text":"(Msb.) Some say, (M,)"},{"kind":"arabic","text_bw":"daAmati Als~amaA='u","text_ar":"دَامَتِ السَّمَا=ءُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"tadiymN","text_ar":"تَدِيمٌ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dayomN","text_ar":"دَيْمٌ"},{"kind":"text","text":", (M, K,) which, if correct, should be included in art."},{"kind":"arabic","text_bw":"dym","text_ar":"ديم"},{"kind":"text","text":", (M,) meaning"},{"kind":"italic_en","text":"The sky rained continually;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"daw~amat","text_ar":"دَوَّمَت","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"day~amat","text_ar":"دَيَّمَت"},{"kind":"text","text":", (M, K,) in which last the"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":"is changed into"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"as it is in"},{"kind":"arabic","text_bw":"diymapN","text_ar":"دِيمَةٌ"},{"kind":"text","text":", (M,) and ↓"},{"kind":"arabic","text_bw":"AdAmt","text_ar":"ادامت","orth_type":"arrow"},{"kind":"text","text":": (K:) or"},{"kind":"italic_en","text":"rained such rain as is termed"},{"kind":"arabic","text_bw":"diymap","text_ar":"دِيمَة"},{"kind":"text","text":"; (M in art."},{"kind":"arabic","text_bw":"dym","text_ar":"ديم"},{"kind":"text","text":";) and so ↓"},{"kind":"arabic","text_bw":"day~amat","text_ar":"دَيَّمَت","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tadoyiymN","text_ar":"تَدْيِيمٌ"},{"kind":"text","text":"; (S in art."},{"kind":"arabic","text_bw":"dym","text_ar":"ديم"},{"kind":"text","text":";) and ↓"},{"kind":"arabic","text_bw":"AdAmt","text_ar":"ادامت","orth_type":"arrow"},{"kind":"text","text":". (Z, TA.) [See also"},{"kind":"arabic","text_bw":"dawomN","text_ar":"دَوْمٌ"},{"kind":"text","text":", below.] IAar cites the following verse, (M, TA,) by Jahm Ibn-Shibl, (TA in this art.,) or Ibn-Sebel, (TA in art."},{"kind":"arabic","text_bw":"sbl","text_ar":"سبل"},{"kind":"text","text":", in which, also, the verse is cited,) in praise of a horse, as is said in “ the Book of Plants ” of Ed-Deenäwaree, and in"},{"kind":"page_break","n":936},{"kind":"text","text":"“ the Book of Horses ” of Ibn-El-Kelbee, not, as J asserts it to be, in praise of a munificent man, (TA,)"},{"kind":"quote","text":"huwa AljawaAdu bonu AljawaAdi boni sabalo\n                      \n                     \n                        jaAda wa A_ino jaAduwA wabalo ↓ \n      A_ino day~amuwA"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is the fleet, the son of the fleet, the son of Sebel"},{"kind":"text","text":"(a famous mare):"},{"kind":"italic_en","text":"if they are unremitting in their running,"},{"kind":"text","text":"(the masc. pl. being here used, though relating to horses, in like manner as it is used in the Kur xli. 20,)"},{"kind":"italic_en","text":"he is fleet; and if they are fleet, he is vehement in his running"},{"kind":"text","text":"]: or, as some relate it,"},{"kind":"arabic","text_bw":"A_ino daw~amuwA","text_ar":"اـِنْ دَوَّمُوا"},{"kind":"text","text":". (M, TA. [It should be observed that the three verbs in this verse, and the word"},{"kind":"arabic","text_bw":"sbl","text_ar":"سبل"},{"kind":"text","text":", also relate to rain.]) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, T)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless;"},{"kind":"text","text":"said of water (T, S, * Msb, K, * TA) left in a pool by a torrent, and of the boiling of a cooking-pot; (Msb;;) and said, in this sense, of the sea: (M:) and"},{"kind":"italic_en","text":"it stopped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stood still."},{"kind":"text","text":"(T, TA.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, tired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigued:"},{"kind":"text","text":"(T, TA:) [app. because he who is so stops to rest.] ―         -b5-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"went round, revolved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circled:"},{"kind":"text","text":"(T, TA:) [app. because that which does so keeps near to one place.]"},{"kind":"arabic","text_bw":"dawamaAnN","text_ar":"دَوَمَانٌ"},{"kind":"text","text":"[an inf. n. of"},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":"like as"},{"kind":"arabic","text_bw":"HawamaAnN","text_ar":"حَوَمَانٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"HaAma","text_ar":"حَامَ"},{"kind":"text","text":",] signifies (tropical:)  The"},{"kind":"italic_en","text":"circling"},{"kind":"text","text":"of a bird (K, TA)"},{"kind":"italic_en","text":"around water."},{"kind":"text","text":"(TA. [But in my MS. copy of the K, and in the CK, in the place of"},{"kind":"arabic","text_bw":"Ald~awamaAnu","text_ar":"الدَّوَمَانُ"},{"kind":"text","text":"I find ↓"},{"kind":"arabic","text_bw":"Ald~awamaA='u","text_ar":"الدَّوَمَا=ءُ","orth_type":"arrow"},{"kind":"text","text":". See also 2.]) [Hence,]"},{"kind":"arabic","text_bw":"diyma bihi","text_ar":"دِيمَ بِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was taken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected, with a vertigo,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"giddiness in the head;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^udiyma","text_ar":"اُدِيمَ","orth_type":"arrow"},{"kind":"text","text":", (M, TA,) and ↓"},{"kind":"arabic","text_bw":"Ausotudiyma","text_ar":"اُسْتُدِيمَ","orth_type":"arrow"},{"kind":"text","text":"[app., in like manner, followed by"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"]. (Z, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"daAmati Ald~alowi","text_ar":"دَامَتِ الدَّلْوِ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"dawomN","text_ar":"دَوْمٌ"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"The bucket became full:"},{"kind":"text","text":"(K:) in this meaning, regard is had to the stagnant water [in the bucket]. (TA.)"}],"source_refs":["M","K","Msb","TK","TA","T"]},{"entry_id":"n13470","headword_ar":"دَامٌ","root":"dwm","body":[{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"daAy^imN","text_ar":"دَايِمٌ"},{"kind":"text","text":": see the latter word."}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AF%D8%A7%D9%85/","headword_ar":"دامجانة","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=51042#775b34","body_html":"دامجانة: انظر: دمجانة."}]}}