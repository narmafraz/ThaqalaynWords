"verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n28641"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D8%B1%D9%8E%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to prepare a wedding feast"},{"pos":"verb","gloss":"to lead the bridegroom’s wife to the groom on the occasion of his marriage"},{"pos":"verb","gloss":"to spend the first wedding night"}]},"etymology":null,"ipa":["/ʔaʕ.ra.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28641","headword_ar":"اعرس","root":"Ers","body":[{"kind":"italic_en","text":"He made,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepared, a marriagefeast."},{"kind":"text","text":"(S, O, Msb, K, TA.) ―         -b2-  ["},{"kind":"italic_en","text":"He became a bridegroom."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"AErs biA^aholihi","text_ar":"اعرس بِاَهْلِهِ"},{"kind":"text","text":", (S, O, K,) or"},{"kind":"arabic","text_bw":"biA@moraA^atihi","text_ar":"بِا@مْرَاَتِهِ"},{"kind":"text","text":", (Mgh, * Msb,)"},{"kind":"italic_en","text":"He had his wife conducted to him on the occasion of the marriage;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"banaY","text_ar":"بَنَى"},{"kind":"arabic","text_bw":"bihaA","text_ar":"بِهَا"},{"kind":"text","text":", (T, S,) or"},{"kind":"arabic","text_bw":"banaY EalayohaA","text_ar":"بَنَى عَلَيْهَا"},{"kind":"text","text":"; (Mgh, O, K;) as also"},{"kind":"arabic","text_bw":"bhA","text_ar":"بها"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Er~s","text_ar":"عرّس","orth_type":"arrow"},{"kind":"text","text":"; (TA;) or this latter is only used by the vulgar; (S, O, TA;) or is a mistake: (Mgh, Msb:) and"},{"kind":"italic_en","text":"he abode with his wife during the days of and after that event:"},{"kind":"text","text":"(TA:) [and]"},{"kind":"italic_en","text":"he went in to his wife"},{"kind":"text","text":"(IAth, Msb) [a signification which may be meant to be included in the explanation"},{"kind":"arabic","text_bw":"bny bhA","text_ar":"بني بها"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"bnY ElyhA","text_ar":"بنى عليها"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"on the occasion of that event;"},{"kind":"text","text":"meaning,"},{"kind":"italic_en","text":"he compressed her;"},{"kind":"arabic","text_bw":"waTo'N","text_ar":"وَطْءٌ"},{"kind":"text","text":"being thus called"},{"kind":"arabic","text_bw":"A_iEoraAsN","text_ar":"اـِعْرَاسٌ"},{"kind":"text","text":"because it is a consequence of"},{"kind":"arabic","text_bw":"A_iEoraAs","text_ar":"اـِعْرَاس"},{"kind":"text","text":"[properly so termed]: (IAth:) the phrase also signifies [simply]"},{"kind":"italic_en","text":"he compressed his wife."},{"kind":"text","text":"(S, TA.)       -A2-  See also 2:       -A3-  and see"},{"kind":"arabic","text_bw":"Earisa bihi","text_ar":"عَرِسَ بِهِ"},{"kind":"text","text":"."}],"source_refs":["S","O","K","T","Mgh","Msb","TA","IAth"]}]},"classical_definitions":null}