{"lemma":"حَصْبَة","slug":"حَصْبَة","root":"ح.ص.ب","root_slug":"ح-ص-ب","root_link":"/words/roots/ح-ص-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n8178","n8179","n8184","n8185","n8186"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B5%D9%92%D8%A8%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"measles"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew חַצֶּבֶת."},"ipa":["/ħasˤ.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8178","headword_ar":"حَصَبَهُ","root":"HSb","body":[{"kind":"text","text":", (S, A, Msb, K,) aor."},{"kind":"text","text":"(S, A, Msb) and"},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"HaSobN","text_ar":"حَصْبٌ"},{"kind":"text","text":", (Msb, TA,)"},{"kind":"italic_en","text":"He threw at him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pelted him with, pebbles,"},{"kind":"text","text":"(S, A,* K,) or"},{"kind":"italic_en","text":"small pebbles."},{"kind":"text","text":"(Msb.) And hence, in a general sense,"},{"kind":"italic_en","text":"He pelted him."},{"kind":"text","text":"(Har p. 234.) And"},{"kind":"arabic","text_bw":"HaSabati Alr~iyHu biAlHaSobaA='i","text_ar":"حَصَبَتِ الرِّيحُ بِالحَصْبَا=ءِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The wind cast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drove along,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tore up, the pebbles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"small pebbles"},{"kind":"text","text":"]. (A.)―         -b2-  Also, (A,) or ↓"},{"kind":"arabic","text_bw":"HS~bhu","text_ar":"حصّبهُ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taHoSiybN","text_ar":"تَحْصِيبٌ"},{"kind":"text","text":", (S,) or both, (Msb, K,) but the latter has an intensive signification, (Msb,)"},{"kind":"italic_en","text":"He spread pebbles in it,"},{"kind":"text","text":"(A, K,) namely, a mosque, (A,) or a place; (K;)"},{"kind":"italic_en","text":"he strewed it,"},{"kind":"text","text":"namely, a mosque, (S, Msb,) &c., (Msb,)"},{"kind":"italic_en","text":"with pebbles,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"with small pebbles."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"HaSaba bihi Aln~aAra","text_ar":"حَصَبَ بِهِ النَّارَ"},{"kind":"italic_en","text":"He threw it"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"into the fire."},{"kind":"text","text":"(AO, S.) ―         -b4-"},{"kind":"arabic","text_bw":"HaSaba","text_ar":"حَصَبَ"},{"kind":"arabic","text_bw":"Aln~aAra","text_ar":"النَّارَ"},{"kind":"italic_en","text":"He threw"},{"kind":"arabic","text_bw":"HaSab","text_ar":"حَصَب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"firewood,"},{"kind":"text","text":"&c.,]"},{"kind":"italic_en","text":"into the fire."},{"kind":"text","text":"(A.) [Also,] inf. n. as above,"},{"kind":"italic_en","text":"He kindled the fire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made it to blaze"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flame,"},{"kind":"text","text":"with"},{"kind":"arabic","text_bw":"HaSab","text_ar":"حَصَب"},{"kind":"text","text":". (TA.)      -A2-"},{"kind":"arabic","text_bw":"HaSabuwA Eanohu","text_ar":"حَصَبُوا عَنْهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"They hastened from him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, in flight."},{"kind":"text","text":"(A, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"HaSaba","text_ar":"حَصَبَ"},{"kind":"arabic","text_bw":"Eano SaAHibihi","text_ar":"عَنْ صَاحِبِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He turned away from his companion;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHSb","text_ar":"احصب","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b3-"},{"kind":"arabic","text_bw":"HaSaba fiY","text_ar":"حَصَبَ فِى"},{"kind":"arabic","text_bw":"AlA^aroDi","text_ar":"الاَرْضِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"*ahaba fiyhaA","text_ar":"ذَهَبَ فِيهَا"},{"kind":"text","text":"[which has two meanings:"},{"kind":"italic_en","text":"he went away in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"into, the country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he discharged his excrement:"},{"kind":"text","text":"the former seems to be here meant]. (S.)       -A3-"},{"kind":"arabic","text_bw":"HuSiba","text_ar":"حُصِبَ"},{"kind":"text","text":"; (K; [in a copy of the A"},{"kind":"arabic","text_bw":"HaSuba","text_ar":"حَصُبَ"},{"kind":"text","text":", but this is probably a mistranscription, as appears to be indicated by its being there added that the part. n. is"},{"kind":"arabic","text_bw":"maHoSuwbN","text_ar":"مَحْصُوبٌ"},{"kind":"text","text":";]) and"},{"kind":"arabic","text_bw":"HaSiba","text_ar":"حَصِبَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HaSabN","text_ar":"حَصَبٌ"},{"kind":"text","text":", (KL,) or"},{"kind":"arabic","text_bw":"HaSabN","text_ar":"حَصَبٌ"},{"kind":"text","text":"; (TK, and indicated in the K;) [and app. ↓"},{"kind":"arabic","text_bw":"HuS~iba","text_ar":"حُصِّبَ","orth_type":"arrow"},{"kind":"text","text":"also; (see"},{"kind":"arabic","text_bw":"maHoSuwbN","text_ar":"مَحْصُوبٌ"},{"kind":"text","text":";)]"},{"kind":"italic_en","text":"He broke forth with"},{"kind":"arabic","text_bw":"HaSobap","text_ar":"حَصْبَة"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"measles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spotted fever"},{"kind":"text","text":"]. (K, KL.) The second of these verbs signifies as above, said of a person's skin. (S.)"}],"source_refs":["S","A","Msb","K","TA","KL"]},{"entry_id":"n8179","headword_ar":"حصّبهُ","root":"HSb","body":[{"kind":"text","text":": see 1.       -A2-  Also"},{"kind":"arabic","text_bw":"HS~b","text_ar":"حصّب"},{"kind":"text","text":", (T, TA,) inf. n."},{"kind":"arabic","text_bw":"taHoSiybN","text_ar":"تَحْصِيبٌ"},{"kind":"text","text":", (T, Mgh, K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a pilgrim)"},{"kind":"italic_en","text":"slept"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"stopped to sleep"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in El-Mohassab"},{"kind":"text","text":"(↓"},{"kind":"arabic","text_bw":"AlmuHaS~ab","text_ar":"المُحَصَّب","orth_type":"arrow"},{"kind":"text","text":"), (T, Mgh, * K,) which is the name of the way between the mountains opening upon the part called"},{"kind":"arabic","text_bw":"AlA^aboTaHu","text_ar":"الاَبْطَحُ"},{"kind":"text","text":", (T, K,) between Mekkeh and Minè, (T, Msb,) so called from the pebbles in it, (T, TA,) and also called ↓"},{"kind":"arabic","text_bw":"AlHaSobaA='u","text_ar":"الحَصْبَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"for an hour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a short time,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"saAEap","text_ar":"سَاعَة"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of the night,"},{"kind":"text","text":"(T, Mgh, K,)"},{"kind":"italic_en","text":"in returning from Minè to Mekkeh:"},{"kind":"text","text":"(T, Mgh, * TA:) this was formerly done in imitation of Mohammad; but it is said to be voluntary; not obligatory. (T, TA.) Also"},{"kind":"italic_en","text":"He slept at that place after going forth from Mekkeh."},{"kind":"text","text":"(TA.) ↓"},{"kind":"arabic","text_bw":"AlmuHaS~abu","text_ar":"المُحَصَّبُ","orth_type":"arrow"},{"kind":"text","text":"is also the name of the place where the pebbles are cast in Minè; (As, S, A, Mgh, Msb, K;) also called ↓"},{"kind":"arabic","text_bw":"HiSaAbN","text_ar":"حِصَابٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)       -A3-"},{"kind":"arabic","text_bw":"HuS~iba","text_ar":"حُصِّبَ"},{"kind":"text","text":": see 1."}],"source_refs":["T","TA","Mgh","K","Msb"]},{"entry_id":"n8184","headword_ar":"حَصْبَةٌ","root":"HSb","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"A single throwing of pebbles"},{"kind":"text","text":"]. ―         -b2-  [Hence, app., because immediately following the day of the last throwing of pebbles in the Valley of Minè,]"},{"kind":"arabic","text_bw":"layolapu AlHaSobapi","text_ar":"لَيْلَةُ الحَصْبَةِ"},{"kind":"italic_en","text":"The night"},{"kind":"text","text":"["},{"kind":"italic_en","text":"next"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"after the days called"},{"kind":"arabic","text_bw":"A^ay~aAmu Alt~a$oriyqi","text_ar":"اَيَّامُ التَّشْرِيقِ"},{"kind":"text","text":"[which are"},{"kind":"italic_en","text":"the"},{"kind":"text","text":"11th"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"12th"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"13th"},{"kind":"italic_en","text":"of Dhu-l-Hijjeh"},{"kind":"text","text":"]. (K.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"HaSabN","text_ar":"حَصَبٌ"},{"kind":"text","text":".       -A2-  Also, (S, A, Msb, K,) and ↓"},{"kind":"arabic","text_bw":"HaSibapN","text_ar":"حَصِبَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) and (sometimes, S) ↓"},{"kind":"arabic","text_bw":"HaSabapN","text_ar":"حَصَبَةٌ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) ["},{"kind":"italic_en","text":"Measles,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spotted fever;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a certain cutaneous eruption:"},{"kind":"text","text":"(S, A, Msb, K:) by some, [contr. to general authority,] said to be"},{"kind":"italic_en","text":"small-pox."},{"kind":"text","text":"(Msb.)"}],"source_refs":["S","A","Msb","K"]},{"entry_id":"n8185","headword_ar":"حَصَبَةٌ","root":"HSb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaSabN","text_ar":"حَصَبٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HaSobaA='u","text_ar":"حَصْبَا=ءُ"},{"kind":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"HaSobapN","text_ar":"حَصْبَةٌ"}],"source_refs":[]},{"entry_id":"n8186","headword_ar":"حَصِبَةٌ","root":"HSb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaSobapN","text_ar":"حَصْبَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}