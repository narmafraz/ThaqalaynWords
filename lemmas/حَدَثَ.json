ext":"or"},{"kind":"italic_en","text":"originated; existed newly, for the first time, not having been before:"},{"kind":"text","text":"(S, Mgh, Msb, TA:) but when mentioned with"},{"kind":"arabic","text_bw":"qaduma","text_ar":"قَدُمَ"},{"kind":"text","text":", it is written"},{"kind":"arabic","text_bw":"Haduva","text_ar":"حَدُثَ"},{"kind":"text","text":", with damm to the"},{"kind":"arabic","text_bw":"d","text_ar":"د"},{"kind":"text","text":", (S, Mgh, K,) as in the saying,"},{"kind":"arabic","text_bw":"A^axa*aniY maA qaduma wamaAHaduva","text_ar":"اَخَذَنِى مَا قَدُمَ وَمَاحَدُثَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"A^axa*ahu","text_ar":"اَخَذَهُ"},{"kind":"arabic","text_bw":"Alx","text_ar":"الخ"},{"kind":"text","text":", (A, Mgh,) meaning"},{"kind":"italic_en","text":"Old and new anxieties and thoughts"},{"kind":"text","text":"["},{"kind":"italic_en","text":"came into my mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his mind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"overcame me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"him"},{"kind":"text","text":"]; (TA;) or"},{"kind":"italic_en","text":"old and new griefs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrows;"},{"kind":"text","text":"(Mgh;) the former saying occurring in a trad.: (TA:) the verb is not thus in any other case [in this sense]. (S.) You say,"},{"kind":"arabic","text_bw":"Hadava bihi EayobN","text_ar":"حَدَثَ بِهِ عَيْبٌ"},{"kind":"italic_en","text":"A vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, originated in him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, not having been before."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Hadava A^amorN","text_ar":"حَدَثَ اَمْرٌ"},{"kind":"italic_en","text":"An affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, originated:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"italic_en","text":"happened,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"came to pass."},{"kind":"text","text":"(S.)"},{"kind":"arabic","text_bw":"HuduwvN","text_ar":"حُدُوثٌ"},{"kind":"text","text":"is of two kinds:"},{"kind":"arabic","text_bw":"HuduwvN zamaAniY~N","text_ar":"حُدُوثٌ زَمَانِىٌّ"},{"kind":"text","text":", which is A thing's"},{"kind":"italic_en","text":"being preceded by non-existence:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HuduwvN *aAtiY~N","text_ar":"حُدُوثٌ ذَاتِىٌّ"},{"kind":"text","text":", which is a thing's"},{"kind":"italic_en","text":"being dependent upon another for its existence."},{"kind":"text","text":"(KT.) ―         -b2-"},{"kind":"arabic","text_bw":"HadaAvapN","text_ar":"حَدَاثَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HuduwvapN","text_ar":"حُدُوثَةٌ"},{"kind":"text","text":", [as inf. ns. of which the verb, if they have one, is, accord. to analogy,"},{"kind":"arabic","text_bw":"Haduva","text_ar":"حَدُثَ"},{"kind":"text","text":",] relating to a man, signify The"},{"kind":"italic_en","text":"being young;"},{"kind":"text","text":"or [as simple substs.]"},{"kind":"italic_en","text":"youthfulness."},{"kind":"text","text":"(ISd, K.)"}],"source_refs":["S","A","Mgh","Msb","K","TA"]}]}}