it, crumbled it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bruised"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brayed it;"},{"kind":"text","text":"said of wheat, &c.;"},{"kind":"italic_en","text":"thus making it what is termed"},{"kind":"arabic","text_bw":"basiysap","text_ar":"بَسِيسَة"},{"kind":"text","text":": (Msb:) or"},{"kind":"italic_en","text":"he mixed it,"},{"kind":"text","text":"namely,"},{"kind":"arabic","text_bw":"sawyq","text_ar":"سَويق"},{"kind":"text","text":"[or meal of parched barley or wheat], and flour, &c.,"},{"kind":"italic_en","text":"with clarified butter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with olive-oil; thus making it what is termed"},{"kind":"arabic","text_bw":"bsiysap","text_ar":"بسِيسَة"},{"kind":"text","text":": (M:) or"},{"kind":"italic_en","text":"he moistened it,"},{"kind":"text","text":"namely,"},{"kind":"arabic","text_bw":"sawiyq","text_ar":"سَوِيق"},{"kind":"text","text":", and flour,"},{"kind":"italic_en","text":"with a little water;"},{"kind":"text","text":"(ISk, Msb;)"},{"kind":"italic_en","text":"but making it more moist than one does in the action termed"},{"kind":"arabic","text_bw":"lat~N","text_ar":"لَتٌّ"},{"kind":"text","text":": (Yaakoob, cited in the S; and ISk, in the Msb:) or"},{"kind":"arabic","text_bw":"bas~N","text_ar":"بَسٌّ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"making,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"preparing,"},{"kind":"arabic","text_bw":"bsiysap","text_ar":"بسِيسَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"by stirring about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"moistening,"},{"kind":"arabic","text_bw":"sawiyq","text_ar":"سَوِيق"},{"kind":"text","text":", or"},{"kind":"italic_en","text":"flour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground"},{"kind":"arabic","text_bw":"A^aqiT","text_ar":"اَقِط"},{"kind":"text","text":","},{"kind":"italic_en","text":"with clarified butter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with olive-oil;"},{"kind":"text","text":"(S, K;) after which it is eaten, without being cooked. (S.) ―         -b4-  [And hence the saying in the Kur lvi. 5,]"},{"kind":"arabic","text_bw":"wabus~ati AljibaAlu bas~FA","text_ar":"وَبُسَّتِ الجِبَالُ بَسًّا"},{"kind":"italic_en","text":"And the mountains shall be crumbled with a"},{"kind":"text","text":"vehement"},{"kind":"italic_en","text":"crumbling,"},{"kind":"text","text":"(Lh, M, A, K,)"},{"kind":"italic_en","text":"like flour, and"},{"kind":"arabic","text_bw":"sawiyq","text_ar":"سَوِيق"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"and become earth:"},{"kind":"text","text":"(Fr, K:) or"},{"kind":"italic_en","text":"become dust cleaving to the earth:"},{"kind":"text","text":"(AO, M, TA:) or"},{"kind":"italic_en","text":"be levelled:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"mixed with the dust:"},{"kind":"text","text":"(Zj, M, TA:) or"},{"kind":"italic_en","text":"reduced to powder and scattered in the wind."},{"kind":"text","text":"(TA.)"}],"source_refs":["M","Msb","Lh","A","K","Fr","AO","TA","Zj"]}]}}