finition":{"source":"lanes","entries":[{"entry_id":"n19996","headword_ar":"سَفَلَ","root":"sfl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":"; (M, MA, Mgh, O, * Msb, K;) and"},{"kind":"arabic","text_bw":"safula","text_ar":"سَفُلَ"},{"kind":"text","text":", aor."},{"kind":"text","text":"; (M, Msb, K;) and"},{"kind":"arabic","text_bw":"safila","text_ar":"سَفِلَ"},{"kind":"text","text":", (O, K,) aor."},{"kind":"text","text":"; (K;) inf. n. (of the first, Mgh, Msb, TA, and of the last, TA)"},{"kind":"arabic","text_bw":"sufuwlN","text_ar":"سُفُولٌ"},{"kind":"text","text":"(M, MA, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"safaAlN","text_ar":"سَفَالٌ"},{"kind":"text","text":"(M, MA, K, TA, in the CK [erroneously]"},{"kind":"arabic","text_bw":"sifAl","text_ar":"سِفال"},{"kind":"text","text":",) and of the second"},{"kind":"arabic","text_bw":"safaAlapN","text_ar":"سَفَالَةٌ"},{"kind":"text","text":"(TA;) and ↓"},{"kind":"arabic","text_bw":"tsf~l","text_ar":"تسفّل","orth_type":"arrow"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low;"},{"kind":"text","text":"(M, * Mgh, O, K; *) the first"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"EalaA","text_ar":"عَلَا"},{"kind":"text","text":"(Mgh, O;) and the third, of"},{"kind":"arabic","text_bw":"EaliYa","text_ar":"عَلِىَ"},{"kind":"text","text":"; and (assumed tropical:)  both are said of a man; (O;)"},{"kind":"arabic","text_bw":"sufuwlN","text_ar":"سُفُولٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"safaAlN","text_ar":"سَفَالٌ"},{"kind":"text","text":"being the contr. of"},{"kind":"arabic","text_bw":"Euluw~N","text_ar":"عُلُوٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"EalA='N","text_ar":"عَلا=ءٌ"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"became lower than another:"},{"kind":"text","text":"(Msb:) [and] the first signifies"},{"kind":"italic_en","text":"it descended, subsided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sank downwards."},{"kind":"text","text":"(MA.) Hence the phrase"},{"kind":"arabic","text_bw":"binotu binoti binotK","text_ar":"بِنْتُ بِنْتِ بِنْتٍ"},{"kind":"arabic","text_bw":"waA_ino safalato","text_ar":"وَاـِنْ سَفَلَتْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A daughter of a daughter of a daughter, and if she be lower in descent"},{"kind":"text","text":"]:"},{"kind":"arabic","text_bw":"safulato","text_ar":"سَفُلَتْ"},{"kind":"text","text":"i. e. with damm to the"},{"kind":"arabic","text_bw":"f","text_ar":"ف"},{"kind":"text","text":", in this case, is a mistake. (Mgh.) And"},{"kind":"arabic","text_bw":"safalato manozilatuhu Einoda AlA^amiyri","text_ar":"سَفَلَتْ مَنْزِلَتُهُ عِنْدَ الاَمِيرِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"His station with,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in the estimation of, the commander, governor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prince, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lower"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"A^amoruhumo fiYsafaAlK","text_ar":"اَمْرُهُمْ فِىسَفَالٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Their case is in a low state"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"safala fiYAl$~Yo'i","text_ar":"سَفَلَ فِىالشّىْءِ"},{"kind":"text","text":", (K, * TA, [in the former of which the context implies that it is"},{"kind":"arabic","text_bw":"safula","text_ar":"سَفُلَ"},{"kind":"text","text":", but it is]) like"},{"kind":"arabic","text_bw":"naSara","text_ar":"نَصَرَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] (TA,) inf. n."},{"kind":"arabic","text_bw":"sufuwlN","text_ar":"سُفُولٌ"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"It subsided in the thing;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it descended from the upper,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uppermost, part of the thing, to the lower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest, part thereof."},{"kind":"text","text":"(K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"safula","text_ar":"سَفُلَ"},{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"safaAlapN","text_ar":"سَفَالَةٌ"},{"kind":"text","text":"(Fr, S, MA, Mgh, O, K *) and"},{"kind":"arabic","text_bw":"safaAliyapN","text_ar":"سَفَالِيَةٌ"},{"kind":"text","text":"(MA) and"},{"kind":"arabic","text_bw":"sufolN","text_ar":"سُفْلٌ"},{"kind":"text","text":", (Fr, O,) (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low, base, vile, ignoble, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid;"},{"kind":"text","text":"(Fr, S, MA, Mgh, O, K; *) as also"},{"kind":"arabic","text_bw":"safala","text_ar":"سَفَلَ"},{"kind":"text","text":", with fet-h, (Fr, O,) or"},{"kind":"arabic","text_bw":"safila","text_ar":"سَفِلَ"},{"kind":"text","text":". (MA.) You say,"},{"kind":"arabic","text_bw":"safala","text_ar":"سَفَلَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qatala","text_ar":"قَتَلَ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"safula","text_ar":"سَفُلَ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"karuma","text_ar":"كَرُمَ"},{"kind":"text","text":", (K,)"},{"kind":"arabic","text_bw":"fiY xuluqihi","text_ar":"فِى خُلُقِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eamalihi","text_ar":"عَمَلِهِ"},{"kind":"text","text":", (Msb, K,) and"},{"kind":"arabic","text_bw":"nasabihi","text_ar":"نَسَبِهِ"},{"kind":"text","text":", (TA,) [aor. in either case"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"safolN","text_ar":"سَفْلٌ"},{"kind":"text","text":"(Msb, K) and"},{"kind":"arabic","text_bw":"sufolN","text_ar":"سُفْلٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"sifaAlN","text_ar":"سِفَالٌ"},{"kind":"text","text":", (Msb, * K, [in the former without any indication of the syll. signs,]) the last like"},{"kind":"arabic","text_bw":"kitaAbN","text_ar":"كِتَابٌ"},{"kind":"text","text":"; (K;) [and app."},{"kind":"arabic","text_bw":"safila","text_ar":"سَفِلَ"},{"kind":"text","text":"also accord. to the MA, as shown above;] and ↓"},{"kind":"arabic","text_bw":"tsf~l","text_ar":"تسفّل","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Astfl","text_ar":"استفل","orth_type":"arrow"},{"kind":"text","text":"; (TA;) (tropical:)"},{"kind":"italic_en","text":"He was low, base, vile, ignoble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean, in his lot,"},{"kind":"text","text":"[or, as seems to be indicated in the Msb,"},{"kind":"italic_en","text":"inferior to others,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in respect of his disposition,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his deed,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his lineage:"},{"kind":"text","text":"(TA:) ↓"},{"kind":"arabic","text_bw":"tsf~l","text_ar":"تسفّل","orth_type":"arrow"},{"kind":"text","text":"is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"jaAda","text_ar":"جَادَ"},{"kind":"text","text":". (Msb.)"}],"source_refs":["O","K","M","MA","Mgh","Msb","S","TA","Fr"]}]}}