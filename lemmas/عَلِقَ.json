{"lemma":"عَلِقَ","slug":"عَلِقَ","root":"ع.ل.ق","root_slug":"ع-ل-ق","root_link":"/words/roots/ع-ل-ق","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَلِقْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَلِقْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَلِقْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَلِقْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَلِقْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَلِقَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَلِقَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَلِقا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَلِقَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَلِقُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَلِقْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْلَق","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْلَقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْلَقِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْلَقا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْلَقانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْلَقُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْلَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْلَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْلَق","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْلَق","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْلَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْلَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْلَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْلَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْلَقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْلَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْلَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"عَلِقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَلِقْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْلَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْلَق","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":30,"cross_references":{"qac":{"found":true,"lemma_key":"عَلِقَ","root":"علق","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":9,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":44},"lanes":{"found":true,"entry_ids":["n30278","n30279","n30280","n30281","n30282"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%84%D9%90%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hang on, to be suspended","tags":["intransitive"],"examples":[{"text":"عَلِقَ اللَّوْحُ عَلَى الحَائِطِ بِإِطِارٍ جَمِيلٍ.","english":"The painting hung on the wall with a beautiful frame."}]},{"pos":"verb","gloss":"to be tied to, to be hooked in (transitive or بِ (bi) or فِي (fī) something)"},{"pos":"verb","gloss":"to cling, to cleave, to be attached (بِ (bi) to)"},{"pos":"verb","gloss":"to get caught (بِ (bi) on, فِي (fī) in; a snare, trap, net or similar)"},{"pos":"verb","gloss":"to begin (followed by the non-past)"},{"pos":"verb","gloss":"to be attached to, to love"},{"pos":"verb","gloss":"to cling to"},{"pos":"verb","gloss":"to know, to learn"},{"pos":"verb","gloss":"to conceive (مِن (min) by), to get big (بِ (bi) with)"},{"pos":"verb","gloss":"to adhere"},{"pos":"verb","gloss":"to browse leaves from high trees"},{"pos":"verb","gloss":"to revile"},{"pos":"verb","gloss":"to hang, to suspend (بِ (bi) or عَلَى (ʕalā) on something)","tags":["transitive"],"examples":[{"text":"فقالَ لِأتباعِهِ أكثَرَ مِن مَرَّةٍ إنَّهُ سيُعَلَّقُ على خَشَبَة.","english":"He told his followers more than once that he would be hanged on a stake."}]},{"pos":"verb","gloss":"to tie to, to hook in or to"},{"pos":"verb","gloss":"to attach (بِ (bi) or عَلَى (ʕalā) to something)","tags":["transitive"]},{"pos":"verb","gloss":"to pin(?)","examples":[{"text":"وَيُعَلِّقُ الأُرْدُنِيُّونَ الآمَالَ عَلَى الخصاونة.","english":"Jordanians pin their hopes on Al-Khasawneh."}]},{"pos":"verb","gloss":"to remark, to comment (عَلَى (ʕalā) on something)"},{"pos":"verb","gloss":"to note down, to make marginal notes"},{"pos":"verb","gloss":"to make dependent (بِ (bi) or عَلَى (ʕalā) to something)","tags":["transitive"]},{"pos":"verb","gloss":"to leave pending","tags":["transitive"]},{"pos":"verb","gloss":"to set leeches"},{"pos":"verb","gloss":"to give one a cancel with provisions to take with him"},{"pos":"verb","gloss":"to mount afresh (an iron tool)"},{"pos":"verb","gloss":"to ignite, to catch fire"},{"pos":"verb","gloss":"to break out"},{"pos":"verb","gloss":"to kindle"},{"pos":"verb","gloss":"to lock up"},{"pos":"verb","gloss":"to be in love"},{"pos":"noun","gloss":"verbal noun of عَلِقَ (ʕaliqa, “to hang (intransitive), be suspended”) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"anything suspended or hung"},{"pos":"noun","gloss":"suspensory cord (of the pulley of a well, a waterskin, etc.)"},{"pos":"noun","gloss":"apparatus holding up the pulley of a well"},{"pos":"noun","gloss":"pulley of a well"},{"pos":"noun","gloss":"clay that clings to the hand"},{"pos":"noun","gloss":"tenacious love"},{"pos":"noun","gloss":"pertinaceous contention in an altercation"},{"pos":"noun","gloss":"disputation, litigation"},{"pos":"noun","gloss":"middle part of a road"},{"pos":"noun","gloss":"leeches","tags":["collective"]},{"pos":"noun","gloss":"blood","tags":["collective"]},{"pos":"noun","gloss":"thick or clotted blood","tags":["collective"],"examples":[{"text":"خَلَقَ الْإِنسَانَ مِنْ عَلَقٍ","english":"(God) created humans from a clinging clot."}]},{"pos":"noun","gloss":"verbal noun of عَلِقَ (ʕaliqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of عَلِقَ (ʕaliqa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"verbal noun of عَلَقَ (ʕalaqa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Causative of عَلِقَ (ʕaliqa, “to be suspended, to hang (intransitive), to be attached”)."},"ipa":["/ʕa.li.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30278","headword_ar":"عَلْقٌ","root":"Elq","body":[{"kind":"italic_en","text":"A hole in a garment,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"caused by one's passing by a tree"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a thorn that has caught to it;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"EalaqN","text_ar":"عَلَقٌ","orth_type":"arrow"},{"kind":"text","text":": (K, TA:) or"},{"kind":"italic_en","text":"a thing that has caught,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"clung, to a garment, and pulled it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and,"},{"kind":"text","text":"app.,"},{"kind":"italic_en","text":"frayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rent, it"},{"kind":"text","text":"]. (S. [See also"},{"kind":"arabic","text_bw":"EaloqapN","text_ar":"عَلْقَةٌ"},{"kind":"text","text":".])       -A2-  And The"},{"kind":"italic_en","text":"act of reviling."},{"kind":"text","text":"(K.) [See also"},{"kind":"arabic","text_bw":"Ealaqahu bilisaAnihi","text_ar":"عَلَقَهُ بِلِسَانِهِ"},{"kind":"text","text":", (of which it is the inf. n.,) near the end of the first paragraph.]       -A3-  And"},{"kind":"italic_en","text":"A species of trees used for tanning."},{"kind":"text","text":"(K.)       -A4-  See also the next paragraph, in two places."}],"source_refs":["K","TA"]},{"entry_id":"n30279","headword_ar":"عِلْقٌ","root":"Elq","body":[{"kind":"italic_en","text":"A precious thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing held in high estimation, of any kind,"},{"kind":"text","text":"(Lh, S, O, K, TA,)"},{"kind":"italic_en","text":"except of animate beings;"},{"kind":"text","text":"(Lh, TA;) as also ↓"},{"kind":"arabic","text_bw":"EaloqN","text_ar":"عَلْقٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) one says,"},{"kind":"arabic","text_bw":"h`*aA Eiloqu maDan~apK","text_ar":"هٰذَا عِلْقُ مَضَنَّةٍ"},{"kind":"italic_en","text":"This is a precious thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thing held in high estimation, of which one is tenacious;"},{"kind":"text","text":"(S, * O;) as also"},{"kind":"arabic","text_bw":"Eiroqu","text_ar":"عِرْقُ"},{"kind":"arabic","text_bw":"maDan~apK","text_ar":"مَضَنَّةٍ"},{"kind":"text","text":"[q. v.]: (O and TA in art."},{"kind":"arabic","text_bw":"Erq","text_ar":"عرق"},{"kind":"text","text":":) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aEolaAqN","text_ar":"اَعْلَاقٌ"},{"kind":"text","text":"(S, K) and [of mult.]"},{"kind":"arabic","text_bw":"EuluwqN","text_ar":"عُلُوقٌ"},{"kind":"text","text":", (K,) and, as some say,"},{"kind":"arabic","text_bw":"EiloqaAtN","text_ar":"عِلْقَاتٌ"},{"kind":"text","text":". (O.) And [particularly]"},{"kind":"italic_en","text":"A garment held in high estimation:"},{"kind":"text","text":"[see also"},{"kind":"arabic","text_bw":"EiloqapN","text_ar":"عِلْقَةٌ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"a shield:"},{"kind":"text","text":"[see again"},{"kind":"arabic","text_bw":"EiloqapN","text_ar":"عِلْقَةٌ"},{"kind":"text","text":":] or"},{"kind":"italic_en","text":"a sword:"},{"kind":"text","text":"(Lh, K, TA:) and"},{"kind":"italic_en","text":"property held in high estimation."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"italic_en","text":"Wine;"},{"kind":"text","text":"(S, O, K;) because held in high estimation: (S, O:) or"},{"kind":"italic_en","text":"old wine."},{"kind":"text","text":"(K, TA.) ―         -b3-  And one says,"},{"kind":"arabic","text_bw":"fulaAnN Eiloqu","text_ar":"فُلَانٌ عِلْقُ"},{"kind":"arabic","text_bw":"EilomK","text_ar":"عِلْمٍ"},{"kind":"italic_en","text":"Such a one is a lover and pursuer of knowledge:"},{"kind":"text","text":"(O, K: *) and in like manner,"},{"kind":"arabic","text_bw":"Eiloqu $ar~K","text_ar":"عِلْقُ شَرٍّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a lover and pursuer of evil"},{"kind":"text","text":"]: (K:) and"},{"kind":"arabic","text_bw":"Eiloqu xayorK","text_ar":"عِلْقُ خَيْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a lover and pursuer of good"},{"kind":"text","text":"]. (TA.)       -A2-  Also"},{"kind":"italic_en","text":"A"},{"kind":"arabic","text_bw":"jiraAb","text_ar":"جِرَاب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bag for travelling-provisions &c."},{"kind":"text","text":"]; and so ↓"},{"kind":"arabic","text_bw":"EaloqN","text_ar":"عَلْقٌ","orth_type":"arrow"},{"kind":"text","text":": (Ibn-'Abbád, O, K:) [pl."},{"kind":"arabic","text_bw":"A^aEolaAqN","text_ar":"اَعْلَاقٌ"},{"kind":"text","text":", of which see an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"raAy^iHN","text_ar":"رَايِحٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"rwH","text_ar":"روح"},{"kind":"text","text":".]       -A3-  See also"},{"kind":"arabic","text_bw":"EuloqapN","text_ar":"عُلْقَةٌ"},{"kind":"text","text":": ―         -b2-  and see"},{"kind":"arabic","text_bw":"EalaAqapN","text_ar":"عَلَاقَةٌ"},{"kind":"text","text":", first quarter."}],"source_refs":["Lh","S","O","K","TA"]},{"entry_id":"n30280","headword_ar":"عَلَقٌ","root":"Elq","body":[{"kind":"italic_en","text":"Anything hung,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspended."},{"kind":"text","text":"(K.) ―         -b2-  The"},{"kind":"italic_en","text":"suspensory"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cord"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"bakorap","text_ar":"بَكْرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pulley of a well"},{"kind":"text","text":"]; (K;) the"},{"kind":"italic_en","text":"apparatus of the"},{"kind":"arabic","text_bw":"bikorap","text_ar":"بِكْرَة"},{"kind":"text","text":","},{"kind":"italic_en","text":"by which it is suspended:"},{"kind":"text","text":"(S, O:) and the"},{"kind":"arabic","text_bw":"bakorap","text_ar":"بَكْرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pulley"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"itself;"},{"kind":"text","text":"(K, TA;) as some say; and the pl. is"},{"kind":"arabic","text_bw":"A^aEolaAqN","text_ar":"اَعْلَاقٌ"},{"kind":"text","text":": (TA:) or [in the CK “ and ”] the"},{"kind":"italic_en","text":"wellrope and the large bucket and"},{"kind":"text","text":"the"},{"kind":"arabic","text_bw":"miHowar","text_ar":"مِحْوَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pin on which the sheave of the pulley turns"},{"kind":"text","text":"] (K, TA)"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"the"},{"kind":"italic_en","text":"pulley,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"all together;"},{"kind":"text","text":"(K, TA;) so says Lh: (TA:) or"},{"kind":"italic_en","text":"all the apparatus for drawing water by means of the pulley; comprising the two pieces of wood at the head of the well, the two upper extremities of which are connected by a rope and then fastened to the ground by means of another rope, the two ends of this being extended to two pegs fixed in the ground; the pulley is suspended to the upper parts of the two pieces of wood, and the water is drawn by means of it with two buckets by two drawers:"},{"kind":"text","text":"it signifies only the"},{"kind":"arabic","text_bw":"saAniyap","text_ar":"سَانِيَة"},{"kind":"text","text":"[here meaning the"},{"kind":"italic_en","text":"large bucket with its apparatus"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and all the apparatus consisting of the"},{"kind":"arabic","text_bw":"xuT~aAf","text_ar":"خُطَّاف"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"bent piece of iron which is on each side of the sheave of the pulley and in which is the pin whereon the sheave turns"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the"},{"kind":"arabic","text_bw":"miHowar","text_ar":"مِحْوَر"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pin itself"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the sheave and the"},{"kind":"arabic","text_bw":"naEaAmataAni","text_ar":"نَعَامَتَانِ"},{"kind":"text","text":"[app. here meaning the"},{"kind":"italic_en","text":"two pieces of wood mentioned above,"},{"kind":"text","text":"agreeably with an explanation mentioned voce"},{"kind":"arabic","text_bw":"zuronuwqN","text_ar":"زُرْنُوقٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"and the ropes thereof:"},{"kind":"text","text":"so says As, on the authority of Arabs: (TA:) or the"},{"kind":"italic_en","text":"rope that is suspended to the pulley:"},{"kind":"text","text":"(K:) or, as some say, the"},{"kind":"italic_en","text":"rope that is at the upper part of the pulley."},{"kind":"text","text":"(TA.) ―         -b3-  And The"},{"kind":"italic_en","text":"suspensory"},{"kind":"text","text":"of a"},{"kind":"arabic","text_bw":"qirobap","text_ar":"قِرْبَة"},{"kind":"text","text":"[or water-skin]; i. e."},{"kind":"arabic","text_bw":"Ealaqu Alqirobapi","text_ar":"عَلَقُ القِرْبَةِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the strap by which the"},{"kind":"arabic","text_bw":"qrbp","text_ar":"قربة"},{"kind":"italic_en","text":"is suspended;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"EaraquhaA","text_ar":"عَرَقُهَا"},{"kind":"text","text":": (S, O, K, TA:) or"},{"kind":"italic_en","text":"the thing with which it is tied and then suspended:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what has remained in it of the grease with which it is greased."},{"kind":"text","text":"(TA.) One says,"},{"kind":"arabic","text_bw":"ja$imotu A_ilayoka Ealaqa Alqirobapi","text_ar":"جَشِمْتُ اـِلَيْكَ عَلَقَ القِرْبَةِ"},{"kind":"text","text":"[expl. in arts."},{"kind":"arabic","text_bw":"j$m","text_ar":"جشم"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Erq","text_ar":"عرق"},{"kind":"text","text":"]. (S, O.) ―         -b4-  Also ["},{"kind":"italic_en","text":"Leeches;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"certain worms,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"certain things resembling worms,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"certain small creeping things,"},{"kind":"text","text":"(O,) or"},{"kind":"italic_en","text":"a"},{"kind":"text","text":"["},{"kind":"italic_en","text":"species of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"small creeping thing,"},{"kind":"text","text":"(K,)"},{"kind":"italic_en","text":"black,"},{"kind":"text","text":"(Mgh, Msb,) or"},{"kind":"italic_en","text":"red,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"found in water,"},{"kind":"text","text":"(S, O, Msb, K,)"},{"kind":"italic_en","text":"and having the property of sucking blood,"},{"kind":"text","text":"(S, O, K, TA,)"},{"kind":"italic_en","text":"and employed to suck the blood from the throat and from sanguineous tumours:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"they cling"},{"kind":"text","text":"(Mgh, Msb)"},{"kind":"italic_en","text":"to the"},{"kind":"arabic","text_bw":"Hanak","text_ar":"حَنَك"},{"kind":"text","text":"[q. v.] (Mgh) or"},{"kind":"italic_en","text":"to the fauces"},{"kind":"text","text":"(Msb)"},{"kind":"italic_en","text":"of the beast when he drinks,"},{"kind":"text","text":"(Mgh, Msb,)"},{"kind":"italic_en","text":"and suck the blood:"},{"kind":"text","text":"(Msb:) one thereof is termed"},{"kind":"arabic","text_bw":"EalaqapN","text_ar":"عَلَقَةٌ"},{"kind":"text","text":". (S, O, Msb.) ―         -b5-  And"},{"kind":"italic_en","text":"Clay that clings to the hand."},{"kind":"text","text":"(K.) ―         -b6-  And"},{"kind":"italic_en","text":"Blood,"},{"kind":"text","text":"in a general sense: or"},{"kind":"italic_en","text":"intensely red blood:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"thick blood:"},{"kind":"text","text":"(S, O, K:) or"},{"kind":"italic_en","text":"clotted blood,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"before it becomes dry:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"clotted, thick, blood;"},{"kind":"text","text":"because of its clinging together: (Mgh:) and"},{"kind":"arabic","text_bw":"EalaqapN","text_ar":"عَلَقَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a portion thereof:"},{"kind":"text","text":"(S, Mgh, O, K:) or this signifies"},{"kind":"italic_en","text":"a little portion of thick blood:"},{"kind":"text","text":"(Jel in xcvi. 2:) or"},{"kind":"italic_en","text":"a portion"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"lump"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of clotted blood:"},{"kind":"text","text":"(TA:) or the"},{"kind":"italic_en","text":"seminal fluid, after its appearance, when it becomes thick, clotted, blood;"},{"kind":"text","text":"after which it passes to another stage, becoming flesh, and is what is termed"},{"kind":"arabic","text_bw":"muDogapN","text_ar":"مُضْغَةٌ"},{"kind":"text","text":". (Msb. [See Kur xxiii. 14.])       -A2-  Also ["},{"kind":"italic_en","text":"Attachment,"},{"kind":"text","text":"as meaning]"},{"kind":"italic_en","text":"tenacious love:"},{"kind":"text","text":"(K:) and [simply]"},{"kind":"italic_en","text":"love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirous love,"},{"kind":"text","text":"(Lh, S, O, K, TA,)"},{"kind":"italic_en","text":"of a man for a woman:"},{"kind":"text","text":"(Lh, TA:) or"},{"kind":"italic_en","text":"love cleaving to the heart;"},{"kind":"text","text":"(TA;) and so ↓"},{"kind":"arabic","text_bw":"EalaAqpN","text_ar":"عَلَاقةٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"EilaAqapN","text_ar":"عِلَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":"; or the former of these two relates to love and the like and the latter relates to a whip and the like [as will be expl. below under the two words]. (K.) [In this sense it is originally an inf. n., of which the verb is"},{"kind":"arabic","text_bw":"Ealiqa","text_ar":"عَلِقَ"},{"kind":"text","text":".] One says,"},{"kind":"arabic","text_bw":"A_in~ahu la*uw EalaqK fiY fulaAnapa","text_ar":"اـِنَّهُ لَذُو عَلَقٍ فِى فُلَانَةَ"},{"kind":"italic_en","text":"Verily he is one having love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirous love, for such a woman:"},{"kind":"text","text":"(Lh, TA:) thus made trans. by means of"},{"kind":"arabic","text_bw":"fY","text_ar":"فى"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"naZorapN mino *iY EalaqK","text_ar":"نَظْرَةٌ مِنْ ذِى عَلَقٍ"},{"kind":"italic_en","text":"A look from one having love,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirous love:"},{"kind":"text","text":"(S, O, TA:) a prov. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"EalaAqapN","text_ar":"عَلَاقَةٌ"},{"kind":"text","text":", first quarter. ―         -b3-  Also"},{"kind":"italic_en","text":"Pertinacious contention in an altercation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such disputation"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"litigation."},{"kind":"text","text":"(K. [In this sense it is originally an inf. n., of which the verb is"},{"kind":"arabic","text_bw":"Ealiqa","text_ar":"عَلِقَ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"EalaAqapN","text_ar":"عَلَاقَةٌ"},{"kind":"text","text":", q. v., has a similar signification.]) ―         -b4-  See also"},{"kind":"arabic","text_bw":"EuloqapN","text_ar":"عُلْقَةٌ"},{"kind":"text","text":", second sentence.       -A3-  And see"},{"kind":"arabic","text_bw":"EaloqN","text_ar":"عَلْقٌ"},{"kind":"text","text":".       -A4-  Also The"},{"kind":"italic_en","text":"main"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"middle"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"beaten track"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of a road."},{"kind":"text","text":"(Ibn-'Abbád, O, K.) [See an ex. of the pl. ("},{"kind":"arabic","text_bw":"A^aEolaAqN","text_ar":"اَعْلَاقٌ"},{"kind":"text","text":") in a verse cited voce"},{"kind":"arabic","text_bw":"EamoqN","text_ar":"عَمْقٌ"},{"kind":"text","text":".]"},{"kind":"page_break","n":2135}],"source_refs":["S","O","TA","K","Mgh","Msb","Lh"]},{"entry_id":"n30281","headword_ar":"عَلِقٌ","root":"Elq","body":[{"kind":"text","text":"[part. n. of"},{"kind":"arabic","text_bw":"Ealiqa","text_ar":"عَلِقَ"},{"kind":"text","text":": as such signifying"},{"kind":"italic_en","text":"Hanging,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"being suspended:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"clinging,"},{"kind":"text","text":"&c.: ―         -b2-  and]"},{"kind":"italic_en","text":"pertinacious; adhering to affairs, and minding them."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"*mr","text_ar":"ذمر"},{"kind":"text","text":".) [See also"},{"kind":"arabic","text_bw":"EalaAqiyapN","text_ar":"عَلَاقِيَةٌ"},{"kind":"text","text":".] ―         -b3-  [Also, as such, applied to a woman,"},{"kind":"italic_en","text":"Pregnant:"},{"kind":"text","text":"a meaning assigned by Golius to"},{"kind":"arabic","text_bw":"EalaqN","text_ar":"عَلَقٌ"},{"kind":"text","text":".]"}],"source_refs":[]},{"entry_id":"n30282","headword_ar":"عُلَقَ","root":"Elq","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fulaqa","text_ar":"فُلَقَ"},{"kind":"text","text":"in the saying"},{"kind":"arabic","text_bw":"jiy^ota biEulaqa fulaqa","text_ar":"جِيْتَ بِعُلَقَ فُلَقَ"},{"kind":"text","text":", [expl. above, see 4,] (S,) or"},{"kind":"arabic","text_bw":"jaA='a biEulaqa fulaqa","text_ar":"جَا=ءَ بِعُلَقَ فُلَقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He brought to pass"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that which was a calamity,"},{"kind":"text","text":"(K,) are imperfectly decl., (S, K,) like"},{"kind":"arabic","text_bw":"Eumar","text_ar":"عُمَر"},{"kind":"text","text":". (S.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EulaqN","text_ar":"عُلَقٌ"},{"kind":"text","text":"[perfectly decl.] signifies"},{"kind":"italic_en","text":"A numerous company,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"collection"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of men"},{"kind":"text","text":"]: (K:) thus it is said to mean: (S:) and this is meant in the saying above mentioned, as some explain it. (TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"EulaqN","text_ar":"عُلَقٌ"},{"kind":"text","text":"accord. to K, but correctly"},{"kind":"arabic","text_bw":"EuluqN","text_ar":"عُلُقٌ"},{"kind":"text","text":", with two dammehs, pl. of ↓"},{"kind":"arabic","text_bw":"EaluwqN","text_ar":"عَلُوقٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) signifies"},{"kind":"italic_en","text":"Deaths,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"decrees of death;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"manaAyaA","text_ar":"مَنَايَا"},{"kind":"text","text":": (K, TA:) and"},{"kind":"italic_en","text":"calamities:"},{"kind":"text","text":"(TA:) and"},{"kind":"italic_en","text":"businesses, occupations,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employments:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such as divert one"},{"kind":"text","text":"from other things: or"},{"kind":"italic_en","text":"occurrences that cause one to forget,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"neglect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be unmindful:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^a$ogaAlN","text_ar":"اَشْغَالٌ"},{"kind":"text","text":". (K, TA.)"}],"source_refs":["S","K","TA"]}]}}