_in_corpus":24,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27749"]}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to gulp, to chug down","examples":[{"text":"وهي الساعة التي يكون فيها مزاجه رائقاً بعد أن يكون قد عبّ ثلاثة أقداح من الويسكي.","english":"It was the hour where he had a buoyant mood already after swigging three stoops of whiskey."}]},{"pos":"noun","gloss":"breast pocket, a pocket in a shirt higher than a جَيْب (jayb)"},{"pos":"noun","gloss":"light"}]},"etymology":{"source":"wiktextract","text":"Considered a vulgar word; probably from Aramaic עוּבָּא / עֻבָּא / ܥܘܒܐ (ʿubbā), broader of meaning: “bosom, lap; any enclosed space; calyx …”. Doublet of غُبّ (ḡubb, “depressed terrain; bosom of the sea”). جَيْب (jayb, “pocket”) is similarly suspect of being an Aramaic borrowing.\n\nCognate with Akkadian 𒅁𒁍 (ebbu) \"to be bright, shiny; to be pure, clean\"."},"ipa":null}