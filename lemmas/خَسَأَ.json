unt":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْسَآ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْسَأُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْسَأُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْسَؤُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْسَؤُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْسَأْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْسَأ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْسَأ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَسَأْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَسَأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n10586","n10633"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%B3%D9%8E%D8%A3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to chase away, to drive away"}]},"etymology":null,"ipa":["/xa.sa.ʔa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10586","headword_ar":"خَسَاَ","root":"xsA^","body":[{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"xaso'N","text_ar":"خَسْءٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"xusuwo'N","text_ar":"خُسُوْءٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He drove away"},{"kind":"text","text":"a dog: (S, K:)"},{"kind":"italic_en","text":"he chid"},{"kind":"text","text":"him. (Lth.)       -A2-  It is also intrans., (S,) and signifies"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a dog)"},{"kind":"italic_en","text":"went away, to a distance;"},{"kind":"text","text":"(S, * K;) ["},{"kind":"italic_en","text":"being driven away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chidden;"},{"kind":"text","text":"] as also"},{"kind":"arabic","text_bw":"xasiy^a","text_ar":"خَسِيَ"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"AnxsA^","text_ar":"انخسا","orth_type":"arrow"},{"kind":"text","text":". (S, K.) ―         -b2-  [Hence,] tropically, said to a man,"},{"kind":"arabic","text_bw":"AixosaA^o A_ilayoka","text_ar":"اِخْسَاْ اـِلَيْكَ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"AixosaA^o Ean~iY","text_ar":"اِخْسَاْ عَنِّى"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Go thou away:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"go thou away from me"},{"kind":"text","text":"]. (TA.)"},{"kind":"arabic","text_bw":"Aixosaw^uwA fiyhaA wa laA tukal~imuwni","text_ar":"اِخْسَوُوا فِيهَا وَ لَا تُكَلِّمُونِ"},{"kind":"text","text":", in the Kur [xxiii. 110], is expressive of removal to a distance with anger; [meaning (assumed tropical:)"},{"kind":"italic_en","text":"Go ye away into it,"},{"kind":"text","text":"(i. e. the fire of Hell,)"},{"kind":"italic_en","text":"and speak not unto Me."},{"kind":"text","text":"] (Zj.) ―         -b3-  [And hence, (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vile and despised and hated:"},{"kind":"text","text":"so says Golius, as on the authority of the KL; but this meaning is not in my copy of that work: it agrees, however, with a signification of the part. n."},{"kind":"arabic","text_bw":"xaAsiy^N","text_ar":"خَاسِيٌ"},{"kind":"text","text":", q. v.]       -A3-  Also, inf. n."},{"kind":"arabic","text_bw":"xaso'N","text_ar":"خَسْءٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xusuwo'N","text_ar":"خُسُوْءٌ"},{"kind":"text","text":"[as above], said of the sight, (AZ, S, K,) (tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, dazzled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confused,"},{"kind":"text","text":"(AZ, S, TA,) and"},{"kind":"italic_en","text":"dim."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["S","K","AZ","TA"]},{"entry_id":"n10633","headword_ar":"خَسَا","root":"xsw","body":[{"kind":"text","text":", (JK, K, * and TA in art."},{"kind":"arabic","text_bw":"zkw","text_ar":"زكو"},{"kind":"text","text":",) without tenween, and accord. to some with tenween, and not having the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"prefixed to it; and in like manner"},{"kind":"arabic","text_bw":"zakaA","text_ar":"زَكَا"},{"kind":"text","text":", which is coupled with the former, is without tenween, and accord. to some with tenween, and not having the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"prefixed to it; (TA in that art.;) [but each has"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"prefixed to it in the K;] accord. to Fr, some make it quasi-coordinate to"},{"kind":"arabic","text_bw":"fatFY","text_ar":"فَتًى"},{"kind":"text","text":"[i. e. with tenween, and masc.]; some, to"},{"kind":"arabic","text_bw":"zfr","text_ar":"زفر"},{"kind":"text","text":"[app. meaning the proper name"},{"kind":"arabic","text_bw":"zufaru","text_ar":"زُفَرُ"},{"kind":"text","text":"i. e. without tenween, and masc.]; and some, to"},{"kind":"arabic","text_bw":"sakoraY","text_ar":"سَكْرَى"},{"kind":"text","text":"[app. meaning without tenween, and fem.]: (TA:) a word that is said in playing with walnuts; (JK;)"},{"kind":"italic_en","text":"An odd number:"},{"kind":"text","text":"(Lth, Fr, K, TA:) and"},{"kind":"arabic","text_bw":"zkA","text_ar":"زكا"},{"kind":"text","text":"signifies an even number: (Lth, Fr, TA:) accord. to IB, its final letter is hemzeh, for one says,"},{"kind":"arabic","text_bw":"yuxaAsiy^u","text_ar":"يُخَاسِيُ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"yuqaAmiru","text_ar":"يُقَامِرُ"},{"kind":"text","text":"[he contends in a game of hazard]; but it is pronounced without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":"to assimilate it to"},{"kind":"arabic","text_bw":"zkA","text_ar":"زكا"},{"kind":"text","text":": (TA:) the pl. is"},{"kind":"arabic","text_bw":"A^axaAsK","text_ar":"اَخَاسٍ"},{"kind":"text","text":", (K, TA,) accord. to the M,"},{"kind":"arabic","text_bw":"maxaAsK","text_ar":"مَخَاسٍ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"masaAwK","text_ar":"مَسَاوٍ"},{"kind":"text","text":", (TA, [but the former pl. occurs in a verse cited in the TA,]) which is anomalous. (K.) One says,"},{"kind":"arabic","text_bw":"xasFA A^awo zakFA","text_ar":"خَسًا اَوْ زَكًا"},{"kind":"text","text":", [so in my copies of the S, with tenween,] i. e."},{"kind":"italic_en","text":"Odd or even?"},{"kind":"text","text":"(S:) [or"},{"kind":"arabic","text_bw":"xasaA A^awo zakaA","text_ar":"خَسَا اَوْ زَكَا"},{"kind":"text","text":", as shown above:] and some say,"},{"kind":"arabic","text_bw":"xasaA zakaA","text_ar":"خَسَا زَكَا"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"xamosapa Ea$ara","text_ar":"خَمْسَةَ عَشَرَ"},{"kind":"text","text":". (IB, TA.) And it is said in a trad.,"},{"kind":"arabic","text_bw":"maA A^adoriY kamo Had~avaniY","text_ar":"مَا اَدْرِى كَمْ حَدَّثَنِى"},{"kind":"arabic","text_bw":"A^abiY Eino rasuwli A@ll~`hi Sal~aY A@ll~`hu Ealayohi wa sal~ama A^axosaA A^amo","text_ar":"اَبِى عِنْ رَسُولِ ا@للّٰهِ صَلَّى ا@للّٰهُ عَلَيْهِ وَ سَلَّمَ اَخْسَا اَمْ"},{"kind":"arabic","text_bw":"zakaA","text_ar":"زَكَا"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"A^axosFA A^amo zakFA","text_ar":"اَخْسًا اَمْ زَكًا"},{"kind":"text","text":", [for the vowel-signs are not written in my original,] meaning"},{"kind":"arabic","text_bw":"farodFA A^amo zawojFA","text_ar":"فَرْدًا اَمْ زَوْجًا"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I know not how many times my father told me, from the Apostle of God, God bless and save him; whether an odd or an even number:"},{"kind":"text","text":"or, perhaps,"},{"kind":"italic_en","text":"once or twice"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["TA","Lth","Fr","K","S"]}]},"classical_definitions":null}