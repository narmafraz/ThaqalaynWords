7411","n7415","n7416","n7417","n7418"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%B0%D9%8E%D9%91%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to watch out"},{"pos":"verb","gloss":"to warn, to admonish","tags":["ditransitive"],"examples":[{"text":"وَحَذَّرَهُمَا أَنَّ خَطِيَّتَهُمَا سَتُؤَدِّي إِلَى الْمَوْتِ","english":"And he warned them both that their sin would lead to death"},{"text":"وَيُحَذِّرُكُمُ ٱللّٰهُ نَفْسَهُ","english":"And Allah warns you about Himself"}]},{"pos":"noun","gloss":"verbal noun of حَذِرَ (ḥaḏira) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"caution, care, precaution","examples":[{"text":"يَا أَيُّهَا ٱلَّذِينَ آمَنُوا خُذُوا حِذْرَكُمْ فَٱنْفِرُوا ثُبَاتٍ أَوِ ٱنْفِرُوا جَمِيعًا"}]},{"pos":"adj","gloss":"cautious, careful"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7411","headword_ar":"حَذِرَ","root":"H*r","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ha*arN","text_ar":"حَذَرٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"text","text":"; (Msb, K;)"},{"kind":"italic_en","text":"He was cautious, wary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigilant; was on his guard; took care;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"was in a state of preparation;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"was in fear; feared."},{"kind":"text","text":"(TA.) [You say,"},{"kind":"arabic","text_bw":"Ha*ira mino A^amorK","text_ar":"حَذِرَ مِنْ اَمْرٍ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"italic_en","text":"He was cautious,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an event."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"Ha*ira Ealayohi mino ka*aA","text_ar":"حَذِرَ عَلَيْهِ مِنْ كَذَا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"italic_en","text":"He was cautious,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for him, of such a thing."},{"kind":"text","text":"And both verbs are also trans.: for you say,]"},{"kind":"arabic","text_bw":"Ha*irahu","text_ar":"حَذِرَهُ"},{"kind":"text","text":", (S, A, Msb,) aor. and inf. n. as above; (S;) and ↓"},{"kind":"arabic","text_bw":"AHt*rhu","text_ar":"احتذرهُ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"HA*rhu","text_ar":"حاذرهُ","orth_type":"arrow"},{"kind":"text","text":"; (A;)"},{"kind":"italic_en","text":"He was cautious of it; guarded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was on his guard, against it;"},{"kind":"text","text":"(S, A;)"},{"kind":"italic_en","text":"prepared, prepared himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was in a state of preparation, against it;"},{"kind":"text","text":"(TA;)"},{"kind":"italic_en","text":"feared it."},{"kind":"text","text":"(Msb, TA.) [And"},{"kind":"arabic","text_bw":"Ha*ira","text_ar":"حَذِرَ"},{"kind":"arabic","text_bw":"A^ano yafoEalahu","text_ar":"اَنْ يَفْعَلَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AHt*r","text_ar":"احتذر","orth_type":"arrow"},{"kind":"italic_en","text":"He was cautious of doing it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he feared doing it."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"Hu*ira Al$~aYo'u faHa*irahu","text_ar":"حُذِرَ الشَّىْءُ فَحَذِرَهُ"},{"kind":"italic_en","text":"The thing was an object of fear, and so he feared it."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"Hu*ira Almawoti","text_ar":"حُذِرَ المَوْتِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Death was an object of fear"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Almawota","text_ar":"المَوْتَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"HA*r","text_ar":"حاذر","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He feared death"},{"kind":"text","text":"]. (A.)"}],"source_refs":["S","A","Msb","TA"]},{"entry_id":"n7415","headword_ar":"حِذْرٌ","root":"H*r","body":[{"kind":"text","text":": see what next follows, in two places."}],"source_refs":[]},{"entry_id":"n7416","headword_ar":"حَذَرٌ","root":"H*r","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Hi*orN","text_ar":"حِذْرٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, Msb, K,) the former an inf. n., (S, Msb,) and the latter a simple subst., (Msb,)"},{"kind":"italic_en","text":"Caution, wariness, vigilance, guard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"care;"},{"kind":"text","text":"(S, A, K;) as also ↓"},{"kind":"arabic","text_bw":"maHo*uwrapN","text_ar":"مَحْذُورَةٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;) or"},{"kind":"italic_en","text":"a state of preparation;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"fear;"},{"kind":"text","text":"(Mgh, * TA;) and so ↓"},{"kind":"arabic","text_bw":"maHo*uwrapN","text_ar":"مَحْذُورَةٌ","orth_type":"arrow"},{"kind":"text","text":": (S, Msb, K:) [pl."},{"kind":"arabic","text_bw":"A^aHo*aArN","text_ar":"اَحْذَارٌ"},{"kind":"text","text":".] You say, ↓"},{"kind":"arabic","text_bw":"A^axa*a Hi*orahu","text_ar":"اَخَذَ حِذْرَهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He took care; was cautious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigilant."},{"kind":"text","text":"(Bd in iv. 73 and 103.) And"},{"kind":"arabic","text_bw":"huwa A@bonu A^aHo*aArK","text_ar":"هُوَ ا@بْنُ اَحْذَارٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He is a son"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"a person"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of resolution,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"determination, and caution,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wariness."},{"kind":"text","text":"(S, K.) And"},{"kind":"arabic","text_bw":"Ha*araka zayodFA","text_ar":"حَذَرَكَ زَيْدًا"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Ha*aAri","text_ar":"حَذَارِ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"A^abuw Ha*arK","text_ar":"اَبُو حَذَرٍ"},{"kind":"italic_en","text":"The male chameleon:"},{"kind":"text","text":"(K:) because of its frequent changes. (TA.)"}],"source_refs":["S","A","Msb","K"]},{"entry_id":"n7417","headword_ar":"حَذُرٌ","root":"H*r","body":[{"kind":"text","text":", and its pl.: see what next follows."}],"source_refs":[]},{"entry_id":"n7418","headword_ar":"حَذِرٌ","root":"H*r","body":[{"kind":"text","text":"(S, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"Ha*urN","text_ar":"حَذُرٌ","orth_type":"arrow"},{"kind":"text","text":"(S, A, K)"},{"kind":"italic_en","text":"Cautious; wary; vigilant; on his guard; careful;"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"in a state of preparation;"},{"kind":"text","text":"(Msb;) as also ↓"},{"kind":"arabic","text_bw":"HaA*irN","text_ar":"حَاذِرٌ","orth_type":"arrow"},{"kind":"text","text":"; (S, A, Msb;) and"},{"kind":"italic_en","text":"fearful:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"very cautious"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wary"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigilant"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"careful;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"HaA*uwrapN","text_ar":"حَاذُورَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K) and ↓"},{"kind":"arabic","text_bw":"Hi*oriyaAnN","text_ar":"حِذْرِيَانٌ","orth_type":"arrow"},{"kind":"text","text":": (A, K:) or this last signifies"},{"kind":"italic_en","text":"very fearful and cautious"},{"kind":"text","text":"&c.: (S:) pl. of the first"},{"kind":"arabic","text_bw":"Ha*iruwna","text_ar":"حَذِرُونَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ha*aAraY","text_ar":"حَذَارَى"},{"kind":"text","text":". (S, K.) Sb cites, as an ex. of"},{"kind":"arabic","text_bw":"Ha*irN","text_ar":"حَذِرٌ"},{"kind":"text","text":"used transitively,"},{"kind":"quote","text":"Ha*irN A^umuwrFA laA tuxaAfu wa A=minN\n                      \n                     \n                        maA layosa munojiyhi mina AlA^aqodaAri"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Cautious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very cautious, of things not to be feared, and trusting in that which will not save him from the decrees of destiny"},{"kind":"text","text":"]: but this is extr.; for an epithet of the measure"},{"kind":"arabic","text_bw":"faEilN","text_ar":"فَعِلٌ"},{"kind":"text","text":"is not [regularly] trans., so as to govern an objective complement. (S, TA.) In the Kur xxvi. 56, some read ↓"},{"kind":"arabic","text_bw":"HaA*iruwna","text_ar":"حَاذِرُونَ","orth_type":"arrow"},{"kind":"text","text":"; and some,"},{"kind":"arabic","text_bw":"Ha*iruwna","text_ar":"حَذِرُونَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Ha*uruwna","text_ar":"حَذُرُونَ","orth_type":"arrow"},{"kind":"text","text":":"},{"kind":"arabic","text_bw":"HA*rwn","text_ar":"حاذرون"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"in a state of preparation;"},{"kind":"text","text":"(Zj, S;) or"},{"kind":"italic_en","text":"fully equipped with arms:"},{"kind":"text","text":"(Sh:) and"},{"kind":"arabic","text_bw":"H*rwn","text_ar":"حذرون"},{"kind":"text","text":","},{"kind":"italic_en","text":"in a state of fear;"},{"kind":"text","text":"(S;) or"},{"kind":"italic_en","text":"in a state of preparation;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"in a state of preparation with the accoutrements of war;"},{"kind":"text","text":"(Ibn-Mes'ood;) or"},{"kind":"italic_en","text":"cautious,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vigilant."},{"kind":"text","text":"(Zj.)"}],"source_refs":["S","A","Msb","K","Sh"]}]}}