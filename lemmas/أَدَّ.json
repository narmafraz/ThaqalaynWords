role":"present_1ms","form":"أَؤُدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَؤُدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَئِدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَئِدّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":61,"cross_references":{"qac":{"found":true,"lemma_key":"أَدَّ","root":"أدد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n416","n417"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"outrageous, heinous","examples":[{"text":"لَقَدْ جِئْتُمْ شَيْئًا إِدًّا","english":"You have certainly made an outrageous claim"}]}]},"etymology":null,"ipa":["/ʔidd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n416","headword_ar":"اَدُّ","root":"Ad","body":[{"kind":"text","text":"(S, M, K) and ↓"},{"kind":"arabic","text_bw":"A_id~u","text_ar":"اـِدُّ","orth_type":"arrow"},{"kind":"text","text":"(T, K) and ↓"},{"kind":"arabic","text_bw":"A=d~u","text_ar":"ا=دُّ","orth_type":"arrow"},{"kind":"text","text":"(K)"},{"kind":"italic_en","text":"Strength; power; force:"},{"kind":"text","text":"(S, M, K:)"},{"kind":"italic_en","text":"superior power or force or influence; mastery; conquest; predominance."},{"kind":"text","text":"(M, K, TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"A_id~u","text_ar":"اـِدُّ"},{"kind":"text","text":", in two places. ―         -b3-  Also, the first, The"},{"kind":"italic_en","text":"sound of treading."},{"kind":"text","text":"(T.)"}],"source_refs":["S","M","K","T"]},{"entry_id":"n417","headword_ar":"اـِدُّ","root":"Ad","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^ad~u","text_ar":"اَدُّ"},{"kind":"text","text":". ―         -b2-  Also, and ↓"},{"kind":"arabic","text_bw":"A_id~apN","text_ar":"اـِدَّةٌ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"A wonder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wonderful thing:"},{"kind":"text","text":"(M, L, K:)"},{"kind":"italic_en","text":"a very evil, abominable, severe, thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair:"},{"kind":"text","text":"(S, M, A, L, K:)"},{"kind":"italic_en","text":"a calamity;"},{"kind":"text","text":"(S, A, L, K,) or thus the former word signifies; (M;) as also ↓"},{"kind":"arabic","text_bw":"A^ad~u","text_ar":"اَدُّ","orth_type":"arrow"},{"kind":"text","text":", (as in the copies of the K,) or ↓"},{"kind":"arabic","text_bw":"A=d~u","text_ar":"ا=دُّ","orth_type":"arrow"},{"kind":"text","text":", [originally"},{"kind":"arabic","text_bw":"A=didF","text_ar":"ا=دِدً"},{"kind":"text","text":"] of the measure"},{"kind":"arabic","text_bw":"faAEilo","text_ar":"فَاعِلْ"},{"kind":"text","text":": (so in the S and L:) pl. (of"},{"kind":"arabic","text_bw":"A_id~u","text_ar":"اـِدُّ"},{"kind":"text","text":"M, TA)"},{"kind":"arabic","text_bw":"A_idAdu","text_ar":"اـِدادُ"},{"kind":"text","text":"(K, TA,) or"},{"kind":"arabic","text_bw":"A^adaAdu","text_ar":"اَدَادُ"},{"kind":"text","text":"(T, CK, [but this, if correct, is a quasi-pl. n.,]) or"},{"kind":"arabic","text_bw":"A=daAdu","text_ar":"ا=دَادُ"},{"kind":"text","text":"(M,) and (of"},{"kind":"arabic","text_bw":"A_id~apN","text_ar":"اـِدَّةٌ"},{"kind":"text","text":", S, M)"},{"kind":"arabic","text_bw":"A_idadN","text_ar":"اـِدَدٌ"},{"kind":"text","text":"(T, S, M, K.) You say also"},{"kind":"arabic","text_bw":"A^amoroA_id~u","text_ar":"اَمْرْاـِدُّ"},{"kind":"text","text":"[meaning as above], using"},{"kind":"arabic","text_bw":"A_id~u","text_ar":"اـِدُّ"},{"kind":"text","text":"as an epithet, accord. to Lh. (M.) And ↓"},{"kind":"arabic","text_bw":"daAhiyapN A_id~apN","text_ar":"دَاهِيَةٌ اـِدَّةٌ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A very evil, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severe, calamity"},{"kind":"text","text":"]. (A.) Hence the saying in the Kur [xix. 91],"},{"kind":"arabic","text_bw":"laqado jiy^otumo $ayoy^FA A_id~FA","text_ar":"لَقَدْ جِيْتُمْ شَيْيًا اـِدًّا"},{"kind":"italic_en","text":"Verily ye have done a very evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abominable, thing:"},{"kind":"text","text":"(S, M: *) or, accord. to one reading, ↓"},{"kind":"arabic","text_bw":"A^ad~uA","text_ar":"اَدُّا","orth_type":"arrow"},{"kind":"text","text":"; both meaning"},{"kind":"italic_en","text":"great,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grievous:"},{"kind":"text","text":"and some of the Arabs say, ↓"},{"kind":"arabic","text_bw":"bi$aYo'K A=d~K","text_ar":"بِشَىْءٍ ا=دٍّ","orth_type":"arrow"},{"kind":"text","text":", which means the same. (T, TA.)"}],"source_refs":["M","L","K","S","A","TA"]}]}}