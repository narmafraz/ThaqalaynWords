{"lemma":"مَظْهَرِ","slug":"مَظْهَرِ","root":"ظ.ه.ر","root_slug":"ظ-ه-ر","root_link":"/words/roots/ظ-ه-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n27735","n27736","n27737","n27738","n27739"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B8%D9%92%D9%87%D9%8E%D8%B1%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"appearance, look","examples":[{"text":"اَلْمَظَاهِرُ خَدَّاعَةٌ","english":"Appearances are deceptive."}]},{"pos":"noun","gloss":"aspect, feature"},{"pos":"noun","gloss":"manifestations, expressions","tags":["in-plural"]}]},"etymology":null,"ipa":["/maðˤ.har/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n27735","headword_ar":"مَظْهَرٌ","root":"Zhr","body":[{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"maSoEadN","text_ar":"مَصْعَدٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"A place of ascent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a place to which one ascends"},{"kind":"text","text":"]; (O, K; in some copies of the latter of which, both words are erroneously written with damm to the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"; TA;) and"},{"kind":"arabic","text_bw":"darajapN","text_ar":"دَرَجَةٌ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"a degree, grade, rank, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"station,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an exalted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a high, grade,"},{"kind":"text","text":"&c.]: (O:) used by En-Nábighah ElJaadee as meaning"},{"kind":"italic_en","text":"Paradise."},{"kind":"text","text":"(O, TA.)"}],"source_refs":["O"]},{"entry_id":"n27736","head