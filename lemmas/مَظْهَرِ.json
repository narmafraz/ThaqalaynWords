xt","text":", without teshdeed; and this is the proper form: (S) or both mean,"},{"kind":"italic_en","text":"in the time of the"},{"kind":"arabic","text_bw":"Zuhor","text_ar":"ظُهْر"},{"kind":"text","text":". (O.)"}],"source_refs":["S"]},{"entry_id":"n27738","headword_ar":"مُظَهَّرٌ","root":"Zhr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"ZahiyrN","text_ar":"ظَهِيرٌ"},{"kind":"text","text":", near the end of the paragraph."}],"source_refs":[]},{"entry_id":"n27739","headword_ar":"مُظَهِّرٌ","root":"Zhr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"muZohirN","text_ar":"مُظْهِرٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}