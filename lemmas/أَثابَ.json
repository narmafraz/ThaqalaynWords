ent_1mp","form":"نُثِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُثِيب","in_corpus":true,"count":6,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":75,"cross_references":{"qac":{"found":true,"lemma_key":"أَثابَ","root":"ثوب","pos":"V","occurrence_count":3},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n4798"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AB%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to reward."}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4798","headword_ar":"اثاب","root":"vwb","body":[{"kind":"text","text":": see 1, in two places. ―         -b2-  It may also mean (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a valley, or a well,)"},{"kind":"italic_en","text":"had a return of water after a stoppage thereof."},{"kind":"text","text":"(Ham p. 598.)       -A2-"},{"kind":"arabic","text_bw":"AvAb A@ll~`hu jisomahu","text_ar":"اثاب ا@للّٰهُ جِسْمَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"God restored him to fatness, after leanness;"},{"kind":"text","text":"(A;)"},{"kind":"italic_en","text":"restored his body to a good state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A_in~a Eamuwda Ald~iyni laA","text_ar":"اـِنَّ عَمُودَ الدِّينِ لَا"},{"kind":"arabic","text_bw":"yuvaAbu biAln~isaA='a A_ino maAla","text_ar":"يُثَابُ بِالنِّسَا=ءَ اـِنْ مَالَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Verily the column of the religion cannot be set upright again by women, if it incline:"},{"kind":"text","text":"said by Umm-Selemeh to 'Áïsheh, when the latter desired to go forth to El-Basrah. (T, L.) ―         -b3-"},{"kind":"arabic","text_bw":"AvAbhu A@ll~`hu","text_ar":"اثابهُ ا@للّٰهُ"},{"kind":"text","text":", (T, S, * M, A, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_ivaAbapN","text_ar":"اـِثَابَةٌ"},{"kind":"text","text":"; (Mgh;) and"},{"kind":"arabic","text_bw":"A^avowabahu","text_ar":"اَثْوَبَهُ"},{"kind":"text","text":"[dev. from rule]; (M, K;) and ↓"},{"kind":"arabic","text_bw":"vw~bhu","text_ar":"ثوّبهُ","orth_type":"arrow"},{"kind":"text","text":", (T, A,) inf. n."},{"kind":"arabic","text_bw":"tvowiybN","text_ar":"تثْوِيبٌ"},{"kind":"text","text":"; (T, Mgh;)"},{"kind":"italic_en","text":"God recompensed, compensated, requited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rewarded, him:"},{"kind":"text","text":"(T, S, * M, A, Mgh, * Msb, K:) said in relation to good and to evil. (T.) And"},{"kind":"arabic","text_bw":"AvAbhu","text_ar":"اثابهُ"},{"kind":"text","text":", (Lh, M,) and"},{"kind":"arabic","text_bw":"A^avowabahu","text_ar":"اَثْوَبَهُ"},{"kind":"text","text":", (T,)"},{"kind":"arabic","text_bw":"mavuwbapF HasanapF","text_ar":"مَثُوبَةً حَسَنَةً"},{"kind":"text","text":", (Lh, T, M,) and"},{"kind":"arabic","text_bw":"mavowabapF","text_ar":"مَثْوَبَةً"},{"kind":"text","text":", (Lh, M,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"gave him a good recompense, compensation,"},{"kind":"text","text":"&c. (M.) And"},{"kind":"arabic","text_bw":"mavuwbatahu","text_ar":"مَثُوبَتَهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"vw~bhu","text_ar":"ثوّبهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He gave him his recompense,"},{"kind":"text","text":"&c. (M, K.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A^aviybuwA A^axaAkumo","text_ar":"اَثِيبُوا اَخَاكُمْ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"Recompense ye your brother for his good deed."},{"kind":"text","text":"(TA.) And in the Kur [lxxxiii. last verse],"},{"kind":"arabic","text_bw":"halo","text_ar":"هَلْ"},{"kind":"arabic","text_bw":"Alkuf~aAru maA kaAnuwA yafoEaluwna","text_ar":"الكُفَّارُ مَا كَانُوا يَفْعَلُونَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"vuw~iba","text_ar":"ثُوِّبَ","orth_type":"arrow"},{"kind":"italic_en","text":"Have the unbelievers been recompensed for what they did?"},{"kind":"text","text":"(T, S, M.) And one says also,"},{"kind":"arabic","text_bw":"AvAbhu mino hibatihi","text_ar":"اثابهُ مِنْ هِبَتِهِ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He gave him a substitute, something instead"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in exchange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a compensation, for his gift."},{"kind":"text","text":"(Mgh, * and TA in art."},{"kind":"arabic","text_bw":"jnb","text_ar":"جنب"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"mino ka*aA","text_ar":"مِنْ كَذَا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"vw~bhu","text_ar":"ثوّبهُ","orth_type":"arrow"},{"kind":"text","text":", (M,) inf. n."},{"kind":"arabic","text_bw":"tavowiybN","text_ar":"تَثْوِيبٌ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He gave him a substitute,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"for such a thing."},{"kind":"text","text":"(M, K. *) ―         -b4-"},{"kind":"arabic","text_bw":"AvAb Alv~awoba","text_ar":"اثاب الثَّوْبَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"A_ivaAbapN","text_ar":"اـِثَابَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He sewed the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, the second time:"},{"kind":"text","text":"when one sews it the first time, [in a slight manner,] you say of him"},{"kind":"arabic","text_bw":"mal~ahu","text_ar":"مَلَّهُ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"$al~ahu","text_ar":"شَلَّهُ"},{"kind":"text","text":", i. e. “ he sewed it in the manner termed ‘ running ’ ”]. (T.) ―         -b5-"},{"kind":"arabic","text_bw":"AvAb AlHawoDa","text_ar":"اثاب الحَوْضَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He filled the watering-trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"nearly filled it."},{"kind":"text","text":"(K.)"}],"source_refs":["T","A","Lh","M","God","K","TA"]}]},"classical_definitions":null}