{"lemma":"فان","slug":"فان","root":"NTWS","root_slug":"NTWS","root_link":"/words/roots/NTWS","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"فان","root":"فني","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["adj"],"has_etymology":true,"sense_count":10},"lanes":{"found":true,"entry_ids":["n34699","n35010"],"search_url":"https://lanelexicon.com/?s=%D9%81%D8%A7%D9%86"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"evanescent, transitory, transient, ephemeral","examples":[{"text":"تَجَاوَز هَذِهِ الفَانِيَة","english":"to leave this world, to pass away"},{"text":"كُلُّ مَنْ عَلَيْهَا فَانٍ","english":"Every being on earth is bound to perish."}]},{"pos":"adj","gloss":"vain"},{"pos":"adj","gloss":"very old, decrepit, geriatric"},{"pos":"adj","gloss":"exhausted"},{"pos":"adj","gloss":"perishable, bound to vanish, perishing"},{"pos":"adj","gloss":"impermanent, destructible"},{"pos":"adj","gloss":"dead, dying, subject to dying"},{"pos":"adj","gloss":"lifeless, departed, deceased"},{"pos":"adj","gloss":"defunct"},{"pos":"adj","gloss":"asleep"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of the verb فَنِيَ (faniya, “to perish”)."},"ipa":["/faː.nin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34699","headword_ar":"فَانٍ","root":"fnY","body":[{"kind":"text","text":"part. n. of"},{"kind":"arabic","text_bw":"faniYa","text_ar":"فَنِىَ"},{"kind":"text","text":"[i. e. signifying"},{"kind":"italic_en","text":"Passing away and coming to an end;"},{"kind":"text","text":"&c.]. (T.) ―         -b2-  And (tropical:)  An old man"},{"kind":"italic_en","text":"extremely aged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"old and infirm;"},{"kind":"text","text":"(M, * Msb, K, * TA;) so called because of his nearness to passing away, or perishing: (Msb:) or an old man"},{"ki