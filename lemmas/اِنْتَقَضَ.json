_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%AA%D9%8E%D9%82%D9%8E%D8%B6%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be broken, to be demolished","tags":["intransitive"]}]},"etymology":{"source":"wiktextract","text":"Morphologically from the root ن ق ض (n q ḍ)."},"ipa":["/in.ta.qa.dˤa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40427","headword_ar":"انتقض","root":"nqD","body":[{"kind":"text","text":"quasi-pass. of"},{"kind":"arabic","text_bw":"naqaDahu","text_ar":"نَقَضَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It became undone; taken,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pulled to pieces: untwisted: unravelled: unwoven: dissolved; broken:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered uncompact, unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"infirm, after it had been made compact, sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firm"},{"kind":"text","text":"]: (M, A, Mgh, Msb, TA:) as also ↓"},{"kind":"arabic","text_bw":"tnq~D","text_ar":"تنقّض","orth_type":"arrow"},{"kind":"text","text":", (A,) and ↓"},{"kind":"arabic","text_bw":"tnAqD","text_ar":"تناقض","orth_type":"arrow"},{"kind":"text","text":": (M, TA:) [respecting the first and last, see a remark upon a mistake in the K, following the first sentence in 1: but"},{"kind":"arabic","text_bw":"AntqD","text_ar":"انتقض"},{"kind":"text","text":"afterwards occurs in the K used properly in the phrase"},{"kind":"arabic","text_bw":"maA A@notaqaDa mina AlbunoyaAni","text_ar":"مَا ا@نْتَقَضَ مِنَ البُنْيَانِ"},{"kind":"text","text":":]"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Ainotakva","text_ar":"اِنْتَكثَ"},{"kind":"text","text":": (S:) said of a building, or structure: and of a rope, or cord: (A, Mgh, Msb, TA:) [and of silk, or flax: and of cloth: (see 1:)] and (tropical:)  of a compact, contract, or covenant: (TA:) [and of a sale: (see 1:)] and (tropical:)  of other things. (A, TA.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"AntqDt AlqaroHapu","text_ar":"انتقضت القَرْحَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The wound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ulcer, became recrudescent."},{"kind":"text","text":"(IF, * A.) And"},{"kind":"arabic","text_bw":"AntqD","text_ar":"انتقض"},{"kind":"arabic","text_bw":"AljuroHu baEoda buroy^ihi","text_ar":"الجُرْحُ بَعْدَ بُرْيِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wound became in a bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corrupt, state, after its healing."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AntqD AlA^amoru baEoda A@lotiy^aAmihi","text_ar":"انتقض الاَمْرُ بَعْدَ ا@لْتِيَامِهِ"},{"kind":"text","text":"(A, * Msb, TA) (tropical:)"},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became in a bad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound state, after it had been in a sound state."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AntqD A^amoru Alv~agori baEoda sad~ihi","text_ar":"انتقض اَمْرُ الثَّغْرِ بَعْدَ سَدِّهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The state of the place through which the invasion of an enemy was feared became unfortified, after its being fortified,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"closed"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"AntqDt AlT~ahaArapu","text_ar":"انتقضت الطَّهَارَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The state of purity became annulled."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"AntqD","text_ar":"انتقض"},{"kind":"arabic","text_bw":"Ealayohi Al$~iEoru","text_ar":"عَلَيْهِ الشِّعْرُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The poetry became undone, annulled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contradicted, by a reply against him:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"yanoquDu Ealayohi","text_ar":"يَنْقُضُ عَلَيْهِ"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["M","A","Mgh","Msb","TA","S"]}]},"classical_definitions":null}