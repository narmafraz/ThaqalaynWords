role":"present_1mp","form":"نَلْتَفّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":61,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n43340"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%84%D9%92%D8%AA%D9%8E%D9%81%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to squirm, to wind oneself, to abound","examples":[{"text":"اِلْتَفَّ ٱلنَّاسُ حَوْلَ قَائِدِهِمْ","english":"People gathered around their leader."}]},{"pos":"verb","gloss":"to wind, to bend, to inflect, to wrap"}]},"etymology":null,"ipa":["/il.taf.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43340","headword_ar":"اِلْتَفَّ","root":"lf","body":[{"kind":"italic_en","text":"It"},{"kind":"text","text":"(herbage)"},{"kind":"italic_en","text":"tangled; became confused, and caught,"},{"kind":"text","text":"one part to another: (Msb:) or"},{"kind":"italic_en","text":"became luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a collection of trees)"},{"kind":"italic_en","text":"became luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant, and close together:"},{"kind":"text","text":"(AHn:) [or"},{"kind":"italic_en","text":"thickly intermixed:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"became collected together, and dense;"},{"kind":"text","text":"(TA:) best rendered"},{"kind":"italic_en","text":"tangled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"luxuriant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abundant and dense."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"Ailotaf~a","text_ar":"اِلْتَفَّ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"talofaf~a","text_ar":"تَلْفَفَّ","orth_type":"arrow"},{"kind":"italic_en","text":"He wrapped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enwrapped, himself"},{"kind":"text","text":"in, or with, a garment; (KL, PS;)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Ai$otamala","text_ar":"اِشْتَمَلَ"},{"kind":"text","text":". (Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"Ailotaf~a wajohu AlgulaAmi","text_ar":"اِلْتَفَّ وَجْهُ الغُلَامِ"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"Ait~aSalato","text_ar":"اِتَّصَلَتْ"},{"kind":"arabic","text_bw":"liHoyatuhu","text_ar":"لِحْيَتُهُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The face of the young man became continuous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"uninterrupted, in its beard"},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Ailotaf~a","text_ar":"اِلْتَفَّ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(an affair)"},{"kind":"italic_en","text":"became complicated."}],"source_refs":["Msb","AHn","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A7%D9%84%D8%AA%D9%81/","headword_ar":"التُّفُّ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=30053#e020ad","body_html":"<span>التُّفُّ، بالضم: وسَخُ الظُّفُرِ، أو إتْباعٌ لأُفٍّ، ج: تِفَفَةٌ، كعِنَبَةٍ.</span><br><span>والتُفَّةُ، كقُفَّةٍ: المرأةُ المَحْقُورةُ، ودُوَيبَّةٌ كجِرْوِ الكَلْبِ، أو كالفَأْرَةِ، فارِسِيَّتُه: سِياهْ كُوشْ.</span><br><span>و\"اسْتَغْنَتِ التُفَّةُ عن الرُّفَّةِ\"، ويُخَفَّفان: يُضْرَبُ للَّئيمِ إذا شَبعَ.</span><br><span>والتُفَفَةُ، كهُمَزَةٍ: دُودةٌ صغيرةٌ تُؤَثِّرُ في الجِلْدِ.</span><br><span>والتُّفاتِفُ: شِبْهُ المُقَطَّعاتِ من الشِّعْرِ.</span><br><span>والتَّفْتافُ: مَن يَلْقُطُ أحاديثَ النساءِ،</span><br><span>كالمُتَفْتِفِ، ج: تَفْتافونَ وتَفاتِفُ.</span><br><span>وأتَيْتُكَ بِتِفَّانِهِ، وعلى تِفَّانِهِ، بالكسرِ: حِينِه وأوانِه.</span><br><span>وتَفَّفَهُ تَتْفيفاً: قال له: تُفّاً.</span>"}]}}