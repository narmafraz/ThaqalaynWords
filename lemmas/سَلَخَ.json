unt":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسْلُخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْلُخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْلَخا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسْلَخانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسْلُخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْلُخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْلَخُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسْلَخُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسْلُخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَسْلَخْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَسْلُخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْلُخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"سَلَخْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَلَخْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسْلَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسْلَخ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":2,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n20391"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D9%84%D9%8E%D8%AE%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to strip"},{"pos":"verb","gloss":"to flay"},{"pos":"noun","gloss":"verbal noun of سَلَخَ (salaḵa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"the act of stripping"},{"pos":"noun","gloss":"hide, skin"}]},"etymology":{"source":"wiktextract","text":"From the root س ل خ (s l ḵ). Compare Hebrew שָׁלַח (šālaḥ) and Classical Syriac ܫܠܚ (šlaḥ)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20391","headword_ar":"سَلَخَ","root":"slx","body":[{"kind":"text","text":", (S, A, Msb, K, &c.,) aor."},{"kind":"text","text":", (S, K, [as in the Kur xxxvi. 37,]) or"},{"kind":"text","text":", (Msb, [but this I find in no other lexicon,]) and"},{"kind":"text","text":", (S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"saloxN","text_ar":"سَلْخٌ"},{"kind":"text","text":", (S, Msb,)"},{"kind":"italic_en","text":"He stripped off"},{"kind":"text","text":"(S, K) the hide, or skin, of a sheep or goat: (S:) or"},{"kind":"italic_en","text":"he skinned a sheep or goat."},{"kind":"text","text":"(A, Msb.) And"},{"kind":"arabic","text_bw":"sulixa","text_ar":"سُلِخَ"},{"kind":"arabic","text_bw":"jiloduhaA","text_ar":"جِلْدُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Its skin was stripped off"},{"kind":"text","text":"]. (A.) One does not say of a camel,"},{"kind":"arabic","text_bw":"salaxotu jilodahu","text_ar":"سَلَخْتُ جِلْدَهُ"},{"kind":"text","text":"; but"},{"kind":"arabic","text_bw":"ka$aTotuhu","text_ar":"كَشَطْتُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"najawotuhu","text_ar":"نَجَوْتُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^anojayotuhu","text_ar":"اَنْجَيْتُهُ"},{"kind":"text","text":". (Msb.) ―         -b2-  [Hence,] (assumed tropical:)"},{"kind":"italic_en","text":"He pulled off"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stripped off"},{"kind":"text","text":"[a garment]. (K, TA.) You say of a woman,"},{"kind":"arabic","text_bw":"salaxato","text_ar":"سَلَخَتْ"},{"kind":"arabic","text_bw":"diroEahaA","text_ar":"دِرْعَهَا"},{"kind":"text","text":", (S, TA,) and"},{"kind":"arabic","text_bw":"salaxato EanohaA diroEahaA","text_ar":"سَلَخَتْ عَنْهَا دِرْعَهَا"},{"kind":"text","text":", (A, TA,) (tropical:)"},{"kind":"italic_en","text":"She pulled off her shift; stripped it off."},{"kind":"text","text":"(S, TA.) ―         -b3-  And [hence,]"},{"kind":"arabic","text_bw":"salaxa Al$~ahora","text_ar":"سَلَخَ الشَّهْرَ"},{"kind":"text","text":", (S, A, Msb,) or"},{"kind":"arabic","text_bw":"$ahorahu","text_ar":"شَهْرَهُ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":"(L, Msb) and"},{"kind":"text","text":", (L,) inf. n."},{"kind":"arabic","text_bw":"saloxN","text_ar":"سَلْخٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"suluwxN","text_ar":"سُلُوخٌ"},{"kind":"text","text":", (L, Msb,) (tropical:)"},{"kind":"italic_en","text":"He passed the month,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his month;"},{"kind":"text","text":"(S, K, TA;)"},{"kind":"italic_en","text":"came to the end of it."},{"kind":"text","text":"(S, A, Msb, K.)"},{"kind":"arabic","text_bw":"salaxonaA Al$~ahora","text_ar":"سَلَخْنَا الشَّهْرَ"},{"kind":"text","text":"means (tropical:)"},{"kind":"italic_en","text":"We passed forth from the month; having pulled off from ourselves every night one thirtieth part until the nights were complete, when we pulled off from ourselves all of it:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aholalonaA hilaAla $ahori","text_ar":"اَهْلَلْنَا هِلَالَ شَهْرِ"},{"kind":"arabic","text_bw":"ka*aA","text_ar":"كَذَا"},{"kind":"text","text":"means “ We entered upon [the period of the new moon of] such a month; clothing ourselves with it and increasing the clothing of ourselves therewith until the passing of the half of it: ” then we pull off from ourselves [by degrees] the whole of it: hence a verse cited voce"},{"kind":"arabic","text_bw":"jumaAdaY","text_ar":"جُمَادَى"},{"kind":"text","text":". (T, TA.) And one says of God,"},{"kind":"arabic","text_bw":"salaxa Aln~ahaAra mina All~ayoli","text_ar":"سَلَخَ النَّهَارَ مِنَ اللَّيْلِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He drew forth gently the day from the night:"},{"kind":"text","text":"(K, TA:) or"},{"kind":"italic_en","text":"He separated the day from the night."},{"kind":"text","text":"(Jel in xxxvi. 37.) ―         -b4-  See also 7, in three places. ―         -b5-"},{"kind":"arabic","text_bw":"salaxa AlHar~u jiloda AlA_inosaAni","text_ar":"سَلَخَ الحَرُّ جِلْدَ الاـِنْسَانِ"},{"kind":"text","text":"and [in an intensive sense] ↓"},{"kind":"arabic","text_bw":"sl~xhu","text_ar":"سلّخهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The heat made the skin of the man to peel off;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excoriated the man"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"salaxa Aljarabu jilodahu","text_ar":"سَلَخَ الجَرَبُ جِلْدَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"The mange,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scab, excoriated him,"},{"kind":"text","text":"i. e., a camel]: (A, TA:) [and so"},{"kind":"arabic","text_bw":"salaxahu","text_ar":"سَلَخَهُ"},{"kind":"text","text":"without the mention of the skin:] see"},{"kind":"arabic","text_bw":"saAlixN","text_ar":"سَالِخٌ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"sulixa AlZ~aliymu","text_ar":"سُلِخَ الظَّلِيمُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The ostrich had a disease in his feathers"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"such as caused many of them to fall off"},{"kind":"text","text":"]. (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"salaxa Aln~abaAtu","text_ar":"سَلَخَ النَّبَاتُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The plant shed its foliage, and then became altogether green again:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"saAlixN","text_ar":"سَالِخٌ"},{"kind":"text","text":":) or]"},{"kind":"italic_en","text":"the plant became green again after having dried up."},{"kind":"text","text":"(M, K.) ―         -b7-"},{"kind":"arabic","text_bw":"fasalaxuwA mawoDiEa AlmaA='i kamaA yusolaxu AlA_ihaAbu faxaraja AlmaA='u","text_ar":"فَسَلَخُوا مَوْضِعَ المَا=ءِ كَمَا يُسْلَخُ الاـِهَابُ فَخَرَجَ المَا=ءُ"},{"kind":"text","text":", in a trad. respecting Solomon and the"},{"kind":"arabic","text_bw":"hudohud","text_ar":"هُدْهُد"},{"kind":"text","text":"[or hoopoe, i. e. (assumed tropical:)"},{"kind":"italic_en","text":"And they stripped off the surface of the place of the water, like as the hide is stripped off, and thereupon the water came forth"},{"kind":"text","text":"], means that they dug until they found the water. (TA.) ―         -b8-"},{"kind":"arabic","text_bw":"sulixa mino baToni A^um~ihi","text_ar":"سُلِخَ مِنْ بَطْنِ اُمِّهِ"},{"kind":"text","text":", said of a child, means (assumed tropical:)"},{"kind":"italic_en","text":"He was drawn out from the belly of his mother."},{"kind":"text","text":"(TA.) ―         -b9-"},{"kind":"arabic","text_bw":"saloxu Al$iEori","text_ar":"سَلْخُ الشِعْرِ"},{"kind":"text","text":"is (assumed tropical:)"},{"kind":"italic_en","text":"The substituting throughout the poetry, for the original words, other words synonymous therewith:"},{"kind":"text","text":"what falls short of this is termed"},{"kind":"arabic","text_bw":"masoxN","text_ar":"مَسْخٌ"},{"kind":"text","text":". (TA. [See Har p. 263.])"}],"source_refs":["S","Msb","K","TA","A","L"]}]},"classical_definitions":null}