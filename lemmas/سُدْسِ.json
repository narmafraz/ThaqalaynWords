{"lemma":"سُدْسِ","slug":"سُدْسِ","root":"سدس","root_slug":"سدس","root_link":"/words/roots/سدس","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"سُدْسِ","root":"سدس","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n19325","n19326","n19327","n19328"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8F%D8%AF%D9%92%D8%B3%D9%90"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"one sixth"},{"pos":"verb","gloss":"to make six, six-angled, six-cornered, six-ribbed, hexagonal, to multiply by six, to repeat six times"}]},"etymology":{"source":"wiktextract","text":"Compare سَادِس (sādis, “sixth”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19325","headword_ar":"سُدْسٌ","root":"sds","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sudusN","text_ar":"سُدُسٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n19326","headword_ar":"سِدْسٌ","root":"sds","body":[{"kind":"text","text":"is the original form of"},{"kind":"arabic","text_bw":"sit~N","text_ar":"سِتٌّ"},{"kind":"text","text":", (M, K,) fem. of"},{"kind":"arabic","text_bw":"sit~apN","text_ar":"سِتَّةٌ"},{"kind":"text","text":", which is originally"},{"kind":"arabic","text_bw":"sidosapN","text_ar":"سِدْسَةٌ"},{"kind":"text","text":", (M,) [meaning"},{"kind":"italic_en","text":"Six;"},{"kind":"text","text":"for] the dim. [of"},{"kind":"arabic","text_bw":"sit~N","text_ar":"سِتٌّ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"sudayosN","text_ar":"سُدَيْسٌ","orth_type":"arrow"},{"kind":"text","text":", and that] of"},{"kind":"arabic","text_bw":"sit~apN","text_ar":"سِتَّةٌ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"sudayosapN","text_ar":"سُدَيْسَةٌ","orth_type":"arrow"},{"kind":"text","text":"; and the pl. is"},{"kind":"arabic","text_bw":"A^asodaAsN","text_ar":"اَسْدَاسٌ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"st","text_ar":"ست"},{"kind":"text","text":", q. v.) ―         -b2-  Also [The"},{"kind":"italic_en","text":"drinking of camels on the sixth day, counting the day of the next preceding drinking as the first;"},{"kind":"text","text":"as will be seen from what here follows;] the"},{"kind":"italic_en","text":"period of the drinking of camels"},{"kind":"text","text":"["},{"kind":"italic_en","text":"next"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"after that called"},{"kind":"arabic","text_bw":"ximosN","text_ar":"خِمْسٌ"},{"kind":"text","text":": or"},{"kind":"italic_en","text":"after six days and five nights:"},{"kind":"text","text":"(M, TA:) or"},{"kind":"italic_en","text":"their being kept from the water five days, and coming to it on the sixth:"},{"kind":"text","text":"(S:) but Sgh says that this is a mistake, and that the correct meaning of the term is,"},{"kind":"italic_en","text":"their being kept from the water four days, and coming to it on the fifth;"},{"kind":"text","text":"and so it is explained in the [A and] K: (TA:) or"},{"kind":"italic_en","text":"their drinking one day, then being kept from the water four days, then coming to it on the fifth day;"},{"kind":"text","text":"so [by the application of the term"},{"kind":"arabic","text_bw":"sidosN","text_ar":"سِدْسٌ"},{"kind":"text","text":"] they include in their reckoning the first day in which the camels drink: (Aboo-Sahl, TA:) or"},{"kind":"italic_en","text":"their remaining in the place of pasture four days"},{"kind":"text","text":"["},{"kind":"italic_en","text":"after drinking"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"then coming to the water on the fifth:"},{"kind":"text","text":"(TA:) pl."},{"kind":"arabic","text_bw":"A^asodaAsN","text_ar":"اَسْدَاسٌ"},{"kind":"text","text":". (M, Sgh, TA.) You say,"},{"kind":"arabic","text_bw":"waradato A_iboluhu sidosFA","text_ar":"وَرَدَتْ اـِبْلُهُ سِدْسًا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His camels came to the water on the sixth day, counting the day of the next preceding drinking as the first"},{"kind":"text","text":"]. (S, A, K.) [Hence the saying,]"},{"kind":"arabic","text_bw":"Daraba A^axomaAsFA","text_ar":"ضَرَبَ اَخْمَاسًا"},{"kind":"arabic","text_bw":"liA^asodaAsK","text_ar":"لِاَسْدَاسٍ"},{"kind":"text","text":"[which see expl. voce"},{"kind":"arabic","text_bw":"ximosN","text_ar":"خِمْسٌ"},{"kind":"text","text":"]. (A.) ―         -b3-  Also The"},{"kind":"italic_en","text":"sixth young one,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"offspring."},{"kind":"text","text":"(A in art."},{"kind":"arabic","text_bw":"vlv","text_ar":"ثلث"},{"kind":"text","text":".)"}],"source_refs":["M","K","TA","S"]},{"entry_id":"n19327","headword_ar":"سَدَسٌ","root":"sds","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"sadiysN","text_ar":"سَدِيسٌ"},{"kind":"text","text":", in three places: ―         -b2-  and, as an epithet applied to a calf, see"},{"kind":"arabic","text_bw":"EaDobN","text_ar":"عَضْبٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n19328","headword_ar":"سُدُسٌ","root":"sds","body":[{"kind":"text","text":"(S, M, A, Msb, K) and ↓"},{"kind":"arabic","text_bw":"sudosN","text_ar":"سُدْسٌ","orth_type":"arrow"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"A sixth part;"},{"kind":"text","text":"(S, M, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"sadiysN","text_ar":"سَدِيسٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) a form used by some, like as one says"},{"kind":"arabic","text_bw":"Eu$orN","text_ar":"عُشْرٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ea$iyrN","text_ar":"عَشِيرٌ"},{"kind":"text","text":": (S:) pl."},{"kind":"arabic","text_bw":"A^asodaAsN","text_ar":"اَسْدَاسٌ"},{"kind":"text","text":". (M, Msb, TA.) ―         -b2-  [Hence, app., the saying,"},{"kind":"arabic","text_bw":"Daraba","text_ar":"ضَرَبَ"},{"kind":"arabic","text_bw":"A^axomaAsahu fiY A^asodaAsihi","text_ar":"اَخْمَاسَهُ فِى اَسْدَاسِهِ"},{"kind":"text","text":", which see expl. voce"},{"kind":"arabic","text_bw":"xumusN","text_ar":"خُمُسٌ"},{"kind":"text","text":".]"}],"source_refs":["S","M","A","Msb","K"]}]},"classical_definitions":null}