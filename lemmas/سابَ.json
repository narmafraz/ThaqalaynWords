m":"تَسِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسِب","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسِيب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسِب","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسِيب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سِبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سِبْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَسِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adj","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n18557","n21378"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to flow, to run"},{"pos":"verb","gloss":"to leave, to abandon"},{"pos":"verb","gloss":"to roam, to wander, to ramble"},{"pos":"verb","gloss":"to exchange insults with","tags":["transitive"]},{"pos":"adj","gloss":"active participle of سَبَّ (sabba)","tags":["active","form-of","participle"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18557","headword_ar":"سَاْبٌ","root":"sA^b","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"misoA^abN","text_ar":"مِسْاَبٌ","orth_type":"arrow"},{"kind":"italic_en","text":"A"},{"kind":"text","text":"["},{"kind":"italic_en","text":"skin such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"ziq~","text_ar":"زِقّ"},{"kind":"text","text":", (S, M, K,)"},{"kind":"italic_en","text":"for wine:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"such as is large:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"a"},{"kind":"arabic","text_bw":"ziq~","text_ar":"زِقّ"},{"kind":"italic_en","text":"of any kind:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"a receptacle of skin,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leather, in which the"},{"kind":"arabic","text_bw":"ziq~","text_ar":"زِقّ"},{"kind":"italic_en","text":"is put:"},{"kind":"text","text":"(M, K:) the former also occurs in a verse in which it is read without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":", for the sake of the rhyme: (M:) and its pl. is"},{"kind":"arabic","text_bw":"suw^uwbN","text_ar":"سُوُوبٌ"},{"kind":"text","text":": (S, M, K:) and (so in the S, but in the K “ or, ”) the latter ("},{"kind":"arabic","text_bw":"msA^b","text_ar":"مساب"},{"kind":"text","text":") signifies"},{"kind":"italic_en","text":"a skin for honey;"},{"kind":"text","text":"(S, K;) and in a verse of Aboo-Dhu-eyb, (S, M, K,) cited voce"},{"kind":"arabic","text_bw":"xaAfapN","text_ar":"خَافَةٌ"},{"kind":"text","text":", (S, M,) it is written"},{"kind":"arabic","text_bw":"misaAbN","text_ar":"مِسَابٌ"},{"kind":"text","text":", (S, M, K,) without"},{"kind":"arabic","text_bw":"'","text_ar":"ء"},{"kind":"text","text":": (S, M:) and it signifies also"},{"kind":"italic_en","text":"a skin in which clarified butter is put."},{"kind":"text","text":"(S and L voce"},{"kind":"arabic","text_bw":"misaAdN","text_ar":"مِسَادٌ"},{"kind":"text","text":".)"}],"source_refs":["S","M","K"]},{"entry_id":"n21378","headword_ar":"سَابَ","root":"syb","body":[{"kind":"text","text":", (S, M, A, Mgh, Msb, K,) aor."},{"kind":"arabic","text_bw":"yasiybu","text_ar":"يَسِيبُ"},{"kind":"text","text":", (S, A,) inf. n."},{"kind":"arabic","text_bw":"sayobN","text_ar":"سَيْبٌ"},{"kind":"text","text":", (S, M, A, K,)"},{"kind":"italic_en","text":"It ran;"},{"kind":"text","text":"(S, M, A, * Mgh, Msb, K;) said of water: (S, M, A, Msb:) and ↓"},{"kind":"arabic","text_bw":"AnsAb","text_ar":"انساب","orth_type":"arrow"},{"kind":"text","text":", likewise said of water,"},{"kind":"italic_en","text":"it ran of itself."},{"kind":"text","text":"(Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"sAbt AlHay~apu","text_ar":"سابت الحَيَّةُ"},{"kind":"text","text":", (M,) aor. as above; (M, A;) and ↓"},{"kind":"arabic","text_bw":"AnsAbt","text_ar":"انسابت","orth_type":"arrow"},{"kind":"text","text":"; (S, M, A, Msb;) (tropical:)"},{"kind":"italic_en","text":"The serpent ran:"},{"kind":"text","text":"(S, A, * Msb:) or"},{"kind":"italic_en","text":"went along"},{"kind":"text","text":"(M, TA)"},{"kind":"italic_en","text":"in a uniform,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continuous, course,"},{"kind":"text","text":"(M,) or"},{"kind":"italic_en","text":"quickly."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"sAb","text_ar":"ساب"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AnsAb","text_ar":"انساب","orth_type":"arrow"},{"kind":"text","text":"both signify (assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, walked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went along, quickly:"},{"kind":"text","text":"(K, TA:) [or] so the former verb. (M.) It is said in a trad., respecting a man who drank from the mouth of a skin,"},{"kind":"arabic","text_bw":"fiY baTonihi Hay~apN","text_ar":"فِى بَطْنِهِ حَيَّةٌ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AinosaAbato","text_ar":"اِنْسَابَتْ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A serpent entered and ran into his belly"},{"kind":"text","text":"with the running of the water: wherefore it was forbidden to drink from the mouth of a skin. (TA.) El-Hareeree, in [his first Makámeh, entitled] the San'áneeyeh, [p. 20,] uses the phrase,"},{"kind":"arabic","text_bw":"fiyhaA EalaY garaArapK","text_ar":"فِيهَا عَلَى غَرَارَةٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnsAb","text_ar":"انساب","orth_type":"arrow"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He entered into it as the serpent enters into its lurking place."},{"kind":"text","text":"(TA.) And you say of a viper,"},{"kind":"arabic","text_bw":"sAb","text_ar":"ساب"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AnsAb","text_ar":"انساب","orth_type":"arrow"},{"kind":"text","text":", meaning (tropical:)"},{"kind":"italic_en","text":"It came forth from its lurkingplace."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"naHowakumo","text_ar":"نَحْوَكُمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AnsAb","text_ar":"انساب","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He returned towards you."},{"kind":"text","text":"(S.) ―         -b3-"},{"kind":"arabic","text_bw":"sAb","text_ar":"ساب"},{"kind":"text","text":", (Mgh, Msb,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"sayabaAnN","text_ar":"سَيَبَانٌ"},{"kind":"text","text":", said of a horse and the like, (assumed tropical:)"},{"kind":"italic_en","text":"He went away at random:"},{"kind":"text","text":"(Msb:) or (assumed tropical:)"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"[app. a horse or the like]"},{"kind":"italic_en","text":"went any,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"every, way:"},{"kind":"text","text":"(Mgh:) or"},{"kind":"arabic","text_bw":"sAbt Ald~aAb~apu","text_ar":"سابت الدَّابَّةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The beast was left alone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by itself, to pasture, without a pastor."},{"kind":"text","text":"(S, * A, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"sAb fiY manoTiqihi","text_ar":"ساب فِى مَنْطِقِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He took every way"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"roved at large"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in his speech:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he dilated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was profuse, without consideration, in his speech."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"sAb fiY AlkalaAmi","text_ar":"ساب فِى الكَلَامِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He entered into talk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse, with loquacity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"irrationality."},{"kind":"text","text":"(TA.) It is said in a trad.,"},{"kind":"arabic","text_bw":"A_in~a AlHiylapa biAlmanoTiqi A^abolagu mina Als~uyuwbi fiY","text_ar":"اـِنَّ الحِيلَةَ بِالمَنْطِقِ اَبْلَغُ مِنَ السُّيُوبِ فِى"},{"kind":"arabic","text_bw":"Alkalimi","text_ar":"الكَلِمِ"},{"kind":"text","text":", meaning (tropical:)  ["},{"kind":"italic_en","text":"Verily art,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"skill, in speech is more eloquent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effective,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"than what is loose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unrestrained,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"rambling,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in words;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"elegance of speech, with paucity,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"is more eloquent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"effective,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"than profusion."},{"kind":"text","text":"(L, TA. ["},{"kind":"arabic","text_bw":"Als~uyuwb","text_ar":"السُّيُوب"},{"kind":"text","text":"is here an inf. n.])"}],"source_refs":["S","M","A","Mgh","Msb","K","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D8%A8/","headword_ar":"ساب","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=124975#860f5f","body_html":"ساب<br>عن العبرية بمعنى شيخ ورجل متقدم في السن. يستخدم للذكور."}]}}