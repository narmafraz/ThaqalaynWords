{"lemma":"أَعْذَرَ","slug":"أَعْذَرَ","root":"ع.ذ.ر","root_slug":"ع-ذ-ر","root_link":"/words/roots/ع-ذ-ر","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَعْذَرْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَعْذَرْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَعْذَرْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَعْذَرْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَعْذَرْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَعْذَرَ","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَعْذَرَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَعْذَرا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَعْذَرَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَعْذَرُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَعْذَرْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُعْذَر","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُعْذِر","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُعْذَرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعْذَرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعْذِرِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُعْذِرِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُعْذَرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعْذَرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعْذِرا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُعْذَرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعْذَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعْذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُعْذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُعْذَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُعْذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُعْذَر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُعْذِر","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُعْذَر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُعْذِر","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُعْذَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْذَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُعْذَرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْذَرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْذِرا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْذِرانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُعْذَرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعْذَرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعْذِرُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُعْذِرُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُعْذَرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُعْذِرْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُعْذَر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعْذَر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعْذِر","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُعْذِر","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَعْذَرْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَعْذَرْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":26,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n28430"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B9%D9%92%D8%B0%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to accept (someone's) excuse","examples":[{"text":"أَعْذَرَ اللهُ إلَى اِمْرِئٍ أَخَّرَ أَجَلَهُ حَتَّى بَلَغَ سِتِّينَ سَنَةً","english":"Allah excuses and grants forgiveness to a person until he attains the age of sixty years."}]}]},"etymology":null,"ipa":["/ʔaʕ.ða.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n28430","headword_ar":"اعذر","root":"E*r","body":[{"kind":"text","text":": see 1, in five places from the commencement. ―         -b2-  Also"},{"kind":"italic_en","text":"He had an excuse;"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, excusable;"},{"kind":"text","text":"] (S, O, K;) and so ↓"},{"kind":"arabic","text_bw":"AEt*r","text_ar":"اعتذر","orth_type":"arrow"},{"kind":"text","text":". (S, O, K.) It is said in a prov.,"},{"kind":"arabic","text_bw":"A^aEo*ara","text_ar":"اَعْذَرَ"},{"kind":"arabic","text_bw":"mano A^ano*ara","text_ar":"مَنْ اَنْذَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has an excuse,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is excusable, who warns"},{"kind":"text","text":"]. (S. [See also below: and see art."},{"kind":"arabic","text_bw":"n*r","text_ar":"نذر"},{"kind":"text","text":". It is held by some in the present day that the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"AE*r","text_ar":"اعذر"},{"kind":"text","text":", in this phrase, has a privative effect, and that the meaning is,"},{"kind":"italic_en","text":"He deprives of excuse who warns:"},{"kind":"text","text":"but for this I have not found any authority.]) And Lebeed says, (S, O, TA,) addressing his two daughters, (O, TA,) and telling them to wail and weep a year for him after his death, (TA,)"},{"kind":"quote","text":"A_ilaY AlHawoli vum~a A@somu Als~alaAmi EalayokumaA\n                      \n                     ↓ \n      wamano yaboki HawolFA kaAmilFA faqado A@Eota*aro"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Until"},{"kind":"text","text":"the end of"},{"kind":"italic_en","text":"the year: then the name of peace be an you both: for such as weeps a whole"},{"kind":"page_break","n":1984},{"kind":"italic_en","text":"year has become excusable"},{"kind":"text","text":"]. (S, O.) You say also,"},{"kind":"arabic","text_bw":"A^aEo*arotu Einoda Als~uloTaAni","text_ar":"اَعْذَرْتُ عِنْدَ السُّلْطَانِ"},{"kind":"italic_en","text":"I got excuse of the Sultán"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"ruling power"},{"kind":"text","text":"]. (TA.) ―         -b3-  And"},{"kind":"italic_en","text":"He manifested an excuse:"},{"kind":"text","text":"(K, TA:) in which sense,"},{"kind":"arabic","text_bw":"Eu*orN","text_ar":"عُذْرٌ"},{"kind":"text","text":"is said to be its inf. n., as well as"},{"kind":"arabic","text_bw":"A_iEo*aArN","text_ar":"اـِعْذَارٌ"},{"kind":"text","text":"; but the former is correctly a simple subst. (TA.) And"},{"kind":"italic_en","text":"He pleaded that by which he should be excused."},{"kind":"text","text":"(TA.) [See also 8.] ―         -b4-"},{"kind":"italic_en","text":"He did that by which he should be excused."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"italic_en","text":"He did that in which he should be excused:"},{"kind":"text","text":"hence the saying of Zuheyr, *"},{"kind":"arabic","text_bw":"satamonaEukumo A^aromaAHunaA A^awo sanuEo*iru","text_ar":"سَتَمْنَعُكُمْ اَرْمَاحُنَا اَوْ سَنُعْذِرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Our spears shall prevent you,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall defend you,"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"we will do that in which we shall be excused."},{"kind":"text","text":"(S, O: but in the latter,"},{"kind":"arabic","text_bw":"watamonaEukumo","text_ar":"وَتَمْنَعُكُمْ"},{"kind":"text","text":".) ―         -b6-  And"},{"kind":"italic_en","text":"He exceeded the usual bounds,"},{"kind":"text","text":"(A, Mgh, O,) or"},{"kind":"italic_en","text":"went to the utmost point,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"in excuse,"},{"kind":"text","text":"(A, Mgh, O, TA,) i. e."},{"kind":"italic_en","text":"in being excused."},{"kind":"text","text":"(A.) So in the saying"},{"kind":"arabic","text_bw":"A^aEo*ara mano A^ano*ara","text_ar":"اَعْذَرَ مَنْ اَنْذَرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He exceeds the usual bounds in rendering himself excused who warns"},{"kind":"text","text":"]. (A, Mgh, O. [See also above, third sentence.]) And it is said in a trad.,"},{"kind":"arabic","text_bw":"laqado A^aEo*ara A@ll~`hu A_ilaY mano","text_ar":"لَقَدْ اَعْذَرَ ا@للّٰهُ اـِلَى مَنْ"},{"kind":"arabic","text_bw":"balaga mina AlEumuri sit~iyna sanapF","text_ar":"بَلَغَ مِنَ العُمُرِ سِتِّينَ سَنَةً"},{"kind":"text","text":"[app. meaning"},{"kind":"italic_en","text":"Verily God hath freed himself from the imputation of injustice to an extraordinary degree,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to the utmost point, to him who hath attained sixty years of age:"},{"kind":"text","text":"] i. e. He hath left him no plea for excuse [for his sins], since He hath granted him respite for all this length of time and he hath not excused himself. (TA. [As"},{"kind":"arabic","text_bw":"AE*r","text_ar":"اعذر"},{"kind":"text","text":"is here followed by"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":", I do not think that this explanation is meant to show that the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"has a privative effect, and that the verb signifies “ he deprived of excuse. ”]) ―         -b7-  [Hence,]"},{"kind":"italic_en","text":"He exerted himself, acted vigorously, took extraordinary pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exceeded the usual bounds,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to render himself excused,"},{"kind":"text","text":"] (S, O, Msb, K, TA,)"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"italic_en","text":"in the affair;"},{"kind":"text","text":"(S, O, Msb;) as, for instance, in eating, in relation to which it occurs in a trad., wherein one is enjoined to do so when eating with others, [app. meaning with guests and with a host,] such having been the custom of the Prophet; for, when he ate with others, he was the last in eating. (TA.) [Hence also,]"},{"kind":"arabic","text_bw":"A^aEo*arotu A_ilayoka","text_ar":"اَعْذَرْتُ اـِلَيْكَ"},{"kind":"italic_en","text":"I took extraordinary pains,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exceeded the usual bounds, in exhortation and precept to thee."},{"kind":"text","text":"(TA.) ―         -b8-  And"},{"kind":"italic_en","text":"He was remiss, wanting, deficient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defective; he fell short,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did less than was incumbent on him; feigning"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yuriY","text_ar":"يُرِى"},{"kind":"text","text":"[in the CK, erroneously,"},{"kind":"arabic","text_bw":"yurY`","text_ar":"يُرىٰ"},{"kind":"text","text":"]) that"},{"kind":"italic_en","text":"he was doing the contrary:"},{"kind":"text","text":"as though the verb bore two contrary significations. (K.) [See also 2.]       -A2-  Also"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"A^anoSafa","text_ar":"اَنْصَفَ"},{"kind":"text","text":": (O, K:) you say,"},{"kind":"arabic","text_bw":"A^aEo*ironiY mino h`*aA","text_ar":"اَعْذِرْنِى مِنْ هٰذَا"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"A^anoSifoniY minohu","text_ar":"اَنْصِفْنِى مِنْهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Give thou me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obtain for me, my right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, from this"},{"kind":"text","text":"person]: and hence the saying of the Prophet to Aboo-Bekr, respecting 'Áïsheh,"},{"kind":"arabic","text_bw":"A^aEo*ironiY minohaA A_ino","text_ar":"اَعْذِرْنِى مِنْهَا اـِنْ"},{"kind":"arabic","text_bw":"A^ad~abotuhaA","text_ar":"اَدَّبْتُهَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Obtain thou for me my right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, from her if I discipline her,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chastise her"},{"kind":"text","text":"]: (O:) or this means"},{"kind":"italic_en","text":"undertake thou to excuse me"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for my conduct to her"},{"kind":"text","text":"&c.]: (TA:) and the Arabs say,"},{"kind":"arabic","text_bw":"A^aEo*ara fulaAnN mino nafosihi","text_ar":"اَعْذَرَ فُلَانٌ مِنْ نَفْسِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one became bound to render an excuse for his conduct to himself;"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"Ea*iyrN","text_ar":"عَذِيرٌ"},{"kind":"text","text":";)] meaning"},{"kind":"italic_en","text":"such a one was destroyed by himself."},{"kind":"text","text":"(Yoo, TA.)       -A3-  As signifying"},{"kind":"italic_en","text":"He circumcised:"},{"kind":"text","text":"see 1, latter half. It is said in a trad.,"},{"kind":"arabic","text_bw":"kun~aA A_iEo*aAra yawomK waAHidK","text_ar":"كُنَّا اـِعْذَارَ يَوْمٍ وَاحِدٍ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"We were circumcised in one day."},{"kind":"text","text":"(TA.) ―         -b2-  Also (tropical:)"},{"kind":"italic_en","text":"He made a feast on the occasion of a circumcision,"},{"kind":"text","text":"(AZ, Msb, K, TA,)"},{"kind":"arabic","text_bw":"liloqawomi","text_ar":"لِلْقَوْمِ"},{"kind":"italic_en","text":"for the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party:"},{"kind":"text","text":"(K:)"},{"kind":"italic_en","text":"he prepared such a feast:"},{"kind":"text","text":"from the same verb signifying “ he circumcised. ” (TA.) [See also 2: and see"},{"kind":"arabic","text_bw":"A_iEo*aArN","text_ar":"اـِعْذَارٌ"},{"kind":"text","text":"as a subst.]       -A4-"},{"kind":"arabic","text_bw":"AE*r Alfarasa","text_ar":"اعذر الفَرَسَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"All~ijaAma","text_ar":"اللِّجَامَ"},{"kind":"text","text":": see 1, latter half, in five places. ―         -b2-  And"},{"kind":"arabic","text_bw":"A^aEo*iro Ean~iY baEiyraka","text_ar":"اَعْذِرْ عَنِّى بَعِيرَكَ"},{"kind":"text","text":": see 2, near the end. ―         -b3-"},{"kind":"arabic","text_bw":"A^aEo*iro EalaY naSiybika","text_ar":"اَعْذِرْ عَلَى نَصِيبِكَ"},{"kind":"italic_en","text":"Make a mark upon thy share."},{"kind":"text","text":"(O.) ―         -b4-"},{"kind":"arabic","text_bw":"AE*r fiY Zahorihi","text_ar":"اعذر فِى ظَهْرِهِ"},{"kind":"italic_en","text":"He beat him"},{"kind":"text","text":"(O, K) with whips (O)"},{"kind":"italic_en","text":"so as to make a mark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks, upon his back."},{"kind":"text","text":"(O, K.) And"},{"kind":"arabic","text_bw":"Darabahu Hat~aY A^aEo*ara matonahu","text_ar":"ضَرَبَهُ حَتَّى اَعْذَرَ مَتْنَهُ"},{"kind":"italic_en","text":"He beat him so that he made the beating heavy upon his back and obtained from him relief from his anger."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"Duriba faA^uEo*ira","text_ar":"ضُرِبَ فَاُعْذِرَ"},{"kind":"text","text":", (S, O, K,) in the Tahdheed of IKtt"},{"kind":"arabic","text_bw":"faA^aEo*ara","text_ar":"فَاَعْذَرَ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was beaten so that he was at the point of death."},{"kind":"text","text":"(S, O, K, TA.) And"},{"kind":"arabic","text_bw":"A^uEo*ira minohu","text_ar":"اُعْذِرَ مِنْهُ"},{"kind":"italic_en","text":"He had wounds inflicted upon him so that fear was excited for him in consequence thereof."},{"kind":"text","text":"(O.) And"},{"kind":"arabic","text_bw":"A^aEo*ara bihi","text_ar":"اَعْذَرَ بِهِ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, left a scar upon him."},{"kind":"text","text":"(O, * TA.) ―         -b5-  And"},{"kind":"arabic","text_bw":"A^aEo*arotu Ald~aAra","text_ar":"اَعْذَرْتُ الدَّارَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fiY Ald~aAri","text_ar":"فِى الدَّارِ"},{"kind":"italic_en","text":"I made a mark,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marks, in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon, the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling."},{"kind":"text","text":"(O.)       -A5-"},{"kind":"arabic","text_bw":"AE*r","text_ar":"اعذر"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, TA)"},{"kind":"italic_en","text":"voided his ordure."},{"kind":"text","text":"(O, K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"AE*rt Ald~aAru","text_ar":"اعذرت الدَّارُ"},{"kind":"italic_en","text":"The house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dwelling, had in it much"},{"kind":"arabic","text_bw":"Ea*irap","text_ar":"عَذِرَة"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"human ordure"},{"kind":"text","text":"]. (S, O.)"}],"source_refs":["S","O","TA","K","A","Mgh","Msb","AZ"]}]},"classical_definitions":null}