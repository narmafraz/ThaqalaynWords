رِيقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرِيقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرُقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رِقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رِقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رُقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رُقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَرُوق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرُوق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرِيق","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرِيق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":6,"cross_references":{"qac":{"found":true,"lemma_key":"راق","root":"رقي","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","verb"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n16421","n17106","n17286"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to glisten, to glint"},{"pos":"verb","gloss":"to be pure, to be clean"},{"pos":"verb","gloss":"to be eminent, to exceed"},{"pos":"verb","gloss":"to delight, to be liked, to appeal (to لِـ someone)","examples":[{"text":"أَعِي تَمَامًا أَنَّ هٰذَا الْكَلَامَ لَنْ يَرُوقَ لِلْكَثِيرِينَ.","english":"I am aware this is not the word many will like."}]},{"pos":"adj","gloss":"active participle of رَقَى (raqā)","tags":["active","form-of","participle"],"examples":[{"text":"وَقِيلَ مَنْ رَاقٍ","english":"and it will be said, “Is there any healer?\""}]}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of رَقَى (raqā)."},"ipa":["/raː.qa/","/raː.qin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16421","headword_ar":"رَاقٍ","root":"rqY","body":[{"kind":"text","text":": see 1, last sentence but one. The saying in the Kur [lxxv. 27],"},{"kind":"arabic","text_bw":"mano raAqK","text_ar":"مَنْ رَاقٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Who is one that charms?"},{"kind":"text","text":"] means that there is no charmer that shall charm him and protect him: or, accord. to I'Ab, the meaning is,"},{"kind":"italic_en","text":"who is he that ascendeth"},{"kind":"text","text":"with his soul? shall the angels of mercy [ascend with it] or the angels of punishment? (TA.) In the saying of a rájiz,"},{"kind":"quote","text":"laqado Ealimota waAlA^ajal~i AlbaAqiY\n                      \n                     \n                        A^ano lano yarud~a Alqadara Alr~awaAqiY"},{"kind":"text","text":"[the meaning may be,"},{"kind":"italic_en","text":"Assuredly thou knowest, by the Most Majestic, the Everlasting, that the female charmers will not repel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"avert, that which is decreed;"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"that the potent charmers will not"},{"kind":"text","text":"&c.: for] the pl. may be that of ↓"},{"kind":"arabic","text_bw":"raAqiyapN","text_ar":"رَاقِيَةٌ","orth_type":"arrow"},{"kind":"text","text":"as an epithet applied to a woman, or of this"},{"kind":"page_break","n":1141},{"kind":"text","text":"same word as an intensive epithet applied to a man. (S.)"}],"source_refs":[]},{"entry_id":"n17106","headword_ar":"رَاقَ","root":"rwq","body":[{"kind":"text","text":", (S, Msb, TA,) aor."},{"kind":"arabic","text_bw":"yaruwqu","text_ar":"يَرُوقُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"rawoqN","text_ar":"رَوْقٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(wine, or beverage, S, or water, Msb, TA, and a thing, TA)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, clear."},{"kind":"text","text":"(S, Msb, TA.)       -A2-"},{"kind":"arabic","text_bw":"rAq Ealayohi","text_ar":"راق عَلَيْهِ"},{"kind":"text","text":", (JK, K,) aor. as above, (JK,) and so the inf. n., (K,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, exceeded him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"(JK:) [and]"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, exceeded him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, in excellence."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"rAq fiY yadiY ka*aA","text_ar":"راق فِى يَدِى كَذَا"},{"kind":"italic_en","text":"Such a thing was redundant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"remained over and above, in my hand;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"raAEa","text_ar":"رَاعَ"},{"kind":"text","text":"; syn."},{"kind":"arabic","text_bw":"zaAda","text_ar":"زَادَ"},{"kind":"text","text":". (L in art."},{"kind":"arabic","text_bw":"ryE","text_ar":"ريع"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"rAq fulaAnN EalaY A^aholihi","text_ar":"راق فُلَانٌ عَلَى اَهْلِهِ"},{"kind":"italic_en","text":"Such a one was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, above,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"superior to, his family; surpassed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excelled, his family."},{"kind":"text","text":"(JK.)       -A3-"},{"kind":"arabic","text_bw":"raAqaniY","text_ar":"رَاقَنِى"},{"kind":"text","text":", (JK, S, MA,) or"},{"kind":"arabic","text_bw":"rAq liY","text_ar":"راق لِى"},{"kind":"text","text":", (so in my copy of the Msb, [perhaps a mistranscription, for only the former is commonly known,]) and"},{"kind":"arabic","text_bw":"rAqahu","text_ar":"راقَهُ"},{"kind":"text","text":", (K,) aor. as above, (JK, S,) and so the inf. n., (JK, K,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"induced in me,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"him, wonder,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"admiration, and pleasure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joy; excited my,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his, admiration and approval; pleased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rejoiced, me,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"him."},{"kind":"text","text":"(JK, S, MA, Msb, K.)       -A4-"},{"kind":"arabic","text_bw":"rawiqa","text_ar":"رَوِقَ"},{"kind":"text","text":", [aor."},{"kind":"arabic","text_bw":"yarowaqu","text_ar":"يَرْوَقُ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"rawaqN","text_ar":"رَوَقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, long-toothed:"},{"kind":"text","text":"(MA:) [or"},{"kind":"italic_en","text":"he had long teeth, the upper of which projected over the lower:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his upper central incisors were longer than the lower, and projecting over them:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"rawaqN","text_ar":"رَوَقٌ"},{"kind":"text","text":", below.]"}],"source_refs":["S","Msb","TA","JK","K","MA"]},{"entry_id":"n17286","headword_ar":"رَاقَ","root":"ryq","body":[{"kind":"text","text":", (JK, S, K,) aor."},{"kind":"arabic","text_bw":"yariyqu","text_ar":"يَرِيقُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"rayoqN","text_ar":"رَيْقٌ"},{"kind":"text","text":", (JK, S,) said of the"},{"kind":"arabic","text_bw":"saraAb","text_ar":"سَرَاب"},{"kind":"text","text":"[or mirage],"},{"kind":"italic_en","text":"It was agitated, and moved to and fro,"},{"kind":"text","text":"(JK, K,) or"},{"kind":"italic_en","text":"it shone,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistened,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"above the ground;"},{"kind":"text","text":"(JK, S, K;) and ↓"},{"kind":"arabic","text_bw":"try~q","text_ar":"تريّق","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (S, O, K.) [And in the former sense,"},{"kind":"arabic","text_bw":"rAq","text_ar":"راق"},{"kind":"text","text":"may be said of water; for the inf. n.]"},{"kind":"arabic","text_bw":"rayoqN","text_ar":"رَيْقٌ"},{"kind":"text","text":"signifies also The"},{"kind":"italic_en","text":"going to and fro"},{"kind":"text","text":"(Lth, JK, K) of water, (JK,) or of"},{"kind":"page_break","n":1203},{"kind":"text","text":"shallow water and the like, (Lth, K,)"},{"kind":"italic_en","text":"upon the surface of the earth."},{"kind":"text","text":"(Lth, JK, K.) ―         -b2-  Also, (Ks, JK, Msb, K,) aor. and inf. n. as above, (Ks, Msb,) said of water, (Ks, JK, Msb, K,) and of blood, (Msb,)"},{"kind":"italic_en","text":"It poured out,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forth."},{"kind":"text","text":"(Ks, Msb, K.) ―         -b3-"},{"kind":"arabic","text_bw":"huwa yariyqu binafosihi","text_ar":"هُوَ يَرِيقُ بِنَفْسِهِ"},{"kind":"text","text":", (JK, S, K,) inf. n."},{"kind":"arabic","text_bw":"ruyuwqN","text_ar":"رُيُوقٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"rayoqN","text_ar":"رَيْقٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He gives up his spirit;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gives away his life;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"yajuwdu bihaA","text_ar":"يَجُودُ بِهَا"},{"kind":"text","text":"; (JK, S, K;)"},{"kind":"italic_en","text":"at death:"},{"kind":"text","text":"(S, K:) mentioned by Ks. (TA.)"}],"source_refs":["JK","S","K","Lth","Ks","Msb","TA"]}]},"classical_definitions":null}