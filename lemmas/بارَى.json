,"headword_ar":"بَارِيٌ","root":"brA^","body":[{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"baAriy^N mino maraDihi","text_ar":"بَارِيٌ مِنْ مَرَضِهِ"},{"kind":"text","text":", (Lh, S, M,) ["},{"kind":"italic_en","text":"Recovering from his disease, sickness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"malady:"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"convalescent;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"becoming sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"healthy, at the close of his disease, but being yet weak;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"recovering, but not completely, his health and strength:"},{"kind":"text","text":"[see 1:] (M, K:) as also ↓"},{"kind":"arabic","text_bw":"bariy^o'N","text_ar":"بَرِيْءٌ","orth_type":"arrow"},{"kind":"text","text":": (Lh, M, K:) but whether the latter be properly used in this sense is disputed; while the former is said to be the act. part. n. of 1 in all its senses: (TA:) pl."},{"kind":"arabic","text_bw":"biraA='N","text_ar":"بِرَا=ءٌ"},{"kind":"text","text":", (M, K,) like as"},{"kind":"arabic","text_bw":"SiHaAHN","text_ar":"صِحَاحٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"SaHiyHN","text_ar":"صَحِيحٌ"},{"kind":"text","text":", accord. to Lh, so that he holds it to be pl. of"},{"kind":"arabic","text_bw":"bariYo'N","text_ar":"بَرِىْءٌ"},{"kind":"text","text":"; or it may be pl. of"},{"kind":"arabic","text_bw":"baAriy^N","text_ar":"بَارِيٌ"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"jiyaAEN","text_ar":"جِيَاعٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"jaAy^iEN","text_ar":"جَايِعٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"SiHaAbN","text_ar":"صِحَابٌ"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"SaAHibN","text_ar":"صَاحِبٌ"},{"kind":"text","text":". (M.) ↓"},{"kind":"arabic","text_bw":"bariYo'N","text_ar":"بَرِىْءٌ","orth_type":"arrow"},{"kind":"text","text":"is sometimes written and pronounced"},{"kind":"arabic","text_bw":"bariY~N","text_ar":"بَرِىٌّ"},{"kind":"text","text":"[in all its senses]. (Kz.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"bariyo'N","text_ar":"بَرِيْءٌ"},{"kind":"text","text":".       -A2-"},{"kind":"arabic","text_bw":"AlbaAriy^u","text_ar":"البَارِيُ"},{"kind":"text","text":", applied to God,"},{"kind":"italic_en","text":"The Creator;"},{"kind":"text","text":"(T, S, Msb;)"},{"kind":"italic_en","text":"He who hath created the things that are created, not after any similitude,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"model;"},{"kind":"text","text":"(Nh;) or"},{"kind":"italic_en","text":"He who hath created those things free from any incongruity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faultiness,"},{"kind":"text","text":"(Mgh, and Bd in ii. 51,)"},{"kind":"italic_en","text":"and distinguished, one from another, by various forms and outward appearances:"},{"kind":"text","text":"(Bd:) or"},{"kind":"italic_en","text":"the Former,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Fashioner;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"AlmuSaw~iru","text_ar":"المُصَوِّرُ"},{"kind":"text","text":"[q. v.]. (M.)"}],"source_refs":["K","Lh","S","M","TA","Bd"]},{"entry_id":"n2439","headword_ar":"بَارِىٌّ","root":"brY","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baAriy~apN","text_ar":"بَارِيَّةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baAriyaA='u","text_ar":"بَارِيَا=ءُ"},{"kind":"text","text":": see in art."},{"kind":"arabic","text_bw":"bwr","text_ar":"بور"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n3524","headword_ar":"بَارِىٌّ","root":"bwr","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"buwriY~N","text_ar":"بُورِىٌّ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"baAriy~apN","text_ar":"بَارِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(As, S, M, K) and ↓"},{"kind":"arabic","text_bw":"buwriy~apN","text_ar":"بُورِيَّةٌ","orth_type":"arrow"},{"kind":"text","text":"(M, K) and ↓"},{"kind":"arabic","text_bw":"baAriyaA='u","text_ar":"بَارِيَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"buwriyaA='u","text_ar":"بُورِيَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", (S, M, K,) all arabicized words, from the Persian, (M,)"},{"kind":"italic_en","text":"A woven mat,"},{"kind":"text","text":"(M, K,)"},{"kind":"italic_en","text":"made of reeds;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"what is called in Persian"},{"kind":"arabic","text_bw":"buwriyaA","text_ar":"بُورِيَا"},{"kind":"text","text":": (As, K:) or"},{"kind":"italic_en","text":"a rough"},{"kind":"arabic","text_bw":"HaSiyr","text_ar":"حَصِير"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"mat"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"brY","text_ar":"برى"},{"kind":"text","text":"[to which the words belong accord. to Fei, and the same is asserted to be the case by some others].) [The pl. is"},{"kind":"arabic","text_bw":"bawaAriY~u","text_ar":"بَوَارِىُّ"},{"kind":"text","text":".] It is said in a trad.,"},{"kind":"arabic","text_bw":"kaAna laA yaraY","text_ar":"كَانَ لَا يَرَى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baA^osFA biAlS~alaApi EalaY AlbuwriY~i","text_ar":"بَاْسًا بِالصَّلَاةِ عَلَى البُورِىِّ","orth_type":"arrow"},{"kind":"text","text":"explained as meaning"},{"kind":"italic_en","text":"He did not see any harm in praying upon a mat made of reeds."},{"kind":"text","text":"(TA.) ―         -b2-  Accord. to some, (M,)"},{"kind":"italic_en","text":"A road;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"TariyqN","text_ar":"طَرِيقٌ"},{"kind":"text","text":": (K, M:) [so, perhaps, in the trad. cited above:] arabicized. (K.)"}],"source_refs":["As","S","M","K"]}]},"classical_definitions":null}