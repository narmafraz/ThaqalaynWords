{"lemma":"خَلا","slug":"خَلا","root":"خ.ل.#","root_slug":"خ-ل-_","root_link":"/words/roots/خ-ل-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"خَلَوْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"خَلَوْتِ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"خَلَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"خَلَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"خَلَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"خَلا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"خَلَت","in_corpus":true,"count":7,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"خَلَوا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"خَلَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"خَلَوْا","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"خَلَوْنَ","in_corpus":true,"count":4,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَخْل","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَخْلُو","in_corpus":true,"count":9,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَخْلِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَخْلِي","in_corpus":true,"count":8,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَخْلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَخْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَخْلُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَخْلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْلُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْل","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَخْلُو","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْل","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَخْلُو","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْلُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْلُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْلُوْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَخْل","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْل","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"خَلَوْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"خَلَوْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَخْلُو","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَخْلُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":106,"cross_references":{"qac":{"found":true,"lemma_key":"خَلا","root":"خلو","pos":"V","occurrence_count":25},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["prep","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n11418","n11422"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D9%84%D8%A7"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be empty, to be devoid (of) (+مِنْ (min) or عَنْ (ʕan))"},{"pos":"verb","gloss":"to pass"},{"pos":"prep","gloss":"except"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11418","headword_ar":"خَلَا","root":"xlw","body":[{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaxoluw","text_ar":"يَخْلُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"xuluw~N","text_ar":"خُلُوٌّ"},{"kind":"text","text":", (S, Msb, K,) or"},{"kind":"arabic","text_bw":"xalaA='N","text_ar":"خَلَا=ءٌ"},{"kind":"text","text":", (Msb,) or both, (K,) said of a place, (K,) of a place of alighting or abode, (Msb,) and of a thing, (S, TA,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, empty, vacant, void, devoid, destitute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"had none,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"nothing, in it;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"AxlY","text_ar":"اخلى","orth_type":"arrow"},{"kind":"text","text":", (Msb, K,) and ↓"},{"kind":"arabic","text_bw":"AstxlY","text_ar":"استخلى","orth_type":"arrow"},{"kind":"text","text":", (K.) ["},{"kind":"arabic","text_bw":"xalaA AlmakaAnu mina","text_ar":"خَلَا المَكَانُ مِنَ"},{"kind":"arabic","text_bw":"Aln~aAsu wa AlmaA='i waAlkalaA^","text_ar":"النَّاسُ وَ المَا=ءِ وَالكَلَا"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The place was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, devoid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destitute, of human beings and water and herbage or pasturage; without human beings"},{"kind":"text","text":"&c.] Of a place of alighting or abode, you say,"},{"kind":"arabic","text_bw":"xalaA mino A^aholihi","text_ar":"خَلَا مِنْ اَهْلِهِ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AxlY","text_ar":"اخلى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, devoid,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destitute, of its occupants"},{"kind":"text","text":"]. (Msb.) And of a vessel,"},{"kind":"arabic","text_bw":"xalaA mim~aA fiyhi","text_ar":"خَلَا مِمَّا فِيهِ"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, empty of what was in it."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"xalawotu","text_ar":"خَلَوْتُ"},{"kind":"arabic","text_bw":"Eani AlT~aEaAmi","text_ar":"عَنِ الطَّعَامِ"},{"kind":"text","text":"(S)"},{"kind":"italic_en","text":"I became empty, in the belly, of food;"},{"kind":"text","text":"(PS;) and"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^axolayotu","text_ar":"اَخْلَيْتُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same. (S.) And"},{"kind":"arabic","text_bw":"xalaA min AlEayobi","text_ar":"خَلَا مِن العَيْبِ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"Eani","text_ar":"عَنِ"},{"kind":"arabic","text_bw":"AlA^amori","text_ar":"الاَمْرِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"minohu","text_ar":"مِنْهُ"},{"kind":"text","text":", (Kudot;,) inf. n."},{"kind":"arabic","text_bw":"xuluw~N","text_ar":"خُلُوٌّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free"},{"kind":"text","text":"(Msb, K)"},{"kind":"italic_en","text":"from fault,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"from the thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair:"},{"kind":"text","text":"(K:) and, accord. to IAar,"},{"kind":"arabic","text_bw":"xlA","text_ar":"خلا"},{"kind":"text","text":"alone signifies"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from a fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like, of which he was accused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"suspected."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xalato Eano maAniEi","text_ar":"خَلَتْ عَنْ مَانِعِ"},{"kind":"arabic","text_bw":"Aln~ikaAHi","text_ar":"النِّكَاحِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuluw~N","text_ar":"خُلُوٌّ"},{"kind":"text","text":", is said of a woman [as meaning"},{"kind":"italic_en","text":"She was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, free from any obstacle to marriage"},{"kind":"text","text":"]. (Msb.) Accord. to the K,"},{"kind":"arabic","text_bw":"xalaA makaAnuhu","text_ar":"خَلَا مَكَانُهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"His place became vacant"},{"kind":"text","text":"] means (tropical:)"},{"kind":"italic_en","text":"he died:"},{"kind":"text","text":"but accord. to IAar,"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"alone has this signification [from the same verb signifying"},{"kind":"arabic","text_bw":"maDaY","text_ar":"مَضَى"},{"kind":"text","text":". explained below]: and if you add"},{"kind":"arabic","text_bw":"mkAnh","text_ar":"مكانه"},{"kind":"text","text":", you say"},{"kind":"arabic","text_bw":"xal~aY","text_ar":"خَلَّى"},{"kind":"text","text":", with teshdeed; which see below. (TA.) You say also,"},{"kind":"arabic","text_bw":"xalaA laka Al$~aYo'u","text_ar":"خَلَا لَكَ الشَّىْءُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AxlY","text_ar":"اخلى","orth_type":"arrow"},{"kind":"text","text":", both signifying the same, (AA, S, TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"faraga","text_ar":"فَرَغَ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"The thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, vacant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied, for thee:"},{"kind":"text","text":"(see an ex. of the former verb in a saying of Tarafeh cited voce"},{"kind":"arabic","text_bw":"jaw~N","text_ar":"جَوٌّ"},{"kind":"text","text":":) and hence,"},{"kind":"italic_en","text":"the thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, exclusively for thee"},{"kind":"text","text":"]. (TA.) AA cites as an ex. the saying of Maan Ibn-Ows,"},{"kind":"quote","text":"A^aEaA*ilu halo yaA^otiY AlqabaAy^ila HaZ~uhaA\n                      \n                     \n                        lanA Almawotu waHodanaA ↓ \n      mina Almawoti A^amo A^axolaY"},{"kind":"text","text":"["},{"kind":"italic_en","text":"O censurer, does their share of death come to the tribes"},{"kind":"text","text":"in common,"},{"kind":"italic_en","text":"or is death exclusively for us alone?"},{"kind":"text","text":"]. (S, TA.) See also the paragraph, below, commencing with"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"as a word denoting exception. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AxlY","text_ar":"اخلى","orth_type":"arrow"},{"kind":"text","text":", (S, K,) said of a man, (TA,) or the same two verbs followed by"},{"kind":"arabic","text_bw":"binafosihi","text_ar":"بِنَفْسِهِ"},{"kind":"text","text":", said of a man, (Msb,) both signify the same; (S;)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"without any companion,"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"alone, by himself;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"he became"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"waqaEa","text_ar":"وَقَعَ"},{"kind":"text","text":"[q. v.])"},{"kind":"italic_en","text":"in a vacant place, in which he was not pressed against,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"straitened."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"xalaA bihi","text_ar":"خَلَا بِهِ"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"maEahu","text_ar":"مَعَهُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"xalowapN","text_ar":"خَلْوَةٌ"},{"kind":"text","text":"(S, Msb, K) and"},{"kind":"arabic","text_bw":"xalaA='N","text_ar":"خَلَا=ءٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"xalowN","text_ar":"خَلْوٌ"},{"kind":"text","text":", (K, TA,) or"},{"kind":"arabic","text_bw":"xuluw~N","text_ar":"خُلُوٌّ"},{"kind":"text","text":", (CK,) or the first of these, i. e."},{"kind":"arabic","text_bw":"xalowapN","text_ar":"خَلْوَةٌ"},{"kind":"text","text":", is a simple subst., and the second and third are the inf. ns.; (TA;) and"},{"kind":"arabic","text_bw":"bh","text_ar":"به"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AxlY","text_ar":"اخلى","orth_type":"arrow"},{"kind":"text","text":", (Lh, K,) and ↓"},{"kind":"arabic","text_bw":"AxlAhu","text_ar":"اخلاهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and"},{"kind":"arabic","text_bw":"bihi","text_ar":"بِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstxlY","text_ar":"استخلى","orth_type":"arrow"},{"kind":"text","text":"; (K; [the last omitted in the CK;])"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone with him;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in company with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he met him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had a meeting or an interview with him, in a vacant place,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a place unoccupied"},{"kind":"text","text":"["},{"kind":"italic_en","text":"by others,"},{"kind":"text","text":"i. e.,"},{"kind":"italic_en","text":"in a private place"},{"kind":"text","text":"]. (S, K.) In the saying in the Kur [ii. 13],"},{"kind":"arabic","text_bw":"waA_i*aA xalawoA A_ilaY","text_ar":"وَاـِذَا خَلَوْا اـِلَى"},{"kind":"arabic","text_bw":"$ayaATiynihimo","text_ar":"شَيَاطِينِهِمْ"},{"kind":"text","text":", it is said that"},{"kind":"arabic","text_bw":"A_ilaY","text_ar":"اـِلَى"},{"kind":"text","text":"is used in the sense of"},{"kind":"arabic","text_bw":"maEa","text_ar":"مَعَ"},{"kind":"text","text":", [so that the meaning is"},{"kind":"italic_en","text":"And when they are alone with their devils,"},{"kind":"text","text":"] as in that other saying in the Kur [iii. 45 and lxi. 14],"},{"kind":"arabic","text_bw":"mano A^anoSaAriY A_ilaY A@ll~`hu","text_ar":"مَنْ اَنْصَارِى اـِلَى ا@للّٰهُ"},{"kind":"text","text":". (S.) A man says to another man,"},{"kind":"arabic","text_bw":"Auxolu maEiY Hat~aY","text_ar":"اُخْلُ مَعِى حَتَّى"},{"kind":"arabic","text_bw":"A^ukal~imaka","text_ar":"اُكَلِّمَكَ"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"Be"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"come"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thou alone with me"},{"kind":"text","text":"["},{"kind":"italic_en","text":"that I may speak to thee"},{"kind":"text","text":"in private]. (TA.) And one says,"},{"kind":"arabic","text_bw":"xalaA bizawojatihi","text_ar":"خَلَا بِزَوْجَتِهِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xalowapN","text_ar":"خَلْوَةٌ"},{"kind":"text","text":", [but see what is said of this noun above,]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone with his wife:"},{"kind":"text","text":"but [properly speaking, according to the law,] the term"},{"kind":"arabic","text_bw":"xalowapN","text_ar":"خَلْوَةٌ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"xalowapN","text_ar":"خَلْوَةٌ"},{"kind":"arabic","text_bw":"SaHiyHapN","text_ar":"صَحِيحَةٌ"},{"kind":"text","text":", in this case,] is not used unless it be"},{"kind":"italic_en","text":"with the enjoyment of"},{"kind":"arabic","text_bw":"AlmufaAxa*ap","text_ar":"المُفَاخَذَة"},{"kind":"text","text":", [see 3 in art."},{"kind":"arabic","text_bw":"fx*","text_ar":"فخذ"},{"kind":"text","text":",] and then it has an effect upon the circumstances of the marriage [by its rendering obligatory the payment of the dowry, though consummation has not taken place]: if with consummation, the act is termed"},{"kind":"arabic","text_bw":"duxuwlN","text_ar":"دُخُولٌ"},{"kind":"text","text":". (Msb.) You say also, ↓"},{"kind":"arabic","text_bw":"A^axoli","text_ar":"اَخْلِ","orth_type":"arrow"},{"kind":"arabic","text_bw":"A^amoraka","text_ar":"اَمْرَكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"biA^amorika","text_ar":"بِاَمْرِكَ"},{"kind":"italic_en","text":"Be thou alone in thine affair, with none to take part with thee in it; confine thyself to it exclusively of other things."},{"kind":"text","text":"(TA. [See also 5.]) And"},{"kind":"arabic","text_bw":"A_ilayoka","text_ar":"اـِلَيْكَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^axoli","text_ar":"اَخْلِ","orth_type":"arrow"},{"kind":"italic_en","text":"Keep thou to thine affair, and be alone in it, with none to take part with thee therein."},{"kind":"text","text":"(JK.) And"},{"kind":"arabic","text_bw":"AlbukaA='u","text_ar":"البُكَا=ءُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstxlY","text_ar":"استخلى","orth_type":"arrow"},{"kind":"text","text":"[app. for"},{"kind":"arabic","text_bw":"biAlbukaA='i","text_ar":"بِالبُكَا=ءِ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alone in weeping, with none to participate with him in it."},{"kind":"text","text":"(TA.) [And"},{"kind":"arabic","text_bw":"xalaA liloA^amori","text_ar":"خَلَا لِلْاَمْرِ"},{"kind":"text","text":": see 5.] And"},{"kind":"arabic","text_bw":"xalaAEalaY","text_ar":"خَلَاعَلَى"},{"kind":"arabic","text_bw":"baEoDi AlT~aEaAmi","text_ar":"بَعْضِ الطَّعَامِ"},{"kind":"italic_en","text":"He restricted himself to a portion of the food."},{"kind":"text","text":"(K.) Temeem say,"},{"kind":"arabic","text_bw":"xalaA fulaAnN EalaY","text_ar":"خَلَا فُلَانٌ عَلَى"},{"kind":"arabic","text_bw":"All~abani wa All~aHomi","text_ar":"اللَّبَنِ وَ اللَّحْمِ"},{"kind":"text","text":"(JK, * TA) i. e."},{"kind":"italic_en","text":"Such a one fed upon milk and flesh-meat alone;"},{"kind":"text","text":"(JK;) or"},{"kind":"italic_en","text":"such a one ate not, nor mixed, anything with milk and flesh-meat:"},{"kind":"text","text":"and Kináneh and Keys say ↓"},{"kind":"arabic","text_bw":"A^axolaY","text_ar":"اَخْلَى","orth_type":"arrow"},{"kind":"text","text":". (Lh, JK, * TA.) [And it seems to be indicated in the T that"},{"kind":"arabic","text_bw":"xalawoA","text_ar":"خَلَوْا"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"They selected a she-camel for a"},{"kind":"arabic","text_bw":"xaliy~ap","text_ar":"خَلِيَّة"},{"kind":"text","text":", q. v.: or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"taxal~awoA bixalay~ipK","text_ar":"تَخَلَّوْا بِخَلَيِّةٍ"},{"kind":"text","text":": see 5.] ―         -b3-"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"also ssignifies"},{"kind":"italic_en","text":"He devoted himself to religious services"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exercises"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"in solitude,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seclusion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a"},{"kind":"arabic","text_bw":"xalowap","text_ar":"خَلْوَة"},{"kind":"text","text":"; or because one generally does so in solitude; or because the doing so involves abstraction from other affairs]. (TA. [See also 5; and see"},{"kind":"arabic","text_bw":"musotaxolK","text_ar":"مُسْتَخْلٍ"},{"kind":"text","text":".]) ―         -b4-  And"},{"kind":"arabic","text_bw":"xalaA bihi","text_ar":"خَلَا بِهِ"},{"kind":"page_break","n":804},{"kind":"text","text":"[sometimes] signifies (tropical:)"},{"kind":"italic_en","text":"He mocked at, scoffed at, laughed at, derided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ridiculed, him:"},{"kind":"text","text":"(Lh, S, Z, K, TA:) said by Az to be strange, and not known by him or any other authority than that of Lh: (TA:) from the saying,"},{"kind":"arabic","text_bw":"xalaA fulaAnN biEiroDi","text_ar":"خَلَا فُلَانٌ بِعِرْضِ"},{"kind":"arabic","text_bw":"fulaAnK yaEobavu bihi","text_ar":"فُلَانٍ يَعْبَثُ بِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one occupied himself alone with the honour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reputation, of such a one, making sport with it"},{"kind":"text","text":"]. (Ksh in ii. 13.) And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"xaAdaEahu","text_ar":"خَادَعَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He deceived, deluded, beguiled, circumvented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"outwitted, him;"},{"kind":"text","text":"&c.: or"},{"kind":"italic_en","text":"he strove to do so"},{"kind":"text","text":"]: (TA:) as also ↓"},{"kind":"arabic","text_bw":"xAlAhu","text_ar":"خالاهُ","orth_type":"arrow"},{"kind":"text","text":", (JK, and K in art."},{"kind":"arabic","text_bw":"xlY","text_ar":"خلى"},{"kind":"text","text":",) inf. n."},{"kind":"arabic","text_bw":"muxaAlaApN","text_ar":"مُخَالَاةٌ"},{"kind":"text","text":". (JK.) ―         -b5-  And"},{"kind":"arabic","text_bw":"xalaA Ealayohi","text_ar":"خَلَا عَلَيْهِ"},{"kind":"italic_en","text":"He relied upon him;"},{"kind":"text","text":"[as though he betook himself to him alone;] syn."},{"kind":"arabic","text_bw":"AiEotamada","text_ar":"اِعْتَمَدَ"},{"kind":"text","text":". (TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":", (JK, K,) inf. n."},{"kind":"arabic","text_bw":"xuluw~N","text_ar":"خُلُوٌّ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"xalaA='N","text_ar":"خَلَا=ءٌ"},{"kind":"text","text":", (JK,) said of a man (JK) and of a thing, (JK, TA,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, went, went away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed away."},{"kind":"text","text":"(JK, K.) Hence, (TA,)"},{"kind":"arabic","text_bw":"wa A_ino mino A^um~apKA_il~aA","text_ar":"وَ اـِنْ مِنْ اُمَّةٍاـِلَّا"},{"kind":"arabic","text_bw":"xalaA fiyhaA na*iyrN","text_ar":"خَلَا فِيهَا نَذِيرٌ"},{"kind":"text","text":", in the Kur [xxxv. 22], means ["},{"kind":"italic_en","text":"And there is not any people but a warner"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"hath gone,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"hath been sent, among them."},{"kind":"text","text":"(S, TA.) [Hence also"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"explained above as meaning"},{"kind":"italic_en","text":"He died."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"xalaA minohaA","text_ar":"خَلَا مِنْهَا"},{"kind":"text","text":"[an elliptical phrase]"},{"kind":"italic_en","text":"She became old; the greater part of her life passed."},{"kind":"text","text":"(TA from a trad.) And"},{"kind":"arabic","text_bw":"xalaAka *am~N","text_ar":"خَلَاكَ ذَمٌّ"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"xalaA Eanoka","text_ar":"خَلَا عَنْكَ"},{"kind":"arabic","text_bw":"*am~N","text_ar":"ذَمٌّ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Blame passed away from thee;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may blame pass away from thee."},{"kind":"text","text":"(Ksh and Bd in ii. 13.) You say,"},{"kind":"arabic","text_bw":"AifoEalo ka*aA wa xalaAka *am~N","text_ar":"اِفْعَلْ كَذَا وَ خَلَاكَ ذَمٌّ"},{"kind":"italic_en","text":"Do thou such a thing, and thou wilt have an excuse;"},{"kind":"text","text":"[i. e.]"},{"kind":"italic_en","text":"blame will fall from thee."},{"kind":"text","text":"(S. [See art."},{"kind":"arabic","text_bw":"*m","text_ar":"ذم"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"xalaAhu AlHuzonu","text_ar":"خَلَاهُ الحُزْنُ"},{"kind":"italic_en","text":"Grief passed away from him,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"quitted him."},{"kind":"text","text":"(Har p. 590, from the Tekmileh.) ―         -b7-"},{"kind":"arabic","text_bw":"xalaA Eani Al$~aYo'i","text_ar":"خَلَا عَنِ الشَّىْءِ"},{"kind":"text","text":": see 2.       -A2-"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"xalaY","text_ar":"خَلَى"},{"kind":"text","text":", probably belonging to art."},{"kind":"arabic","text_bw":"xlY","text_ar":"خلى"},{"kind":"text","text":", though mentioned in the present art.,]"},{"kind":"italic_en","text":"He ate what was good, sweet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasant."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","Msb","K","TA","AA","CK","Lh","Z","JK"]},{"entry_id":"n11422","headword_ar":"خَلَا","root":"xlw","body":[{"kind":"text","text":"as a word denoting exception, (S, Mughnee, K,) when it governs a gen. case, (S, Mughnee,) as when you say,"},{"kind":"arabic","text_bw":"jaAw^uwniY xalaA zayodK","text_ar":"جَاوُونِى خَلَا زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They came to me, except Zeyd"},{"kind":"text","text":"], is a particle, (S, Mughnee, K,) accord. to some of the grammarians, like"},{"kind":"arabic","text_bw":"HaA$aY","text_ar":"حَاشَى"},{"kind":"text","text":"; but accord. to some, a prefixed inf. n. (S.) ↓ It. also governs an accus. case, as a verb: (S, Mughnee:) so that you say,"},{"kind":"arabic","text_bw":"jaAw^uwniY xalaA zayodFA","text_ar":"جَاوُونِى خَلَا زَيْدًا"},{"kind":"text","text":"[meaning as above]; the agent of"},{"kind":"arabic","text_bw":"xlA","text_ar":"خلا"},{"kind":"text","text":"being implied, (S, Mughnee, *) like that of"},{"kind":"arabic","text_bw":"HaA$aY","text_ar":"حَاشَى"},{"kind":"text","text":"[used as a verb]: it is as though you said,"},{"kind":"arabic","text_bw":"xalaA mano jaA='aniY mino zayodK","text_ar":"خَلَا مَنْ جَا=ءَنِى مِنْ زَيْدٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"those who came to me were without Zeyd"},{"kind":"text","text":"]: (S:) or correctly, accord. to IB,"},{"kind":"arabic","text_bw":"xalaA baEoDuhumo zayodFA","text_ar":"خَلَا بَعْضُهُمْ زَيْدًا"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"mino zayodK","text_ar":"مِنْ زَيْدٍ"},{"kind":"text","text":", like as you say,"},{"kind":"arabic","text_bw":"xalaAka *am~N","text_ar":"خَلَاكَ ذَمٌّ"},{"kind":"text","text":", for"},{"kind":"arabic","text_bw":"xalaA","text_ar":"خَلَا"},{"kind":"arabic","text_bw":"Eanoka *am~N","text_ar":"عَنْكَ ذَمٌّ"},{"kind":"text","text":"]. (TA.) When you say"},{"kind":"arabic","text_bw":"maA xalaA","text_ar":"مَا خَلَا"},{"kind":"text","text":", it is followed only by an accus., because"},{"kind":"arabic","text_bw":"mA xlA","text_ar":"ما خلا"},{"kind":"text","text":"is equivalent to an inf. n.; (S, Mughnee;) so that when you say,"},{"kind":"arabic","text_bw":"jaAw^uwniY maA xalaA zayodFA","text_ar":"جَاوُونِى مَا خَلَا زَيْدًا"},{"kind":"text","text":"[meaning as above], it is as if you said,"},{"kind":"arabic","text_bw":"jaAw^uwniY xuluw~a zayodK","text_ar":"جَاوُونِى خُلُوَّ زَيْدٍ"},{"kind":"text","text":"[or"},{"kind":"arabic","text_bw":"xuluw~FA","text_ar":"خُلُوًّا"},{"kind":"arabic","text_bw":"zayodFA","text_ar":"زَيْدًا"},{"kind":"text","text":"], i. e."},{"kind":"arabic","text_bw":"xuluw~ahumo mino zayodK","text_ar":"خُلُوَّهُمْ مِنْ زَيْدٍ"},{"kind":"text","text":", (S,) which two phrases mean"},{"kind":"arabic","text_bw":"jaAw^uwniY xaAliyna mino zayodK","text_ar":"جَاوُونِى خَالِينَ مِنْ زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"They came to me, they being without Zeyd"},{"kind":"text","text":"]: (S, K:) [for] accord. to Seer,"},{"kind":"arabic","text_bw":"mAxlA","text_ar":"ماخلا"},{"kind":"text","text":"occupies the place of a noun in the accus. as a denotative of state: but some say, as an adv. n. of time; so that, accord. to these,"},{"kind":"arabic","text_bw":"maA xalaA zayodFA","text_ar":"مَا خَلَا زَيْدًا"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"waqota xuluw~ihimo Eano zayodK","text_ar":"وَقْتَ خُلُوِّهِمْ عَنْ زَيْدٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the time of their being without Zeyd"},{"kind":"text","text":"]. (Mughnee.) You say also,"},{"kind":"arabic","text_bw":"maA A^aradotu masaA='ataka xalaA A^an~iY waEaZotuka","text_ar":"مَا اَرَدْتُ مَسَا=ءَتَكَ خَلَا اَنِّى وَعَظْتُكَ"},{"kind":"text","text":", meaning ["},{"kind":"italic_en","text":"I desired not to displease thee,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"but I admonished thee"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A_il~aA A^an~iY waEaZotuka","text_ar":"اـِلَّا اَنِّى وَعَظْتُكَ"},{"kind":"text","text":"). (JK, TA.)"}],"source_refs":["S","K"]}]}}