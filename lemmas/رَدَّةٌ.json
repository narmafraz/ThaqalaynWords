{"lemma":"رَدَّةٌ","slug":"رَدَّةٌ","root":"ر.د.د","root_slug":"ر-د-د","root_link":"/words/roots/ر-د-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n15190"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%AF%D9%8E%D9%91%D8%A9%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"apostasy"}]},"etymology":null,"ipa":["/rid.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15190","headword_ar":"رَدَّةٌ","root":"rd","body":[{"kind":"text","text":", (T, S, A, K,) or ↓"},{"kind":"arabic","text_bw":"rd~apN","text_ar":"ردَّةٌ","orth_type":"arrow"},{"kind":"text","text":", (so in a copy of the M,) (tropical:)  ["},{"kind":"italic_en","text":"A quality that repels the eye:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"unseemliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugliness,"},{"kind":"text","text":"(IAar, IDrd, S, M, K,)"},{"kind":"italic_en","text":"with somewhat of comeliness,"},{"kind":"text","text":"in the face: (S:) or"},{"kind":"italic_en","text":"somewhat of unseemliness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugliness"},{"kind":"text","text":"(T, A) in the face of a woman who has some comeliness, (T,) or in the face of a comely woman: (A:) or"},{"kind":"italic_en","text":"unseemliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugliness, from which the eye reverts:"},{"kind":"text","text":"(Aboo-Leylà:) and"},{"kind":"italic_en","text":"a fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"defect,"},{"kind":"text","text":"(IAar, IDrd, M,) in a man, (IAar,) or in the face. (IDrd, M.) ―         -b2-  And the former, (accord. to a copy of the M,) or ↓ the latter, (A, K,) (tropical:)"},{"kind":"italic_en","text":"A receding"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"taqaAEasN","text_ar":"تَقَاعَسٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in the chin,"},{"kind":"text","text":"(M, A, K)"},{"kind":"italic_en","text":"when there is in the face somewhat of unseemliness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ugliness, and somewhat of comeliness."},{"kind":"text","text":"(M.) ―         -b3-  And the former, (accord. to a copy of the A,) or ↓ the latter, (K,) (tropical:)  The"},{"kind":"italic_en","text":"returned sound of"},{"kind":"text","text":"the echo; as in the phrase,"},{"kind":"arabic","text_bw":"samiEotu rad~apa AlS~adaY","text_ar":"سَمِعْتُ رَدَّةَ الصَّدَى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I heard the returned sound of the echo"},{"kind":"text","text":"]: (A:) or the"},{"kind":"italic_en","text":"echo of a mountain."},{"kind":"text","text":"(K.) ―         -b4-  Also the former,"},{"kind":"italic_en","text":"A gift,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stipend;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EaTiy~apN","text_ar":"عَطِيَّةٌ"},{"kind":"text","text":". (L, from a trad.) ―         -b5-  And"},{"kind":"italic_en","text":"Affection, and desire:"},{"kind":"text","text":"so in the phrase,"},{"kind":"page_break","n":1064},{"kind":"arabic","text_bw":"lahu rad~apN fiynaA","text_ar":"لَهُ رَدَّةٌ فِينَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has affection, and desire, for us"},{"kind":"text","text":"], in a verse of 'Orweh Ibn-El-Ward. (Sh.)"}],"source_refs":["T","S","A","K","IAar","IDrd","M"]}]},"classical_definitions":null}