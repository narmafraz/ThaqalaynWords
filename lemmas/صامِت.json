ind":"text","text":"(S, K,) and"},{"kind":"italic_en","text":"sheep"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goats,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"animals:"},{"kind":"text","text":"(M:) i. e."},{"kind":"italic_en","text":"he has not aught."},{"kind":"text","text":"(S.) ―         -b2-  Also, of camels, (assumed tropical:)"},{"kind":"italic_en","text":"Twenty,"},{"kind":"text","text":"(O, K,) and"},{"kind":"italic_en","text":"the like."},{"kind":"text","text":"(O.) ―         -b3-  And of milk, (assumed tropical:)"},{"kind":"italic_en","text":"Such as is thick."},{"kind":"text","text":"(S, O, K.)"}],"source_refs":["Msb","S","M","A","K","O"]}]}}