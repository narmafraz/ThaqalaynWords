{"lemma":"نِبْرٌ","slug":"نِبْرٌ","root":"ن.ب.ر","root_slug":"ن-ب-ر","root_link":"/words/roots/ن-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":8},"lanes":{"found":true,"entry_ids":["n39223"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%90%D8%A8%D9%92%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to raise, to lift"},{"pos":"verb","gloss":"to grow, to flourish, to develop","tags":["intransitive"]},{"pos":"verb","gloss":"to raise one's voice","tags":["intransitive"]},{"pos":"verb","gloss":"to shout at"},{"pos":"verb","gloss":"to bite or sting"},{"pos":"noun","gloss":"verbal noun of نَبَرَ (nabara) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"accentuation"},{"pos":"noun","gloss":"tick"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39223","headword_ar":"نِبْرٌ","root":"nbr","body":[{"kind":"text","text":"sing. of"},{"kind":"arabic","text_bw":"A^anobaArN","text_ar":"اَنْبَارٌ"},{"kind":"text","text":", (T, S,) which signifies"},{"kind":"italic_en","text":"Heaps,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^akodaAsN","text_ar":"اَكْدَاسٌ"},{"kind":"text","text":", (M, K,) or"},{"kind":"italic_en","text":"a collection,"},{"kind":"text","text":"(M, S,) of"},{"kind":"arabic","text_bw":"TaEaAm","text_ar":"طَعَام"},{"kind":"text","text":", (S, M, K, MS,) meaning of wheat, and of barley, [or other corn,] and of dates: (MS:) or [in the TA, and]"},{"kind":"italic_en","text":"granaries"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"A^ahoraA='","text_ar":"اَهْرَا=ء"},{"kind":"text","text":") of"},{"kind":"arabic","text_bw":"TaEaAm","text_ar":"طَعَام"},{"kind":"text","text":": (in the present day,"},{"kind":"italic_en","text":"a granary:"},{"kind":"text","text":"] what is called"},{"kind":"arabic","text_bw":"huroYN","text_ar":"هُرْىٌ"},{"kind":"text","text":"being also called"},{"kind":"arabic","text_bw":"niborN","text_ar":"نِبْرٌ"},{"kind":"text","text":"because the"},{"kind":"arabic","text_bw":"TEAm","text_ar":"طعام"},{"kind":"text","text":", when poured in its place, rises: and the pl. pl. [i. e. pl. of"},{"kind":"arabic","text_bw":"AnbAr","text_ar":"انبار"},{"kind":"text","text":"] is"},{"kind":"arabic","text_bw":"A^anaAbiyru","text_ar":"اَنَابِيرُ"},{"kind":"text","text":". (T.) ―         -b2-"},{"kind":"arabic","text_bw":"A^anobaArN","text_ar":"اَنْبَارٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A merchant's magazine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chamber,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"bayot","text_ar":"بَيْت"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in which he puts together, in order,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piles up, his goods."},{"kind":"text","text":"(M, K.) [In the K, it is added, that the sing. is"},{"kind":"arabic","text_bw":"niborN","text_ar":"نِبْرٌ"},{"kind":"text","text":": but this addition seems to be misplaced: for"},{"kind":"arabic","text_bw":"AnbAr","text_ar":"انبار"},{"kind":"text","text":"in the last of the senses here explained, as well as when applied to a granary. and to a collection of"},{"kind":"arabic","text_bw":"TEAm","text_ar":"طعام"},{"kind":"text","text":", appears to be a pl. without a sing.]"}],"source_refs":["T","S","M","K","MS"]}]},"classical_definitions":null}