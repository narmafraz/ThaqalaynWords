{"lemma":"شَرِقَ","slug":"شَرِقَ","root":"ش.ر.ق","root_slug":"ش-ر-ق","root_link":"/words/roots/ش-ر-ق","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"شَرِقْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"شَرِقْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"شَرِقْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"شَرِقْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"شَرِقْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"شَرِقَ","in_corpus":true,"count":8,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"شَرِقَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"شَرِقا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"شَرِقَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"شَرِقُوا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"شَرِقْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَشْرَق","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَشْرَقِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَشْرَقِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَشْرَقانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَشْرَقا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَشْرَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَشْرَقُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَشْرَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَشْرَق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَشْرَق","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَشْرَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَشْرَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَشْرَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَشْرَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَشْرَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَشْرَقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَشْرَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"شَرِقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"شَرِقْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَشْرَق","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَشْرَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":17,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":13},"lanes":{"found":true,"entry_ids":["n22186","n22191","n22192","n22193","n22194"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%90%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"east; Orient"},{"pos":"verb","gloss":"to rise (of the sun)"},{"pos":"verb","gloss":"to shine"},{"pos":"verb","gloss":"to become tall (of a tree, etc.)"},{"pos":"verb","gloss":"to become lit from the sun (of a place)"},{"pos":"verb","gloss":"to become dry due to lack of irrigation (of land)"},{"pos":"verb","gloss":"to become full and cramped (of a space)"},{"pos":"verb","gloss":"to appear (in one's eye, of blood; i.e. the eyes become bloodshot)"},{"pos":"verb","gloss":"to choke","examples":[{"text":"وَمَا شَرَقِي بِالْمَاءِ إِلَّا تَذَكُّرًا / لِمَاءٍ بِهِ أَهْلُ الْحَبِيبِ نُزُولُ\nيُحَرِّمُهُ لَمْعُ الْأَسِنَّةِ فَوْقَهُ / فَلْيْسَ لِظَمْآنٍ إِلَيْهِ وُصُولُ\nwamā šaraqī bi-l-māʔi ʔillā taḏakkuran / limāʔin bihī ʔahlu l-ḥabībi nuzūlu","english":"Water does not choke me except [at the time of] remembrance / It was for water that the Household of the Beloved descended"}]},{"pos":"verb","gloss":"to turn red (of dates, one's face, etc.)"},{"pos":"verb","gloss":"to become confused, to become mixed up (of a thing)"},{"pos":"verb","gloss":"to come [with مَا بَينَ ‘between people’] (of discord, evil, etc.)"},{"pos":"noun","gloss":"verbal noun of شَرِقَ (šariqa) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":["/ʃarq/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22186","headword_ar":"شرّق","root":"$rq","body":[{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"ta$oriyqN","text_ar":"تَشْرِيقٌ"},{"kind":"text","text":", (S, O, K,)"},{"kind":"italic_en","text":"He took to the direction of the east,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of sunrise:"},{"kind":"text","text":"(S, O, K, TA:)"},{"kind":"italic_en","text":"he went to the east: he came to the east:"},{"kind":"text","text":"(M, TA:) and"},{"kind":"italic_en","text":"he directed himself to the east."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"italic_en","text":"He prayed at sunrise:"},{"kind":"text","text":"and hence, app.,"},{"kind":"italic_en","text":"He performed the prayer of the festival of the sacrifice:"},{"kind":"text","text":"(TA:) or this meaning is from"},{"kind":"arabic","text_bw":"$araqati Al$~amosu","text_ar":"شَرَقَتِ الشَّمْسُ"},{"kind":"text","text":". (Mgh: it is also mentioned in the M.) ―         -b3-"},{"kind":"arabic","text_bw":"$r~qt AlA^aroDu","text_ar":"شرّقت الاَرْضُ"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"The land became affected with drought, and dryness of the earth, being"},{"kind":"text","text":"["},{"kind":"italic_en","text":"parched by the sun and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"not reached by water:"},{"kind":"text","text":"whence the term ↓"},{"kind":"arabic","text_bw":"$araAqiY~","text_ar":"شَرَاقِىّ","orth_type":"arrow"},{"kind":"text","text":"[q. v.] in the dial. of Egypt. (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"ta$oriyqN","text_ar":"تَشْرِيقٌ"},{"kind":"text","text":"also signifies The"},{"kind":"italic_en","text":"being beautiful, and"},{"kind":"text","text":"["},{"kind":"italic_en","text":"sunny"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"shining in face."},{"kind":"text","text":"(Sh, O, K.)       -A2-"},{"kind":"arabic","text_bw":"$r~q All~aHoma","text_ar":"شرّق اللَّحْمَ"},{"kind":"text","text":", (M, Mgh, Msb,) inf. n. as above, (S, M, Mgh, O, Msb, K,)"},{"kind":"italic_en","text":"He cut the flesh-meat into strips, and dried it in the sun,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"spread it in the sun to dry:"},{"kind":"text","text":"(S, M, Mgh, O, Msb, K:) or [simply]"},{"kind":"italic_en","text":"he cut it into pieces,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"into strips."},{"kind":"text","text":"(Msb.) [In like manner also]"},{"kind":"arabic","text_bw":"ta$oriyqu Al$~aEiyri","text_ar":"تَشْرِيقُ الشَّعِيرِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"The throwing barley in a sunny place in order that it may dry."},{"kind":"text","text":"(Mgh.) And one says of the [wild] bull,"},{"kind":"arabic","text_bw":"yu$ar~iqu","text_ar":"يُشَرِّقُ"},{"kind":"arabic","text_bw":"matonahu","text_ar":"مَتْنَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He exposes his back to the sun in order that what is upon it of the dew of night may dry:"},{"kind":"text","text":"in this sense the phrase is used by Aboo-Dhu-eyb. (M.) ―         -b2-"},{"kind":"arabic","text_bw":"A^ay~aAmu Alt~a$oriyqi","text_ar":"اَيَّامُ التَّشْرِيقِ"},{"kind":"text","text":"is an appellation of"},{"kind":"italic_en","text":"The three days next after the day of sacrifice:"},{"kind":"text","text":"(S, M, O, Msb:) [i. e. the eleventh and twelfth and thirteenth days of Dhu-l-Hijjeh:] these days were so called because the flesh of the victims was therein cut into strips, and dried in the sun, or spread in the sun to dry: (S, M, Mgh, O, Msb, K: *) or because the victims were not sacrificed until the sun rose: (IAar, S, O, K:) or from the prayer of the day of sacrifice, which they follow: (Mgh:) or because they used to say, [on that day,] (S, M, O,) in the Time of Ignorance, (M,)"},{"kind":"arabic","text_bw":"vabiyro kayomaA nugiyro","text_ar":"ثَبِيرْ كَيْمَا نُغِيرْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^a$oriqo","text_ar":"اَشْرِقْ","orth_type":"arrow"},{"kind":"text","text":", (S, M, O,) which means"},{"kind":"italic_en","text":"Enter thou upon the time of sunrise, Thebeer,"},{"kind":"text","text":"(addressing one of the mountains of Mekkeh, M, * Mgh,)"},{"kind":"italic_en","text":"that we may push,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"press, on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forward,"},{"kind":"text","text":"(M, Mgh, Msb,)"},{"kind":"italic_en","text":"to return from Minè:"},{"kind":"text","text":"(M: [see also 4 in art."},{"kind":"arabic","text_bw":"gwr","text_ar":"غور"},{"kind":"text","text":":]) Aboo- Haneefeh used to hold that"},{"kind":"arabic","text_bw":"Alt~a$oriyq","text_ar":"التَّشْرِيق"},{"kind":"text","text":"means"},{"kind":"arabic","text_bw":"Alt~akobiyr","text_ar":"التَّكْبِير"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"the saying"},{"kind":"arabic","text_bw":"Aall~`hu A^akobaro","text_ar":"اَللّٰهُ اَكْبَرْ"},{"kind":"text","text":"]; but none beside him has held this opinion. (TA.) It is said in a trad. that the days thus called are days of eating and drinking, and of celebrating the praises of God. (O.) ―         -b3-"},{"kind":"arabic","text_bw":"$r~q Alv~awoba","text_ar":"شرّق الثَّوْبَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He made"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"dyed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth, yellow:"},{"kind":"text","text":"(Ibn-'Abbád, O:) [or"},{"kind":"italic_en","text":"he dyed it red:"},{"kind":"text","text":"(see the pass. part. n., below:)] or"},{"kind":"arabic","text_bw":"ta$oriyqN","text_ar":"تَشْرِيقٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"dyeing with saffron,"},{"kind":"text","text":"(M, L,)"},{"kind":"italic_en","text":"so that the thing dyed is saturated,"},{"kind":"text","text":"(L,) or"},{"kind":"italic_en","text":"not so that the thing is saturated:"},{"kind":"text","text":"(so in a copy of the M:) it is not with safflower. (M, L."},{"kind":"page_break","n":1540},{"kind":"text","text":"[See also 4, last signification.])       -A3-"},{"kind":"arabic","text_bw":"$r~q AlaHowaD","text_ar":"شرّق الَحْوَض"},{"kind":"text","text":"is sometimes said for"},{"kind":"arabic","text_bw":"Sar~ajahu","text_ar":"صَرَّجَهُ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"He plastered the watering-trough,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tank, with"},{"kind":"arabic","text_bw":"$aAruwq","text_ar":"شَارُوق"},{"kind":"text","text":"[q. v.], or"},{"kind":"arabic","text_bw":"SaAruwj","text_ar":"صَارُوج"},{"kind":"text","text":". (M in art."},{"kind":"arabic","text_bw":"Srj","text_ar":"صرج"},{"kind":"text","text":".)"}],"source_refs":["TA","S","O","K","M","Mgh","Msb","IAar","L"]},{"entry_id":"n22191","headword_ar":"شَرْقٌ","root":"$rq","body":[{"kind":"text","text":"[an inf. n.: see 1, first sentence. ―         -b2-  Also] The"},{"kind":"italic_en","text":"sun;"},{"kind":"text","text":"(S, O, K;) and so ↓"},{"kind":"arabic","text_bw":"$araqN","text_ar":"شَرَقٌ","orth_type":"arrow"},{"kind":"text","text":": (K, and thus in one of my copies of the S in the place of the former:) [or] ↓"},{"kind":"arabic","text_bw":"$aroqapN","text_ar":"شَرْقَةٌ","orth_type":"arrow"},{"kind":"text","text":"has this signification: (M, Msb:) and"},{"kind":"arabic","text_bw":"$aroqN","text_ar":"شَرْقٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"rising sun;"},{"kind":"text","text":"(M, TA;) as some say; (M;) thus accord. to AA and IAar; (TA;) and so ↓"},{"kind":"arabic","text_bw":"$araqN","text_ar":"شَرَقٌ","orth_type":"arrow"},{"kind":"text","text":", (M, Msb,) and ↓"},{"kind":"arabic","text_bw":"$aroqapN","text_ar":"شَرْقَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"$ariqapN","text_ar":"شَرِقَةٌ","orth_type":"arrow"},{"kind":"text","text":", (M, K,) and ↓"},{"kind":"arabic","text_bw":"$araqapN","text_ar":"شَرَقَةٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) and ↓"},{"kind":"arabic","text_bw":"$aAriqN","text_ar":"شَارِقٌ","orth_type":"arrow"},{"kind":"text","text":", (S, * M, K,) and ↓"},{"kind":"arabic","text_bw":"$ariyqN","text_ar":"شَرِيقٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K:) one says,"},{"kind":"arabic","text_bw":"TalaEati Al$~aroqu","text_ar":"طَلَعَتِ الشَّرْقُ"},{"kind":"italic_en","text":"The sun rose;"},{"kind":"text","text":"(S, M, O; in one of my copies of the S ↓"},{"kind":"arabic","text_bw":"Al$~araqu","text_ar":"الشَّرَقُ","orth_type":"arrow"},{"kind":"text","text":";) but not"},{"kind":"arabic","text_bw":"garabati Al$~aroqu","text_ar":"غَرَبَتِ الشَّرْقُ"},{"kind":"text","text":": (M:) and ↓"},{"kind":"arabic","text_bw":"A=tiyka kul~a $aAriqK","text_ar":"ا=تِيكَ كُلَّ شَارِقٍ","orth_type":"arrow"},{"kind":"italic_en","text":"I will come to thee every day that the sun rises:"},{"kind":"text","text":"or, as some say,"},{"kind":"arabic","text_bw":"$aAriqN","text_ar":"شَارِقٌ"},{"kind":"text","text":"signifies the"},{"kind":"italic_en","text":"upper limb"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"qaron","text_ar":"قَرْن"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the sun:"},{"kind":"text","text":"(M:) and one says,"},{"kind":"arabic","text_bw":"laA A=tiyka maA *ar~a $aAriqN","text_ar":"لَا ا=تِيكَ مَا ذَرَّ شَارِقٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I will not come to thee as long as a sun,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the upper limb of a sun, rises,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"begins to rise"},{"kind":"text","text":"]. (S, M.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"ma$oriqN","text_ar":"مَشْرِقٌ"},{"kind":"text","text":", in three places. ―         -b4-  Also"},{"kind":"italic_en","text":"A place where the sun shines"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Hayovu tu$oriqu","text_ar":"حَيْثُ تُشْرِقُ"},{"kind":"arabic","text_bw":"Al$~amosu","text_ar":"الشَّمْسُ"},{"kind":"text","text":"). (K.) See"},{"kind":"arabic","text_bw":"ma$oruqapN","text_ar":"مَشْرُقَةٌ"},{"kind":"text","text":". ―         -b5-  The"},{"kind":"italic_en","text":"warmth"},{"kind":"text","text":"of the sun. (TA.) ―         -b6-  The"},{"kind":"italic_en","text":"light that enters from the chink of a door;"},{"kind":"text","text":"(IAar, Th, K;) as also ↓"},{"kind":"arabic","text_bw":"$iroqN","text_ar":"شِرْقٌ","orth_type":"arrow"},{"kind":"text","text":". (K.) In a trad. of I'Ab, (TA,) it is said of a gate in Heaven, called ↓"},{"kind":"arabic","text_bw":"Almi$oriyqu","text_ar":"المِشْرِيقُ","orth_type":"arrow"},{"kind":"text","text":"[q. v.],"},{"kind":"arabic","text_bw":"qado rud~a","text_ar":"قَدْ رُدَّ"},{"kind":"arabic","text_bw":"Hat~aY maA baqiYa A_il~aA $aroquhu","text_ar":"حَتَّى مَا بَقِىَ اـِلَّا شَرْقُهُ"},{"kind":"text","text":"(O, K, TA) i. e."},{"kind":"italic_en","text":"It had been closed so that there remained not save its light entering from the chink thereof:"},{"kind":"text","text":"so says I'Ab. (O, TA.) ―         -b7-  And"},{"kind":"italic_en","text":"A chink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fissure."},{"kind":"text","text":"(K, TA.) One says,"},{"kind":"arabic","text_bw":"maA daxala $aroqa famiY $aYo'N","text_ar":"مَا دَخَلَ شَرْقَ فَمِى شَىْءٌ"},{"kind":"italic_en","text":"Nothing entered the chink of my mouth."},{"kind":"text","text":"(Z, TA.)       -A2-  Also"},{"kind":"italic_en","text":"A certain bird,"},{"kind":"text","text":"(Sh, M, K,)"},{"kind":"italic_en","text":"one of the birds of prey,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"between the kite and the hawk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falcon,"},{"kind":"text","text":"(Sh, K,) or"},{"kind":"italic_en","text":"between the kite and the"},{"kind":"text","text":"["},{"kind":"italic_en","text":"species of falcon called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"$aAhiyn","text_ar":"شَاهِين"},{"kind":"text","text":"[q. v.]: (O:) pl."},{"kind":"arabic","text_bw":"$uruwqN","text_ar":"شُرُوقٌ"},{"kind":"text","text":". (M.)"}],"source_refs":["M","Msb","K","TA","O","Sh"]},{"entry_id":"n22192","headword_ar":"شِرْقٌ","root":"$rq","body":[{"kind":"text","text":": see the next preceding paragraph."}],"source_refs":[]},{"entry_id":"n22193","headword_ar":"شَرَقٌ","root":"$rq","body":[{"kind":"text","text":"[inf. n. of"},{"kind":"arabic","text_bw":"$ariqa","text_ar":"شَرِقَ"},{"kind":"text","text":", q. v. ―         -b2-  And also a subst.]: see"},{"kind":"arabic","text_bw":"$aroqN","text_ar":"شَرْقٌ"},{"kind":"text","text":", in three places. ―         -b3-  Also"},{"kind":"italic_en","text":"A thing"},{"kind":"text","text":"["},{"kind":"italic_en","text":"such as spittle"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"the like"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"$ariqa","text_ar":"شَرِقَ"},{"kind":"text","text":")]"},{"kind":"italic_en","text":"obstructing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"choking, the throat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fauces."},{"kind":"text","text":"(S, and Har p. 477.)"}],"source_refs":[]},{"entry_id":"n22194","headword_ar":"شَرِقٌ","root":"$rq","body":[{"kind":"text","text":"A place"},{"kind":"italic_en","text":"bright by reason of the sun's shining upon it;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"mu$oriqN","text_ar":"مُشْرِقٌ","orth_type":"arrow"},{"kind":"text","text":". (M, TA.) ―         -b2-  A man"},{"kind":"italic_en","text":"choked"},{"kind":"text","text":"with his spittle, or with water, or the like. (M, TA.) ―         -b3-  (assumed tropical:)  A plant, or herbage,"},{"kind":"italic_en","text":"having plentiful irrigation;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flourishing and fresh,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"juicy, by reason of plentiful irrigation;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"ray~aAnu","text_ar":"رَيَّانُ"},{"kind":"text","text":". (TA.) ―         -b4-  (assumed tropical:)  A garment, or piece of cloth,"},{"kind":"italic_en","text":"red; that is glutted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saturated,"},{"kind":"text","text":"[so I render"},{"kind":"arabic","text_bw":"Aal~a*iY $ariqa","text_ar":"اَلَّذِى شَرِقَ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"with dye:"},{"kind":"text","text":"(O:) and"},{"kind":"arabic","text_bw":"$ariqN biAljaAdiY~i","text_ar":"شَرِقٌ بِالجَادِىِّ"},{"kind":"text","text":"applied to a garment, or piece of cloth, [app. signifies (assumed tropical:)"},{"kind":"italic_en","text":"glutted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"saturated, with"},{"kind":"text","text":"the dye of"},{"kind":"italic_en","text":"saffron:"},{"kind":"text","text":"see also"},{"kind":"arabic","text_bw":"mu$ar~aqN","text_ar":"مُشَرَّقٌ"},{"kind":"text","text":", and see 4.] (TA.) One says also"},{"kind":"arabic","text_bw":"SariyEN $ariqN bidamihi","text_ar":"صَرِيعٌ شَرِقٌ بِدَمِهِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Prostrated,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"dyed with his blood."},{"kind":"text","text":"(M, TA.) ―         -b5-  (tropical:)  Flesh-meat (S, M, O, TA) that is"},{"kind":"italic_en","text":"red,"},{"kind":"text","text":"(M, O, TA,)"},{"kind":"italic_en","text":"having no grease,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gravy."},{"kind":"text","text":"(S, M, O, TA.) ―         -b6-  (assumed tropical:)  A thing"},{"kind":"italic_en","text":"intensely red, with blood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with a beautiful red colour."},{"kind":"text","text":"(M.) ―         -b7-  And (assumed tropical:)  A thing"},{"kind":"italic_en","text":"mixed, commingled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"blended."},{"kind":"text","text":"(M.)"}],"source_refs":["O","S","M","TA"]}]}}