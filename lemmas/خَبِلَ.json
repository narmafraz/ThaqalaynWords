n":"m","num":"p"},{"role":"present_2mp","form":"تَخْبَلُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَخْبَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَخْبَل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَخْبَل","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَخْبَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَخْبَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَخْبَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَخْبَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَخْبَلُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَخْبَلُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَخْبَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"خَبِلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"خَبِلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نَخْبَل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَخْبَل","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n9950"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8E%D8%A8%D9%90%D9%84%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9950","headword_ar":"خَبِلَ","root":"xbl","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":"(JK, K, TA) and"},{"kind":"arabic","text_bw":"xabalN","text_ar":"خَبَلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, corrupted, unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in an absolute sense;"},{"kind":"text","text":"and particularly]"},{"kind":"italic_en","text":"in his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect:"},{"kind":"text","text":"(TA:) [or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a corrupt, an unsound, a vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disordered, state, occasioning him agitation like that of possession"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insanity, by disease affecting the reason and thought:"},{"kind":"text","text":"(see"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":", below:) and hence,]"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, possessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insane."},{"kind":"text","text":"(JK, K, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xabila","text_ar":"خَبِلَ"},{"kind":"text","text":", [inf. n."},{"kind":"arabic","text_bw":"xabalN","text_ar":"خَبَلٌ"},{"kind":"text","text":", (q. v. voce"},{"kind":"arabic","text_bw":"xabaAlN","text_ar":"خَبَالٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the palsy termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"faAlij","text_ar":"فَالِج"},{"kind":"text","text":". (JK.) ―         -b3-  And"},{"kind":"arabic","text_bw":"xabilato yaduhu","text_ar":"خَبِلَتْ يَدُهُ"},{"kind":"italic_en","text":"His arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, became corrupted, unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, so as to be rendered motionless;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dried up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became lost;"},{"kind":"text","text":"(K, TA;) or"},{"kind":"italic_en","text":"was cut off."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"xabalahu","text_ar":"خَبَلَهُ"},{"kind":"text","text":", (JK, S, Msb, K,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"xabolN","text_ar":"خَبْلٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"xb~lhu","text_ar":"خبّلهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"taxobiylN","text_ar":"تَخْبِيلٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"Axtblhu","text_ar":"اختبلهُ","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(grief, JK, K, and love, JK, T, TA, and time, or fortune, and the ruling power, and disease, T, TA)"},{"kind":"italic_en","text":"rendered him possessed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"insane:"},{"kind":"text","text":"(JK, K, TA:) and"},{"kind":"italic_en","text":"it corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his limb,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"member:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(grief)"},{"kind":"italic_en","text":"deprived him of his heart:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, one of his limbs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"members:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deprived him of his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"xabala qalobahu","text_ar":"خَبَلَ قَلْبَهُ"},{"kind":"text","text":", aor."},{"kind":"text","text":"and"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(love)"},{"kind":"italic_en","text":"corrupted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered unsound, his heart."},{"kind":"text","text":"(JM.) And"},{"kind":"arabic","text_bw":"xabala fulaAnN yada fulaAnK","text_ar":"خَبَلَ فُلَانٌ يَدَ فُلَانٍ"},{"kind":"italic_en","text":"Such a one corrupted, rendered unsound, vitiated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disordered, the arm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hand, of such a one, so that it became motionless;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused it to dry up;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deprived him of it."},{"kind":"text","text":"(JK.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"xabalahu","text_ar":"خَبَلَهُ"},{"kind":"text","text":", (TA,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"xabolN","text_ar":"خَبْلٌ"},{"kind":"text","text":", (K, TA,)"},{"kind":"italic_en","text":"He restrained, withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred, him:"},{"kind":"text","text":"(K, * TA:) and ↓"},{"kind":"arabic","text_bw":"Axtbl","text_ar":"اختبل","orth_type":"arrow"},{"kind":"text","text":"likewise signifies"},{"kind":"italic_en","text":"he restrained, withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"debarred."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"maA xabalaka Ean~aA","text_ar":"مَا خَبَلَكَ عَنَّا"},{"kind":"italic_en","text":"What withheld,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has withheld, thee from us?"},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"xabalahu Eano ka*aA","text_ar":"خَبَلَهُ عَنْ كَذَا"},{"kind":"text","text":", aor. and inf. n. as above,"},{"kind":"italic_en","text":"He prevented,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hindered, him from doing such a thing."},{"kind":"text","text":"(K, * TA.)       -A3-"},{"kind":"arabic","text_bw":"xabala Eano fiEoli A^abiyhi","text_ar":"خَبَلَ عَنْ فِعْلِ اَبِيهِ"},{"kind":"italic_en","text":"He fell short of the doing of his father."},{"kind":"text","text":"(JK, K.)"}],"source_refs":["JK","K","TA","S","Msb"]}]},"classical_definitions":null}