num":"d"},{"role":"present_3fd","form":"تُحَيَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَيِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُحَيِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُحَيُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُحَيُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُحَيَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُحَيِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُحَيّ","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"حَيَّيْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حَيَّيْتُ","in_corpus":true,"count":2,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَيَّى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَيَّى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُحَيِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُحَيِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4625,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n9662","n9677","n9678"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%8A%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to live"},{"pos":"verb","gloss":"to be ashamed"}]},"etymology":{"source":"wiktextract","text":"From Proto-Semitic *ḥyw (“to live”), cognate with Hebrew חַי (kháy, “to live”)."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9662","headword_ar":"حَيِىَ","root":"HY: or HY and Hyw","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) and"},{"kind":"arabic","text_bw":"HaY~a","text_ar":"حَىَّ"},{"kind":"text","text":", (S, K,) which latter is the more common, (Fr, S,) [like"},{"kind":"arabic","text_bw":"mal~a","text_ar":"مَلَّ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"malila","text_ar":"مَلِلَ"},{"kind":"text","text":",] dual"},{"kind":"arabic","text_bw":"HayiyaA","text_ar":"حَيِيَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Hay~aA","text_ar":"حَيَّا"},{"kind":"text","text":", (Fr,) pl."},{"kind":"arabic","text_bw":"HayuwA","text_ar":"حَيُوا"},{"kind":"text","text":", (Fr, S,) like"},{"kind":"arabic","text_bw":"xa$uwA","text_ar":"خَشُوا"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"Hay~uwA","text_ar":"حَيُّوا"},{"kind":"text","text":", (Fr, S,) as some say, (S,) aor."},{"kind":"arabic","text_bw":"yaHoyaA","text_ar":"يَحْيَا"},{"kind":"text","text":", (S, Msb, K,) and"},{"kind":"arabic","text_bw":"yaHaY~u","text_ar":"يَحَىُّ"},{"kind":"text","text":", (Fr, K,) [like"},{"kind":"arabic","text_bw":"yamal~u","text_ar":"يَمَلُّ"},{"kind":"text","text":", originally"},{"kind":"arabic","text_bw":"yamolalu","text_ar":"يَمْلَلُ"},{"kind":"text","text":",] occurring in poetry, but improper, and disallowed by the Basrees, (Fr,) inf. n."},{"kind":"arabic","text_bw":"HayaApN","text_ar":"حَيَاةٌ"},{"kind":"text","text":"[q. v. infrà], (IB, Mgh, Msb,) or"},{"kind":"arabic","text_bw":"HayaA='N","text_ar":"حَيَا=ءٌ"},{"kind":"text","text":", (K,) and"},{"kind":"arabic","text_bw":"HiY~N","text_ar":"حِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HayawaAnN","text_ar":"حَيَوَانٌ"},{"kind":"text","text":", (IB,) which last has an intensive signification, like its contr."},{"kind":"arabic","text_bw":"mawataAnN","text_ar":"مَوَتَانٌ"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, lived;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in the state termed"},{"kind":"arabic","text_bw":"HayaApN","text_ar":"حَيَاةٌ"},{"kind":"text","text":", explained below. (S, K.) [The inf. n."},{"kind":"arabic","text_bw":"HayawaAnN","text_ar":"حَيَوَانٌ"},{"kind":"text","text":"(q. v. infrà) suggests the supposition that"},{"kind":"arabic","text_bw":"HayiYa","text_ar":"حَيِىَ"},{"kind":"text","text":"may be originally"},{"kind":"arabic","text_bw":"Hayiwa","text_ar":"حَيِوَ"},{"kind":"text","text":"; but I find no authority for this supposition; and if it be the case, this verb presents the only instance of a root of which the medial radical letter is"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":"and the final"},{"kind":"arabic","text_bw":"w","text_ar":"و"},{"kind":"text","text":".] ―         -b2-"},{"kind":"arabic","text_bw":"HayuwA","text_ar":"حَيُوا"},{"kind":"text","text":", said of a people, or company of men, (assumed tropical:)"},{"kind":"italic_en","text":"They were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in good condition:"},{"kind":"text","text":"(AA, S:) or"},{"kind":"italic_en","text":"they were,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fat, by having the means of subsistence,"},{"kind":"arabic","text_bw":"baEoda huzaAlK","text_ar":"بَعْدَ هُزَالٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"after leanness"},{"kind":"text","text":"]. (AZ. [See also 4.]) ―         -b3-  You say also,"},{"kind":"arabic","text_bw":"Hay~ati Aln~aAru","text_ar":"حَيَّتِ النَّارُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HayaApN","text_ar":"حَيَاةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HayaA='N","text_ar":"حَيَا=ءٌ"},{"kind":"text","text":", (assumed tropical:)  ["},{"kind":"italic_en","text":"The fire was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, alive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"burning,"},{"kind":"text","text":"] like as you say,"},{"kind":"arabic","text_bw":"maAtat","text_ar":"مَاتَت"},{"kind":"text","text":". (AHn.) ―         -b4-"},{"kind":"arabic","text_bw":"HayiYa AlT~ariyqu","text_ar":"حَيِىَ الطَّرِيقُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"A_i*aA HayiYa","text_ar":"اـِذَا حَيِىَ"},{"kind":"arabic","text_bw":"laka AlT~ariyqu faxu*o yamonapF","text_ar":"لَكَ الطَّرِيقُ فَخُذْ يَمْنَةً"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"When the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way, becomes apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinct, to thee, take to the right"},{"kind":"text","text":"]. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"HayiYa","text_ar":"حَيِىَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HayiYa minohu","text_ar":"حَيِىَ مِنْهُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaHoyaA","text_ar":"يَحْيَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HayaA='N","text_ar":"حَيَا=ءٌ"},{"kind":"text","text":": see 10, in two places.       -A2-"},{"kind":"arabic","text_bw":"HaY~a","text_ar":"حَىَّ"},{"kind":"arabic","text_bw":"Alxamosiyna","text_ar":"الخَمْسِينَ"},{"kind":"text","text":": see 2."},{"kind":"page_break","n":680}],"source_refs":["S","Mgh","Msb","K","Fr","IB","AA"]},{"entry_id":"n9677","headword_ar":"حَيِىٌّ","root":"HY: or HY and Hyw","body":[{"kind":"italic_en","text":"Having"},{"kind":"arabic","text_bw":"HayaA='","text_ar":"حَيَا=ء"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"shame, shyness, bashfulness, pudency,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"modesty"},{"kind":"text","text":"]; (K;) part. n. of"},{"kind":"arabic","text_bw":"HayiYa","text_ar":"حَيِىَ"},{"kind":"text","text":"as syn. with"},{"kind":"arabic","text_bw":"AstHyY","text_ar":"استحيى"},{"kind":"text","text":"; of the measure"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":": (Msb:) fem."},{"kind":"arabic","text_bw":"Hayiy~apN","text_ar":"حَيِيَّةٌ"},{"kind":"text","text":". (TA.) The saying of I'Ab,"},{"kind":"arabic","text_bw":"Aall~`hu HayiY~N","text_ar":"اَللّٰهُ حَيِىٌّ"},{"kind":"text","text":", means"},{"kind":"italic_en","text":"God is one who acts with others in the manner of him who has"},{"kind":"arabic","text_bw":"HayaA='","text_ar":"حَيَا=ء"},{"kind":"text","text":"; for"},{"kind":"arabic","text_bw":"HayaA='","text_ar":"حَيَا=ء"},{"kind":"text","text":"in its proper sense is not ascribable to Him: (Mgh:) or"},{"kind":"italic_en","text":"one who leaves undone evil deeds, and does good deeds."},{"kind":"text","text":"(Er-Rághib.)"}],"source_refs":["Msb","Mgh"]},{"entry_id":"n9678","headword_ar":"حُيَىٌّ","root":"HY: or HY and Hyw","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"HaY~N","text_ar":"حَىٌّ"},{"kind":"text","text":", of which it is the dim."}],"source_refs":[]}]}}