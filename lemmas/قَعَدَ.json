{"lemma":"قَعَدَ","slug":"قَعَدَ","root":"ق.ع.د","root_slug":"ق-ع-د","root_link":"/words/roots/ق-ع-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"قَعَدْتَ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"قَعَدْتِ","in_corpus":true,"count":6,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"قَعَدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"قَعَدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"قَعَدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"قَعَدَ","in_corpus":true,"count":24,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"قَعَدَت","in_corpus":true,"count":6,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"قَعَدا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"قَعَدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"قَعَدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"قَعَدْنَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَقْعُد","in_corpus":true,"count":38,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَقْعُدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَقْعُدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَقْعُدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَقْعُدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَقْعُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَقْعُدُوا","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَقْعُدْنَ","in_corpus":true,"count":1,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَقْعُد","in_corpus":true,"count":17,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَقْعُد","in_corpus":true,"count":38,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَقْعُدانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَقْعُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَقْعُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَقْعُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَقْعُدُونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَقْعُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَقْعُدْنَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"قَعَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"قَعَدْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَقْعُد","in_corpus":true,"count":9,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَقْعُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":154,"cross_references":{"qac":{"found":true,"lemma_key":"قَعَدَ","root":"قعد","pos":"V","occurrence_count":12},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":16},"lanes":{"found":true,"entry_ids":["n35940"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B9%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sit down"},{"pos":"verb","gloss":"to sit"},{"pos":"verb","gloss":"to remain sitting, to abide, to dwell"},{"pos":"verb","gloss":"to be pensioned"},{"pos":"verb","gloss":"to roost"},{"pos":"verb","gloss":"to invite to sit, to seat"},{"pos":"verb","gloss":"to stand"},{"pos":"verb","gloss":"to be stiff"},{"pos":"verb","gloss":"to be idle"},{"pos":"verb","gloss":"to desist (عَن (ʕan) from), to cease"},{"pos":"verb","gloss":"to bear no fruit every second year"},{"pos":"verb","gloss":"to make a stand (بِ (bi) against)"},{"pos":"verb","gloss":"to neglect"},{"pos":"verb","gloss":"to keep from"},{"pos":"verb","gloss":"to prepare a plan","tags":["intransitive"]},{"pos":"verb","gloss":"to become","tags":["copulative"],"examples":[{"text":"وَلَا تَجْعَلْ يَدَكَ مَغْلُولَةً إِلَىٰ عُنُقِكَ وَلَا تَبْسُطْهَا كُلَّ الْبَسْطِ فَتَقْعُدَ مَلُومًا مَحْسُورًا","english":"Do not be so tight-fisted, for you will be blameworthy; nor so open-handed, for you will end up in poverty."}]}]},"etymology":null,"ipa":["/qa.ʕa.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35940","headword_ar":"قَعَدَ","root":"qEd","body":[{"kind":"text","text":", (S, K, &c.,) aor."},{"kind":"text","text":", (A, L,) inf. n."},{"kind":"arabic","text_bw":"quEuwdN","text_ar":"قُعُودٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maqoEadN","text_ar":"مَقْعَدٌ"},{"kind":"text","text":"(S, L, K) and"},{"kind":"arabic","text_bw":"qaEodN","text_ar":"قَعْدٌ"},{"kind":"text","text":", (L,)"},{"kind":"italic_en","text":"He sat; i. q."},{"kind":"arabic","text_bw":"jalasa","text_ar":"جَلَسَ"},{"kind":"text","text":"[when the latter is used in its largest sense]; (S, A, L, K;) so accord. to 'Orweh Ibn-Zubeyr, a high authority;"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":": (L:) or it signifies"},{"kind":"italic_en","text":"he sat down;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sat after standing:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jls","text_ar":"جلس"},{"kind":"text","text":", he sat after lying on his side or prostrating himself: (Kh, IKh, El-Hareeree, K:) or, as some say,"},{"kind":"arabic","text_bw":"qEd","text_ar":"قعد"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he sat for some length of time."},{"kind":"text","text":"(MF.) See also"},{"kind":"arabic","text_bw":"jalasa","text_ar":"جَلَسَ"},{"kind":"text","text":". ―         -b2-  [And hence,"},{"kind":"italic_en","text":"He remained."},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"qaAma waqaEada","text_ar":"قَامَ وَقَعَدَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He experienced griefs which disquieted him so that he could not remain at rest, but stood up and sat down."},{"kind":"text","text":"(Mgh, art."},{"kind":"arabic","text_bw":"qdm","text_ar":"قدم"},{"kind":"text","text":".) [See an ex. voce"},{"kind":"arabic","text_bw":"sud~apN","text_ar":"سُدَّةٌ"},{"kind":"text","text":".]"},{"kind":"arabic","text_bw":"h`*aA $aYo'N yaqoEudu","text_ar":"هٰذَا شَىْءٌ يَقْعُدُ"},{"kind":"arabic","text_bw":"bihi Ealayoka AlEaduw~u wayaquwmu","text_ar":"بِهِ عَلَيْكَ العَدُوُّ وَيَقُومُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"This is a thing for which the enemy will be restless in his attempts against thee"},{"kind":"text","text":"]. (A.)"},{"kind":"arabic","text_bw":"Darabahu Darobapa A@bonapi A@qoEudiY waquwmiY","text_ar":"ضَرَبَهُ ضَرْبَةَ ا@بْنَةِ ا@قْعُدِى وَقُومِى"},{"kind":"italic_en","text":"He beat him with a beating of a female slave:"},{"kind":"text","text":"(IAar, L, K: *) who is thus called because she sits and stands in the service of her masters, being ordered to do so. (IAar, L.) ―         -b4-  ["},{"kind":"arabic","text_bw":"qaEada lahu","text_ar":"قَعَدَ لَهُ"},{"kind":"text","text":", properly,"},{"kind":"italic_en","text":"He sat for him,"},{"kind":"text","text":"often means"},{"kind":"italic_en","text":"He lay in wait for him, in the road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way:"},{"kind":"text","text":"see an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"sad~N","text_ar":"سَدٌّ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"qaEadati Alr~axamapu","text_ar":"قَعَدَتِ الرَّخَمَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The"},{"kind":"page_break","n":2545},{"kind":"italic_en","text":"aquiline vulture lay upon its breast on the ground;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"javamat","text_ar":"جَثَمَت"},{"kind":"text","text":". (S, A, K.) See also"},{"kind":"arabic","text_bw":"jalasa","text_ar":"جَلَسَ"},{"kind":"text","text":". ―         -b6-  [Hence, from the notion of sitting down over against any one,]"},{"kind":"arabic","text_bw":"qaEada biqironihi","text_ar":"قَعَدَ بِقِرْنِهِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He was able to contend with his adversary."},{"kind":"text","text":"(L, K.) ―         -b7-"},{"kind":"arabic","text_bw":"banuw fulaAnK","text_ar":"بَنُو فُلَانٍ"},{"kind":"arabic","text_bw":"libaniY fulaAnK yaqoEuduwna","text_ar":"لِبَنِى فُلَانٍ يَقْعُدُونَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sons of such a one are able to contend with the sons of such a one, and come to them with their numbers."},{"kind":"text","text":"(L.) ―         -b8-"},{"kind":"arabic","text_bw":"qaEaduwA Ean~aA","text_ar":"قَعَدُوا عَنَّا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They were able to contend for us, with their warriors, and to suffice us in war."},{"kind":"text","text":"(L.) ―         -b9-"},{"kind":"arabic","text_bw":"qaEada liloHarobi","text_ar":"قَعَدَ لِلْحَرْبِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He prepared for war those who should contend therein."},{"kind":"text","text":"(L, K.) ―         -b10-"},{"kind":"arabic","text_bw":"qaEada liloA^amori","text_ar":"قَعَدَ لِلْاَمْرِ"},{"kind":"italic_en","text":"He performed the affair;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A_ihotam~a bihi","text_ar":"اـِهْتَمَّ بِهِ"},{"kind":"text","text":". (Msb.) ―         -b11-"},{"kind":"arabic","text_bw":"qaEada ya$otimuniY","text_ar":"قَعَدَ يَشْتِمُنِى"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He set about, fell to,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"commenced, reviling me."},{"kind":"text","text":"(Fr, A, L.) ―         -b12-  [And from the notion of sitting down in refusal or unwillingness,]"},{"kind":"arabic","text_bw":"qaEada Eani AlA^amori","text_ar":"قَعَدَ عَنِ الاَمْرِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He abstained from, omitted, neglected, left, relinquished,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forsook, the thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair;"},{"kind":"text","text":"(A, Mgh;)"},{"kind":"italic_en","text":"he hung back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back, from it."},{"kind":"text","text":"(IKtt.)"},{"kind":"arabic","text_bw":"qaEada Eano HaAjatihi","text_ar":"قَعَدَ عَنْ حَاجَتِهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He hung, back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held back, from accomplishing his want."},{"kind":"text","text":"(Msb.)"},{"kind":"arabic","text_bw":"qaEada Eani Alqawomi","text_ar":"قَعَدَ عَنِ القَوْمِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He remained behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party,"},{"kind":"text","text":"not going with them. (Msb, art."},{"kind":"arabic","text_bw":"xlf","text_ar":"خلف"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"qaEadotu baEodahu","text_ar":"قَعَدْتُ بَعْدَهُ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"I remained behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, him;"},{"kind":"text","text":"] as also"},{"kind":"arabic","text_bw":"qEdt","text_ar":"قعدت"},{"kind":"arabic","text_bw":"xilaAfahu","text_ar":"خِلَافَهُ"},{"kind":"text","text":": (Msb, ibid.:) and"},{"kind":"arabic","text_bw":"qaEada xilaAfa A^aSoHaAbihi","text_ar":"قَعَدَ خِلَافَ اَصْحَابِهِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He remained behind,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after, his companions; he did not go forth with them"},{"kind":"text","text":"(TA, in art."},{"kind":"arabic","text_bw":"xlf","text_ar":"خلف"},{"kind":"text","text":") ―         -b13-  ["},{"kind":"arabic","text_bw":"qaEada maEahu","text_ar":"قَعَدَ مَعَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"qaEada A_ilayohi","text_ar":"قَعَدَ اـِلَيْهِ"},{"kind":"text","text":"are like"},{"kind":"arabic","text_bw":"jalasa maEahu","text_ar":"جَلَسَ مَعَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jalasa A_ilayohi","text_ar":"جَلَسَ اـِلَيْهِ"},{"kind":"text","text":", q. v.] ―         -b14-"},{"kind":"arabic","text_bw":"qaEada bihi","text_ar":"قَعَدَ بِهِ"},{"kind":"text","text":", see 4 in three places, and 5. ―         -b15-"},{"kind":"arabic","text_bw":"qaEadato","text_ar":"قَعَدَتْ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"quEuwdN","text_ar":"قُعُودٌ"},{"kind":"text","text":"; (K;) or"},{"kind":"arabic","text_bw":"qaEadato Eani","text_ar":"قَعَدَتْ عَنِ"},{"kind":"arabic","text_bw":"Alwaladi","text_ar":"الوَلَدِ"},{"kind":"text","text":", (Mgh, K,) and"},{"kind":"arabic","text_bw":"AlHayoDi","text_ar":"الحَيْضِ"},{"kind":"text","text":", (A, Mgh, Msb, K,) and"},{"kind":"arabic","text_bw":"Alz~awoji","text_ar":"الزَّوْجِ"},{"kind":"text","text":"; (A, Msb, K;) (tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"ceased from bearing children,"},{"kind":"text","text":"(A, Mgh, K,) and"},{"kind":"italic_en","text":"from having the menstrual discharge,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"from having a husband."},{"kind":"text","text":"(A, K.) [And hence,] (tropical:)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"had no husband:"},{"kind":"text","text":"(K, * TA:) said of her who is, and of her who is not, a virgin. (TA.) ―         -b16-"},{"kind":"arabic","text_bw":"qaEadati Aln~axolapu","text_ar":"قَعَدَتِ النَّخْلَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The palm-tree bore fruit one year and not another."},{"kind":"text","text":"(L, K.) ―         -b17-"},{"kind":"arabic","text_bw":"qaEada maqaAEida","text_ar":"قَعَدَ مَقَاعِدَ"},{"kind":"arabic","text_bw":"riqaAqFA","text_ar":"رِقَاقًا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He had thin evacuations of the bowels:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"sad~a","text_ar":"سَدَّ"},{"kind":"text","text":"] (TA, in art."},{"kind":"arabic","text_bw":"sk","text_ar":"سك"},{"kind":"text","text":".) ―         -b18-"},{"kind":"arabic","text_bw":"qaEadN","text_ar":"قَعَدٌ"},{"kind":"italic_en","text":"Laxness"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"and depression"},{"kind":"text","text":"(S)"},{"kind":"italic_en","text":"in the shank"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"waZiyf","text_ar":"وَظِيف"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of a camel."},{"kind":"text","text":"(S, K.) [App. an inf. n., of which the verb is"},{"kind":"arabic","text_bw":"qaEida","text_ar":"قَعِدَ"},{"kind":"text","text":". But see 1 in art."},{"kind":"arabic","text_bw":"Sdf","text_ar":"صدف"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"he"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"became;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaAra","text_ar":"صَارَ"},{"kind":"text","text":". Ex."},{"kind":"arabic","text_bw":"Had~ada $aforatahu","text_ar":"حَدَّدَ شَفْرَتَهُ"},{"kind":"arabic","text_bw":"Hat~aY qaEadato kaA^an~ahaA HarobapN","text_ar":"حَتَّى قَعَدَتْ كَاَنَّهَا حَرْبَةٌ"},{"kind":"italic_en","text":"He sharpened his large knife so that it became as though it were a javelin."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"vawobaka laA taqoEudu taTiyru bihi Alr~iyHu","text_ar":"ثَوْبَكَ لَا تَقْعُدُ تَطِيرُ بِهِ الرِّيحُ"},{"kind":"text","text":"[in the CK,"},{"kind":"arabic","text_bw":"vawobuka","text_ar":"ثَوْبُكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaqoEudu","text_ar":"يَقْعُدُ"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"Take care of thy garment, that the wind do not become flying away with it."},{"kind":"text","text":"(IAar, L, K. *)"},{"kind":"arabic","text_bw":"vwbk","text_ar":"ثوبك"},{"kind":"text","text":"is here in the acc. case because the verb"},{"kind":"arabic","text_bw":"AiHofaZo","text_ar":"اِحْفَظْ"},{"kind":"text","text":"is understood before it. (L.) ―         -b2-"},{"kind":"arabic","text_bw":"qaEadati A=lfasiylapu","text_ar":"قَعَدَتِ ا=لفَسِيلَةُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The young palm-tree came to have a trunk."},{"kind":"text","text":"(S, A, K.)       -A3-"},{"kind":"arabic","text_bw":"qaEada","text_ar":"قَعَدَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, AZ)"},{"kind":"italic_en","text":"stood."},{"kind":"text","text":"Thus it bears two contr. significations. (AZ, L, K.)"}],"source_refs":["A","L","S","K","Mgh","Msb"]}]}}