{"lemma":"مُضارِبٌ","slug":"مُضارِبٌ","root":"ض.ر.ب","root_slug":"ض-ر-ب","root_link":"/words/roots/ض-ر-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n25719"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%B6%D8%A7%D8%B1%D9%90%D8%A8%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n25719","headword_ar":"مُضَارِبٌ","root":"Drb","body":[{"kind":"italic_en","text":"One who is employed by another to traffic for him with his"},{"kind":"text","text":"("},{"kind":"italic_en","text":"the latter's"},{"kind":"text","text":")"},{"kind":"italic_en","text":"property, on the condition of their sharing the gain together:"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"one who employs another to traffic for him with his"},{"kind":"text","text":"("},{"kind":"italic_en","text":"the former's"},{"kind":"text","text":")"},{"kind":"italic_en","text":"property, on that condition:"},{"kind":"text","text":"thus expl. by En-Nadr; and Az also allows the use of the word in these two senses. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}