{"lemma":"اِبْتِذال","slug":"اِبْتِذال","root":"ب.ذ.ل","root_slug":"ب-ذ-ل","root_link":"/words/roots/ب-ذ-ل","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n2118"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%A8%D9%92%D8%AA%D9%90%D8%B0%D8%A7%D9%84"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"verbal noun of اِبْتَذَلَ (ibtaḏala) (form VIII)","tags":["form-of","noun-from-verb"]}]},"etymology":{"source":"wiktextract","text":"Verbal noun of اِبْتَذَلَ (ibtaḏala)."},"ipa":["/ib.ti.ðaːl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2118","headword_ar":"اِبْتِذَالٌ","root":"b*l","body":[{"kind":"text","text":"is the"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"SiyaAnapN","text_ar":"صِيَانَةٌ"},{"kind":"text","text":"; (M, K;) [i. e.]"},{"kind":"arabic","text_bw":"Abt*lhu","text_ar":"ابتذلهُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"He held it in mean estimation;"},{"kind":"text","text":"namely, a garment or other thing; (TA;) ["},{"kind":"italic_en","text":"he was careless of it; he used it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"employed it, on,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for, ordinary, mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vile, occasions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"purposes;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he used it for service and work;"},{"kind":"text","text":"namely, a garment &c.; syn."},{"kind":"arabic","text_bw":"Aimotahanahu","text_ar":"اِمْتَهَنَهُ"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"he wore it"},{"kind":"text","text":"(a garment)"},{"kind":"italic_en","text":"in times of service and work;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"ba*alahu","text_ar":"بَذَلَهُ","orth_type":"arrow"},{"kind":"text","text":"; (Msb, TA;) or, as IKoot says,"},{"kind":"arabic","text_bw":"ba*alahu","text_ar":"بَذَلَهُ"},{"kind":"text","text":", [aor."},{"kind":"text","text":"and"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"ba*olapN","text_ar":"بَذْلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"bi*olapN","text_ar":"بِذْلَةٌ"},{"kind":"text","text":", signifies"},{"kind":"italic_en","text":"he did not preserve it, lay it up, take care of it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reserve it;"},{"kind":"text","text":"namely, a garment. (Msb.) See also 5, in two places. You say also,"},{"kind":"arabic","text_bw":"Abt*l Eadowahu","text_ar":"ابتذل عَدْوَهُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"performed his run freely,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without reservation;"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"SaAnahu","text_ar":"صَانَهُ"},{"kind":"text","text":"]. (T.) See 1."}],"source_refs":[]}]}}