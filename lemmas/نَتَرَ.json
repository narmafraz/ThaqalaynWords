"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39294","headword_ar":"نَتَرَ","root":"ntr","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (S, M, A, Msb,) inf. n."},{"kind":"arabic","text_bw":"natorN","text_ar":"نَتْرٌ"},{"kind":"text","text":", (S, M, Msb, K,)"},{"kind":"italic_en","text":"He pulled"},{"kind":"text","text":"a thing, (S, M, Msb, K, *) [as, for instance,] a garment, or piece of cloth, (A,) and his"},{"kind":"arabic","text_bw":"*akar","text_ar":"ذَكَر"},{"kind":"text","text":", which a man is required to do three times after"},{"kind":"arabic","text_bw":"bawol","text_ar":"بَوْل"},{"kind":"text","text":", (S, TA,)"},{"kind":"italic_en","text":"hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with vehemence."},{"kind":"text","text":"(S, M, A, Msb, K.) ―         -b2-"},{"kind":"italic_en","text":"He drew"},{"kind":"text","text":"a bow"},{"kind":"italic_en","text":"vehemently:"},{"kind":"text","text":"(K, * TA:)"},{"kind":"italic_en","text":"he drew"},{"kind":"text","text":"the bow-string"},{"kind":"italic_en","text":"strongly;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"so that the bow nearly broke."},{"kind":"text","text":"(A.) ―         -b3-"},{"kind":"italic_en","text":"He rent"},{"kind":"text","text":"a"},{"kind":"page_break","n":2762},{"kind":"text","text":"garment, or piece of cloth,"},{"kind":"italic_en","text":"with his fingers"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with his teeth."},{"kind":"text","text":"(M, K.) And [in like manner,]"},{"kind":"arabic","text_bw":"natarati AlqisiY~u A^awotaArahaA","text_ar":"نَتَرَتِ القِسِىُّ اَوْتَارَهَا"},{"kind":"italic_en","text":"The bows broke their strings."},{"kind":"text","text":"(IKtt.) ―         -b4-"},{"kind":"italic_en","text":"He snatched"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"unawares."},{"kind":"text","text":"(K, * TK.) ―         -b5-"},{"kind":"italic_en","text":"He acted ungently, roughly, harshly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"violently,"},{"kind":"text","text":"(K, * TA,) in an affair. (TA.) ―         -b6-"},{"kind":"arabic","text_bw":"natara fiY ma$oyihi","text_ar":"نَتَرَ فِى مَشْيِهِ"},{"kind":"text","text":", (T, M,) inf. n. as above, (T,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was as though he were pulling, in his walking:"},{"kind":"text","text":"(T:)"},{"kind":"italic_en","text":"he leaned in his walking;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Anttr","text_ar":"انتتر","orth_type":"arrow"},{"kind":"text","text":". (M.)"}],"source_refs":["S","M","A","Msb","K","TA","T"]}]},"classical_definitions":null}