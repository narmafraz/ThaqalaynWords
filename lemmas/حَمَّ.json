ency_in_corpus":14,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n8985"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D9%85%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to heat"},{"pos":"noun","gloss":"father-in-law"},{"pos":"noun","gloss":"a male relation of someone's spouse, such as the father, brother, or paternal uncle"}]},"etymology":{"source":"wiktextract","text":"Cognate with Hebrew חַם (kham, “hot”)\n\nInherited from Proto-Semitic *ḥamw-."},"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n8985","headword_ar":"حَمَّ","root":"Hm","body":[{"kind":"text","text":", (S, K,) see. pers."},{"kind":"arabic","text_bw":"Hamimota","text_ar":"حَمِمْتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Ham~N","text_ar":"حَمٌّ"},{"kind":"text","text":", (TA,) [or perhaps this should be"},{"kind":"arabic","text_bw":"HamamN","text_ar":"حَمَمٌ"},{"kind":"text","text":",]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(water)"},{"kind":"italic_en","text":"became hot."},{"kind":"text","text":"(S, K, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Hamimotu","text_ar":"حَمِمْتُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"HamamN","text_ar":"حَمَمٌ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"I was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"arabic","text_bw":"A^aHam~","text_ar":"اَحَمّ"},{"kind":"text","text":", signifying"},{"kind":"italic_en","text":"black;"},{"kind":"text","text":"(S, K; [accord. to the latter of which, and accord. to El-Hejeree, this epithet also signifies"},{"kind":"italic_en","text":"white;"},{"kind":"text","text":"but it appears from the TA that the former only is here meant; and the verb seems primarily to signify"},{"kind":"italic_en","text":"I became rendered black by heat;"},{"kind":"text","text":"]) as also ↓"},{"kind":"arabic","text_bw":"AiHomawomayotu","text_ar":"اِحْمَوْمَيْتُ","orth_type":"arrow"},{"kind":"text","text":"[originally"},{"kind":"arabic","text_bw":"AiHomawomamotu","text_ar":"اِحْمَوْمَمْتُ"},{"kind":"text","text":", or from"},{"kind":"arabic","text_bw":"HamaY","text_ar":"حَمَى"},{"kind":"text","text":", q. v.], and ↓"},{"kind":"arabic","text_bw":"tHm~mt","text_ar":"تحمّمت","orth_type":"arrow"},{"kind":"text","text":", (K, [omitted in the TA,]) and ↓"},{"kind":"arabic","text_bw":"taHamoHamotu","text_ar":"تَحَمْحَمْتُ","orth_type":"arrow"},{"kind":"text","text":". (K, TA: the last, in the CK, written"},{"kind":"arabic","text_bw":"taHomamotu","text_ar":"تَحْمَمْتُ"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"Ham~a Aljamoru","text_ar":"حَمَّ الجَمْرُ"},{"kind":"text","text":", see. pers."},{"kind":"arabic","text_bw":"Hamimota","text_ar":"حَمِمْتَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HamamN","text_ar":"حَمَمٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The live coals became black, after their flaming had ceased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"after they had become extinguished:"},{"kind":"text","text":"(Msb:) or"},{"kind":"arabic","text_bw":"Ham~ati Aljamorapu","text_ar":"حَمَّتِ الجَمْرَةُ"},{"kind":"text","text":", (S, K,) sec. pers. as above, (TA,) aor."},{"kind":"text","text":","},{"kind":"italic_en","text":"the live coal became a piece of charcoal,"},{"kind":"text","text":"(S, K,) or"},{"kind":"italic_en","text":"of ashes."},{"kind":"text","text":"(S.)       -A2- ,"},{"kind":"arabic","text_bw":"Ham~ahu","text_ar":"حَمَّهُ"},{"kind":"text","text":"(S, K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"Ham~N","text_ar":"حَمٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He heated it,"},{"kind":"text","text":"namely, water, (S, K, TA,)"},{"kind":"italic_en","text":"with fire;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"AHm~hu","text_ar":"احمّهُ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) and ↓"},{"kind":"arabic","text_bw":"Hm~mhu","text_ar":"حمّمهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) You say,"},{"kind":"arabic","text_bw":"lanaA AlmaA='a","text_ar":"لَنَا المَا=ءَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^aHim~uwA","text_ar":"اَحِمُّوا","orth_type":"arrow"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"mina AlmaA='i","text_ar":"مِنَ المَا=ءِ"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"Heat ye for us the water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"some of the water."},{"kind":"text","text":"(S, TA.) ―         -b2-"},{"kind":"italic_en","text":"He heated it; kindled fire in it; filled it with firewood, to heat it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heated it fully with fuel;"},{"kind":"text","text":"namely, an oven. (K, * TA.) ―         -b3-"},{"kind":"arabic","text_bw":"Ham~a AlA^aloyapa","text_ar":"حَمَّ الاَلْيَةَ"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Al$~aHomapa","text_ar":"الشَّحْمَةَ"},{"kind":"text","text":", (K,) aor."},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"Ham~N","text_ar":"حَمٌّ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He melted"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the fat of a sheep's tail,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the piece of fat"},{"kind":"text","text":"]. (S, K.) ―         -b4-"},{"kind":"arabic","text_bw":"Ham~a nafosahu","text_ar":"حَمَّ نَفْسَهُ"},{"kind":"text","text":": see 4 ―         -b5-"},{"kind":"arabic","text_bw":"Hum~a","text_ar":"حُمَّ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fevered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affected with fever;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was sick of, a fever:"},{"kind":"text","text":"(S, Mgh, Msb, K:) or one says [of himself],"},{"kind":"arabic","text_bw":"Humimotu Hum~aY","text_ar":"حُمِمْتُ حُمَّى"},{"kind":"text","text":", (K, TA, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"Hamamotu","text_ar":"حَمَمْتُ"},{"kind":"text","text":",])"},{"kind":"arabic","text_bw":"Hum~aY","text_ar":"حُمَّى"},{"kind":"text","text":"being held by ISd to be an inf. n. like"},{"kind":"arabic","text_bw":"bu$oraY","text_ar":"بُشْرَى"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"rujoEaY","text_ar":"رُجْعَى"},{"kind":"text","text":"; (TA;) and the simple subst. [also] is"},{"kind":"arabic","text_bw":"Hum~aY","text_ar":"حُمَّى"},{"kind":"text","text":": (K:) [or the inf. n. is"},{"kind":"arabic","text_bw":"Ham~N","text_ar":"حَمٌّ"},{"kind":"text","text":"; for] you say,"},{"kind":"arabic","text_bw":"Humimotu Ham~FA","text_ar":"حُمِمْتُ حَمًّا"},{"kind":"text","text":"; and the simple subst. is"},{"kind":"arabic","text_bw":"Hum~aY","text_ar":"حُمَّى"},{"kind":"text","text":". (L.) And"},{"kind":"arabic","text_bw":"Hum~a EalaY TaEaAmK","text_ar":"حُمَّ عَلَى طَعَامٍ"},{"kind":"italic_en","text":"He had a fever from eating"},{"kind":"text","text":"[certain]"},{"kind":"italic_en","text":"food."},{"kind":"text","text":"(K, * TA.) And"},{"kind":"arabic","text_bw":"Hm~","text_ar":"حمّ"},{"kind":"text","text":", [app."},{"kind":"arabic","text_bw":"Hum~a","text_ar":"حُمَّ"},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"HumaAmN","text_ar":"حُمَامٌ"},{"kind":"text","text":"said of a camel,"},{"kind":"italic_en","text":"He had a fever."},{"kind":"text","text":"(TA. [See"},{"kind":"arabic","text_bw":"HumaAmN","text_ar":"حُمَامٌ"},{"kind":"text","text":", below.]) ―         -b6-"},{"kind":"arabic","text_bw":"Ham~ahu","text_ar":"حَمَّهُ"},{"kind":"text","text":"said of an affair, an event, or a case: see 4. ―         -b7-"},{"kind":"arabic","text_bw":"Ham~a A@rotiHaAla","text_ar":"حَمَّ ا@رْتِحَالَ"},{"kind":"text","text":","},{"kind":"arabic","text_bw":"AlbaEiyri","text_ar":"البَعِيرِ"},{"kind":"text","text":", (Fr, S, K,) aor."},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"He hastened the going,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departure, of the camel."},{"kind":"text","text":"(Fr, S, K.)       -A3-"},{"kind":"arabic","text_bw":"Ham~a lahu ka*aA","text_ar":"حَمَّ لَهُ كَذَا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"AHm~","text_ar":"احمّ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(God)"},{"kind":"italic_en","text":"decreed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for him, such a thing."},{"kind":"text","text":"(K, TA.) And"},{"kind":"arabic","text_bw":"Hum~a","text_ar":"حُمَّ"},{"kind":"text","text":", (S, K,) inf. n."},{"kind":"arabic","text_bw":"Ham~N","text_ar":"حَمٌّ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"HumuwmN","text_ar":"حُمُومٌ"},{"kind":"text","text":", (Har p. 347,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, or an event, K)"},{"kind":"italic_en","text":"was decreed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed;"},{"kind":"text","text":"(Sudot;, K;) as also ↓"},{"kind":"arabic","text_bw":"A^uHimN","text_ar":"اُحِمٌ","orth_type":"arrow"},{"kind":"text","text":". (S.) And"},{"kind":"arabic","text_bw":"Hum~a lahu *`lika","text_ar":"حُمَّ لَهُ ذٰلِكَ"},{"kind":"italic_en","text":"That was decreed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appointed, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for him."},{"kind":"text","text":"(K.)       -A4-"},{"kind":"arabic","text_bw":"Ham~a Ham~ahu","text_ar":"حَمَّ حَمَّهُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"qaSada qaSodahu","text_ar":"قَصَدَ قَصْدَهُ"},{"kind":"text","text":"[like"},{"kind":"arabic","text_bw":"A^ab~a A^ab~ahu","text_ar":"اَبَّ اَبَّهُ"},{"kind":"text","text":", q. v.;"},{"kind":"arabic","text_bw":"Ham~a","text_ar":"حَمَّ"},{"kind":"text","text":"in this sense being a dial. var. of"},{"kind":"arabic","text_bw":"A^am~a","text_ar":"اَمَّ"},{"kind":"text","text":", as also"},{"kind":"arabic","text_bw":"A^ab~a","text_ar":"اَبَّ"},{"kind":"text","text":"]. (S, K.) ―         -b2-  See also 4 as an in trans. v."}],"source_refs":["S","K","TA","Msb","Mgh","Fr","God"]}]}}