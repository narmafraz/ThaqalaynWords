{"lemma":"قاطِعَةٍ","slug":"قاطِعَةٍ","root":"ق.ط.ع","root_slug":"ق-ط-ع","root_link":"/words/roots/ق-ط-ع","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"قاطِعَةٍ","root":"قطع","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["n42714"],"search_url":"https://lanelexicon.com/?s=%D9%82%D8%A7%D8%B7%D9%90%D8%B9%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to separate oneself from (construed with a direct object), renounce, cut one's acquaintance"},{"pos":"verb","gloss":"to interrupt"},{"pos":"verb","gloss":"to give work at a fixed price","tags":["Arabic","Modern","Standard"]},{"pos":"verb","gloss":"to boycott","tags":["Arabic","Modern","Standard"]},{"pos":"noun","gloss":"secant (symbol: قا)"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42714","headword_ar":"قَاطَعَهُ","root":"qTE","body":[{"kind":"italic_en","text":"He separated himself from him, with the latter's concurrence;"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"faArazahu","text_ar":"فَارَزَهُ"},{"kind":"text","text":"; and see"},{"kind":"arabic","text_bw":"AinoqaTaEa","text_ar":"اِنْقَطَعَ"},{"kind":"arabic","text_bw":"Eanohu","text_ar":"عَنْهُ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"qaATaEaA","text_ar":"قَاطَعَا"},{"kind":"italic_en","text":"They disunited themselves, each form the other; severed the bond of friendship that united them, each to the other; contr. of"},{"kind":"arabic","text_bw":"waASalaA","text_ar":"وَاصَلَا"},{"kind":"text","text":". (K.) See 6."}],"source_refs":[]}]},"classical_definitions":null}