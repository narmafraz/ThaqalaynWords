nition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to germinate, to sprout"},{"pos":"verb","gloss":"to grow"},{"pos":"noun","gloss":"germination, sprouting"},{"pos":"noun","gloss":"vegetation"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39152","headword_ar":"نَبَتَ","root":"nbt","body":[{"kind":"text","text":", (S, M, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nabotN","text_ar":"نَبْتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nabaAtN","text_ar":"نَبَاتٌ"},{"kind":"text","text":"; [which two ns. see mentioned as substs.;] and ↓"},{"kind":"arabic","text_bw":"tnb~t","text_ar":"تنبّت","orth_type":"arrow"},{"kind":"text","text":"; (M;) and ↓"},{"kind":"arabic","text_bw":"Anbt","text_ar":"انبت","orth_type":"arrow"},{"kind":"text","text":"; (Fr, S, K;) [respecting which last see below;]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, M, or a leguminous [or other] plant, S, K,)"},{"kind":"italic_en","text":"grew; grew forth; sprouted; vegetated;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"germinated."},{"kind":"text","text":"(S, M, K.) As disallows ↓"},{"kind":"arabic","text_bw":"Anbt","text_ar":"انبت","orth_type":"arrow"},{"kind":"text","text":"in this sense; but AO allows it, alleging the words of Zuheyr,"},{"kind":"arabic","text_bw":"Albaqolu","text_ar":"البَقْلُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Hat~aY A_i*aA A^anobata","text_ar":"حَتَّى اـِذَا اَنْبَتَ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Until, when the leguminous plants grew"},{"kind":"text","text":"]."},{"kind":"arabic","text_bw":"nabata","text_ar":"نَبَتَ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^anobata","text_ar":"اَنْبَتَ","orth_type":"arrow"},{"kind":"text","text":"are said to be like"},{"kind":"arabic","text_bw":"maTarati Als~amA='u","text_ar":"مَطَرَتِ السَّما=ءُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^amoTarat","text_ar":"اَمْطَرَت"},{"kind":"text","text":". In the Kur, xxiii. 20, Ibn-Ketheer, Aboo-'Amr and El-Hadremee read"},{"kind":"arabic","text_bw":"tunobitu","text_ar":"تُنْبِتُ"},{"kind":"text","text":": others,"},{"kind":"arabic","text_bw":"tanobutu","text_ar":"تَنْبُتُ"},{"kind":"text","text":": but ISd says, that, accord. to the former reading, some hold"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":", which follows"},{"kind":"arabic","text_bw":"tunobitu","text_ar":"تُنْبِتُ"},{"kind":"text","text":", to be redundant; and others hold that"},{"kind":"arabic","text_bw":"maA tunobutu","text_ar":"مَا تُنْبُتُ"},{"kind":"text","text":"is understood after"},{"kind":"arabic","text_bw":"tunobitu","text_ar":"تُنْبِتُ"},{"kind":"text","text":". Fr holds them to be syn. (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"nabata EalaYa HaAlapK HasanapK","text_ar":"نَبَتَ عَلَىَ حَالَةٍ حَسَنَةٍ"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, grew in a good manner, condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state."},{"kind":"text","text":"(L.) ―         -b3-"},{"kind":"arabic","text_bw":"nabata","text_ar":"نَبَتَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"nubuwtN","text_ar":"نُبُوتٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a girl's breast)"},{"kind":"italic_en","text":"became swelling, prominent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protuberant."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"arabic","text_bw":"nabatati AlA^aroDu","text_ar":"نَبَتَتِ الاَرْضُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"A^anobatat","text_ar":"اَنْبَتَت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The land produced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gave growth to, plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage."},{"kind":"text","text":"(S, K.)"}],"source_refs":["S","M","K"]}]}}