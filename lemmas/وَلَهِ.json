{"lemma":"وَلَهِ","slug":"وَلَهِ","root":"#.ل.ه","root_slug":"_-ل-ه","root_link":"/words/roots/_-ل-ه","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n44741","n44742"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%84%D9%8E%D9%87%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44741","headword_ar":"وَلِهَ","root":"wlh","body":[{"kind":"italic_en","text":"His reason departed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became bereft of his reason"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect, in consequence of grief;"},{"kind":"text","text":"(K;) or"},{"kind":"italic_en","text":"of joy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"grief;"},{"kind":"text","text":"(Msb;) or"},{"kind":"italic_en","text":"of intense grief;"},{"kind":"text","text":"(S, Mgh;) or"},{"kind":"italic_en","text":"of the loss of the beloved:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"he grieved,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sorrowed:"},{"kind":"text","text":"(K:) and"},{"kind":"italic_en","text":"he became confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"by reason of intense grief:"},{"kind":"text","text":"(S, TA:) and"},{"kind":"italic_en","text":"he feared."},{"kind":"text","text":"(K.) See also"},{"kind":"arabic","text_bw":"A^aliha","text_ar":"اَلِهَ"},{"kind":"text","text":", in two places. ―         -b2-"},{"kind":"arabic","text_bw":"waliha A_ilaY A^um~ih","text_ar":"وَلِهَ اـِلَى اُمِّه"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(an infant)"},{"kind":"italic_en","text":"yearned for his mother."},{"kind":"text","text":"(T