, and whose property he inherits if he dies having no"},{"kind":"text","text":"["},{"kind":"italic_en","text":"natural or other legal"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"heir."},{"kind":"text","text":"(TA.) And (K)"},{"kind":"italic_en","text":"a slave:"},{"kind":"text","text":"(M, K:) fem. with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":". (M.)"}],"source_refs":["S","Msb","K","IAar","M"]}]},"classical_definitions":null}