,"num":"p"},{"role":"present_2mp","form":"تَفْرَحُوا","in_corpus":true,"count":3,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَفْرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَفْرَح","in_corpus":true,"count":5,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَفْرَح","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَفْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَفْرَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَفْرَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَفْرَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَفْرَحُونَ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَفْرَحُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَفْرَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"فَرِحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"فَرِحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَفْرَح","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَفْرَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":38,"cross_references":{"qac":{"found":true,"lemma_key":"فَرِحَ","root":"فرح","pos":"V","occurrence_count":16},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":9},"lanes":{"found":true,"entry_ids":["n33398"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B1%D9%90%D8%AD%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be happy, to be glad, to be merry, to be joyful, to exult, to rejoice (بِ (bi) in)","tags":["stative"],"examples":[{"text":"إِنْ تَمْسَسْكُمْ حَسَنَةٌ تَسُؤْهُمْ وَإِن تُصِبْكُمْ سَيِّئَةٌ يَفْرَحُوا بِهَا"}]},{"pos":"verb","gloss":"to be pleased, to be content","tags":["stative"]},{"pos":"noun","gloss":"verbal noun of فَرِحَ (fariḥa) (form I)","tags":["form-of","noun-from-verb","obsolete"],"examples":[{"text":"لَا تَفْرَحْ إِنَّ ٱللَّهَ لَا يُحِبُّ ٱلْفَرِحِينَ"}]},{"pos":"noun","gloss":"happiness, gladness, mirth, joy, exultation"},{"pos":"noun","gloss":"a state of being well pleased or content"},{"pos":"noun","gloss":"wedding"},{"pos":"verb","gloss":"to make glad, happy"},{"pos":"adj","gloss":"happy, glad, merry, joyful, exulting"},{"pos":"adj","gloss":"well pleased, content"}]},"etymology":null,"ipa":["/fa.ri.ħa/","/fa.raħ/","/far.ra.ħa/","/fa.riħ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33398","headword_ar":"فَرِحَ","root":"frH","body":[{"kind":"text","text":", (S, A, L, Msb, K, &c.,) [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"faraHN","text_ar":"فَرَحٌ"},{"kind":"text","text":", (S, * L, * Msb, &c.,)"},{"kind":"italic_en","text":"He rejoiced; was joyful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glad;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was happy;"},{"kind":"text","text":"(S, A, L, Msb, K, &c.;) syn."},{"kind":"arabic","text_bw":"sur~a","text_ar":"سُرَّ"},{"kind":"text","text":": (S, A, Msb, * &c.:) or"},{"kind":"italic_en","text":"he experienced a sensation of lightness in his heart:"},{"kind":"text","text":"(Th, TA:) or"},{"kind":"italic_en","text":"his bosom became dilated with delight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pleasure, of short continuance, transitory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fleeting, not lasting, as is the case in bodily and worldly pleasures;"},{"kind":"arabic","text_bw":"faraHN","text_ar":"فَرَحٌ"},{"kind":"text","text":"differing from"},{"kind":"arabic","text_bw":"suruwrN","text_ar":"سُرُورٌ"},{"kind":"text","text":"in the manner expl. below, though each is sometimes used as syn. with the other. (Er-Rághib, TA.) You say,"},{"kind":"arabic","text_bw":"fariHa bihi","text_ar":"فَرِحَ بِهِ"},{"kind":"italic_en","text":"He rejoiced, was joyful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glad,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was happy, by reason of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"sur~a","text_ar":"سُرَّ"},{"kind":"text","text":". (S, A, Msb. *) ―         -b2-  And"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, well pleased,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"content."},{"kind":"text","text":"―         -b3-  And"},{"kind":"italic_en","text":"He exulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rejoiced above measure;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he exulted greatly, and behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully."},{"kind":"text","text":"(S, Msb, K.) The verb is used in this sense in the Kur xxviii. 76. (TA.)"}],"source_refs":["Th","TA"]}]}}