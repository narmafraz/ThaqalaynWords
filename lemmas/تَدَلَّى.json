m":"p"},{"role":"present_1ms","form":"أَتَدَلَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَتَدَلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَتَدَلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":true,"lemma_key":"تَدَلَّى","root":"دلو","pos":"V","occurrence_count":1},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n13013"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%AF%D9%8E%D9%84%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to hang down, to dangle, to droop"}]},"etymology":null,"ipa":["/ta.dal.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13013","headword_ar":"تدلّى","root":"dlw","body":[{"kind":"italic_en","text":"It was let down"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowered; it hung down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dangled; it was let down;"},{"kind":"text","text":"(T, * M, Mgh;) into, and over, a pit or the like; (M;)"},{"kind":"italic_en","text":"it hung"},{"kind":"text","text":"(K) from ("},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":") a tree; (S, K)"},{"kind":"italic_en","text":"it hung down as a fruit"},{"kind":"text","text":"[from a tree]. (Bd in liii. 8.) [Hence,]"},{"kind":"arabic","text_bw":"tdl~Y EalayonaA mino A^aroDi ka*aA","text_ar":"تدلّى عَلَيْنَا مِنْ اَرْضِ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, came down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"descended, upon us from such a land"},{"kind":"text","text":"]. (TA.) And"},{"kind":"arabic","text_bw":"tdl~Y biAl$~ar~i","text_ar":"تدلّى بِالشَّرِّ"},{"kind":"italic_en","text":"He descended"},{"kind":"text","text":"upon one"},{"kind":"italic_en","text":"with evil,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mischief."},{"kind":"text","text":"(TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"He drew near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached:"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"dlY","text_ar":"دلى"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"he drew near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"from above,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"after being high."},{"kind":"text","text":"(IAar, T.) Accord. to Fr,"},{"kind":"arabic","text_bw":"vum~a danaA fatadal~aY","text_ar":"ثُمَّ دَنَا فَتَدَلَّى"},{"kind":"text","text":"[in the Kur liii. 8] means"},{"kind":"arabic","text_bw":"vam~a tadal~aY fadanaA","text_ar":"ثَمَّ تَدَلَّى فَدَنَا"},{"kind":"text","text":", (T,) i. e."},{"kind":"italic_en","text":"Then he"},{"kind":"text","text":"(Gabriel)"},{"kind":"italic_en","text":"hung down"},{"kind":"text","text":"from the highest region of the sky,"},{"kind":"italic_en","text":"and so drew near"},{"kind":"text","text":"to the Apostle: showing that he took him up without becoming separated from his place: or the meaning of the phrase, as it stands, is,"},{"kind":"italic_en","text":"then he drew near"},{"kind":"text","text":"to the Prophet,"},{"kind":"italic_en","text":"and he clung"},{"kind":"text","text":"to him: (Bd:) but accord. to Zj, it means"},{"kind":"italic_en","text":"then he drew near, and drew nearer;"},{"kind":"text","text":"and is like the phrase"},{"kind":"arabic","text_bw":"danaA fulaAnN min~iY waqaruba","text_ar":"دَنَا فُلَانٌ مِنِّى وَقَرُبَ"},{"kind":"text","text":". (T. [See also another explanation in what follows.]) ―         -b3-  And"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he lowered, humbled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abased, himself."},{"kind":"text","text":"(IAar, T; and K in art."},{"kind":"arabic","text_bw":"dlY","text_ar":"دلى"},{"kind":"text","text":".) ―         -b4-  In the saying of a poet,"},{"kind":"quote","text":"kaA^ana raAkibahaA guSonN bimarowaHapK\n                      \n                     \n                        A_i*aA tadal~ato bihi A^awo $aAribN vamilN"},{"kind":"arabic","text_bw":"tdl~t","text_ar":"تدلّت"},{"kind":"text","text":"may be quasi-pass. of"},{"kind":"arabic","text_bw":"dalaA","text_ar":"دَلَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"dalowN","text_ar":"دَلْوٌ"},{"kind":"text","text":", signifying “ he drove, or urged on, gently: ” or it may be for"},{"kind":"arabic","text_bw":"tadal~alato","text_ar":"تَدَلَّلَتْ"},{"kind":"text","text":": [so that the meaning may be,"},{"kind":"italic_en","text":"As though her rider were a branch of a tree in a place over which the wind was blowing, when she became urged on gently with him, or an intoxicated drinker:"},{"kind":"text","text":"or,"},{"kind":"italic_en","text":"when she emboldened herself with him,"},{"kind":"text","text":"&c.:] (M:) [for]"},{"kind":"arabic","text_bw":"tadal~aY","text_ar":"تَدَلَّى"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"tadal~ala","text_ar":"تَدَلَّلَ"},{"kind":"text","text":": (S, K:) and [J says that] this is its meaning in the saying in the Kur [otherwise explained above]"},{"kind":"arabic","text_bw":"vum~a danaA fatadal~aY","text_ar":"ثُمَّ دَنَا فَتَدَلَّى"},{"kind":"text","text":": being like"},{"kind":"arabic","text_bw":"yatamaT~aY","text_ar":"يَتَمَطَّى"},{"kind":"text","text":"in the Kur [lxxv. 33], i. e."},{"kind":"arabic","text_bw":"yatamaT~aTu","text_ar":"يَتَمَطَّطُ"},{"kind":"text","text":". (S.)"}],"source_refs":["K","S","T","Bd","M"]}]},"classical_definitions":null}