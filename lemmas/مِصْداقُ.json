{"lemma":"مِصْداقُ","slug":"مِصْداقُ","root":"ص.د.ق","root_slug":"ص-د-ق","root_link":"/words/roots/ص-د-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n24026"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%90%D8%B5%D9%92%D8%AF%D8%A7%D9%82%D9%8F"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24026","headword_ar":"مِصْدَاقٌ","root":"Sdq","body":[{"kind":"italic_en","text":"A thing that confirms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proves, the truth"},{"kind":"text","text":"of a thing: (S, K:) [and]"},{"kind":"italic_en","text":"a verbal evidence of the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"veracity,"},{"kind":"text","text":"of a man. (Har p. 106.) One says,"},{"kind":"arabic","text_bw":"h`*aA miSodaAqu h`*aA","text_ar":"هٰذَا مِصْدَاقُ هٰذَا"},{"kind":"italic_en","text":"This is what confirms,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proves, the truth of this."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"$aYo'N layosa","text_ar":"شَىْءٌ لَيْسَ"},{"kind":"arabic","text_bw":"lahu miSodaAqN","text_ar":"لَهُ مِصْدَاقٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"A thing having nothing to verify it"},{"kind":"text","text":"]. (IAar, TA in art."},{"kind":"arabic","text_bw":"brq","text_ar":"برق"},{"kind":"text","text":".)"}],"source_refs":["S","K"]}]}}