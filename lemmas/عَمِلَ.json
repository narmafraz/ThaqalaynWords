:"present_2mp","form":"تَعْمَلُوا","in_corpus":true,"count":2,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْمَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْمَل","in_corpus":true,"count":84,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْمَل","in_corpus":true,"count":41,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْمَلانِ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْمَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْمَلانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْمَلا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْمَلُونَ","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْمَلُوا","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْمَلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْمَل","in_corpus":true,"count":41,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْمَل","in_corpus":true,"count":18,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَمِلْنا","in_corpus":true,"count":14,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَمِلْتُ","in_corpus":true,"count":7,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":455,"cross_references":{"qac":{"found":true,"lemma_key":"عَمِلَ","root":"عمل","pos":"V","occurrence_count":276},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":18},"lanes":{"found":true,"entry_ids":["n30565"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%85%D9%90%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to work, perform","tags":["intransitive"],"examples":[{"text":"هُوَ يَعْمَلُ فِي مَجَالِ التَكْنُولُوجِيَا.","english":"He works in the field of technology."},{"text":"أَنَا أَعْمَلُ مُدَرِّسًا فِي الْمَدْرَسَةِ.","english":"I work as a teacher at the school."}]},{"pos":"verb","gloss":"to do (with deliberate thought)","tags":["transitive"],"examples":[{"text":"إِنَّ اللَّهَ يُدْخِلُ الَّذِينَ آمَنُوا وَعَمِلُوا الصَّالِحَاتِ جَنَّاتٍ تَجْرِي مِن تَحْتِهَا الْأَنْهَارُ","english":"Allah will surely admit those who believe and do good into Gardens, under which rivers flow"}]},{"pos":"verb","gloss":"to practice, profess"},{"pos":"verb","gloss":"to produce an effect"},{"pos":"verb","gloss":"to be brisk, walk fast"},{"pos":"verb","gloss":"to exercise an influence"},{"pos":"verb","gloss":"to govern a case","tags":["intransitive"]},{"pos":"verb","gloss":"to take pains (عَلَى (ʕalā) with)"},{"pos":"verb","gloss":"to work to an end"},{"pos":"verb","gloss":"to take care of"},{"pos":"verb","gloss":"to last without interruption"},{"pos":"verb","gloss":"to pay (someone) their fee or wages"},{"pos":"verb","gloss":"to make (someone) an administrator or governor"},{"pos":"verb","gloss":"to suppurate, grow cancerous"},{"pos":"noun","gloss":"verbal noun of عَمِلَ (ʕamila) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"action, act, deed"},{"pos":"noun","gloss":"work, business","examples":[{"text":"الْعَمَلُ الْجَمَاعِيُّ يُمْكِنُ أَن يَكُونَ مُفِيدًا فِي إِنْجَازِ الْمُشَارِيعِ الْكَبِيرَةِ.","english":"Collaborative work can be beneficial in completing large projects."}]},{"pos":"noun","gloss":"government"}]},"etymology":{"source":"wiktextract","text":"The grammatical “government” meaning is a semantic loan from Medieval Latin vīs. Compare Hebrew עָמָל (`Amal, “work, deed”)."},"ipa":["/ʕa.mi.la/","/ʕam.ma.la/","/ʕa.mal/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30565","headword_ar":"عَمِلَ","root":"Eml","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EamalN","text_ar":"عَمَلٌ"},{"kind":"text","text":", (S, O, Msb, K,)"},{"kind":"italic_en","text":"He worked,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wrought; laboured; served,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"did service: he did, acted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"performed:"},{"kind":"text","text":"(K, TA:) [generally,"},{"kind":"italic_en","text":"he did,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"with a sort of difficulty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with intention;"},{"kind":"text","text":"but sometimes said of an inanimate thing: (see"},{"kind":"arabic","text_bw":"EamalN","text_ar":"عَمَلٌ"},{"kind":"text","text":", below:)]"},{"kind":"italic_en","text":"he did,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he made, wrought, manufactured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constructed,"},{"kind":"text","text":"a thing. (Msb. [See, again,"},{"kind":"arabic","text_bw":"EamalN","text_ar":"عَمَلٌ"},{"kind":"text","text":", below.]) Accord. to Az,"},{"kind":"arabic","text_bw":"Eamila","text_ar":"عَمِلَ"},{"kind":"text","text":"is the only trans. verb of its measure having the inf. n. of the measure"},{"kind":"arabic","text_bw":"faEalN","text_ar":"فَعَلٌ"},{"kind":"text","text":", except"},{"kind":"arabic","text_bw":"habilat","text_ar":"هَبِلَت"},{"kind":"text","text":", said of a mother, inf. n."},{"kind":"arabic","text_bw":"habalN","text_ar":"هَبَلٌ"},{"kind":"text","text":"; other similar verbs having the inf. n. of the measure"},{"kind":"arabic","text_bw":"faEolN","text_ar":"فَعْلٌ"},{"kind":"text","text":"; as"},{"kind":"arabic","text_bw":"sariTotu All~uqomapa","text_ar":"سَرِطْتُ اللُّقْمَةَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"saroTN","text_ar":"سَرْطٌ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"baliEotuhu","text_ar":"بَلِعْتُهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baloEN","text_ar":"بَلْعٌ"},{"kind":"text","text":". (TA. [But see arts."},{"kind":"arabic","text_bw":"srT","text_ar":"سرط"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"blE","text_ar":"بلع"},{"kind":"text","text":"; with respect to the former of which I must here state that, since it was printed, I have found an authority for"},{"kind":"arabic","text_bw":"saroTN","text_ar":"سَرْطٌ"},{"kind":"text","text":"as inf. n. of"},{"kind":"arabic","text_bw":"sariTa","text_ar":"سَرِطَ"},{"kind":"text","text":"in a copy of the S; though in the K it is said to be"},{"kind":"arabic","text_bw":"muHar~akap","text_ar":"مُحَرَّكَة"},{"kind":"text","text":", and accord. to the Msb it is like"},{"kind":"arabic","text_bw":"taEabN","text_ar":"تَعَبٌ"},{"kind":"text","text":".]) You say,"},{"kind":"arabic","text_bw":"Eamilotu EalaY AlS~adaqapi","text_ar":"عَمِلْتُ عَلَى الصَّدَقَةِ"},{"kind":"italic_en","text":"I officiated in the collecting of the poor-rate."},{"kind":"text","text":"(Msb.) [And"},{"kind":"arabic","text_bw":"Eamila bimaA fiY kitaAbi A@ll~`hi","text_ar":"عَمِلَ بِمَا فِى كِتَابِ ا@للّٰهِ"},{"kind":"italic_en","text":"He did according to what is"},{"kind":"text","text":"enjoined"},{"kind":"italic_en","text":"in the Book of God."},{"kind":"text","text":"] And"},{"kind":"arabic","text_bw":"Eamila fiY halaAkihi","text_ar":"عَمِلَ فِى هَلَاكِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He laboured to destroy him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to kill him"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"$yT","text_ar":"شيط"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"Eamila fiyhi","text_ar":"عَمِلَ فِيهِ"},{"kind":"italic_en","text":"It acted upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"and, said of a sword &c.,"},{"kind":"italic_en","text":"it had effect,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made an impression, upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"] ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Eamila fiyhi","text_ar":"عَمِلَ فِيهِ"},{"kind":"text","text":"signifies [also (assumed tropical:)"},{"kind":"italic_en","text":"It governed it syntactically;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused"},{"kind":"text","text":"it to be"},{"kind":"arabic","text_bw":"marofuwE","text_ar":"مَرْفُوع"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"manoSuwb","text_ar":"مَنْصُوب"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"majoruwr","text_ar":"مَجْرُور"},{"kind":"text","text":"&c.; i. e.]"},{"kind":"italic_en","text":"it produced in it a certain species of syntactical desinence."},{"kind":"text","text":"(K.) ―         -b3-  And"},{"kind":"arabic","text_bw":"Eamila Albaroqu","text_ar":"عَمِلَ البَرْقُ"},{"kind":"italic_en","text":"The lightning was continual."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"Eamilato biA^u*unayohaA","text_ar":"عَمِلَتْ بِاُذُنَيْهَا"},{"kind":"text","text":", said of a she-camel, (K,) and also, in a trad., of [the beast]"},{"kind":"arabic","text_bw":"AlburaAq","text_ar":"البُرَاق"},{"kind":"text","text":", (O, * TA,)"},{"kind":"italic_en","text":"She went quickly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swiftly;"},{"kind":"text","text":"(O, K, TA;) because she that does thus puts her ears in motion by reason of the vehemence of the pace. (TA.) And"},{"kind":"arabic","text_bw":"Eamilat","text_ar":"عَمِلَت"},{"kind":"text","text":"[alone] said of a she-camel, signifies [the same: or]"},{"kind":"italic_en","text":"She was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, brisk, light, active,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quick."},{"kind":"text","text":"(K.) ―         -b4-  And [hence, app.,]"},{"kind":"arabic","text_bw":"lamo A^ara Aln~afaqapa taEomalu kamaA taEomalu bimak~apa","text_ar":"لَمْ اَرَ النَّفَقَةَ تَعْمَلُ كَمَا تَعْمَلُ بِمَكَّةَ"},{"kind":"text","text":", a saying mentioned by Lh, is expl. by ISd as meaning"},{"kind":"arabic","text_bw":"tanofaqu","text_ar":"تَنْفَقُ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"I have not seen the money that that one expends pass away as it passes away in Mekkeh"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["S","O","Msb","K","TA"]}]}}