nt_1ms","form":"أَشْتَدّ","in_corpus":true,"count":19,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":56,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n21912"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%B4%D9%92%D8%AA%D9%8E%D8%AF%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to become more vehement, to aggravate, to grow in intensity or tightness","examples":[{"text":"أُعَلِّمُهُ ٱلرِّمَايَةَ كُلَّ يَوْمٍ / فَلَمَّا ٱشْتَدَّ سَاعِدُهُ رَمَانِي.","english":"I teach him shooting every day; and when his arm was steady he shot me."},{"text":"أَنَا مَعَهُ حَتَّى قَدِمْنَا الْمَدِينَةَ فَتَلَقَّاهُ النَّاسُ فَخَرَجُوا فِي الطَّرِيقِ وَعَلَى الْأَجَاجِيرِ فَٱشْتَدَّ الْخَدَمُ وَٱلصِّبْيَانُ فِي ٱلطَّرِيقِ يَقُولُونَ ٱللّٰهُ أَكْبَرُ جَاءَ رَسُولُ ٱللّٰهِ صَلَّى ٱللّٰهُ عَلَيْهِ وَسَلَّمَ جَاءَ مُحَمَّدٌ","english":"I was with him and we stepped upon Medina where he met upon people who went out onto the streets and onto the roofs and the servants and boys crowded the road saying “God is great, the Messenger of God (PBUH) has come, Muḥammad has come!”"}]}]},"etymology":null,"ipa":["/iʃ.tad.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21912","headword_ar":"اشتدّ","root":"$d","body":[{"kind":"text","text":"; (S, A, L, Msb;) and ↓"},{"kind":"arabic","text_bw":"$ad~a","text_ar":"شَدَّ","orth_type":"arrow"},{"kind":"text","text":", aor"},{"kind":"text","text":", (L, Msb,) the only form of its aor., (L,) inf. n."},{"kind":"arabic","text_bw":"$id~apN","text_ar":"شِدَّةٌ"},{"kind":"text","text":", (S, Msb,) whence the former verb; (S;) and ↓"},{"kind":"arabic","text_bw":"t$Ad~","text_ar":"تشادّ","orth_type":"arrow"},{"kind":"text","text":"; (L;)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard,"},{"kind":"text","text":"(L, and MA and KL and PS in explanation of the first,) said of a substance and of an attribute: (L:)"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm, compact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sound;"},{"kind":"text","text":"(L &c. as above;)"},{"kind":"italic_en","text":"strong, powerful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"forcible; vigorous, robust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sturdy;"},{"kind":"text","text":"(L, and A and MA and KL in explanation of the first, and Msb in explanation of the second:) [also"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, bound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tied, firmly, fast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strongly:"},{"kind":"text","text":"] and the first of these verbs, [and the second also,]"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, hard to be borne, heavy, vehement, violent, intense, pressing, severe, strict, rigorous, tight, strait"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"difficult, distressing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressful, afflictive, calamitous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adverse."},{"kind":"text","text":"(MA, L, KL.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA tabiyEuwA AlHab~a Hat~aY ya$otad~a","text_ar":"لَا تَبِيعُوا الحَبَّ حَتَّى يَشْتَدَّ"},{"kind":"text","text":"i. e. ["},{"kind":"italic_en","text":"Ye shall not sell grain"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"until it becomes hard,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strong."},{"kind":"text","text":"(L.) And you say,"},{"kind":"arabic","text_bw":"A$td~t AlEuqodapu","text_ar":"اشتدّت العُقْدَةُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The knot became tied firmly, fast,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strongly;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became tight"},{"kind":"text","text":"]. (A, Mgh, Msb.) And"},{"kind":"arabic","text_bw":"A$td~ Alz~amanu Ealayohimo","text_ar":"اشتدّ الزَّمَنُ عَلَيْهِمْ"},{"kind":"italic_en","text":"The time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune, became hard upon them;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"severe, rigorous, distressful, afflictive, calamitous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"adverse, to them."},{"kind":"text","text":"(L. [See also 2.]) And"},{"kind":"arabic","text_bw":"A$td~ bihi AlA^amoru","text_ar":"اشتدّ بِهِ الاَمْرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"event, distressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"afflicted, him;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"A$td~ Ealayohi","text_ar":"اشتدّ عَلَيْهِ"},{"kind":"text","text":"]. (L in art."},{"kind":"arabic","text_bw":"jd","text_ar":"جد"},{"kind":"text","text":", &c.) ―         -b2-  See also 1, former half, in four places."}],"source_refs":["L","Msb","S"]}]},"classical_definitions":null}