وسُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبُوسُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبُسْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبُس","in_corpus":true,"count":9,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَبُوس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبُس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَبُوس","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبُوسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبُوسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبُوسا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبُوسانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبُوسُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبُوسُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبُسْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بُسْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بُسْتُ","in_corpus":true,"count":4,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبُوس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَبُوس","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":1167,"cross_references":{"qac":{"found":true,"lemma_key":"باسَ","root":"بأس","pos":"N","occurrence_count":25},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n1670"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D8%A7%D8%B3%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to kiss","tags":["post-Classical","transitive"]}]},"etymology":{"source":"wiktextract","text":"Usually considered to be from Classical Persian بوسیدن (bōsīdan), an onomatopoeia in which the initial labial represents the protruding lips and the sibilant represents the smacking sound. Similar onomatopoeias are found in many Indo-European as well as non-Indo-European languages. Compare e.g. English buss, Bavarian Busserl, French bisou, Latin basium, Quechua much'a, Lao ຈູບ (chūp). Therefore, while Persian origin is likely, an independent Arabic derivation cannot be ruled out prima facie."},"ipa":["/baː.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1670","headword_ar":"بَاْسٌ","root":"bA^s","body":[{"kind":"italic_en","text":"Might,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strength,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"in war"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fight:"},{"kind":"text","text":"(S, A, K:)"},{"kind":"italic_en","text":"courage; valour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"valiantness; prowess."},{"kind":"text","text":"(M, K.) ―         -b2-"},{"kind":"italic_en","text":"War,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fight;"},{"kind":"text","text":"(M, Msb;) as also ↓"},{"kind":"arabic","text_bw":"bay^iyosN","text_ar":"بَيِيْسٌ","orth_type":"arrow"},{"kind":"text","text":"(M) and ↓"},{"kind":"arabic","text_bw":"baA^osaA='u","text_ar":"بَاْسَا=ءُ","orth_type":"arrow"},{"kind":"text","text":": (TA:) pl. of the first,"},{"kind":"arabic","text_bw":"A^abow^asN","text_ar":"اَبْوَسٌ"},{"kind":"text","text":". (Msb.) ―         -b3-  Hence, (M,) (assumed tropical:)"},{"kind":"italic_en","text":"Fear,"},{"kind":"text","text":"(M, TA,) in the saying,"},{"kind":"arabic","text_bw":"laA bA^osa","text_ar":"لَا باْسَ"},{"kind":"arabic","text_bw":"Ealayoka","text_ar":"عَلَيْكَ"},{"kind":"text","text":", (M, TA, *) and"},{"kind":"arabic","text_bw":"bika","text_ar":"بِكَ"},{"kind":"text","text":", (M,) [(assumed tropical:)"},{"kind":"italic_en","text":"There is no fear for thee:"},{"kind":"text","text":"lit.,"},{"kind":"italic_en","text":"there is no war against thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with thee"},{"kind":"text","text":"]: the saying of which to an enemy implies the granting him security, or protection: and in the same sense it is used in a trad., in the phrase"},{"kind":"arabic","text_bw":"Ai$otad~a AlbaA^osu","text_ar":"اِشْتَدَّ البَاْسُ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"Fear became vehement"},{"kind":"text","text":"]. (TA.) ―         -b4-"},{"kind":"italic_en","text":"I. q."},{"kind":"arabic","text_bw":"DararN","text_ar":"ضَرَرٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Harm, injury,"},{"kind":"text","text":"&c.]: so in the phrase"},{"kind":"arabic","text_bw":"laA baA^osa","text_ar":"لَا بَاْسَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will be, no harm,"},{"kind":"text","text":"&c.; and"},{"kind":"arabic","text_bw":"laA baA^osa bika*aA","text_ar":"لَا بَاْسَ بِكَذَا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"fiY ka*aA","text_ar":"فِى كَذَا"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"There is,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"will be, no harm in such a thing"},{"kind":"text","text":"]. (Har p. 311.) It is said in a trad.,"},{"kind":"arabic","text_bw":"laA baA^osa biA@loginay","text_ar":"لَا بَاْسَ بِا@لْغِنَي"},{"kind":"arabic","text_bw":"limani A@t~aqay","text_ar":"لِمَنِ ا@تَّقَي"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is no harm in wealth to him who is pious"},{"kind":"text","text":"]. (El-Jámi' es-Sagheer of Es-Suyootee.)"},{"kind":"arabic","text_bw":"baAs","text_ar":"بَاس"},{"kind":"text","text":"also occurs for"},{"kind":"arabic","text_bw":"baA^os","text_ar":"بَاْس"},{"kind":"text","text":"; the being suppressed, agreeably with analogy; not altered by permutation. (M, TA.) ―         -b5-"},{"kind":"italic_en","text":"Punishment:"},{"kind":"text","text":"(S, A, K:) or"},{"kind":"italic_en","text":"severe punishment;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"bay^isN","text_ar":"بَيِسٌ","orth_type":"arrow"},{"kind":"text","text":", in measure like"},{"kind":"arabic","text_bw":"katifN","text_ar":"كَتِفٌ"},{"kind":"text","text":". (IAar, TA.) ―         -b6-  See also"},{"kind":"arabic","text_bw":"buw^osN","text_ar":"بُوْسٌ"},{"kind":"text","text":", in two places."}],"source_refs":["S","A","Msb","K","M","TA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%A8%D8%A7%D8%B3/","headword_ar":"باس","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=49976#02b726","body_html":"باس: ابتأس: خاف (فوك).<br>بَأسُ: قولهم فلان أو شيء لا بأس به يعني إنه جيد بالغ الجودة. فقد جاء في كتاب ابن عبد الملك (ص 125و) مثلاً: وكان كاتباً وافر الحظ من الأدب يقرض شعراً لا بأس به، وفيه في ص140و: وكان نحوياً حاذقاً وصنف في العربية مختصراً لا بأس به. وفي كتاب محمد بن الحارث ص311: وكان من أهل الرواية لا بأس به وقد سمعت به وكتبت عنه. وفي ص328 منه: وهي لا بأس بعملها ولا تقصير في صوابها (يريد ان يقول: إنه لابد من معرفة هذه الفتاوى). ويقول العبدري (ص 43ق)، بعد أن ذكر أن أهل القاهرة من شر الناس، وقد سمعت من جال (ممن جال) في صعيد مصر وريفها أن أهلها لا بأس بهم وأنهم أشبه حالاً من المذكورين بكثير، وفي كتاب الخطيب ص 22و: ذكر ابن الزبير أن قوماً بغرناطة يعرفون بهذه المعرفة، فان كان منهم فله أولية لا بأس بها. وانظر الفخري 345، والمقدمة 2: 147، 155، 158، 160، والمقري 1: 526، وأماري 668.<br>بأس: مرض (فوك).<br>تبئيس: جاءت في شعر في الكامل ص308:<br>نحن قتلنا مصعبا وعيسى ... وابن الزبير البطل الرئيسا<br>عمداً أذقنا مضر التبئيسا"}]}}