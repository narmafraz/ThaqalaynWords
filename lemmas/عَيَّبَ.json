syn."},{"kind":"arabic","text_bw":"waSomapN","text_ar":"وَصْمَةٌ"},{"kind":"text","text":", (A, K,) and"},{"kind":"arabic","text_bw":"naqiySapN","text_ar":"نَقِيصَةٌ"},{"kind":"text","text":": (TK:) in Pers."},{"kind":"arabic","text_bw":"A=huw","text_ar":"ا=هُو"},{"kind":"text","text":": (PS:) or ↓"},{"kind":"arabic","text_bw":"maEaAbN","text_ar":"مَعَابٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEaAbapN","text_ar":"مَعَابَةٌ","orth_type":"arrow"},{"kind":"text","text":"signify"},{"kind":"italic_en","text":"a place of"},{"kind":"arabic","text_bw":"Eayob","text_ar":"عَيْب"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"vice, fault,"},{"kind":"text","text":"&c.; app. as meaning"},{"kind":"italic_en","text":"a ground for"},{"kind":"arabic","text_bw":"Eayob","text_ar":"عَيْب"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"finding fault,"},{"kind":"text","text":"&c.]. ↓"},{"kind":"arabic","text_bw":"maA fiyhi maEaAbN","text_ar":"مَا فِيهِ مَعَابٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEaAbapN","text_ar":"مَعَابَةٌ","orth_type":"arrow"},{"kind":"text","text":"meaning ["},{"kind":"italic_en","text":"There is not in him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it,"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"mawoDiEu Eayob","text_ar":"مَوْضِعُ عَيْب"},{"kind":"text","text":": [and so ↓"},{"kind":"arabic","text_bw":"maEiybN","text_ar":"مَعِيبٌ","orth_type":"arrow"},{"kind":"text","text":"as is shown by what follows; and ↓"},{"kind":"arabic","text_bw":"maEoyabapN","text_ar":"مَعْيَبَةٌ","orth_type":"arrow"},{"kind":"text","text":"as expl. in Har p. 475, which last and ↓"},{"kind":"arabic","text_bw":"maEaAbapN","text_ar":"مَعَابَةٌ","orth_type":"arrow"},{"kind":"text","text":"may be expl. agreeably with analogy as signifying"},{"kind":"italic_en","text":"a cause of"},{"kind":"arabic","text_bw":"Eayob","text_ar":"عَيْب"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a thing for which one is to be found fault with, blamed, upbraided,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reproached;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"ma*am~apN","text_ar":"مَذَمَّةٌ"},{"kind":"text","text":";] for [although]"},{"kind":"arabic","text_bw":"mafoEl","text_ar":"مَفْعل"},{"kind":"text","text":"from triliteral-radical verb such as"},{"kind":"arabic","text_bw":"kaAla","text_ar":"كَالَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yakiylu","text_ar":"يَكِيلُ"},{"kind":"text","text":", as the measure of a subst. [or n. of place] is with kesr [to the"},{"kind":"arabic","text_bw":"E","text_ar":"ع"},{"kind":"text","text":",] and as the measure of an inf. n. with fet-h, yet it is allowable to use fet-h or kesr in either case, for the Arabs say"},{"kind":"arabic","text_bw":"masaArN","text_ar":"مَسَارٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"masiyrN","text_ar":"مَسِيرٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"maEaA$N","text_ar":"مَعَاشٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"maEiy$N","text_ar":"مَعِيشٌ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"maEaAbN","text_ar":"مَعَابٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"maEiybN","text_ar":"مَعِيبٌ","orth_type":"arrow"},{"kind":"text","text":": (S, O:) the pl. of"},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"EuyuwbN","text_ar":"عُيُوبٌ"},{"kind":"text","text":"[a pl. of mult.] (S, A, O, Msb) and"},{"kind":"arabic","text_bw":"A^aEoyaAbN","text_ar":"اَعْيَابٌ"},{"kind":"text","text":"[a pl. of pauc.]; (Th, TA;) and"},{"kind":"arabic","text_bw":"maEaAyibu","text_ar":"مَعَايِبُ"},{"kind":"text","text":"[as pl. of ↓"},{"kind":"arabic","text_bw":"maEaAbN","text_ar":"مَعَابٌ","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"maEiybN","text_ar":"مَعِيبٌ","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"maEaAbapN","text_ar":"مَعَابَةٌ","orth_type":"arrow"},{"kind":"text","text":", or as an anomalous pl. of"},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":"like as"},{"kind":"arabic","text_bw":"ma$aAyinu","text_ar":"مَشَايِنُ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"$ayonN","text_ar":"شَيْنٌ"},{"kind":"text","text":",] is syn. with"},{"kind":"arabic","text_bw":"EuyuwbN","text_ar":"عُيُوبٌ"},{"kind":"text","text":". (S, O.)"}],"source_refs":["S","A","O","Msb","K","TK","PS"]}]}}