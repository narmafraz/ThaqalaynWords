{"lemma":"رَغْمٌ","slug":"رَغْمٌ","root":"ر.غ.م","root_slug":"ر-غ-م","root_link":"/words/roots/ر-غ-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":10},"lanes":{"found":true,"entry_ids":["n16030"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D8%BA%D9%92%D9%85%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to force, to compel","tags":["transitive"]},{"pos":"verb","gloss":"to humiliate, to degrade","tags":["transitive"],"examples":[{"text":"رَغَمَ الرَّجُلَ","english":"he humiliated the man"}]},{"pos":"verb","gloss":"to be humiliated, to be abased","tags":["intransitive"]},{"pos":"verb","gloss":"to stick in the dirt, to make dirty","tags":["literally","transitive"]},{"pos":"verb","gloss":"to become dirty (especially of one's nose)","tags":["intransitive","literally"],"examples":[{"text":"رَغَمَ أَنْفُهُ","english":"his nose soiled"}]},{"pos":"verb","gloss":"to be humiliated, to be abased","tags":["intransitive"]},{"pos":"verb","gloss":"to humble, to humiliate","tags":["transitive"]},{"pos":"verb","gloss":"to upset","tags":["transitive"]},{"pos":"noun","gloss":"verbal noun of رَغِمَ (raḡima) (form I)","tags":["form-of","noun-from-verb","transitive"]},{"pos":"noun","gloss":"forcefulness, dislike","tags":["transitive"],"examples":[{"text":"رَغْمًا عَن فُلَان","english":"against one's will"},{"text":"عَلَى الرَّغْمِ مِنْ كَذَا","english":"in spite of/despite this"}]}]},"etymology":null,"ipa":["/ra.ɣi.ma/","/ra.ɣa.ma/","/ra.ɣu.ma/","/raɣ.ɣa.ma/","/raɣm/","/ruɣm/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16030","headword_ar":"رَغْمٌ","root":"rgm","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rugomN","text_ar":"رُغْمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rigomN","text_ar":"رِغْمٌ","orth_type":"arrow"},{"kind":"text","text":"are inf. ns. of"},{"kind":"arabic","text_bw":"ragima","text_ar":"رَغِمَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ragama","text_ar":"رَغَمَ"},{"kind":"text","text":"said of the nose; and ↓"},{"kind":"arabic","text_bw":"marogamapN","text_ar":"مَرْغَمَةٌ","orth_type":"arrow"},{"kind":"text","text":"is syn. therewith; (S;) as is also ↓"},{"kind":"arabic","text_bw":"marogamN","text_ar":"مَرْغَمٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) One says to another, [by way of imprecation,]"},{"kind":"arabic","text_bw":"ragomFA","text_ar":"رَغْمًا"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"ragima A^anofuka ragamFA","text_ar":"رَغِمَ اَنْفُكَ رَغَمًا"},{"kind":"italic_en","text":"May thy nose cleave fast to the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust;"},{"kind":"text","text":"meant to be understood in the proper sense, or in a tropical sense explained by what follows]; (JK, M, K;) and [sometimes]"},{"kind":"arabic","text_bw":"dagomFA","text_ar":"دَغْمًا"},{"kind":"text","text":"is added, (M,) which is an imitative sequent to"},{"kind":"arabic","text_bw":"ragomFA","text_ar":"رَغْمًا"},{"kind":"text","text":". (K in art."},{"kind":"arabic","text_bw":"dgm","text_ar":"دغم"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"liA^anofihi Alr~agomu","text_ar":"لِاَنْفِهِ الرَّغْمُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Almarogamapu","text_ar":"المَرْغَمَةُ","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"May cleaving to the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dust, befall his nose;"},{"kind":"text","text":"which may likewise be meant to be understood properly, or tropically]. (TA.) ―         -b2-  [Hence,] the first also signifies, (IAar, K, TA,) and so ↓"},{"kind":"arabic","text_bw":"marogamapN","text_ar":"مَرْغَمَةٌ","orth_type":"arrow"},{"kind":"text","text":"also, (TA,) (tropical:)"},{"kind":"italic_en","text":"Abasement."},{"kind":"text","text":"(IAar, Mgh, K, TA.) The Prophet said, ↓"},{"kind":"arabic","text_bw":"buEivotu marogamapF","text_ar":"بُعِثْتُ مَرْغَمَةً","orth_type":"arrow"},{"kind":"text","text":", (S,) i. e. (tropical:)"},{"kind":"italic_en","text":"I was sent for abasement"},{"kind":"text","text":"to the believers in a plurality of gods, [or]"},{"kind":"italic_en","text":"by reason of dislike"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disapproval"},{"kind":"text","text":"[of their state; agreeably with the explanation next following]. (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"ragomN","text_ar":"رَغْمٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"rugomN","text_ar":"رُغْمٌ","orth_type":"arrow"},{"kind":"text","text":"(Msb, K, TA) and ↓"},{"kind":"arabic","text_bw":"rigomN","text_ar":"رِغْمٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"marogamapN","text_ar":"مَرْغَمَةٌ","orth_type":"arrow"},{"kind":"text","text":"(K, TA) also signify (tropical:)"},{"kind":"italic_en","text":"Dislike, disapproval,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred."},{"kind":"text","text":"(Msb, K, TA.) You say,"},{"kind":"arabic","text_bw":"faEalahu ragomFA","text_ar":"فَعَلَهُ رَغْمًا"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"rugomFA","text_ar":"رُغْمًا","orth_type":"arrow"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"rigomFA","text_ar":"رِغْمًا","orth_type":"arrow"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"EalaY ragomK","text_ar":"عَلَى رَغْمٍ"},{"kind":"text","text":", (ISh, TA,) and"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"arabic","text_bw":"ragomihi","text_ar":"رَغْمِهِ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"ElY Alr~agomi minohu","text_ar":"على الرَّغْمِ مِنْهُ"},{"kind":"text","text":", (TA,) and"},{"kind":"arabic","text_bw":"ElY ragomi A^anofihi","text_ar":"على رَغْمِ اَنْفِهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^anofihi","text_ar":"اَنْفِهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"rugomi","text_ar":"رُغْمِ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) and"},{"kind":"arabic","text_bw":"ElY Alr~agomi mino A^anofihi","text_ar":"على الرَّغْمِ مِنْ اَنْفِهِ"},{"kind":"text","text":", (S,) i. e. (tropical:)  ["},{"kind":"italic_en","text":"He did it against his wish; in spite of him;"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"notwithstanding his dislike,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disapproval,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hatred."},{"kind":"text","text":"(Msb, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"Hat~aY yaxoruja","text_ar":"حَتَّى يَخْرُجَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"manohu Alr~ugomu","text_ar":"مَنْهُ الرُّغْمُ","orth_type":"arrow"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"Alr~agomu","text_ar":"الرَّغْمُ"},{"kind":"text","text":", in the TA without the vowel-sign,] occurring in a trad., means (assumed tropical:)"},{"kind":"italic_en","text":"In order that"},{"kind":"text","text":"he may become humble and abased, and"},{"kind":"italic_en","text":"the pride of the Devil may go forth from him."},{"kind":"text","text":"(Mgh, TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"ragaAmN","text_ar":"رَغَامٌ"},{"kind":"text","text":"."}],"source_refs":["M","IAar","K","TA","S","Msb","ISh"]}]},"classical_definitions":null}