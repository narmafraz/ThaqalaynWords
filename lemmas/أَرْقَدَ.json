mology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n16328"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B1%D9%92%D9%82%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause to sleep"},{"pos":"verb","gloss":"to remain, stay, dwell, abide"}]},"etymology":null,"ipa":["/ʔar.qa.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16328","headword_ar":"ارقدّ","root":"rqd","body":[{"kind":"text","text":", (JK, S, A,) inf. n."},{"kind":"arabic","text_bw":"AiroqidaAdN","text_ar":"اِرْقِدَادٌ"},{"kind":"text","text":", (JK, S, K,)"},{"kind":"italic_en","text":"He hastened;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was quick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"swift;"},{"kind":"text","text":"(JK, S, M, A, K;) in his pace, or going: (M, A:) or"},{"kind":"italic_en","text":"he ran vehemently;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"Armd~","text_ar":"ارمدّ"},{"kind":"text","text":"; said of a camel: (AA, T in art."},{"kind":"arabic","text_bw":"rmd","text_ar":"رمد"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"he ran with leaps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounds, as though leaping,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bounding, from a thing:"},{"kind":"text","text":"(As, L in art."},{"kind":"arabic","text_bw":"rmd","text_ar":"رمد"},{"kind":"text","text":":) or"},{"kind":"italic_en","text":"he went at random, heedlessly, headlong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a headlong course; and quickly;"},{"kind":"text","text":"(As, JK, L in art."},{"kind":"arabic","text_bw":"rmd","text_ar":"رمد"},{"kind":"text","text":";) as also"},{"kind":"arabic","text_bw":"Armd~","text_ar":"ارمدّ"},{"kind":"text","text":". (As, T in that art.)"}],"source_refs":["JK","S","A","K","M"]}]}}