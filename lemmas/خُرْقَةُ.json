{"lemma":"خُرْقَةُ","slug":"خُرْقَةُ","root":"خ.ر.ق","root_slug":"خ-ر-ق","root_link":"/words/roots/خ-ر-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n10425","n10426","n10436","n10437"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D8%B1%D9%92%D9%82%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"rag, tatter, shred"}]},"etymology":null,"ipa":["/xir.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10425","headword_ar":"خَرَقَهُ","root":"xrq","body":[{"kind":"text","text":", (JK, S, Mgh, Msb, K,) aor."},{"kind":"text","text":"(Mgh, Msb, K) and"},{"kind":"text","text":", (K,) the former of which is the more chaste, (TA,) inf. n."},{"kind":"arabic","text_bw":"xaroqN","text_ar":"خَرْقٌ"},{"kind":"text","text":", (S, Mgh, Msb, KL,)"},{"kind":"italic_en","text":"He made a hole in it, perforated it, pierced it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored it;"},{"kind":"text","text":"(Msb, * KL;) syn."},{"kind":"arabic","text_bw":"jaAbahu","text_ar":"جَابَهُ"},{"kind":"text","text":"[in this sense, as well as in another to be explained below], (K, [in the CK, erroneously,"},{"kind":"arabic","text_bw":"jA'a bhi","text_ar":"جاءَ بهِ"},{"kind":"text","text":",]) and"},{"kind":"arabic","text_bw":"vaqabahu","text_ar":"ثَقَبَهُ"},{"kind":"text","text":": (TA:) and"},{"kind":"italic_en","text":"he cut it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"so as to make a hole"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a slit in it"},{"kind":"text","text":"]: (Msb:) and"},{"kind":"italic_en","text":"he rent it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tore it."},{"kind":"text","text":"(JK, K, KL.) You say,"},{"kind":"arabic","text_bw":"xaraqa Alvawoba","text_ar":"خَرَقَ الثَوْبَ"},{"kind":"text","text":", (JK, S, Mgh, K,) aor."},{"kind":"text","text":"[and"},{"kind":"text","text":"], inf. n. as above, (Mgh,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"["},{"kind":"italic_en","text":"made a hole in,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"rent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tore, the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth;"},{"kind":"text","text":"(JK, K;) and"},{"kind":"arabic","text_bw":"Alxuf~a","text_ar":"الخُفَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the boot"},{"kind":"text","text":"]; and the like. (Mgh.) And"},{"kind":"arabic","text_bw":"xaraqa","text_ar":"خَرَقَ"},{"kind":"arabic","text_bw":"AlS~axorapa","text_ar":"الصَّخْرَةَ"},{"kind":"italic_en","text":"He made a hole in the rock;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"jaAbahu","text_ar":"جَابَهُ"},{"kind":"text","text":". (A in art."},{"kind":"arabic","text_bw":"jwb","text_ar":"جوب"},{"kind":"text","text":".) [And"},{"kind":"arabic","text_bw":"xaraqa AlHaAy^iTa","text_ar":"خَرَقَ الحَايِطَ"},{"kind":"italic_en","text":"He made a hole in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"through, the wall:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"xaroqN","text_ar":"خَرْقٌ"},{"kind":"text","text":", below.] And"},{"kind":"arabic","text_bw":"xaraqahu biAlmivoqabi","text_ar":"خَرَقَهُ بِالمِثْقَبِ"},{"kind":"italic_en","text":"He made a hole in it"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"through it, perforated it, pierced it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored it, with a drill"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"vaqabahu","text_ar":"ثَقَبَهُ"},{"kind":"text","text":". (Msb in art."},{"kind":"arabic","text_bw":"vqb","text_ar":"ثقب"},{"kind":"text","text":".)"},{"kind":"arabic","text_bw":"xaraqa Als~afiynapa","text_ar":"خَرَقَ السَّفِينَةَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He made a hole in the ship"},{"kind":"text","text":"], in the Kur xviii. 70, means that he did so by taking out, from the ship, with an axe, (Ksh, Bd, Jel,) a plank, (Jel,) or two planks. (Ksh, Bd.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"xaraqa AlA^aroDa","text_ar":"خَرَقَ الاَرْضَ"},{"kind":"text","text":", (JK, S, Msb,) or"},{"kind":"arabic","text_bw":"AlmafaAzapa","text_ar":"المَفَازَةَ"},{"kind":"text","text":", (Mgh, K, *) (tropical:)"},{"kind":"italic_en","text":"He traversed, crossed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cut through by journeying,"},{"kind":"text","text":"(JK, S, Mgh, Msb, K,)"},{"kind":"italic_en","text":"the earth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land,"},{"kind":"text","text":"(JK, S, Msb,) or"},{"kind":"italic_en","text":"the desert;"},{"kind":"text","text":"(Mgh, K;) syn."},{"kind":"arabic","text_bw":"qaTaEahaA","text_ar":"قَطَعَهَا"},{"kind":"text","text":"; (JK, Mgh, K; *) or"},{"kind":"arabic","text_bw":"jaAbahaA","text_ar":"جَابَهَا"},{"kind":"text","text":"; (S, Msb;)"},{"kind":"italic_en","text":"so as to reach the furthest part thereof."},{"kind":"text","text":"(Mgh, TA.) [See also 8.] It is said in the Kur [xvii. 39],"},{"kind":"arabic","text_bw":"A_in~aka lano taxoriqa AlA^aroDa","text_ar":"اـِنَّكَ لَنْ تَخْرِقَ الاَرْضَ"},{"kind":"text","text":", meaning,"},{"kind":"italic_en","text":"For thou shalt not reach the extremities of the earth:"},{"kind":"text","text":"or, accord. to Az,"},{"kind":"italic_en","text":"thou shalt not traverse the earth in length and breadth:"},{"kind":"text","text":"(TA:) or it means"},{"kind":"italic_en","text":"thou shalt not bore through the earth,"},{"kind":"text","text":"(Jel, TA,)"},{"kind":"italic_en","text":"so as to reach the end thereof:"},{"kind":"text","text":"(Jel:) or"},{"kind":"italic_en","text":"thou shalt not make a hole in the earth"},{"kind":"text","text":"by thy vehement treading: (Ksh, Bd:) accord. to one reading,"},{"kind":"arabic","text_bw":"ln taxoruqa","text_ar":"لن تَخْرُقَ"},{"kind":"text","text":". (Ksh, TA.) ―         -b3-  [And"},{"kind":"arabic","text_bw":"xaraqati Alr~iyHu","text_ar":"خَرَقَتِ الرِّيحُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The wind passed along:"},{"kind":"text","text":"and (assumed tropical:)"},{"kind":"italic_en","text":"blew:"},{"kind":"text","text":"for] the inf. n."},{"kind":"arabic","text_bw":"xaroqN","text_ar":"خَرْقٌ"},{"kind":"text","text":"signifies (assumed tropical:)  the"},{"kind":"italic_en","text":"passing"},{"kind":"text","text":"of the wind: and (assumed tropical:)  the"},{"kind":"italic_en","text":"blowing"},{"kind":"text","text":"thereof. (KL.) [See also 7 and 8.] ―         -b4-"},{"kind":"arabic","text_bw":"xaraqa Alka*iba","text_ar":"خَرَقَ الكَذِبَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He forged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feigned, the lie;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"Axtrqhu","text_ar":"اخترقهُ"},{"kind":"text","text":". (K, TA.) It is said in the Kur vi. 100,"},{"kind":"arabic","text_bw":"waxaraquwA lahu baniyna wabanaAtK","text_ar":"وَخَرَقُوا لَهُ بَنِينَ وَبَنَاتٍ"},{"kind":"text","text":", i. e. (tropical:)"},{"kind":"italic_en","text":"And they have feigned Him to have,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"falsely attributed to Him, sons and daughters."},{"kind":"text","text":"(Ksh, Bd, Jel. [See also 2.]) And"},{"kind":"arabic","text_bw":"xaraqa","text_ar":"خَرَقَ"},{"kind":"text","text":"[alone, the object being understood], (K,) inf. n. as above, (KL,) signifies (tropical:)"},{"kind":"italic_en","text":"He lied; told a lie:"},{"kind":"text","text":"(K, KL, TA:) and ↓"},{"kind":"arabic","text_bw":"txr~q","text_ar":"تخرّق","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"he forged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"feigned, a lie."},{"kind":"text","text":"(S, K, TA.)       -A2-"},{"kind":"arabic","text_bw":"xariqati Al$~aApu","text_ar":"خَرِقَتِ الشَّاةُ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xaraqN","text_ar":"خَرَقٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The sheep had in its ear a"},{"kind":"arabic","text_bw":"xaroq","text_ar":"خَرْق"},{"kind":"text","text":", i. e."},{"kind":"italic_en","text":"a round hole"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perforation."},{"kind":"text","text":"(Msb.)       -A3-"},{"kind":"arabic","text_bw":"xariqa fiY","text_ar":"خَرِقَ فِى"},{"kind":"arabic","text_bw":"Albayoti","text_ar":"البَيْتِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (JK, K,) inf. n."},{"kind":"arabic","text_bw":"xuruwqN","text_ar":"خُرُوقٌ"},{"kind":"text","text":", (JK,) or"},{"kind":"page_break","n":728},{"kind":"arabic","text_bw":"xaraqN","text_ar":"خَرَقٌ"},{"kind":"text","text":"; (TK;) and"},{"kind":"arabic","text_bw":"xaraqa","text_ar":"خَرَقَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xuruwqN","text_ar":"خُرُوقٌ"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"He remained in the house,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tent, not quitting it."},{"kind":"text","text":"(JK, * K.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xariqa","text_ar":"خَرِقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"xaraqN","text_ar":"خَرَقٌ"},{"kind":"text","text":", said of a gazelle, or young gazelle, (Msb, K, TA,) when hunted, (TA,) or when overtaken by the dog, (IAar,)"},{"kind":"italic_en","text":"It was frightened,"},{"kind":"text","text":"(Msb, K, TA, [in the CK,"},{"kind":"arabic","text_bw":"Aano yaEoraqa","text_ar":"اَنْ يَعْرَقَ"},{"kind":"text","text":"is erroneously put for"},{"kind":"arabic","text_bw":"A^ano","text_ar":"اَنْ"},{"kind":"arabic","text_bw":"yaforaqa","text_ar":"يَفْرَقَ"},{"kind":"text","text":",])"},{"kind":"italic_en","text":"so as to be unable to go away,"},{"kind":"text","text":"(Msb,) or"},{"kind":"italic_en","text":"so as to be unable to rise,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and clave to the ground:"},{"kind":"text","text":"(IAar, TA:) and in like manner said of a bird, (Msb, K,)"},{"kind":"italic_en","text":"it became frightened,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"impatient,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"so as to be unable to fly away."},{"kind":"text","text":"(K, TA.) ―         -b3-  And hence, (Msb,) the same verb, (S, Msb, K,) with the same aor., (Msb, K,) and the same inf. n., (S, Msb, K,) said of a man, (Msb,)"},{"kind":"italic_en","text":"He became confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he became bereft of his reason"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect, because of fear,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of shame:"},{"kind":"text","text":"(S, Msb, K:) or"},{"kind":"italic_en","text":"he was confounded, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed,"},{"kind":"text","text":"[for"},{"kind":"arabic","text_bw":"yatahay~aba","text_ar":"يَتَهَيَّبَ"},{"kind":"text","text":"in the CK, I read"},{"kind":"arabic","text_bw":"yabohata","text_ar":"يَبْهَتَ"},{"kind":"text","text":", as in other copies of the K and in the TA,]"},{"kind":"italic_en","text":"opening his eyes, and looking:"},{"kind":"text","text":"(K, TA:) and"},{"kind":"italic_en","text":"he remained confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed, and unable to see his right course, by reason of anxiety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of hardship,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distress."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"waqaEa faxariqa","text_ar":"وَقَعَ فَخَرِقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He fell down and clave to the ground"},{"kind":"text","text":"], occurring in a trad, means"},{"kind":"italic_en","text":"he fell down dead."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"xariqa","text_ar":"خَرِقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (JK, S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"xaraqN","text_ar":"خَرَقٌ"},{"kind":"text","text":"; (S, Msb, K; *) and"},{"kind":"arabic","text_bw":"xaruqa","text_ar":"خَرُقَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (JK, K,) [of which"},{"kind":"arabic","text_bw":"xuroqN","text_ar":"خُرْقٌ"},{"kind":"text","text":", said in the S and Msb to be a simple subst., may be the inf. n., like as"},{"kind":"arabic","text_bw":"HusonN","text_ar":"حُسْنٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"Hasona","text_ar":"حَسْنَ"},{"kind":"text","text":";]"},{"kind":"italic_en","text":"He was rough, ungentle, clumsy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"awkward,"},{"kind":"text","text":"(S, Msb, K,)"},{"kind":"italic_en","text":"in doing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making, a thing:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"he was unskilful in work,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in the management of affairs:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he was foolish; stupid;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient, in intellect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"understanding:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"he was ignorant:"},{"kind":"text","text":"(JK:) or the latter verb signifies"},{"kind":"italic_en","text":"he knew not his work with his hand,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his handicraft."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"xaruqa biAl$~aYo'i","text_ar":"خَرُقَ بِالشَّىْءِ"},{"kind":"italic_en","text":"He was ignorant of the thing,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and did it not well."},{"kind":"text","text":"(TA.)"}],"source_refs":["JK","S","Mgh","Msb","K","TA","KL","Ksh","Bd","Jel","IAar"]},{"entry_id":"n10426","headword_ar":"خرّقه","root":"xrq","body":[{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"taxoriyqN","text_ar":"تَخْرِيقٌ"},{"kind":"text","text":", (Msb, K,) is similar to"},{"kind":"arabic","text_bw":"xaraqahu","text_ar":"خَرَقَهُ"},{"kind":"text","text":", but has an intensive signification; ["},{"kind":"italic_en","text":"He made holes in it; perforated it, pierced it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"bored it, in several,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, places: he cut it so as to make holes"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slits in it:"},{"kind":"text","text":"] (Msb:)"},{"kind":"italic_en","text":"he rent it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tore it, much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in several,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, places:"},{"kind":"text","text":"(K, TA:) namely, a garment, (S, TA,) &c. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"xr~q","text_ar":"خرّق"},{"kind":"text","text":", (TA,) inf. n. as above, (K,) (assumed tropical:)"},{"kind":"italic_en","text":"He lied much."},{"kind":"text","text":"(K, TA.) Aboo-Jaafar and Náfi' read, [in the Kur vi. 100,]"},{"kind":"arabic","text_bw":"waxar~aquwA lahu","text_ar":"وَخَرَّقُوا لَهُ"},{"kind":"arabic","text_bw":"baniyna wabanaAtK","text_ar":"بَنِينَ وَبَنَاتٍ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"And they have very falsely attributed to Him sons and daughters"},{"kind":"text","text":"]. (TA. [See also 1.])"}],"source_refs":["S","Msb","K","TA"]},{"entry_id":"n10436","headword_ar":"خُرْقَةٌ","root":"xrq","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xuroqN","text_ar":"خُرْقٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n10437","headword_ar":"خِرْقَةٌ","root":"xrq","body":[{"kind":"italic_en","text":"A piece,"},{"kind":"text","text":"(S, Msb, K,) or"},{"kind":"italic_en","text":"piece torn off,"},{"kind":"text","text":"(TA,) of a garment, or of cloth; ["},{"kind":"italic_en","text":"a rag;"},{"kind":"text","text":"] pl."},{"kind":"arabic","text_bw":"xiraqN","text_ar":"خِرَقٌ"},{"kind":"text","text":". (S, Msb, TA.) ―         -b2-  ["},{"kind":"italic_en","text":"A ragged, patched, garment:"},{"kind":"text","text":"and particularly"},{"kind":"italic_en","text":"one worn by a devotee;"},{"kind":"text","text":"also called"},{"kind":"arabic","text_bw":"muraq~aEapN","text_ar":"مُرَقَّعَةٌ"},{"kind":"text","text":", q. v.: but this is probably postclassical. Hence,"},{"kind":"arabic","text_bw":"A^aSoHaAbu Alxiraqi","text_ar":"اَصْحَابُ الخِرَقِ"},{"kind":"italic_en","text":"The devotees."},{"kind":"text","text":"] ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"A portion"},{"kind":"text","text":"of a swarm of locusts, (K, TA,) less than a"},{"kind":"arabic","text_bw":"rijol","text_ar":"رِجْل"},{"kind":"text","text":"; as also"},{"kind":"arabic","text_bw":"HizoqapN","text_ar":"حِزْقَةٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","Msb","K","TA"]}]},"classical_definitions":null}