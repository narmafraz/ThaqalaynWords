role":"present_3fd","form":"تُوَلَّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَلِّيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُوَلِّيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُوَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُوَلُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُوَلَّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُوَلِّيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُوَلَّى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَلَّى","in_corpus":true,"count":182,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوَلِّي","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُوَلِّي","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"وَلَّيْنا","in_corpus":true,"count":8,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"وَلَّيْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُوَلّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":308,"cross_references":{"qac":{"found":true,"lemma_key":"وَلَّى","root":"ولي","pos":"V","occurrence_count":30},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n44745"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D9%84%D9%8E%D9%91%D9%89"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to turn away (from); to turn tail, to flee","tags":["intransitive"],"examples":[{"text":"وَأَلْقِ عَصَاكَ فَلَمَّا رَءَاهَا تَهْتَزُّ كَأَنَّهَا جَانٌّ وَلَّى مُدْبِرًا وَلَمْ يُعَقِّبْ","english":"And [he was told]: “Throw down your staff.” But when he saw it writhing as if it were a snake, he turned in flight and did not return."}]},{"pos":"verb","gloss":"to turn away (from); to shun","tags":["intransitive"]},{"pos":"verb","gloss":"to turn away (from); to pass by, to glide away, to elapse","tags":["intransitive"]},{"pos":"verb","gloss":"to assign to, to appoint for, to commission with","tags":["ditransitive"]}]},"etymology":null,"ipa":["/wal.laː/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n44745","headword_ar":"وَلَّى","root":"wlY","body":[{"kind":"italic_en","text":"He caused to turn away, or back."},{"kind":"text","text":"(Kur-án, ch. ii. v. 136.) ―         -b2-"},{"kind":"italic_en","text":"He caused to turn towards,"},{"kind":"text","text":"with acc. (Idem, ch. ii. v. 139.) ―         -b3-"},{"kind":"italic_en","text":"He turned away,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"departed."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"wal~aY Eanohu","text_ar":"وَلَّى عَنْهُ"},{"kind":"italic_en","text":"He turned away from, avoided, shunned, and left, him or it."},{"kind":"text","text":"(Msb.) ―         -b5-"},{"kind":"arabic","text_bw":"wal~ati AlHarobu","text_ar":"وَلَّتِ الحَرْبُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The war declined"},{"kind":"text","text":"]. (A, K, in art."},{"kind":"arabic","text_bw":"sfr","text_ar":"سفر"},{"kind":"text","text":".) ―         -b6-"},{"kind":"arabic","text_bw":"wal~aY haAribFA","text_ar":"وَلَّى هَارِبًا"},{"kind":"italic_en","text":"He went back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retreated, fleeing."},{"kind":"text","text":"(S.) ―         -b7-"},{"kind":"arabic","text_bw":"wal~ayotuhu ZahoriY","text_ar":"وَلَّيْتُهُ ظَهْرِى"},{"kind":"italic_en","text":"I placed him behind me, and betook myself to defending him."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"$zn","text_ar":"شزن"},{"kind":"text","text":".) ―         -b8-  More commonly"},{"kind":"italic_en","text":"I turned my back upon him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it:"},{"kind":"text","text":"see Har, p. 564. ―         -b9-"},{"kind":"arabic","text_bw":"wal~aY All~ayolu liya*ohaba","text_ar":"وَلَّى اللَّيْلُ لِيَذْهَبَ"},{"kind":"italic_en","text":"The night"},{"kind":"text","text":"["},{"kind":"italic_en","text":"declined,"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"retreated to depart;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^adobara","text_ar":"اَدْبَرَ"},{"kind":"text","text":". (T in art."},{"kind":"arabic","text_bw":"dbr","text_ar":"دبر"},{"kind":"text","text":".) ―         -b10-"},{"kind":"arabic","text_bw":"wal~aY A^amoru Alqawomi lifasaAdi","text_ar":"وَلَّى اَمْرُ القَوْمِ لِفَسَادِ"},{"kind":"italic_en","text":"The case of the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, declined,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became reduced to a bad state;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A^adobara","text_ar":"اَدْبَرَ"},{"kind":"text","text":". (M in art."},{"kind":"arabic","text_bw":"dbr","text_ar":"دبر"},{"kind":"text","text":".) ―         -b11-  ["},{"kind":"arabic","text_bw":"wal~aY kibarFA","text_ar":"وَلَّى كِبَرًا"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"wal~aY","text_ar":"وَلَّى"},{"kind":"text","text":"alone, both of frequent occurrence in the lexicons, &c.,"},{"kind":"italic_en","text":"He became in a declining state by reason of age."},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"wal~aY","text_ar":"وَلَّى"},{"kind":"text","text":"said of a man is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"dabara","text_ar":"دَبَرَ"},{"kind":"text","text":"; as also"},{"kind":"arabic","text_bw":"$ay~axa","text_ar":"شَيَّخَ"},{"kind":"text","text":". (S in art."},{"kind":"arabic","text_bw":"dbr","text_ar":"دبر"},{"kind":"text","text":".) See also two exs., p. 75, col. 3. ―         -b12-"},{"kind":"arabic","text_bw":"Alt~awoliyapu","text_ar":"التَّوْلِيَةُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"AlA_idobaAru","text_ar":"الاـِدْبَارُ"},{"kind":"text","text":", properly signifies"},{"kind":"italic_en","text":"Retrogression;"},{"kind":"text","text":"and hence, like this English word, tropically,"},{"kind":"italic_en","text":"declension."},{"kind":"text","text":"―         -b13-"},{"kind":"arabic","text_bw":"wal~aAhu A^amorFA","text_ar":"وَلَّاهُ اَمْرًا"},{"kind":"italic_en","text":"He set him over the thing; appointed him superintendent of it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"set him to do it;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"A_iy~aAhu","text_ar":"اـِيَّاهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^awolaAhu","text_ar":"اَوْلَاهُ","orth_type":"arrow"},{"kind":"text","text":". ―         -b14-"},{"kind":"arabic","text_bw":"wal~aY duburahu","text_ar":"وَلَّى دُبُرَهُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"wal~aAhu duburahu","text_ar":"وَلَّاهُ دُبُرَهُ"},{"kind":"text","text":"; see"},{"kind":"arabic","text_bw":"duburN","text_ar":"دُبُرٌ"},{"kind":"text","text":", and see three phrases voce"},{"kind":"arabic","text_bw":"*anabN","text_ar":"ذَنَبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}