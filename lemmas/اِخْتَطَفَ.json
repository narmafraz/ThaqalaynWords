16"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D8%AE%D9%92%D8%AA%D9%8E%D8%B7%D9%8E%D9%81%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to snatch"},{"pos":"verb","gloss":"to kidnap","examples":[{"text":"وأفادت وزارة الداخلية اللبنانية في بيان «تم فجر اليوم تحرير اللبنانيين الثلاثة (…)، بعدما اختطفتهم عصابة» لدى وصولهم إلى بغداد.","english":"And the Lebanese Minister of the Interior reported in his statement that “in the dawn of the day there happened the liberation of the three Lebanese, after a gang had kidnapped them” at their arrival at Baghdad."}]}]},"etymology":null,"ipa":["/ix.ta.tˤa.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11016","headword_ar":"اختطف","root":"xTf","body":[{"kind":"text","text":"; and its variations"},{"kind":"arabic","text_bw":"xaT~afa","text_ar":"خَطَّفَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"xiT~ifa","text_ar":"خِطِّفَ"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"yixiT~ifu","text_ar":"يِخِطِّفُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"yaxiT~ifu","text_ar":"يَخِطِّفُ"},{"kind":"text","text":", variations of its aor.: see 1, in seven places. ―         -b2-"},{"kind":"arabic","text_bw":"kaA^an~ahu yaxotaTifu fiY","text_ar":"كَاَنَّهُ يَخْتَطِفُ فِى"},{"kind":"arabic","text_bw":"ma$oyihi Eunuqahu","text_ar":"مَشْيِهِ عُنُقَهُ"},{"kind":"text","text":", said of a swift camel, means"},{"kind":"italic_en","text":"As though he were straining,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stretching,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"yajota*ibu","text_ar":"يَجْتَذِبُ"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"in his going along, his neck."},{"kind":"text","text":"(S.)       -A2-  See also 4."}],"source_refs":[]}]},"classical_definitions":null}