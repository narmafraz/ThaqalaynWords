{"lemma":"مُمَرِّضِي","slug":"مُمَرِّضِي","root":"م.ر.ض","root_slug":"م-ر-ض","root_link":"/words/roots/م-ر-ض","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n38490"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D9%85%D9%8E%D8%B1%D9%90%D9%91%D8%B6%D9%90%D9%8A"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"nurse (person who takes care of the sick)"}]},"etymology":null,"ipa":["/mu.mar.ridˤ/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n38490","headword_ar":"مُمْرِضٌ","root":"mrD","body":[{"kind":"text","text":"A man"},{"kind":"italic_en","text":"having diseased camels:"},{"kind":"text","text":"so in the following trad.:"},{"kind":"arabic","text_bw":"laA yuwridu mumoriDN EalaY muSiH~K","text_ar":"لَا يُورِدُ مُمْرِضٌ عَلَى مُصِحٍّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"One having diseased camels shall not bring them to water immediately after one whose camels are in a healthy state"},{"kind":"text","text":"]: the prohibition being not because of the transition of disease by contagion; but because sometimes disease may befall the healthy beasts, and it may come into the mind of the owner that that is from contagion. (TA.) [See also"},{"kind":"arabic","text_bw":"muSiH~N","text_ar":"مُصِحٌّ"},{"kind":"text","text":".]"}],"source_refs":[]}]},"classical_definitions":null}