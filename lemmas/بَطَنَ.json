{"lemma":"بَطَنَ","slug":"بَطَنَ","root":"ب.ط.ن","root_slug":"ب-ط-ن","root_link":"/words/roots/ب-ط-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَطَنْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَطَنْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَطَنْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَطَنْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَطَنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَطَنَ","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَطَنَت","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَطَنا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَطَنَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَطَنُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَطَنَّ","in_corpus":true,"count":75,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْطُن","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْطُنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْطُنِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْطُنانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْطُنا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْطُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْطُنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْطُنَّ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْطُن","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْطُن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْطُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْطُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْطُنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْطُنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْطُنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْطُنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْطُنَّ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَطَنّا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَطَنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْطُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْطُن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":89,"cross_references":{"qac":{"found":true,"lemma_key":"بَطَنَ","root":"بطن","pos":"V","occurrence_count":2},"wiktextract":{"found":true,"entry_count":6,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":14},"lanes":{"found":true,"entry_ids":["n2799","n2807","n2808","n2809"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B7%D9%8E%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"stomach, abdomen"},{"pos":"noun","gloss":"womb","examples":[{"text":"هُوَ أَعْلَمُ بِكُمْ إِذْ أَنْشَأَكُمْ مِنَ الْأَرْضِ وَإِذْ أَنْتُمْ أَجِنَّةٌ فِي بُطُونِ أُمَّهَاتِكُمْ"}]},{"pos":"noun","gloss":"interior"},{"pos":"noun","gloss":"depth"},{"pos":"noun","gloss":"clan"},{"pos":"adj","gloss":"big-bellied, pot-bellied"},{"pos":"verb","gloss":"to be concealed, to be hidden"},{"pos":"verb","gloss":"to enter, to become familiar"},{"pos":"verb","gloss":"to enter (a valley, a house, etc.)","tags":["transitive"]},{"pos":"verb","gloss":"to know, to become familiar with (an issue, a person, etc.)","tags":["transitive"]},{"pos":"verb","gloss":"to afflict [with بِ (bi) ‘someone’] (of a disease)"},{"pos":"verb","gloss":"to be big-bellied, to be paunchy"},{"pos":"verb","gloss":"to strike (someone's) belly"},{"pos":"verb","gloss":"to fill, to line, to inlay"}]},"etymology":{"source":"wiktextract","text":"From the root ب ط ن (b ṭ n). Cognate with Hebrew בֶּטֶן (béten, “stomach”), Aramaic בטנא (baṭnā, “womb”), Ugaritic 𐎁𐎉𐎐 (bṭn, “to be pregnant”)."},"ipa":["/batˤn/","/ba.tˤin/","/ba.tˤa.na/","/ba.tˤu.na/","/ba.tˤi.na/","/batˤ.tˤa.na/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2799","headword_ar":"بَطُنَ","root":"bTn","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"baTaAnapN","text_ar":"بَطَانَةٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large, in the belly,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"in consequence of much eating."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"baTina","text_ar":"بَطِنَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"baTanN","text_ar":"بَطَنٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, big,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"large, in the belly, in consequence of satiety,"},{"kind":"text","text":"(S, TA,)"},{"kind":"italic_en","text":"and disordered therein:"},{"kind":"text","text":"(TA:)"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a state of repletion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"much filled with food."},{"kind":"text","text":"(TA.) ―         -b3-  ―         -b4-  And [hence,]"},{"kind":"arabic","text_bw":"baTina","text_ar":"بَطِنَ"},{"kind":"text","text":"signifies also (tropical:)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^a$ira","text_ar":"اَشِرَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baTira","text_ar":"بَطِرَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He exulted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exulted greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, and behaved insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"&c.]. (TA.) ―         -b5-"},{"kind":"arabic","text_bw":"buTina","text_ar":"بُطِنَ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, TA)"},{"kind":"italic_en","text":"had a complaint of,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a disease in,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a pain in, his belly."},{"kind":"text","text":"(S, Msb, TA.)       -A2-"},{"kind":"arabic","text_bw":"baTanahu","text_ar":"بَطَنَهُ"},{"kind":"text","text":", (S, K,) aor."},{"kind":"text","text":", (S, TA,) inf. n."},{"kind":"arabic","text_bw":"baTonN","text_ar":"بَطْنٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He struck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beat, his belly;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"baTana lahu","text_ar":"بَطَنَ لَهُ"},{"kind":"text","text":", (S, K,) accord. to some, or the"},{"kind":"arabic","text_bw":"l","text_ar":"ل"},{"kind":"text","text":"is added [only] in verse; (S;) and ↓"},{"kind":"arabic","text_bw":"bT~nhu","text_ar":"بطّنهُ","orth_type":"arrow"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"taboTiynN","text_ar":"تَبْطِينٌ"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a disease)"},{"kind":"italic_en","text":"entered into him:"},{"kind":"text","text":"[as though it penetrated into his belly: see 10:] in this sense it has for its inf. n."},{"kind":"arabic","text_bw":"buTuwnN","text_ar":"بُطُونٌ"},{"kind":"text","text":". (TA.) And"},{"kind":"arabic","text_bw":"baTanato bihi AlHum~aY","text_ar":"بَطَنَتْ بِهِ الحُمَّى"},{"kind":"italic_en","text":"The fever produced an effect within him."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"italic_en","text":"He entered into it;"},{"kind":"text","text":"namely, a valley; (S, TA;) in which sense it has for its inf. n."},{"kind":"arabic","text_bw":"baTonN","text_ar":"بَطْنٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"tbT~nhu","text_ar":"تبطّنهُ","orth_type":"arrow"},{"kind":"text","text":"signifies the same: or the latter,"},{"kind":"italic_en","text":"he went about in it;"},{"kind":"text","text":"namely, the valley; as also ↓"},{"kind":"arabic","text_bw":"AstbTnhu","text_ar":"استبطنهُ","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b4-  (tropical:)  ["},{"kind":"italic_en","text":"He penetrated into it mentally;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"he knew it;"},{"kind":"text","text":"(Msb, K, TA;) namely, the news or story, or the state or case, of another: (K, TA:) (tropical:)"},{"kind":"italic_en","text":"he knew the inward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intrinsic, state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances thereof;"},{"kind":"text","text":"(S, Msb, TA;) i. e., of a case, or an affair; (S,"},{"kind":"page_break","n":220},{"kind":"text","text":"TA;) as also ↓"},{"kind":"arabic","text_bw":"AstbTnhu","text_ar":"استبطنهُ","orth_type":"arrow"},{"kind":"text","text":": (K, A, TA:) and ↓"},{"kind":"arabic","text_bw":"tbT~nhu","text_ar":"تبطّنهُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"he entered into it so that he knew its inward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intrinsic, state"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances."},{"kind":"text","text":"(Ham p. 688.) ―         -b5-"},{"kind":"arabic","text_bw":"baTana bifulaAnK","text_ar":"بَطَنَ بِفُلَانٍ"},{"kind":"text","text":", accord. to the S and M, but in the K"},{"kind":"arabic","text_bw":"mino fulaAnK","text_ar":"مِنْ فُلَانٍ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He became one of his particular,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"special, intimates, friends,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"associates,"},{"kind":"text","text":"(S, K, TA,)"},{"kind":"italic_en","text":"entering into his affair"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"affairs"},{"kind":"text","text":"]: (TA:) or"},{"kind":"arabic","text_bw":"baTana bihi","text_ar":"بَطَنَ بِهِ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buTuwnN","text_ar":"بُطُونٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"baTaAnapN","text_ar":"بَطَانَةٌ"},{"kind":"text","text":", means (assumed tropical:)"},{"kind":"italic_en","text":"he entered into his affair"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"affairs"},{"kind":"text","text":"]. (TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"baTana","text_ar":"بَطَنَ"},{"kind":"text","text":", (Msb, K,) aor."},{"kind":"text","text":", said of a thing, (Msb,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unapparent, hidden, concealed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"covert;"},{"kind":"text","text":"(K, TA;)"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"Zahara","text_ar":"ظَهَرَ"},{"kind":"text","text":". (Msb.) ―         -b7-  See also 4."}],"source_refs":["K","TA","S","A","Msb"]},{"entry_id":"n2807","headword_ar":"بَطْنٌ","root":"bTn","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"belly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abdomen;"},{"kind":"text","text":"i. e. the"},{"kind":"italic_en","text":"part of the body which is separated from the"},{"kind":"arabic","text_bw":"jawof","text_ar":"جَوْف"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"chest,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thorax,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by the"},{"kind":"arabic","text_bw":"HijaAb","text_ar":"حِجَاب"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"midriff,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"diaphragm"},{"kind":"text","text":"];"},{"kind":"italic_en","text":"containing the liver and the spleen and the stomach and the lower intestines &c.;"},{"kind":"text","text":"(Zj in his “ Khalk el-Insán; ” [in which it is erroneously said to comprise also the lungs;])"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"; (S, Msb, K;) of a man and of any animal: (TA:) of the masc. gender, (S, K,) and, accord. to AO, fem. also: (AHát, S:) pl."},{"kind":"arabic","text_bw":"A^aboTunN","text_ar":"اَبْطُنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buTuwnN","text_ar":"بُطُونٌ"},{"kind":"text","text":"(Az, Msb, K) and"},{"kind":"arabic","text_bw":"buTonaAnN","text_ar":"بُطْنَانٌ"},{"kind":"text","text":"; (K;) the first a pl. of pauc.; and the second [as also the third] a pl. of mult., applied to more than ten. (Az, TA.) [Hence,]"},{"kind":"arabic","text_bw":"*uw AlbaToni","text_ar":"ذُو البَطْنِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"What is in the belly:"},{"kind":"text","text":"but generally meaning]"},{"kind":"italic_en","text":"excrement, ordure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dung."},{"kind":"text","text":"(K, TA.) You say,"},{"kind":"arabic","text_bw":"A^aloqaY *aA baTonihi","text_ar":"اَلْقَى ذَا بَطْنِهِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"ejected his excrement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ordure."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"A^aloqato *aA baTonihaA","text_ar":"اَلْقَتْ ذَا بَطْنِهَا"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman, TA)"},{"kind":"italic_en","text":"brought forth;"},{"kind":"text","text":"(K;) as also"},{"kind":"arabic","text_bw":"waDaEato *aAta baTonihaA","text_ar":"وَضَعَتْ ذَاتَ بَطْنِهَا"},{"kind":"text","text":": (TA in art."},{"kind":"arabic","text_bw":"*w","text_ar":"ذو"},{"kind":"text","text":":) and"},{"kind":"italic_en","text":"she"},{"kind":"text","text":"(a hen)"},{"kind":"italic_en","text":"laid an egg."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"navarato *aA","text_ar":"نَثَرَتْ ذَا"},{"kind":"arabic","text_bw":"baTonihaA","text_ar":"بَطْنِهَا"},{"kind":"text","text":", (T and Mgh in art."},{"kind":"arabic","text_bw":"nvr","text_ar":"نثر"},{"kind":"text","text":",) and [elliptically]"},{"kind":"arabic","text_bw":"navarato baTonahaA","text_ar":"نَثَرَتْ بَطْنَهَا"},{"kind":"text","text":", (T and A and Mgh in that art.,)"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"brought forth many children."},{"kind":"text","text":"(T in that art.) And it is said in a prov., (TA,)"},{"kind":"arabic","text_bw":"Al*~iy^obu","text_ar":"الذِّيْبُ"},{"kind":"arabic","text_bw":"yugobaTu bi*iY baTonihi","text_ar":"يُغْبَطُ بِذِى بَطْنِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The wolf is envied for what is in his belly"},{"kind":"text","text":"]: for one never thinks him to be hungry, but only thinks him to be in a state of repletion, because of his hostility to men and cattle, (A'Obeyd, K,) though he is sometimes distressed by hunger. (A'Obeyd. [See various readings of this prov. in Freytag's Arab. Prov. i. 500 and 501.])"},{"kind":"arabic","text_bw":"maAtato fiY baTonK","text_ar":"مَاتَتْ فِى بَطْنٍ"},{"kind":"text","text":", a phrase occurring in a trad., means"},{"kind":"italic_en","text":"She"},{"kind":"text","text":"(a woman)"},{"kind":"italic_en","text":"died in childbirth."},{"kind":"text","text":"(TA.) See also"},{"kind":"arabic","text_bw":"fulaAnN A@bonu baTonihi. baTanN","text_ar":"فُلَانٌ ا@بْنُ بَطْنِهِ. بَطَنٌ"},{"kind":"text","text":". means (assumed tropical:)"},{"kind":"italic_en","text":"Such a one is solicitous for his belly."},{"kind":"text","text":"(Er-Rághib, TA in art."},{"kind":"arabic","text_bw":"bnY","text_ar":"بنى"},{"kind":"text","text":".) [Many phrases in which the word"},{"kind":"arabic","text_bw":"baTon","text_ar":"بَطْن"},{"kind":"text","text":"occurs will be found explained under other words of those phrases; as"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^axa*a","text_ar":"اَخَذَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"EuSofuwrN","text_ar":"عُصْفُورٌ"},{"kind":"text","text":", &c.]"},{"kind":"arabic","text_bw":"baTonu AlHuwti","text_ar":"بَطْنُ الحُوتِ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Alr~i$aA='u","text_ar":"الرِّشَا=ءُ"},{"kind":"text","text":". ―         -b2-  Also The"},{"kind":"italic_en","text":"inside,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interior,"},{"kind":"text","text":"of anything; syn."},{"kind":"arabic","text_bw":"jawofN","text_ar":"جَوْفٌ"},{"kind":"text","text":": and so ↓"},{"kind":"arabic","text_bw":"baATinN","text_ar":"بَاطِنٌ","orth_type":"arrow"},{"kind":"text","text":"; syn."},{"kind":"arabic","text_bw":"daAxilN","text_ar":"دَاخِلٌ"},{"kind":"text","text":": (K:) pl. of the former as above. (TA.) Thus"},{"kind":"arabic","text_bw":"baTonu waAdK","text_ar":"بَطْنُ وَادٍ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The interior of a water-course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"riverbed"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"valley;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"its bottom, in which flows, occasionally"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constantly, its torrent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"river"},{"kind":"text","text":"]. (MA.) And"},{"kind":"arabic","text_bw":"baTonu mak~apa","text_ar":"بَطْنُ مَكَّةَ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The interior of Mekkeh."},{"kind":"text","text":"(Bd in xlviii. 24.) [Hence,] it is said of the Kur-án,"},{"kind":"arabic","text_bw":"likul~i A=yapK minohaA ZahorN wa baTonN","text_ar":"لِكُلِّ ا=يَةٍ مِنْهَا ظَهْرٌ وَ بَطْنٌ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"To every verse thereof is an apparent sense and a sense requiring development."},{"kind":"text","text":"(TA.) [See"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":".] See also"},{"kind":"arabic","text_bw":"baATinN","text_ar":"بَاطِنٌ"},{"kind":"text","text":". [And its pl."},{"kind":"arabic","text_bw":"buTonaAnN","text_ar":"بُطْنَانٌ"},{"kind":"text","text":"is also used as a sing., meaning The"},{"kind":"italic_en","text":"middle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"midst,"},{"kind":"text","text":"of a thing: and the"},{"kind":"italic_en","text":"lower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest, part,"},{"kind":"text","text":"or the"},{"kind":"italic_en","text":"foundation."},{"kind":"text","text":"Thus,]"},{"kind":"arabic","text_bw":"buTonaAnu Aljan~api","text_ar":"بُطْنَانُ الجَنَّةِ"},{"kind":"text","text":"means"},{"kind":"italic_en","text":"The middle,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"midst, of Paradise:"},{"kind":"text","text":"(S, TA:) and"},{"kind":"arabic","text_bw":"buTonaAnu AlEaro$i","text_ar":"بُطْنَانُ العَرْشِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The lower,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lowest, part,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the foundation, of the"},{"kind":"arabic","text_bw":"Er$","text_ar":"عرش"},{"kind":"text","text":"[vulgarly held to be the"},{"kind":"italic_en","text":"throne of God"},{"kind":"text","text":"]. (TA.) You say also ["},{"kind":"arabic","text_bw":"baTonu Alkaf~i","text_ar":"بَطْنُ الكَفِّ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"Alkaf~i","text_ar":"الكَفِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baATinu","text_ar":"بَاطِنُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The palm of the hand"},{"kind":"text","text":"[opposed to"},{"kind":"arabic","text_bw":"ZahoruhaA","text_ar":"ظَهْرُهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ZaAhiruhaA","text_ar":"ظَاهِرُهَا"},{"kind":"text","text":"]: and ["},{"kind":"arabic","text_bw":"baTonu Alqadami","text_ar":"بَطْنُ القَدَمِ"},{"kind":"text","text":"and]"},{"kind":"arabic","text_bw":"Alqadami","text_ar":"القَدَمِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baATinu","text_ar":"بَاطِنُ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The sole of the foot"},{"kind":"text","text":"[likewise opposed to"},{"kind":"arabic","text_bw":"ZahoruhaA","text_ar":"ظَهْرُهَا"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ZaAhiruhaA","text_ar":"ظَاهِرُهَا"},{"kind":"text","text":"]: (Zj in his “ Khalk- el-Insán: ”) and"},{"kind":"arabic","text_bw":"baTonu AlHaAfiru","text_ar":"بَطْنُ الحَافِرُ"},{"kind":"text","text":"(S in art."},{"kind":"arabic","text_bw":"nsr","text_ar":"نسر"},{"kind":"text","text":") and"},{"kind":"arabic","text_bw":"AlHaAfiri","text_ar":"الحَافِرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baATinu","text_ar":"بَاطِنُ","orth_type":"arrow"},{"kind":"text","text":"(M and K in that art.) (assumed tropical:)  ["},{"kind":"italic_en","text":"The sole of the solid hoof;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the part of the solid hoof in which is the"},{"kind":"arabic","text_bw":"nasor","text_ar":"نَسْر"},{"kind":"text","text":", q. v. (S and M and K in that art.)"},{"kind":"arabic","text_bw":"baTonu Alr~aAHapi","text_ar":"بَطْنُ الرَّاحَةِ"},{"kind":"text","text":"is well known [as another name for"},{"kind":"arabic","text_bw":"baTonu Alkaf~i","text_ar":"بَطْنُ الكَفِّ"},{"kind":"text","text":", explained above; for"},{"kind":"arabic","text_bw":"Alr~aAHap","text_ar":"الرَّاحَة"},{"kind":"text","text":"is often used as syn. with"},{"kind":"arabic","text_bw":"Alkaf~","text_ar":"الكَفّ"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Alxuf~i","text_ar":"الخُفِّ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baATinu","text_ar":"بَاطِنُ","orth_type":"arrow"},{"kind":"text","text":"is [said to be] (assumed tropical:)"},{"kind":"italic_en","text":"The part of the foot of a camel or the like that is next the leg:"},{"kind":"text","text":"and one says, ↓"},{"kind":"arabic","text_bw":"baATinu","text_ar":"بَاطِنُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlA_iboTi","text_ar":"الاـِبْطِ"},{"kind":"text","text":", [meaning (assumed tropical:)"},{"kind":"italic_en","text":"The armpit,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hollow of the inner side of the shoulder-joint,"},{"kind":"text","text":"] but not"},{"kind":"arabic","text_bw":"baTonu","text_ar":"بَطْنُ"},{"kind":"arabic","text_bw":"AlA_iboTi","text_ar":"الاـِبْطِ"},{"kind":"text","text":": (TA:) [and"},{"kind":"arabic","text_bw":"AlEunuqi","text_ar":"العُنُقِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"baATinu","text_ar":"بَاطِنُ","orth_type":"arrow"},{"kind":"italic_en","text":"the throat."},{"kind":"text","text":"] The"},{"kind":"arabic","text_bw":"baTon","text_ar":"بَطْن"},{"kind":"text","text":"of a feather is (tropical:)  The"},{"kind":"italic_en","text":"long,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"longer,"},{"kind":"text","text":"(K,) [or"},{"kind":"italic_en","text":"wider,"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"inner,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"lateral half:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"buTonaAnN","text_ar":"بُطْنَانٌ"},{"kind":"text","text":"; (S, K, TA;) which is explained as signifying the"},{"kind":"italic_en","text":"parts beneath the shaft:"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"ZuhoraAnN","text_ar":"ظُهْرَانٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"[q. v.]. (TA.) ―         -b3-  Also"},{"kind":"italic_en","text":"A low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"portion,"},{"kind":"text","text":"of land, or ground; (S, TA;) and so ↓"},{"kind":"arabic","text_bw":"baATinN","text_ar":"بَاطِنٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) [or"},{"kind":"italic_en","text":"a bottom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"low land;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a low, soft flat;"},{"kind":"text","text":"i. e.]"},{"kind":"italic_en","text":"soft, plain, fine, low land"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground;"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"[q. v.]: (TA in art."},{"kind":"arabic","text_bw":"Zhr","text_ar":"ظهر"},{"kind":"text","text":":) pl. of the former, (S,) or of the latter, (K,)"},{"kind":"arabic","text_bw":"buTonaAnN","text_ar":"بُطْنَانٌ"},{"kind":"text","text":", (S, K,) a pl. of mult., (TA,) and"},{"kind":"arabic","text_bw":"A^aboTinapN","text_ar":"اَبْطِنَةٌ"},{"kind":"text","text":", (K,) a pl. of pauc., and anomalous [as pl. of either]: (TA:) the former pl., in relation to land, is also used as a sing., like"},{"kind":"arabic","text_bw":"baTonN","text_ar":"بَطْنٌ"},{"kind":"text","text":": (AHn, TA:) and accord. to ISh,"},{"kind":"arabic","text_bw":"buTonaAnu AlA^aroDi","text_ar":"بُطْنَانُ الاَرْضِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the low,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"depressed, tract,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tracts, of land, of the plain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"soft, parts thereof, and of the rugged, and of the meadows, where water rests and stagnates:"},{"kind":"text","text":"and such tracts are also called"},{"kind":"arabic","text_bw":"bawaATinu","text_ar":"بَوَاطِنُ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buTuwnN","text_ar":"بُطُونٌ"},{"kind":"text","text":". (TA.) ―         -b4-"},{"kind":"arabic","text_bw":"baTonu Als~amaA='i","text_ar":"بَطْنُ السَّمَا=ءِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Zahoru Als~amaA='i","text_ar":"ظَهْرُ السَّمَا=ءِ"},{"kind":"text","text":"both signify (assumed tropical:)"},{"kind":"italic_en","text":"The apparent, visible, part of the sky."},{"kind":"text","text":"(Fr, T voce"},{"kind":"arabic","text_bw":"ZahorN","text_ar":"ظَهْرٌ"},{"kind":"text","text":"[q. v.].)       -A2-  Also"},{"kind":"page_break","n":221},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"A tribe below that which is termed"},{"kind":"arabic","text_bw":"qabiylap","text_ar":"قَبِيلَة"},{"kind":"text","text":": (S, Msb, K, TA:) or"},{"kind":"italic_en","text":"next below the"},{"kind":"arabic","text_bw":"EimaArap","text_ar":"عِمَارَة"},{"kind":"text","text":": (S and TA voce"},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ"},{"kind":"text","text":", &c.:) or"},{"kind":"italic_en","text":"below the"},{"kind":"arabic","text_bw":"faxi*","text_ar":"فَخِذ"},{"kind":"italic_en","text":"and above the"},{"kind":"arabic","text_bw":"EmArp","text_ar":"عمارة"},{"kind":"text","text":": (K: [but for this I have found no other authority:]) of the masc. gender: (TA:) or [properly] fem.: but if"},{"kind":"arabic","text_bw":"Hay~N","text_ar":"حَيٌّ"},{"kind":"text","text":"[said by some to signify"},{"kind":"italic_en","text":"a tribe,"},{"kind":"text","text":"absolutely,] be meant thereby, it is masc.: (Msb:) or fem. if used in the sense of"},{"kind":"arabic","text_bw":"qabiylap","text_ar":"قَبِيلَة"},{"kind":"text","text":": (TA:) pl. [of pauc.]"},{"kind":"arabic","text_bw":"A^aboTunN","text_ar":"اَبْطُنٌ"},{"kind":"text","text":"and [of mult.]"},{"kind":"arabic","text_bw":"buTuwnN","text_ar":"بُطُونٌ"},{"kind":"text","text":". (Msb, K.) [See"},{"kind":"arabic","text_bw":"$aEobN","text_ar":"شَعْبٌ"},{"kind":"text","text":".]"}],"source_refs":["TA","S","K","Az","Msb","AHn"]},{"entry_id":"n2808","headword_ar":"بَطَنٌ","root":"bTn","body":[{"kind":"italic_en","text":"Disease of the belly,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"being a state of enlargement thereof arising from satiety;"},{"kind":"text","text":"and so ↓"},{"kind":"arabic","text_bw":"baTonN","text_ar":"بَطْنٌ","orth_type":"arrow"},{"kind":"text","text":"; whence the phrase"},{"kind":"arabic","text_bw":"maAta biAlbaToni","text_ar":"مَاتَ بِالبَطْنِ"},{"kind":"italic_en","text":"He died by the disease of the belly."},{"kind":"text","text":"(TA.)"}],"source_refs":["K","TA"]},{"entry_id":"n2809","headword_ar":"بَطَنٌ","root":"bTn","body":[{"kind":"text","text":"One"},{"kind":"italic_en","text":"whose object of care,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety, is his belly:"},{"kind":"text","text":"(K:) or"},{"kind":"italic_en","text":"who has an inordinate desire,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appetite, for food;"},{"kind":"text","text":"(S;)"},{"kind":"italic_en","text":"whom nothing causes care,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"anxiety, but his belly;"},{"kind":"text","text":"(S, TA;) as also ↓"},{"kind":"arabic","text_bw":"miboTaAnN","text_ar":"مِبْطَانٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or the former, (TA,) or ↓ the latter, (S,)"},{"kind":"italic_en","text":"ever large,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"big, in the belly in consequence of much eating:"},{"kind":"text","text":"(S, TA:) or ↓ both signify"},{"kind":"italic_en","text":"voracious; not ceasing from eating."},{"kind":"text","text":"(K.) ―         -b2-  And [hence,] (tropical:)  One"},{"kind":"italic_en","text":"who exults,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exults greatly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"excessively, and behaves insolently and unthankfully,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ungratefully:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"who does so, being abundant in wealth."},{"kind":"text","text":"(K, TA.)"}],"source_refs":["K","TA","S"]}]}}