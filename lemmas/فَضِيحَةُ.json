{"lemma":"فَضِيحَةُ","slug":"فَضِيحَةُ","root":"ف.ض.ح","root_slug":"ف-ض-ح","root_link":"/words/roots/ف-ض-ح","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n34064"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8E%D8%B6%D9%90%D9%8A%D8%AD%D9%8E%D8%A9%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"scandal"},{"pos":"noun","gloss":"shame"},{"pos":"noun","gloss":"disgraceful action, disgrace"},{"pos":"noun","gloss":"ignominy"}]},"etymology":{"source":"wiktextract","text":"Compare فَضَحَ (faḍaḥa, “to shame, disgrace”)."},"ipa":["/fa.dˤiː.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34064","headword_ar":"فَضِيحَةٌ","root":"fDH","body":[{"kind":"text","text":"a subst. from"},{"kind":"arabic","text_bw":"faDaHahu","text_ar":"فَضَحَهُ"},{"kind":"text","text":", as also ↓"},{"kind":"arabic","text_bw":"fuDuwHN","text_ar":"فُضُوحٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, L, K,) and ↓"},{"kind":"arabic","text_bw":"fuDuwHapN","text_ar":"فُضُوحَةٌ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"faDaAHapN","text_ar":"فَضَاحَةٌ","orth_type":"arrow"},{"kind":"text","text":", (L, K,) and ↓"},{"kind":"arabic","text_bw":"fiDaAHN","text_ar":"فِضَاحٌ","orth_type":"arrow"},{"kind":"text","text":"; (K;)"},{"kind":"italic_en","text":"Disgrace, shame,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignominy;"},{"kind":"text","text":"(PS, TA;)"},{"kind":"italic_en","text":"a state of exposure of the vices, faults,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil qualities"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"actions,"},{"kind":"text","text":"of a man: (Har p. 3:)"},{"kind":"italic_en","text":"any evil thing that exposes its author to disgrace"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shame; any disgraceful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shameful, thing:"},{"kind":"text","text":"(L:)"},{"kind":"italic_en","text":"a vice,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fault,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EayobN","text_ar":"عَيْبٌ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"faDaAy^iHu","text_ar":"فَضَايِحُ"},{"kind":"text","text":": (Msb:) [and]"},{"kind":"italic_en","text":"a disgracing; putting to shame;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendering ignominious."},{"kind":"text","text":"(MA and KL; in both of which it is mentioned as an inf. n.) It is said in a trad.,"},{"kind":"arabic","text_bw":"Ald~unoyaA A^ahowanu mino fuDuwHi","text_ar":"الدُّنْيَا اَهْوَنُ مِنْ فُضُوحِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"fuDuwHu","text_ar":"فُضُوحُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"AlA=xirapi","text_ar":"الا=خِرَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The disgrace of the present world is easier to bear than the disgrace of the world to come"},{"kind":"text","text":"]. (A, TA.)"}],"source_refs":["S","A","L","K","Msb"]}]},"classical_definitions":null}