{"lemma":"سَبَّبَ","slug":"سَبَّبَ","root":"س.ب.ب","root_slug":"س-ب-ب","root_link":"/words/roots/س-ب-ب","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"سَبَّبْتَ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"سَبَّبْتِ","in_corpus":true,"count":3,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"سَبَّبْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"سَبَّبْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"سَبَّبْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"سَبَّبَ","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"سَبَّبَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"سَبَّبا","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"سَبَّبَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"سَبَّبُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"سَبَّبْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُسَبِّب","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُسَبِّبِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُسَبِّبِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُسَبِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُسَبِّبا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُسَبِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُسَبِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُسَبِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُسَبِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُسَبِّب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُسَبِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُسَبِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُسَبِّبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُسَبِّبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُسَبِّبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُسَبِّبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُسَبِّبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُسَبِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُسَبِّب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"سَبَّبْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سَبَّبْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":16,"cross_references":{"qac":{"found":true,"lemma_key":"سَبَّبَ","root":"سبب","pos":"N","occurrence_count":9},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":4},"lanes":{"found":true,"entry_ids":["n18613"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8E%D8%A8%D9%8E%D9%91%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to cause, to effect, to trigger, to generate"},{"pos":"noun","gloss":"cable, rope","tags":["Classical"]},{"pos":"noun","gloss":"cause, grounds, aetiological reason","examples":[{"text":"بِسَبَب ذٰلِكَ","english":"because of that"},{"text":"وَكَانَ سَبَبُ قَتْلِهِ أَنَّ أَبَاهُ اسْتَعْمَلَهُ عَلَى الْأَنْدَلُسِ، كَمَا ذَكَرْنَا، عِنْدَ عَوْدِهِ إِلَى الشَّامِ، فَضَبَطَهَا وَسَدَّدَ أُمُورَهَا، وَحَمَى ثُغُورَهَا، وَافْتَتَحَ فِي إِمَارَتِهِ مَدَائِنَ بَقِيَتْ بَعْدَ أَبِيهِ،","english":"\"And the reason for his killing was that his father had appointed him over Al-Andalus, as we have mentioned, upon his return to Ash-Sham, so he brought it under control and set its affairs in order, and protected its frontiers, and opened during his emirate cities that remained after his father,\""}]},{"pos":"noun","gloss":"alibi"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew סיבה (sibá, “cause, reason”)."},"ipa":["/sab.ba.ba/","/sa.bab/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n18613","headword_ar":"سَبَبٌ","root":"sb","body":[{"kind":"italic_en","text":"A rope,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cord;"},{"kind":"text","text":"(S, M, A, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"sib~N","text_ar":"سِبٌّ","orth_type":"arrow"},{"kind":"text","text":"; (S, M, K;) the latter of the dial. of Hudheyl, (S,) and occurring in this sense in a verse of Aboo-Dhu-eyb cited voce"},{"kind":"arabic","text_bw":"xayoTapN","text_ar":"خَيْطَةٌ"},{"kind":"text","text":"; (S, M;) accord. to some, as there meaning"},{"kind":"italic_en","text":"a wooden peg,"},{"kind":"text","text":"[a meaning assigned to it in the K,] but the former is the correct meaning: (M:) the pl. of both words is"},{"kind":"arabic","text_bw":"A^asobaAbN","text_ar":"اَسْبَابٌ"},{"kind":"text","text":", (M, TA, *) [and] the pl. of the latter word is"},{"kind":"arabic","text_bw":"subuwbN","text_ar":"سُبُوبٌ"},{"kind":"text","text":"(S, TA) also: (TA:) or"},{"kind":"arabic","text_bw":"sababN","text_ar":"سَبَبٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"any rope let down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made to descend, from above:"},{"kind":"text","text":"(AO, TA:) or"},{"kind":"italic_en","text":"a strong and long rope,"},{"kind":"text","text":"but no rope is so called except one"},{"kind":"italic_en","text":"by means of which one ascends and descends:"},{"kind":"text","text":"(Khálid Ibn-Jembeh, TA:) or this appellation is only given to"},{"kind":"italic_en","text":"a rope of which one end is attached to a roof"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceiling"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"one by means of which one ascends palm-trees:"},{"kind":"text","text":"(Er-Rághib, TA:) [and]"},{"kind":"italic_en","text":"a rope by means of which one reaches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gains access to, water."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"faloyamodudo","text_ar":"فَلْيَمْدُدْ"},{"kind":"arabic","text_bw":"bisababK A_ilaY A@ls~amaA='i vum~a liyaqoTaEo","text_ar":"بِسَبَبٍ اـِلَى ا@لسَّمَا=ءِ ثُمَّ لِيَقْطَعْ"},{"kind":"text","text":", in the Kur [xxii. 15], means"},{"kind":"italic_en","text":"Let him stretch a rope to the roof,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ceiling,"},{"kind":"text","text":"of his dwelling;"},{"kind":"italic_en","text":"then let him die strangled:"},{"kind":"text","text":"i. e. let him die of rage: (M, TA:) or, as some say,"},{"kind":"italic_en","text":"let him stretch a rope to"},{"kind":"text","text":"the lowest"},{"kind":"italic_en","text":"heaven; then let him traverse"},{"kind":"text","text":"the intervening space until he reach the highest part thereof. (Bd.) The saying"},{"kind":"quote","text":"jab~ato nisaA='a AlEaAlamiyna biAls~ababo"},{"kind":"text","text":"has been expl. in art."},{"kind":"arabic","text_bw":"jb","text_ar":"جب"},{"kind":"text","text":": in this instance, a"},{"kind":"italic_en","text":"rope"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cord,"},{"kind":"text","text":"may be meant; or a"},{"kind":"italic_en","text":"string,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thread."},{"kind":"text","text":"(M, TA.) ―         -b2-  Hence, (Msb,) (tropical:)"},{"kind":"italic_en","text":"A thing"},{"kind":"text","text":"(S, M, Msb, K)"},{"kind":"italic_en","text":"of any kind"},{"kind":"text","text":"(S, Msb, K)"},{"kind":"italic_en","text":"by means of which one attains, reaches,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"gains access to another thing:"},{"kind":"text","text":"(S, M, Msb, K:) pl. as above. (M.) One says,"},{"kind":"arabic","text_bw":"jaEalotu fulaAnFA liY sababFA A_ilaY","text_ar":"جَعَلْتُ فُلَانًا لِى سَبَبًا اـِلَى"},{"kind":"arabic","text_bw":"fulaAnN fiY HaAjatiY","text_ar":"فُلَانٌ فِى حَاجَتِى"},{"kind":"text","text":", i. e. (assumed tropical:)  ["},{"kind":"italic_en","text":"I made such a one"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a means of access"},{"kind":"text","text":"["},{"kind":"italic_en","text":"to such a one in the case of my want"},{"kind":"text","text":"]. (TA.) Hence, (M,)"},{"kind":"arabic","text_bw":"A^asobaAbu Als~amaA='i","text_ar":"اَسْبَابُ السَّمَا=ءِ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The places of ascent of the heaven,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sky:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"the tracts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"regions, thereof:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"the gates thereof."},{"kind":"text","text":"(Ibn-Es-Seed, K. [See an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"vamaAnuwna","text_ar":"ثَمَانُونَ"},{"kind":"text","text":".]) And the saying,"},{"kind":"arabic","text_bw":"AirotaqaY fiY AlA^asobaAbi","text_ar":"اِرْتَقَى فِى الاَسْبَابِ"},{"kind":"text","text":", meaning (assumed tropical:)"},{"kind":"italic_en","text":"He excelled"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"attained to excellence"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"in religion."},{"kind":"text","text":"(M.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"A road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way."},{"kind":"text","text":"(A. [There mentioned among proper, not tropical, significations.]) So in the saying, in the Kur xviii. 88 and 91,"},{"kind":"arabic","text_bw":"vum~a A@t~abaEa sababFA","text_ar":"ثُمَّ ا@تَّبَعَ سَبَبًا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Then he followed a road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way"},{"kind":"text","text":"]. (Bd.) [And] so in the saying,"},{"kind":"arabic","text_bw":"maA liY A_ilayohi sababN","text_ar":"مَا لِى اـِلَيْهِ سَبَبٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"There is not for me any road,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"way, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (A.) So too ↓"},{"kind":"arabic","text_bw":"sabiybapN","text_ar":"سَبِيبَةٌ","orth_type":"arrow"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"sabaAy^ibu","text_ar":"سَبَايِبُ"},{"kind":"text","text":". (Ham p. 347.) ―         -b4-  [(assumed tropical:)"},{"kind":"italic_en","text":"A mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"means, used in order to any end: a means by which a thing is brought about: a cause;"},{"kind":"text","text":"but more properly only"},{"kind":"italic_en","text":"a second cause: an occasion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"accidental cause:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"a reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motive."},{"kind":"text","text":"] One says,"},{"kind":"arabic","text_bw":"h`*aA sababu h`*aA","text_ar":"هٰذَا سَبَبُ هٰذَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"This is the cause,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occasion, of this"},{"kind":"text","text":"]. (Msb.) And"},{"kind":"arabic","text_bw":"bisababihi kaAna ka*aA","text_ar":"بِسَبَبِهِ كَانَ كَذَا"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Because of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, it was thus,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"such a thing was"},{"kind":"text","text":"]. (Msb in art"},{"kind":"arabic","text_bw":"Ajl","text_ar":"اجل"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"sab~aba A@ll~`hu laka sababa xayorK","text_ar":"سَبَّبَ ا@للّٰهُ لَكَ سَبَبَ خَيْرٍ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"May God appoint,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prepare, for thee a means,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cause, of good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prosperity"},{"kind":"text","text":"]. (A.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"A connexion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tie,"},{"kind":"text","text":"(S, A, K, TA,)"},{"kind":"italic_en","text":"of relationship"},{"kind":"text","text":"(S, K, TA)"},{"kind":"italic_en","text":"by marriage;"},{"kind":"text","text":"distinguished from"},{"kind":"arabic","text_bw":"nasabN","text_ar":"نَسَبٌ"},{"kind":"text","text":", which is by birth: from the same word as signifying “ a rope by means of which one reaches, or gains access to, water. ” (TA.) One says,"},{"kind":"arabic","text_bw":"AinoqaTaEa bayonahumu Als~ababu","text_ar":"اِنْقَطَعَ بَيْنَهُمُ السَّبَبُ"},{"kind":"text","text":"i. e. (tropical:)"},{"kind":"italic_en","text":"The connexion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tie,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of affinity between them was severed,"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"AlA^asobaAbu","text_ar":"الاَسْبَابُ"},{"kind":"italic_en","text":"the connexions,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ties."},{"kind":"text","text":"(A)"},{"kind":"arabic","text_bw":"wataqaT~aEato bihimu AlA^asobaAbu","text_ar":"وَتَقَطَّعَتْ بِهِمُ الاَسْبَابُ"},{"kind":"text","text":"[in the Kur ii. 161] means, accord. to I'Ab, (assumed tropical:)"},{"kind":"italic_en","text":"And their ties and affections"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shall be dissundered"},{"kind":"text","text":"]: or, accord. to AZ, (assumed tropical:)"},{"kind":"italic_en","text":"and their places of abode"},{"kind":"text","text":"["},{"kind":"italic_en","text":"shall be divided asunder"},{"kind":"text","text":"]. (TA.) [But]"},{"kind":"arabic","text_bw":"qaTaEa A@ll~`hu bihi Als~ababa","text_ar":"قَطَعَ ا@للّٰهُ بِهِ السَّبَبَ"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"God cut short,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"may God cut short,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his life."},{"kind":"text","text":"(M, K.) ―         -b6-  Also, [from the same word as signifying the “ cord, or rope, of a"},{"kind":"arabic","text_bw":"bayot","text_ar":"بَيْت"},{"kind":"text","text":", ” properly meaning “ tent, ” and tropically “ verse, ”] (assumed tropical:)"},{"kind":"italic_en","text":"A portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"division, of a foot of a verse, consisting of a movent letter and a quiescent letter;"},{"kind":"text","text":"and also"},{"kind":"italic_en","text":"one consisting of two movent letters:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"A^asobaAbN","text_ar":"اَسْبَابٌ"},{"kind":"text","text":". (M, K. [In some of the copies of the K, the latter kind is not mentioned.])"},{"kind":"arabic","text_bw":"sababN xafiyfN","text_ar":"سَبَبٌ خَفِيفٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A light cord"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"a movent letter followed by a quiescent letter;"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"qumo","text_ar":"قُمْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mino","text_ar":"مِنْ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"sababN","text_ar":"سَبَبٌ"},{"kind":"arabic","text_bw":"vaqiylN","text_ar":"ثَقِيلٌ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A heavy cord"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"two movent letters;"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"laka","text_ar":"لَكَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lima","text_ar":"لِمَ"},{"kind":"text","text":". (KT.)"},{"kind":"arabic","text_bw":"sababaAni maqoruwnaAni","text_ar":"سَبَبَانِ مَقْرُونَانِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Two conjoined cords"},{"kind":"text","text":"] means"},{"kind":"italic_en","text":"two portions in which are three successive short vowels followed by a quiescent letter;"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"mutafaA","text_ar":"مُتَفَا"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"mutafaAEiluno","text_ar":"مُتَفَاعِلُنْ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Ealatuno","text_ar":"عَلَتُنْ"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"mufaAEalatuno","text_ar":"مُفَاعَلَتُنْ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"sababaAni maforuwqaAni","text_ar":"سَبَبَانِ مَفْرُوقَانِ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"Two disjoined cords"},{"kind":"text","text":"],"},{"kind":"italic_en","text":"two portions of which each consists of a movent letter and a quiescent letter, and which is followed by a movent letter;"},{"kind":"text","text":"as"},{"kind":"arabic","text_bw":"musotafo","text_ar":"مُسْتَفْ"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"musotafoEiluno","text_ar":"مُسْتَفْعِلُنْ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Eiyluno","text_ar":"عِيلُنْ"},{"kind":"text","text":"in"},{"kind":"arabic","text_bw":"mafaAEiyluno","text_ar":"مَفَاعِيلُنْ"},{"kind":"text","text":". (M, TA.)"}],"source_refs":["S","M","TA","AO","Msb","K","A"]}]}}