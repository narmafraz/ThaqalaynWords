pus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُشْرِقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْرِقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْرَقانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُشْرَقا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُشْرِقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْرِقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْرَقُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُشْرَقُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُشْرِقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُشْرَقْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أُشْرِق","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْرِق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُشْرَق","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُشْرَق","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"أَشْرَقْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَشْرَقْتُ","in_corpus":true,"count":3,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":21,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n22187"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B4%D9%92%D8%B1%D9%8E%D9%82%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22187","headword_ar":"اشرق","root":"$rq","body":[{"kind":"text","text":": see 1, in six places. One says also,"},{"kind":"arabic","text_bw":"A$rq wajohuhu","text_ar":"اشرق وَجْهُهُ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"lawonuhu","text_ar":"لَوْنُهُ"},{"kind":"text","text":", (M,)"},{"kind":"italic_en","text":"His face,"},{"kind":"text","text":"(S,) and"},{"kind":"italic_en","text":"his colour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"complexion,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"shone,"},{"kind":"text","text":"(S, M,)"},{"kind":"italic_en","text":"and was bright, with beauty."},{"kind":"text","text":"(S.) ―         -b2-  Some allow its being made trans.; [meaning"},{"kind":"italic_en","text":"It caused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made, to shine;"},{"kind":"text","text":"] as in the saying,"},{"kind":"quote","text":"valaAvapN tu$oraqu Ald~unoyaA bibahojatihaA\n                      \n                     \n                        $amosu AlD~uHaY waA^abuw A_isoHaAqa wAlqamaru"},{"kind":"text","text":"[There are"},{"kind":"italic_en","text":"three things, with the beauty of which the world is made to shine; the sun of the bright early morning, and Aboo-Is-hák, and the moon"},{"kind":"text","text":"]: but there is no proof in this, because [the right reading may be"},{"kind":"arabic","text_bw":"tu$oriqu","text_ar":"تُشْرِقُ"},{"kind":"text","text":", and so]"},{"kind":"arabic","text_bw":"AldnyA","text_ar":"الدنيا"},{"kind":"text","text":"may be an agent; therefore the making the verb trans. [in this sense] is said to be post-classical, though it is mentioned by the author of the Ksh. (MF, TA.) ―         -b3-  It signifies also"},{"kind":"italic_en","text":"He entered upon the time of sunrise:"},{"kind":"text","text":"(S, M, Mgh, Msb, K:) similarly to"},{"kind":"arabic","text_bw":"A^afojara","text_ar":"اَفْجَرَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^aSobaHa","text_ar":"اَصْبَحَ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^aZohara","text_ar":"اَظْهَرَ"},{"kind":"text","text":". (TA.) See 2.       -A2-"},{"kind":"arabic","text_bw":"A$rq Eaduw~ahu","text_ar":"اشرق عَدُوَّهُ"},{"kind":"italic_en","text":"He caused his enemy to become choked"},{"kind":"text","text":"[with his spittle, or with water, or the like: see 1]. (O, K.) And"},{"kind":"arabic","text_bw":"A^a$oraqotu fulaAnFA biriyqihi","text_ar":"اَشْرَقْتُ فُلَانًا بِرِيقِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"I choked the utterance,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impeded the action, of such a one;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"I did not allow such a one to say,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to do, a thing."},{"kind":"text","text":"(Z, TA.) ―         -b2-"},{"kind":"arabic","text_bw":"A$rq Alv~awoba biAlS~ibogi","text_ar":"اشرق الثَّوْبَ بِالصِّبْغِ"},{"kind":"text","text":", (Moheet, A, O,) or"},{"kind":"arabic","text_bw":"fiY AlS~ibogi","text_ar":"فِى الصِّبْغِ"},{"kind":"text","text":", (K,) (tropical:)"},{"kind":"italic_en","text":"He exceeded the usual degree in dyeing the garment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"piece of cloth;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"saturated it with dye;"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"dyed it thoroughly."},{"kind":"text","text":"(K, TA. [See also 2, last signification but one.])"}],"source_refs":["S","M","Mgh","Msb","K","Moheet","A","O"]}]},"classical_definitions":null}