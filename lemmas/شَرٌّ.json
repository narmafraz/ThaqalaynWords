{"lemma": "شَرٌّ", "slug": "شَرٌّ", "root": "ش.ر.ر", "root_slug": "ش-ر-ر", "root_link": "/words/roots/ش-ر-ر", "pos": "N", "pos_camel": "noun", "paradigm": [], "frequency_in_corpus": 0, "cross_references": {"qac": {"found": true, "lemma_key": "شَرّ", "root": "شرر", "pos": "N", "occurrence_count": 30}, "wiktextract": {"found": true, "entry_count": 7, "pos_tags": ["adj", "noun", "verb"], "has_etymology": true, "sense_count": 8}, "lanes": {"found": true, "entry_ids": ["n22003"], "search_url": "https://lanelexicon.com/?s=%D8%B4%D9%8E%D8%B1%D9%8C%D9%91"}}, "translations": {"en": "evil", "fa": "شر", "ur": "شر", "tr": "kötülük", "id": "kejahatan", "bn": "মন্দ", "es": "mal", "fr": "mal", "de": "Böses", "ru": "зло", "zh": "恶"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to be bad, to be evil, to act badly"}, {"pos": "verb", "gloss": "to blame, to rebuke"}, {"pos": "verb", "gloss": "to be bad, to be evil, to act badly"}, {"pos": "verb", "gloss": "to be bad, to be evil, to act badly"}, {"pos": "noun", "gloss": "verbal noun of شَرَّ (šarra) (form I)", "tags": ["form-of", "noun-from-verb"]}, {"pos": "noun", "gloss": "evil", "examples": [{"text": "وَيَدْعُ ٱلْإِنْسَانُ بِٱلشَّرِّ دُعَاءَهُ بِٱلْخَيْرِ ۖ وَكَانَ الْإِنْسَانُ عَجُولًا", "english": "And man prays for evil as he prays for good. For man is ever hasty."}, {"text": "فَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُ / وَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُ", "english": "So whoever does an atom's weight of good will see it, / And whoever does an atom's weight of evil will see it."}]}, {"pos": "adj", "gloss": "more evil, worse; most evil, worst"}, {"pos": "noun", "gloss": "verbal noun of شَرَّ (šarra) (form I)", "tags": ["form-of", "noun-from-verb"]}]}, "etymology": {"source": "wiktextract", "text": "Compare Ugaritic 𐎌𐎗𐎗 (šrr)."}, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n22003", "headword_ar": "شَرٌّ", "root": "$r", "body": [{"kind": "text", "t