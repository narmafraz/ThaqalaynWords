,{"kind":"text","text":"[so called by the Arabs]), (T, * S, K,)"},{"kind":"italic_en","text":"the son of Isaac the Prophet;"},{"kind":"text","text":"(TA;) [i. e."},{"kind":"italic_en","text":"the Greeks;"},{"kind":"text","text":"generally meaning,"},{"kind":"italic_en","text":"of the Lower Empire;"},{"kind":"text","text":"but sometimes, only"},{"kind":"italic_en","text":"those of Asia;"},{"kind":"text","text":"and sometimes"},{"kind":"italic_en","text":"those of the Lower Empire together with all the nations of Europe beside:"},{"kind":"text","text":"the ancient Greeks are more properly called by the Arabs"},{"kind":"arabic","text_bw":"AlyuwnaAnu","text_ar":"اليُونَانُ"},{"kind":"text","text":":] one says ↓"},{"kind":"arabic","text_bw":"ruwmiY~N","text_ar":"رُومِىٌّ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"ruwmN","text_ar":"رُومٌ"},{"kind":"text","text":"; (S, K;) the former of these two appellations being applied to a single person, (M, K,) and the latter being the pl., (S, K,) [or rather a coll. gen. n.,] like"},{"kind":"arabic","text_bw":"zinojiY~N","text_ar":"زِنْجِىٌّ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zinojN","text_ar":"زِنْجٌ"},{"kind":"text","text":"; (AAF, S, M;) the former being distinguished from the latter only by the doubled"},{"kind":"arabic","text_bw":"Y","text_ar":"ى"},{"kind":"text","text":", like as"},{"kind":"arabic","text_bw":"tamorapN","text_ar":"تَمْرَةٌ"},{"kind":"text","text":"is distinguished from"},{"kind":"arabic","text_bw":"tamorN","text_ar":"تَمْرٌ"},{"kind":"text","text":"its pl. [or coll. gen. n.] only by the"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": (S:) and"},{"kind":"arabic","text_bw":"ruwmiY~N","text_ar":"رُومِىٌّ"},{"kind":"text","text":"has for [its proper] pl. ↓"},{"kind":"arabic","text_bw":"A^arowaAmN","text_ar":"اَرْوَامٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.) [It is also applied to"},{"kind":"italic_en","text":"The country of the nation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"people, so called,"},{"kind":"text","text":"both"},{"kind":"italic_en","text":"in Europe and Asia,"},{"kind":"text","text":"and sometimes only"},{"kind":"italic_en","text":"in Asia."},{"kind":"text","text":"Hence,"},{"kind":"arabic","text_bw":"baHoru Alr~uwmi","text_ar":"بَحْرُ الرُّومِ"},{"kind":"italic_en","text":"The Sea of the Greeks;"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"the Mediterranean Sea."},{"kind":"text","text":"]"}],"source_refs":["M","K","S"]}]},"classical_definitions":null}