, "gen": "f", "num": "p"}, {"role": "past_1mp", "form": "سِلْنا", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "p"}, {"role": "past_1ms", "form": "سِلْتُ", "in_corpus": false, "count": null, "asp": "p", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1ms", "form": "أَسِيل", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "s"}, {"role": "present_1mp", "form": "نَسِيل", "in_corpus": false, "count": null, "asp": "i", "per": "1", "gen": "m", "num": "p"}], "frequency_in_corpus": 1819, "cross_references": {"qac": {"found": true, "lemma_key": "سالَ", "root": "سأل", "pos": "V", "occurrence_count": 106}, "wiktextract": {"found": true, "entry_count": 2, "pos_tags": ["verb"], "has_etymology": true, "sense_count": 3}, "lanes": {"found": true, "entry_ids": ["n20308", "n20581", "n21313", "n21457"], "search_url": "https://lanelexicon.com/?s=%D8%B3%D8%A7%D9%84%D9%8E"}}, "translations": {"en": "to flow", "fa": "جاری شدن", "ur": "بہنا", "tr": "akmak", "id": "mengalir", "bn": "প্রবাহিত হওয়া", "es": "fluir", "fr": "couler", "de": "fließen", "ru": "течь", "zh": "流动"}, "definition": {"source": "wiktextract", "senses": [{"pos": "verb", "gloss": "to flow, to run"}, {"pos": "verb", "gloss": "to stretch over a horse's forehead and nose (of a white spot)"}, {"pos": "verb", "gloss": "alternative form of سَأَلَ (saʔala)", "tags": ["alt-of", "alternative", "dialectal"]}]}, "etymology": {"source": "wiktextract", "text": "From the root س و ل (s w l), alternative form of س ء ل (s ʔ l)."}, "ipa": null, "lanes_definition": {"source": "lanes", "entries": [{"entry_id": "n20308", "headword_ar": "سَالٌّ", "root": "sl", "body": [{"kind": "text", "text": "[act. part. n. of"}, {"kind": "arabic", "text_bw": "sal~a", "text_ar": "سَلَّ"}, {"kind": "text", "text": ","}, {"kind": "italic_en", "text": "Drawing out,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "forth:"}, {"kind": "text", "text": "&c. ―         -b2-"}, {"kind": "italic_en", "text": "Stealing:"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "stealing covertly, secretly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "clandestinely:"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "a thief;"}, {"kind": "text", "text": "as also ↓"}, {"kind": "arabic", "text_bw": "sal~aAlN", "text_ar": "سَلَّالٌ", "orth_type": "arrow"}, {"kind": "text", "text": "[which is commonly applied in the present day to"}, {"kind": "italic_en", "text": "a horse-stealer"}, {"kind": "text", "text": "and"}, {"kind": "italic_en", "text": "the like"}, {"kind": "text", "text": "] and ↓"}, {"kind": "arabic", "text_bw": "A^asal~u", "text_ar": "اَسَلُّ", "orth_type": "arrow"}, {"kind": "text", "text": ". (TA.)       -A2-  See also"}, {"kind": "arabic", "text_bw": "saliylN", "text_ar": "سَلِيلٌ"}, {"kind": "text", "text": "."}], "source_refs": []}, {"entry_id": "n20581", "headword_ar": "سَالٍ", "root": "slw", "body": [{"kind": "text", "text": "[act. part. n. of 1: as such often signifying]"}, {"kind": "italic_en", "text": "Having his heart free from love,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "affection."}, {"kind": "text", "text": "(Har p. 41.)"}], "source_refs": []}, {"entry_id": "n21313", "headword_ar": "سَالَ", "root": "swl", "body": [{"kind": "text", "text": ", aor."}, {"kind": "arabic", "text_bw": "yasaAlu", "text_ar": "يَسَالُ"}, {"kind": "text", "text": ", (Akh, and S, M, Msb, K, all in art."}, {"kind": "arabic", "text_bw": "sA^l", "text_ar": "سال"}, {"kind": "text", "text": ",) like"}, {"kind": "arabic", "text_bw": "xaAfa", "text_ar": "خَافَ"}, {"kind": "text", "text": ", aor."}, {"kind": "arabic", "text_bw": "yaxaAfu", "text_ar": "يَخَافُ"}, {"kind": "text", "text": ", (Msb and K ibid.,) first pers. pret."}, {"kind": "arabic", "text_bw": "silotu", "text_ar": "سِلْتُ"}, {"kind": "text", "text": ", [like"}, {"kind": "arabic", "text_bw": "xifotu", "text_ar": "خِفْتُ"}, {"kind": "text", "text": ",] (Sb, M in the present art., [in the K in this art., erroneously,"}, {"kind": "arabic", "text_bw": "salotu", "text_ar": "سَلْتُ"}, {"kind": "text", "text": ",]) and aor."}, {"kind": "arabic", "text_bw": "A^asaAlu", "text_ar": "اَسَالُ"}, {"kind": "text", "text": ", (Sb, M and K in this art.,) imperative"}, {"kind": "arabic", "text_bw": "salo", "text_ar": "سَلْ"}, {"kind": "text", "text": ", (S, Msb, K, TA, all in art."}, {"kind": "arabic", "text_bw": "sA^l", "text_ar": "سال"}, {"kind": "text", "text": ",) dual"}, {"kind": "arabic", "text_bw": "salaA", "text_ar": "سَلَا"}, {"kind": "text", "text": ", and pl."}, {"kind": "arabic", "text_bw": "saluwA", "text_ar": "سَلُوا"}, {"kind": "text", "text": ", these two being irregular, (Msb in that art.,) inf. n."}, {"kind": "arabic", "text_bw": "suwaAlN", "text_ar": "سُوَالٌ"}, {"kind": "text", "text": ", (M and K in the present art.,) mentioned by Sb and by Th, (M ibid.,) and"}, {"kind": "arabic", "text_bw": "siwaAlN", "text_ar": "سِوَالٌ"}, {"kind": "text", "text": ", (M and K ibid.,) mentioned by Th, (M ibid.,)"}, {"kind": "italic_en", "text": "i. q."}, {"kind": "arabic", "text_bw": "saA^ala", "text_ar": "سَاَلَ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "He asked,"}, {"kind": "text", "text": "&c.], (Akh, and S, M, Msb, K, all in art."}, {"kind": "arabic", "text_bw": "sA^l", "text_ar": "سال"}, {"kind": "text", "text": ",) and"}, {"kind": "arabic", "text_bw": "saA^alotu", "text_ar": "سَاَلْتُ"}, {"kind": "text", "text": "; a dial. var. of the verb with"}, {"kind": "arabic", "text_bw": "A^", "text_ar": "ا"}, {"kind": "text", "text": ", (Sb, M and K in the present art.,) the medial radical being originally"}, {"kind": "arabic", "text_bw": "w", "text_ar": "و"}, {"kind": "text", "text": ", (M and K ibid.,) not a substitute for"}, {"kind": "arabic", "text_bw": "A^", "text_ar": "ا"}, {"kind": "text", "text": ", (M ibid.) as is shown by the phrase"}, {"kind": "arabic", "text_bw": "humaAyatasaAwalaAni", "text_ar": "هُمَايَتَسَاوَلَانِ"}, {"kind": "text", "text": ", (M and K ibid.,) mentioned by AZ: (M ibid.:) it is of the dial. of Hudheyl. (TA in art."}, {"kind": "arabic", "text_bw": "sA^l", "text_ar": "سال"}, {"kind": "text", "text": ".) [For the pass. ("}, {"kind": "arabic", "text_bw": "siyla", "text_ar": "سِيلَ"}, {"kind": "text", "text": "&c.), see"}, {"kind": "arabic", "text_bw": "saA^ala", "text_ar": "سَاَلَ"}, {"kind": "text", "text": ".] A certain elegant scholar says,"}, {"kind": "quote", "text": "saAlato ha*ayolN rasuwla A@ll~`hi faAHi$apF"}, {"kind": "text", "text": "i. e. ["}, {"kind": "italic_en", "text": "Hudheyl"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "asked of the Apostle of God as a thing wished for"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "something beyond measure evil"}, {"kind": "text", "text": "]: it is not from"}, {"kind": "arabic", "text_bw": "saA^ala", "text_ar": "سَاَلَ"}, {"kind": "text", "text": ", [i. e. it is originally"}, {"kind": "arabic", "text_bw": "sawila", "text_ar": "سَوِلَ"}, {"kind": "text", "text": ", not formed from"}, {"kind": "arabic", "text_bw": "saA^ala", "text_ar": "سَاَلَ"}, {"kind": "text", "text": "by the substitution of"}, {"kind": "arabic", "text_bw": "A", "text_ar": "ا"}, {"kind": "text", "text": "for"}, {"kind": "arabic", "text_bw": "A^", "text_ar": "ا"}, {"kind": "text", "text": ",] as many of the elegant scholars say. (Er-Rághib, TA.)       -A2-"}, {"kind": "arabic", "text_bw": "sawila", "text_ar": "سَوِلَ"}, {"kind": "text", "text": ", (M, K,) [aor."}, {"kind": "arabic", "text_bw": "yasowalu", "text_ar": "يَسْوَلُ"}, {"kind": "text", "text": ",] inf. n."}, {"kind": "arabic", "text_bw": "sawalN", "text_ar": "سَوَلٌ"}, {"kind": "text", "text": ", (M,)"}, {"kind": "italic_en", "text": "He,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it, was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, lax, flaccid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "uncompact;"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "it hung down loosely; was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, pendent,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pendulous:"}, {"kind": "text", "text": "(M, K:) [or, said of a man,"}, {"kind": "italic_en", "text": "he was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, flaccid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pendulous, in the belly,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "in the part of the belly below the navel;"}, {"kind": "text", "text": "as appears from an explanation of"}, {"kind": "arabic", "text_bw": "A^asowalu", "text_ar": "اَسْوَلُ"}, {"kind": "text", "text": "and from what here follows:]"}, {"kind": "arabic", "text_bw": "sawalN", "text_ar": "سَوَلٌ"}, {"kind": "text", "text": ", (S, TA,) in the K, erroneously, ↓"}, {"kind": "arabic", "text_bw": "sawolap", "text_ar": "سَوْلَة", "orth_type": "arrow"}, {"kind": "text", "text": ", (TA,) signifies"}, {"kind": "italic_en", "text": "flaccidity,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "uncompactness,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "pendulousness,"}, {"kind": "text", "text": "(S, K, TA,) of the belly, (K,) and so ↓"}, {"kind": "arabic", "text_bw": "tasaw~ulN", "text_ar": "تَسَوُّلٌ", "orth_type": "arrow"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "tasaw~unN", "text_ar": "تَسَوُّنٌ"}, {"kind": "text", "text": ", (TA,) or of the part of the belly below the navel; (S, TA;) and of other things, (K, TA,) as, for instance, (TA,) of a cloud also. (S, TA.)"}], "source_refs": ["M", "K", "S", "TA"]}, {"entry_id": "n21457", "headword_ar": "سَالَ", "root": "syl", "body": [{"kind": "text", "text": ", (S, M, Msb, K,) said of water, (S, Msb, TA,) or of a thing, (M,) aor."}, {"kind": "arabic", "text_bw": "yasiylu", "text_ar": "يَسِيلُ"}, {"kind": "text", "text": ", (Msb, K,) inf. n."}, {"kind": "arabic", "text_bw": "sayolN", "text_ar": "سَيْلٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "sayalaAnN", "text_ar": "سَيَلَانٌ"}, {"kind": "text", "text": "(S, M, Msb, K, TA) and"}, {"kind": "arabic", "text_bw": "masiylN", "text_ar": "مَسِيلٌ"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "masaAlN", "text_ar": "مَسَالٌ"}, {"kind": "text", "text": ", (TA,)"}, {"kind": "italic_en", "text": "It flowed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ran:"}, {"kind": "text", "text": "(M, K, TA:) or, said of water,"}, {"kind": "italic_en", "text": "it rose so as to become excessively copious, and flowed,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "ran:"}, {"kind": "text", "text": "and"}, {"kind": "arabic", "text_bw": "sAl", "text_ar": "سال"}, {"kind": "text", "text": "said of thing,"}, {"kind": "italic_en", "text": "it was,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "became, fluid,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "liquid;"}, {"kind": "text", "text": "contr. of"}, {"kind": "arabic", "text_bw": "jamada", "text_ar": "جَمَدَ"}, {"kind": "text", "text": ". (Msb.) ―         -b2-  The Arabs say,"}, {"kind": "arabic", "text_bw": "saAla bihimu Als~ayolu wajaA$a binaA AlbaHoru", "text_ar": "سَالَ بِهِمُ السَّيْلُ وَجَاشَ بِنَا البَحْرُ"}, {"kind": "text", "text": "["}, {"kind": "italic_en", "text": "The torrent flowed with them, and the sea estuated with us so as to be unnavigable;"}, {"kind": "text", "text": "] meaning, (assumed tropical:)"}, {"kind": "italic_en", "text": "they fell into a hard case, and we fell into one that was harder than it:"}, {"kind": "text", "text": "(M, Meyd:) a proverb. (Meyd.) ―         -b3-  And"}, {"kind": "arabic", "text_bw": "saAlato Ealayohi Alxayolu", "text_ar": "سَالَتْ عَلَيْهِ الخَيْلُ"}, {"kind": "text", "text": "(tropical:)  ["}, {"kind": "italic_en", "text": "The horsemen poured upon him"}, {"kind": "text", "text": "]. (TA. [See also 6.]) ―         -b4-  And"}, {"kind": "arabic", "text_bw": "sAlt Algur~apu", "text_ar": "سالت الغُرَّةُ"}, {"kind": "text", "text": "(assumed tropical:)  ["}, {"kind": "italic_en", "text": "The blaze upon the face of a horse"}, {"kind": "text", "text": "]"}, {"kind": "italic_en", "text": "extended,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "spread, long and wide:"}, {"kind": "text", "text": "(S:) [or, simply,"}, {"kind": "italic_en", "text": "extended down the face;"}, {"kind": "text", "text": "as appears from an explanation of the word"}, {"kind": "arabic", "text_bw": "$imoraAxN", "text_ar": "شِمْرَاخٌ"}, {"kind": "text", "text": "in the S and K &c.: see also"}, {"kind": "arabic", "text_bw": "saAy^ilapN", "text_ar": "سَايِلَةٌ"}, {"kind": "text", "text": ", below. And in like manner"}, {"kind": "arabic", "text_bw": "sAl", "text_ar": "سال"}, {"kind": "text", "text": "is often said of flowing, or defluent, hair.]       -A2-"}, {"kind": "arabic", "text_bw": "siyla", "text_ar": "سِيلَ"}, {"kind": "text", "text": "&c. for"}, {"kind": "arabic", "text_bw": "suy^ila", "text_ar": "سُيِلَ"}, {"kind": "text", "text": ", pass, of"}, {"kind": "arabic", "text_bw": "saA^ala", "text_ar": "سَاَلَ"}, {"kind": "text", "text": ": see this last word, in art."}, {"kind": "arabic", "text_bw": "sA^l", "text_ar": "سال"}, {"kind": "text", "text": "."}], "source_refs": ["S", "M", "Msb", "K", "TA", "Meyd"]}]}, "classical_definitions": {"source": "hawramani", "url": "https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D9%84/", "headword_ar": "سال", "entries": [{"lexicon_id": "dictionary_31", "lexicon_en": "Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)", "lexicon_ar": "المفردات في غريب القرآن للراغب الأصفهاني", "permalink": "https://arabiclexicon.hawramani.com/?p=61778#97e68d", "body_html": "<span class=\"title1\">سال</span><br><span>سَالَ الشيء يَسِيلُ، وأَسَلْتُهُ أنا، قال:</span><br><span>وَأَسَلْنا لَهُ عَيْنَ الْقِطْرِ</span><br><span>[سبأ/ 12] ، أي: أذبنا له، والْإِسَالَةُ في الحقيقة: حالة في القطر تحصل بعد الإذابة، والسَّيْلُ أصله مصدر، وجعل اسما للماء الذي يأتيك ولم يصبك مطره، قال:</span><br><span>فَاحْتَمَلَ السَّيْلُ زَبَداً رابِياً [الرعد/ 17] ، فَأَرْسَلْنا عَلَيْهِمْ سَيْلَ الْعَرِمِ</span><br><span>[سبأ/ 16] ، والسِّيلَانُ: الممتدّ من الحديد، الدّاخل من النّصاب في المقبض.</span>"}]}, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}