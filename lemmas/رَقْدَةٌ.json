{"lemma":"رَقْدَةٌ","slug":"رَقْدَةٌ","root":"ر.ق.د","root_slug":"ر-ق-د","root_link":"/words/roots/ر-ق-د","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n16331"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D9%8E%D9%82%D9%92%D8%AF%D9%8E%D8%A9%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n16331","headword_ar":"رَقْدَةٌ","root":"rqd","body":[{"kind":"italic_en","text":"A sleep."},{"kind":"text","text":"(S.) One says,"},{"kind":"arabic","text_bw":"maA A^aToyaba raqodapa","text_ar":"مَا اَطْيَبَ رَقْدَةَ"},{"kind":"arabic","text_bw":"Als~aHari","text_ar":"السَّحَرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"How sweet is the sleep of the time a little before daybreak!"},{"kind":"text","text":"]. (A.) ―         -b2-"},{"kind":"italic_en","text":"A state of extinction of vitality"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"hamodapN","text_ar":"هَمْدَةٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"between the present life and the life to come."},{"kind":"text","text":"(JK, A. *) ―         -b3-"},{"kind":"arabic","text_bw":"A^aSaAbatonaA raqodapN mana AlHar~i","text_ar":"اَصَابَتْنَا رَقْدَةٌ مَنَ الحَرِّ"},{"kind":"text","text":"(JK, A, K) (tropical:)"},{"kind":"italic_en","text":"A period of heat befell us lasting half a month,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"less,"},{"kind":"text","text":"(A,) or"},{"kind":"italic_en","text":"ten days:"},{"kind":"text","text":"(JK, K:) or"},{"kind":"arabic","text_bw":"raqodapN","text_ar":"رَقْدَةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a heat that befalls one after days of wind and an abatement of violent heat."},{"kind":"text","text":"(L.)"}],"source_refs":["JK","A","K"]}]},"classical_definitions":null}