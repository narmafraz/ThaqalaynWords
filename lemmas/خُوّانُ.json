{"lemma":"خُوّانُ","slug":"خُوّانُ","root":"خ.#.ن","root_slug":"خ-_-ن","root_link":"/words/roots/خ-_-ن","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"خائِن","root":"خون","pos":"N","occurrence_count":3},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["adj","noun"],"has_etymology":true,"sense_count":5},"lanes":{"found":true,"entry_ids":["n11770","n11772","n11773"],"search_url":"https://lanelexicon.com/?s=%D8%AE%D9%8F%D9%88%D9%91%D8%A7%D9%86%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"adj","gloss":"disloyal, faithless, false, unreliable, untrue, unfaithful"},{"pos":"adj","gloss":"traitorous, treacherous, perfidious, treasonous"},{"pos":"noun","gloss":"traitor, judas, betrayer"},{"pos":"noun","gloss":"cheat, deceiver"},{"pos":"noun","gloss":"changeling"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle from خَانَ (ḵāna, “to be disloyal, to betray”)."},"ipa":["/xaː.ʔin/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11770","headword_ar":"خِوَانٌ","root":"xwn","body":[{"kind":"text","text":"(JK, S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"xuwaAnN","text_ar":"خُوَانٌ"},{"kind":"text","text":"(ISk, Msb, K) and ↓"},{"kind":"arabic","text_bw":"A_ixowaAnN","text_ar":"اـِخْوَانٌ","orth_type":"arrow"},{"kind":"text","text":", (IF, Msb, K,) the first of which is the most common, (Msb,)"},{"kind":"italic_en","text":"A table;"},{"kind":"text","text":"(JK;)"},{"kind":"italic_en","text":"a thing upon which one eats;"},{"kind":"text","text":"(S, Mgh, Msb;)"},{"kind":"italic_en","text":"a thing upon which food is eaten:"},{"kind":"text","text":"(K:) but said to be not so called except"},{"kind":"italic_en","text":"when food is upon it:"},{"kind":"text","text":"(Har p. 360:) arabicized [from the Persian]: (S, Msb:) the pl. (of pauc., of the first, S, Msb) is"},{"kind":"arabic","text_bw":"A^axowinapN","text_ar":"اَخْوِنَةٌ"},{"kind":"text","text":"and (of mult., S, Msb)"},{"kind":"arabic","text_bw":"xuwnN","text_ar":"خُونٌ"},{"kind":"text","text":", (S, Mgh, Msb, K,) said by IB to be the only instance of its kind except"},{"kind":"arabic","text_bw":"buwnN","text_ar":"بُونٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"biwaAnN","text_ar":"بِوَانٌ"},{"kind":"text","text":", (TA,) originally"},{"kind":"arabic","text_bw":"xuwunN","text_ar":"خُوُنٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"kutubN","text_ar":"كُتُبٌ"},{"kind":"text","text":"pl. of"},{"kind":"arabic","text_bw":"kitaAbN","text_ar":"كِتَابٌ"},{"kind":"text","text":", (Msb,) but"},{"kind":"arabic","text_bw":"xuwunN","text_ar":"خُوُنٌ"},{"kind":"text","text":"is not used: (S:) the pl. of ↓"},{"kind":"arabic","text_bw":"AxwAn","text_ar":"اخوان","orth_type":"arrow"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"A^axaAwinu","text_ar":"اَخَاوِنُ"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"A^axaAwiynu","text_ar":"اَخَاوِينُ"},{"kind":"text","text":". (TA, from a trad.)"}],"source_refs":["JK","S","Mgh","Msb","K","ISk","IF","TA"]},{"entry_id":"n11772","headword_ar":"خَوَّانٌ","root":"xwn","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"xaAy^inN","text_ar":"خَايِنٌ"},{"kind":"text","text":". ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"Alxaw~aAnu","text_ar":"الخَوَّانُ"},{"kind":"italic_en","text":"The lion:"},{"kind":"text","text":"(JK, S:) because he is [very] treacherous. (JK.) And (assumed tropical:)"},{"kind":"italic_en","text":"Time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fortune."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"A^aEuw*u","text_ar":"اَعُوذُ"},{"kind":"arabic","text_bw":"biA@ll~`hi mina Alxaw~aAni","text_ar":"بِا@للّٰهِ مِنَ الخَوَّانِ"},{"kind":"text","text":"means (assumed tropical:)  ["},{"kind":"italic_en","text":"I seek protection by God"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"from the day of the exhaustion of provisions."},{"kind":"text","text":"(A, TA.)       -A2-  Also, and ↓"},{"kind":"arabic","text_bw":"xuw~aAnN","text_ar":"خُوَّانٌ","orth_type":"arrow"},{"kind":"text","text":", [accord. to the CK, each is with"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":", but this seems to be a mis take, (see"},{"kind":"arabic","text_bw":"$ahorN","text_ar":"شَهْرٌ"},{"kind":"text","text":",)]"},{"kind":"italic_en","text":"The month"},{"kind":"text","text":"["},{"kind":"italic_en","text":"latterly called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"rabiyEN AlA^aw~ala","text_ar":"رَبِيعٌ الاَوَّلَ"},{"kind":"text","text":": pl."},{"kind":"arabic","text_bw":"A^axowinapN","text_ar":"اَخْوِنَةٌ"},{"kind":"text","text":": (K:) but ISd says, \"I know not how this is.\" (TA.)"}],"source_refs":["JK","S","K"]},{"entry_id":"n11773","headword_ar":"خُوَّانٌ","root":"xwn","body":[{"kind":"text","text":": see what next precedes."}],"source_refs":[]}]}}