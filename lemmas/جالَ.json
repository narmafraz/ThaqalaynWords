ac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":3},"lanes":{"found":true,"entry_ids":["n6040","n6206","n6745","n6740","n6744"],"search_url":"https://lanelexicon.com/?s=%D8%AC%D8%A7%D9%84%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to wander, to travel, to roam, to pass, to go around and through"},{"pos":"verb","gloss":"to wander, to travel, to roam, to pass, to go around and through; to come to mind; to think","examples":[{"text":"مَا الَّذِي يَجُولُ فِي ذِهْنِكِ؟","english":"What is on your mind?"}]},{"pos":"noun","gloss":"edge, (of well, valley, sea, etc), shore"}]},"etymology":{"source":"wiktextract","text":"Compare Hebrew גַּל (gal, “wave, tide”)."},"ipa":["/d͡ʒaː.la/","/d͡ʒaːl/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n6040","headword_ar":"جَالٌّ","root":"jl","body":[{"kind":"italic_en","text":"Going forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emigrating, from a country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town, to another country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town;"},{"kind":"text","text":"(Msb;) [as also"},{"kind":"arabic","text_bw":"jaAlK","text_ar":"جَالٍ"},{"kind":"text","text":"; (see art."},{"kind":"arabic","text_bw":"jlw","text_ar":"جلو"},{"kind":"text","text":";)] and so"},{"kind":"arabic","text_bw":"jaAl~apN","text_ar":"جَالَّةٌ"},{"kind":"text","text":", (S, Msb, K,) its pl., (Msb,) applied to a people, or company of men; (S, Msb, K;) originally applied to the Jews who were expelled from El-Hijáz; as also"},{"kind":"arabic","text_bw":"jaAliyapN","text_ar":"جَالِيَةٌ"},{"kind":"text","text":". (Msb.) ―         -b2-  Hence, ↓"},{"kind":"arabic","text_bw":"jaAl~apN","text_ar":"جَالَّةٌ","orth_type":"arrow"},{"kind":"text","text":", as a subst., meaning The"},{"kind":"italic_en","text":"poll-tax;"},{"kind":"text","text":"(Msb;) as also"},{"kind":"arabic","text_bw":"jaAliyapN","text_ar":"جَالِيَةٌ"},{"kind":"text","text":", (S and Msb in art"},{"kind":"arabic","text_bw":"jlw","text_ar":"جلو"},{"kind":"text","text":".) You say,"},{"kind":"arabic","text_bw":"AusotuEomila","text_ar":"اُسْتُعْمِلَ"},{"kind":"arabic","text_bw":"ifulaAnN EalaY AljaAl~ap","text_ar":"ِفُلَانٌ عَلَى الجَالَّة"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one was employed as collector of the poll-tax"},{"kind":"text","text":"]; like as you say,"},{"kind":"arabic","text_bw":"ElY","text_ar":"على"},{"kind":"arabic","text_bw":"AljaAliyapi","text_ar":"الجَالِيَةِ"},{"kind":"text","text":". (S, Msb.)       -A2-"},{"kind":"arabic","text_bw":"jaAl~apN","text_ar":"جَالَّةٌ"},{"kind":"text","text":"as a fem. epithet used as a subst.: see"},{"kind":"arabic","text_bw":"jal~aAlapN","text_ar":"جَلَّالَةٌ"},{"kind":"text","text":"."}],"source_refs":["S","Msb","K"]},{"entry_id":"n6206","headword_ar":"جَالٍ","root":"jlw","body":[{"kind":"italic_en","text":"Going forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emigrating,"},{"kind":"text","text":"from his country, or town: [like"},{"kind":"arabic","text_bw":"jaAl~N","text_ar":"جَالٌّ"},{"kind":"text","text":":] and so"},{"kind":"arabic","text_bw":"jaAliyapN","text_ar":"جَالِيَةٌ"},{"kind":"text","text":", applied to a company of people; [as also"},{"kind":"arabic","text_bw":"jaAl~apN","text_ar":"جَالَّةٌ"},{"kind":"text","text":";] (Msb;) or to"},{"kind":"italic_en","text":"people who have gone forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emigrated, from their homes;"},{"kind":"text","text":"(S;) and particularly to those tributaries, (Mgh, Msb,) namely, certain Jews, (Mgh,) whom 'Omar expelled from the country of the Arabs; (Mgh, Msb;) and afterwards, to"},{"kind":"italic_en","text":"such as have the poll-tax imposed upon them, of the people of the Bible, and of the Magians, though not having emigrated from their homes;"},{"kind":"text","text":"(Mgh;) [i. e.] the"},{"kind":"italic_en","text":"free non-Muslim subjects of a Muslim government;"},{"kind":"text","text":"because they were expelled by 'Omar from Arabia; (K;) the word being fem. because denoting a"},{"kind":"arabic","text_bw":"jamaAEap","text_ar":"جَمَاعَة"},{"kind":"text","text":"; (Mgh;) and its pl. is"},{"kind":"arabic","text_bw":"jawaAlK","text_ar":"جَوَالٍ"},{"kind":"text","text":". (Mgh, Msb.) ―         -b2-  Hence, (Msb,) ↓"},{"kind":"arabic","text_bw":"jaAliyapN","text_ar":"جَالِيَةٌ","orth_type":"arrow"},{"kind":"text","text":"[as a subst.] is applied to The"},{"kind":"italic_en","text":"poll-tax that is exacted from the persons last mentioned above;"},{"kind":"text","text":"(S, Mgh, Msb;) as also"},{"kind":"arabic","text_bw":"jaAl~apN","text_ar":"جَالَّةٌ"},{"kind":"text","text":": (S:) first, in this sense, applied to that which was exacted from the people expelled from Arabia by 'Omar. (Msb.) You say,"},{"kind":"arabic","text_bw":"AusotuEomila fulaAnN EalaY","text_ar":"اُسْتُعْمِلَ فُلَانٌ عَلَى"},{"kind":"arabic","text_bw":"AljaAliyapi","text_ar":"الجَالِيَةِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Such a one was employed as collector of the poll-tax"},{"kind":"text","text":"]. (S, Mgh, Msb.)       -A2-  See also"},{"kind":"arabic","text_bw":"jaAy^ilN","text_ar":"جَايِلٌ"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"jwl","text_ar":"جول"},{"kind":"text","text":"."}],"source_refs":["Mgh","Msb","S"]},{"entry_id":"n6745","headword_ar":"جَالٍ","root":"jwl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"jaAy^ilN","text_ar":"جَايِلٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n6740","headword_ar":"جَالَ","root":"jwl","body":[{"kind":"text","text":", (S, K, &c.,) aor."},{"kind":"arabic","text_bw":"yajuwlu","text_ar":"يَجُولُ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"jawolN","text_ar":"جَوْلٌ"},{"kind":"text","text":"(S, K) and"},{"kind":"arabic","text_bw":"juwlN","text_ar":"جُولٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"jawalaAnN","text_ar":"جَوَلَانٌ"},{"kind":"text","text":"(Az, S, ISd, Z, Sgh) and"},{"kind":"arabic","text_bw":"juw^uwlN","text_ar":"جُوُولٌ"},{"kind":"text","text":"(ISd, K) and"},{"kind":"arabic","text_bw":"jiylaAlN","text_ar":"جِيلَالٌ"},{"kind":"text","text":", (Ibn-'Abbád, K, TA,) in some copies of the K"},{"kind":"arabic","text_bw":"jiylaAn","text_ar":"جِيلَان"},{"kind":"text","text":"; (TA;) and in like manner, ↓"},{"kind":"arabic","text_bw":"AjtAl","text_ar":"اجتال","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"AnjAl","text_ar":"انجال","orth_type":"arrow"},{"kind":"text","text":"; (S, K;)"},{"kind":"italic_en","text":"He went round"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about,"},{"kind":"text","text":"or or"},{"kind":"italic_en","text":"round about;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"jw~l","text_ar":"جوّل","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"tajowaAlN","text_ar":"تَجْوَالٌ"},{"kind":"text","text":": (K:) or"},{"kind":"arabic","text_bw":"jw~l","text_ar":"جوّل"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he went round,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"round about, much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often;"},{"kind":"text","text":"agreeably with what Sb says of the measure"},{"kind":"arabic","text_bw":"tafoEaAlN","text_ar":"تَفْعَالٌ"},{"kind":"text","text":"; but accord. to the O,"},{"kind":"arabic","text_bw":"tajowaAlN","text_ar":"تَجْوَالٌ"},{"kind":"text","text":"is an inf. n. of"},{"kind":"arabic","text_bw":"jAl","text_ar":"جال"},{"kind":"text","text":". (TA.) You say,"},{"kind":"arabic","text_bw":"jAl fiY AlbilaAdi","text_ar":"جال فِى البِلَادِ"},{"kind":"italic_en","text":"He went about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"round about, in the countries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"districts, not remaining fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled:"},{"kind":"text","text":"(Msb:) and"},{"kind":"arabic","text_bw":"AlbilaAda","text_ar":"البِلَادَ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"jw~l","text_ar":"جوّل","orth_type":"arrow"},{"kind":"text","text":", (T, TA,) or"},{"kind":"arabic","text_bw":"jw~l fiY AlbilaAdi","text_ar":"جوّل فِى البِلَادِ"},{"kind":"text","text":", (S,) inf. n."},{"kind":"arabic","text_bw":"tajowiylN","text_ar":"تَجْوِيلٌ"},{"kind":"text","text":", (T, TA,) or"},{"kind":"arabic","text_bw":"tajowaAlN","text_ar":"تَجْوَالٌ"},{"kind":"text","text":", (S,)"},{"kind":"italic_en","text":"he went about,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"round about, much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"often, in the countries,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"districts."},{"kind":"text","text":"(T, S, TA.) And"},{"kind":"arabic","text_bw":"jAl fiY AlmayodaAni","text_ar":"جال فِى المَيْدَانِ"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"jawolapN","text_ar":"جَوْلَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"jawalaAnN","text_ar":"جَوَلَانٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"traversed the sides,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lateral parts"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tracts, of the horse-course;"},{"kind":"text","text":"which are termed"},{"kind":"arabic","text_bw":"A^ajowaAlN","text_ar":"اَجْوَالٌ"},{"kind":"text","text":", pl. of"},{"kind":"arabic","text_bw":"juwlN","text_ar":"جُولٌ"},{"kind":"text","text":". (Msb.) And"},{"kind":"arabic","text_bw":"jAl fiY AlHarobi","text_ar":"جال فِى الحَرْبِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jawolapN","text_ar":"جَوْلَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He wheeled round,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, in battle."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"far~a lilojawalaAni vum~a EaAda liloqitaAli","text_ar":"فَرَّ لِلْجَوَلَانِ ثُمَّ عَادَ لِلْقِتَالِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He fled, to wheel round,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"about, and then returned to the fight"},{"kind":"text","text":"]. (Msb in art."},{"kind":"arabic","text_bw":"kr","text_ar":"كر"},{"kind":"text","text":".) And"},{"kind":"arabic","text_bw":"jAluwA","text_ar":"جالُوا"},{"kind":"text","text":", (Msb,) or ↓"},{"kind":"arabic","text_bw":"tajaAwaluwA","text_ar":"تَجَاوَلُوا","orth_type":"arrow"},{"kind":"text","text":", (S, K,) means"},{"kind":"arabic","text_bw":"jAl baEoDuhumo EalaY baEoDK","text_ar":"جال بَعْضُهُمْ عَلَى بَعْضٍ"},{"kind":"text","text":", (S, Msb,"},{"kind":"page_break","n":489},{"kind":"text","text":"K,) i. e.,"},{"kind":"italic_en","text":"They assailed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assaulted, one another,"},{"kind":"text","text":"(TA,)"},{"kind":"arabic","text_bw":"fiY AlHarobi","text_ar":"فِى الحَرْبِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in battle"},{"kind":"text","text":"]; (S, Msb, K;) [and so, app., ↓"},{"kind":"arabic","text_bw":"jaAwaluwA","text_ar":"جَاوَلُوا","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mujaAwalapN","text_ar":"مُجَاوَلَةٌ"},{"kind":"text","text":":] and"},{"kind":"arabic","text_bw":"kaAnato bayonahumo","text_ar":"كَانَتْ بَيْنَهُمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"mujaAwalaAtN","text_ar":"مُجَاوَلَاتٌ","orth_type":"arrow"},{"kind":"text","text":"(S, K *)"},{"kind":"italic_en","text":"There were between them mutual"},{"kind":"text","text":"["},{"kind":"italic_en","text":"assailings,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assaults, and"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"defendings."},{"kind":"text","text":"(Ibn-'Abbád, TA.) And"},{"kind":"arabic","text_bw":"jAl Alqawomu","text_ar":"جال القَوْمُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"jawolapN","text_ar":"جَوْلَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The company of men were routed, defeated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"put to flight,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Ainoka$afuwA","text_ar":"اِنْكَشَفُوا"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"and then returned to the fight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"charged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assaulted."},{"kind":"text","text":"(K.) And"},{"kind":"arabic","text_bw":"A^aSaAba","text_ar":"اَصَابَ"},{"kind":"arabic","text_bw":"Almusolimiyna jawolapN","text_ar":"المُسْلِمِينَ جَوْلَةٌ"},{"kind":"italic_en","text":"Defeat befell the Muslims:"},{"kind":"text","text":"a metonymy; used only in relation to the favourites of God; from"},{"kind":"arabic","text_bw":"AljawalaAnu","text_ar":"الجَوَلَانُ"},{"kind":"text","text":". (Mgh.) ―         -b2-"},{"kind":"arabic","text_bw":"jAlwuA fiY","text_ar":"جالوُا فِى"},{"kind":"arabic","text_bw":"AlD~alaAlapi","text_ar":"الضَّلَالَةِ"},{"kind":"text","text":", (Sgh, TA,) or"},{"kind":"arabic","text_bw":"A_ilaY AlD~alaAlapi","text_ar":"اـِلَى الضَّلَالَةِ"},{"kind":"text","text":", (A, TA,) (assumed tropical:)"},{"kind":"italic_en","text":"They became excited to lightness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"levity, and unsteadiness, and carried away, and driven,"},{"kind":"text","text":"(Sgh, TA,) or"},{"kind":"italic_en","text":"they became fascinated, and turned away,"},{"kind":"text","text":"(A, TA,) by the influence of devils, (A, Sgh, TA,) from their religion, (Sgh, TA,) or from the right course, (A, TA,)"},{"kind":"italic_en","text":"to error."},{"kind":"text","text":"(A, Sgh, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"jAl Alt~uraAbu","text_ar":"جال التُّرَابُ"},{"kind":"text","text":", (ISd, K,) inf. n."},{"kind":"arabic","text_bw":"jawolN","text_ar":"جَوْلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The dust went away, and rose;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AnjAl","text_ar":"انجال","orth_type":"arrow"},{"kind":"text","text":": (ISd, K:) or the latter signifies"},{"kind":"italic_en","text":"became removed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cleared away"},{"kind":"text","text":"[by the wind]; syn."},{"kind":"arabic","text_bw":"Ainoka$aTa","text_ar":"اِنْكَشَطَ"},{"kind":"text","text":". (T, TA.) ―         -b4-"},{"kind":"arabic","text_bw":"yajuwlu fiY SadoriY A^ano A^afoEalahu","text_ar":"يَجُولُ فِى صَدْرِى اَنْ اَفْعَلَهُ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"It is revolved in my bosom,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind, that I should do it"},{"kind":"text","text":"]. (TA.) ―         -b5-  See also 4, in two places.       -A2-"},{"kind":"arabic","text_bw":"jAl","text_ar":"جال"},{"kind":"arabic","text_bw":"Al$~aYo'a","text_ar":"الشَّىْءَ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"jawolN","text_ar":"جَوْلٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He chose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"selected, the thing."},{"kind":"text","text":"(K.) You say,"},{"kind":"arabic","text_bw":"julotu h`*aA mino","text_ar":"جُلْتُ هٰذَا مِنْ"},{"kind":"arabic","text_bw":"h`*aA","text_ar":"هٰذَا"},{"kind":"italic_en","text":"I chose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"selected, this from this."},{"kind":"text","text":"(AA, S.) And"},{"kind":"arabic","text_bw":"manohumo jawolFA","text_ar":"مَنْهُمْ جَوْلًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Aijotalotu","text_ar":"اِجْتَلْتُ","orth_type":"arrow"},{"kind":"italic_en","text":"I chose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"selected, from them"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a choice portion"},{"kind":"text","text":"]; (S, K, * TA;) and"},{"kind":"italic_en","text":"separated some of them from others."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"mino maAlihi jawolFA","text_ar":"مِنْ مَالِهِ جَوْلًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AjtAl","text_ar":"اجتال","orth_type":"arrow"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"jawaAlapF","text_ar":"جَوَالَةً"},{"kind":"text","text":","},{"kind":"italic_en","text":"He chose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"selected, from his property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cattle, a choice portion."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","Az","ISd","Z","Sgh","Msb","T","TA","A"]},{"entry_id":"n6744","headword_ar":"جَالٌ","root":"jwl","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"juwlN","text_ar":"جُولٌ"},{"kind":"text","text":", in five places: ―         -b2-  and"},{"kind":"arabic","text_bw":"mijowalN","text_ar":"مِجْوَلٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}