,"num":"d"},{"role":"present_2mp","form":"تُكافِئُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُكافِئُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُكافِئْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُكافِئ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُكافِئ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُكافِئا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُكافِئانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُكافِئا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُكافِئانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُكافِئُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُكافِئُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُكافِئْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"كافَأْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"كافَأْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أُكافِئ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُكافِئ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":4,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":false}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be equal to","tags":["transitive"]},{"pos":"verb","gloss":"to remunerate; to reward; to award","tags":["transitive"]}]},"etymology":null,"ipa":["/kaː.fa.ʔa/"],"lanes_definition":null,"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%83%D8%A7%D9%81%D8%A3/","headword_ar":"كَافَأَهُ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=24030#375033","body_html":"<span>كَافَأَهُ مُكافَأَةً وكِفَاءً: جازَاه،</span><br><span>وـ فلاناً: ماثَلَه، وراقَبَه. والحمدُ لله كِفَاءَ الواجِبِ، أي: ما يكونُ مُكافِئاً له، والاسمُ: الكفَاءَةُ والكَفَاءُ، بفتحهما ومدِّهما.</span><br><span>وهذا كِفاؤُه وكِفْأَتُهُ وكَفِيئُه وكُفْؤُه وكَفْؤُه وكِفْؤُه وكُفوؤُه: مَثْلُه، ج: أكْفاءٌ وكِفَاءٌ.</span><br><span>وكَفَأَه، كمنعه: صَرَفَهُ، وكَبَّهُ، وقَلَبَه،</span><br><span>كأكْفَأَه واكْتَفَأَه، وتَبِعَهُ،</span><br><span>وـ الغَنَمُ في الشِّعْبِ: دَخَلَتْ،</span><br><span>وـ فلاناً: طَرَدَهُ،</span><br><span>وـ القومُ: انْصَرَفُوا وانْهَزَموا،</span><br><span>وـ عنِ القَصْد: جاروا.</span><br><span>وأَكْفَأَ: مالَ وأمالَ، وقَلَبَ، وخالَفَ بَيْنَ إعْرَابِ القَوافي، أَوْ خالَفَ بين هِجائِها، أِوْ أَقْوَى، أَوْ أفْسَدَ في آخِرِ البَيْتِ أيَّ إفْسَادٍ كان،</span><br><span>وـ الإِبِلُ: كَثُرَ نِتاجُها،</span><br><span>وـ إبلَه فلاناً: جَعَلَ له مَنَافعَها.</span><br><span>والكَفْأَةُ، ويُضَمُّ: حَمْلُ النَّخْلِ سَنَتَها،</span><br><span>وـ في الأَرْضِ: زراعةُ سَنَتِها،</span><br><span>وـ الإِبِلِ: نِتَاجُ عامِها، أَوْ نِتَاجُها بعدَ حِيالِ سَنَةٍ أَوْ أكْثَرَ.</span><br><span>ومَنَحَه كَفْأَةَ غَنَمِه، ويُضَمُّ: وَهَبَ له أَلْبَانَها وأولادَها وأصْوافَها سَنَةً، ورَدَّ عليه الأُمَّهاتِ.</span><br><span>والكِفاءُ، ككتابٍ: سُتْرَةٌ من أعْلَى البَيْتِ إلى أسفله من مُؤَخَّرِه، أَو الشُّقَّةُ في مؤَخَّرِ الخباءِ، أَوْ كِساءٌ يُلْقَى على الخباءِ حتى يَبْلُغَ الأَرْض، وقد أكْفَأْتُ البَيْتَ.</span><br><span>وكَفيءُ اللَّوْنِ، </span><span>ومُكْفَؤُه: كاسِفُه مُتَغَيِّرُه.</span><br><span>وكافَأَهُ: دافَعَه،</span><br><span>وـ بَيْنَ فَارِسَيْنِ بِرُمْحِه: طَعَنَ هذا ثُمَّ هذا.</span><br><span>وشاتانِ مُكافَأَتَانِ، وتُكْسَرُ الفاءُ: كُلُّ واحدةٍ منهما مُساوِيةٌ لصاحِبَتها في السِّنِّ.</span><br><span>وانْكَفَأَ: رَجَعَ،</span><br><span>وـ لَوْنُهُ: تَغَيَّرَ.</span><br><span>والكَفِيءُ والكِفْءُ، بالكسر: بَطْنُ الوادي.</span><br><span>والتَّكَافُؤُ: الاستواءُ.</span>"}]}}