{"lemma":"تَراخِيانِ","slug":"تَراخِيانِ","root":"ر.خ.#","root_slug":"ر-خ-_","root_link":"/words/roots/ر-خ-_","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n15166"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D8%B1%D8%A7%D8%AE%D9%90%D9%8A%D8%A7%D9%86%D9%90"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n15166","headword_ar":"تراخى","root":"rxw","body":[{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"remitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flagged, in his running;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, remiss,"},{"kind":"text","text":"or"},{"kind":"page_break","n":1061},{"kind":"italic_en","text":"languid, therein."},{"kind":"text","text":"(Az, TA.) And [in like manner]"},{"kind":"arabic","text_bw":"fiY AlA^amori","text_ar":"فِى الاَمْرِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"AstrxY","text_ar":"استرخى","orth_type":"arrow"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He remitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flagged, in the affair;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, remiss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languid, therein"},{"kind":"text","text":"]. (K in arts."},{"kind":"arabic","text_bw":"bn$","text_ar":"بنش"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"fn$","text_ar":"فنش"},{"kind":"text","text":", &c.) And"},{"kind":"arabic","text_bw":"trAxY Eano HaAjatihi","text_ar":"تراخى عَنْ حَاجَتِهِ"},{"kind":"italic_en","text":"He remitted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flagged, in the accomplishment of his want;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, remiss,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"languid, therein."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"He drew back, held back,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"hung back,"},{"kind":"text","text":"(JK, K, TA,)"},{"kind":"arabic","text_bw":"Ean~iY","text_ar":"عَنِّى"},{"kind":"italic_en","text":"from me,"},{"kind":"text","text":"(TA,) or"},{"kind":"arabic","text_bw":"Eani Al$~aYo'a","text_ar":"عَنِ الشَّىْءَ"},{"kind":"italic_en","text":"from the thing."},{"kind":"text","text":"(JK.) ―         -b3-"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slow, sluggish, tardy, dilatory, late,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"backward."},{"kind":"text","text":"(JK, TA.) You say also,"},{"kind":"arabic","text_bw":"trAxY Als~amaA='u","text_ar":"تراخى السَّمَا=ءُ"},{"kind":"italic_en","text":"The rain delayed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was tardy, late,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"backward."},{"kind":"text","text":"(S, K.) [And"},{"kind":"arabic","text_bw":"trAxY Alwaqotu","text_ar":"تراخى الوَقْتُ"},{"kind":"italic_en","text":"The time was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, late:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it became protracted."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"trAxY Eanohu","text_ar":"تراخى عَنْهُ"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, after,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"later than, it:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"mutaraAxK","text_ar":"مُتَرَاخٍ"},{"kind":"text","text":", below.] And"},{"kind":"arabic","text_bw":"trAxY AlA^amoru","text_ar":"تراخى الاَمْرُ"},{"kind":"italic_en","text":"The affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, protracted; the time thereof became extended."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"fiY AlA^amori taraAxK","text_ar":"فِى الاَمْرِ تَرَاخٍ"},{"kind":"italic_en","text":"In the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, is ample time"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scope"},{"kind":"text","text":"["},{"kind":"italic_en","text":"for action &c."},{"kind":"text","text":"]; syn."},{"kind":"arabic","text_bw":"fusoHapN","text_ar":"فُسْحَةٌ"},{"kind":"text","text":"; (Msb, TA;) and"},{"kind":"italic_en","text":"extension,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"protractedness:"},{"kind":"text","text":"(TA:) or"},{"kind":"italic_en","text":"remoteness;"},{"kind":"text","text":"referring to the case of the resurrection, i. e. the time thereof. (Mgh in art."},{"kind":"arabic","text_bw":"ntj","text_ar":"نتج"},{"kind":"text","text":".)"}],"source_refs":["JK","K","TA"]}]},"classical_definitions":null}