ext":"or"},{"kind":"italic_en","text":"became, firm, strong, sound, free from defect"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imperfection, established,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"confirmed:"},{"kind":"text","text":"] and, said of an affair, or a case,"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, in a firm, solid, sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"on a firm, solid, sound,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"good, footing;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"AHtkm","text_ar":"احتكم","orth_type":"arrow"},{"kind":"text","text":". (TA.) ―         -b3-"},{"kind":"arabic","text_bw":"AstHkm Ealayohi","text_ar":"استحكم عَلَيْهِ"},{"kind":"arabic","text_bw":"AlA^amoru","text_ar":"الاَمْرُ"},{"kind":"italic_en","text":"The thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, became confused and dubious to him;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"Ailotabasa","text_ar":"اِلْتَبَسَ"},{"kind":"text","text":": so in the A. (TA. [But this seems to require confirmation.])"}],"source_refs":["S","Mgh","Msb","K"]}]},"classical_definitions":null}