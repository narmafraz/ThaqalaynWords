of sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herd of goats:"},{"kind":"text","text":"(S, K:) a Pers. word, (S,) arabicized, (S, K,) from"},{"kind":"arabic","text_bw":"ramaho","text_ar":"رَمَهْ"},{"kind":"text","text":". (K.)"}],"source_refs":["Lth","K","S","Mgh","Msb","TA"]},{"entry_id":"n16673","headword_ar":"رُمُقٌ","root":"rmq","body":[{"kind":"text","text":", a pl., signifying"},{"kind":"italic_en","text":"Poor"},{"kind":"text","text":"men,"},{"kind":"italic_en","text":"who are satisfied with little sustenance, such as suffices to stay,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"arrest, the remains of life,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to maintain the strength:"},{"kind":"text","text":"―         -b2-  and"},{"kind":"italic_en","text":"envying"},{"kind":"text","text":"persons: sing. ↓"},{"kind":"arabic","text_bw":"raAmiqN","text_ar":"رَامِقٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"ramuwqN","text_ar":"رَمُوقٌ","orth_type":"arrow"},{"kind":"text","text":": (IAar, K, TA:) which signifies one."},{"kind":"italic_en","text":"who looks at men from the outer angle of the eye and with envy."},{"kind":"text","text":"(IAar, TA.)"}],"source_refs":["IAar","K","TA"]},{"entry_id":"n16679","headword_ar":"رُمَّقٌ","root":"rmq","body":[{"kind":"italic_en","text":"Weak;"},{"kind":"text","text":"(K;) applied to a man. (TA.)"}],"source_refs":[]}]}}