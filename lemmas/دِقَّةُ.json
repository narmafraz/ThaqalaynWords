{"lemma":"دِقَّةُ","slug":"دِقَّةُ","root":"د.ق.ق","root_slug":"د-ق-ق","root_link":"/words/roots/د-ق-ق","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n12789","n12790"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%90%D9%82%D9%8E%D9%91%D8%A9%D9%8F"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"accuracy, precision"},{"pos":"noun","gloss":"resolution"},{"pos":"noun","gloss":"powder, fine dust, dukkah (spice mixture dish)"}]},"etymology":null,"ipa":["/diq.qa/","/daq.qa/","/duq.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n12789","headword_ar":"دُقَّةٌ","root":"dq","body":[{"kind":"italic_en","text":"Soft dust swept by the wind"},{"kind":"text","text":"(S, K)"},{"kind":"italic_en","text":"from the ground:"},{"kind":"text","text":"pl."},{"kind":"arabic","text_bw":"duqaqN","text_ar":"دُقَقٌ"},{"kind":"text","text":": (S:) or"},{"kind":"italic_en","text":"dust swept from the ground;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"duqaAqapN","text_ar":"دُقَاقَةٌ","orth_type":"arrow"},{"kind":"text","text":": (TA:) or"},{"kind":"arabic","text_bw":"duqaqu","text_ar":"دُقَقُ"},{"kind":"arabic","text_bw":"Alt~uraAbi","text_ar":"التُّرَابِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"fine dust;"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"duq~apN","text_ar":"دُقَّةٌ"},{"kind":"text","text":"is its sing.: (M:) or, accord. to IB, the sing. of"},{"kind":"arabic","text_bw":"duqaqN","text_ar":"دُقَقٌ"},{"kind":"text","text":"is ↓"},{"kind":"arabic","text_bw":"duq~aY","text_ar":"دُقَّى","orth_type":"arrow"},{"kind":"text","text":", like as the sing. of"},{"kind":"arabic","text_bw":"julalN","text_ar":"جُلَلٌ"},{"kind":"text","text":"is"},{"kind":"arabic","text_bw":"jul~aY","text_ar":"جُلَّى"},{"kind":"text","text":". (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Seeds that are used in cooking, for seasoning food,"},{"kind":"text","text":"(IDrd, M, K,)"},{"kind":"italic_en","text":"bruised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brayed,"},{"kind":"text","text":"(M,)"},{"kind":"italic_en","text":"and what are mixed therewith;"},{"kind":"text","text":"(IDrd;)"},{"kind":"italic_en","text":"such as are termed"},{"kind":"arabic","text_bw":"qazoH","text_ar":"قَزْح"},{"kind":"text","text":", and"},{"kind":"italic_en","text":"the like: all such seeds of the cooking-pot"},{"kind":"text","text":"are called"},{"kind":"arabic","text_bw":"duq~ap","text_ar":"دُقَّة"},{"kind":"text","text":"by the people of Mekkeh: (IDrd, Sgh:) and"},{"kind":"italic_en","text":"salt with such seeds mixed therewith:"},{"kind":"text","text":"(M, K:) this is the application now commonly obtaining: (TA:) or"},{"kind":"italic_en","text":"salt alone:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"salt bruised,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"brayed:"},{"kind":"text","text":"(Lth, K:) whence the saying,"},{"kind":"arabic","text_bw":"maA lahu duq~apN","text_ar":"مَا لَهُ دُقَّةٌ"},{"kind":"italic_en","text":"He has not salt."},{"kind":"text","text":"(Lth, M, K. *) ―         -b3-  And [hence,] (tropical:)"},{"kind":"italic_en","text":"Beauty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prettiness:"},{"kind":"text","text":"(M, K, TA:) whence the phrase"},{"kind":"arabic","text_bw":"AimoraA^apN laA duq~apa lahaA","text_ar":"اِمْرَاَةٌ لَا دُقَّةَ لَهَا"},{"kind":"text","text":", (M,) or"},{"kind":"arabic","text_bw":"qaliylapu Ald~uq~api","text_ar":"قَلِيلَةُ الدُّقَّةِ"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"maA lahaA duq~apN","text_ar":"مَا لَهَا دُقَّةٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"A woman who is not beautiful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pretty;"},{"kind":"text","text":"(M, K; *)"},{"kind":"italic_en","text":"who has not beauty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prettiness."},{"kind":"text","text":"(TA.) ―         -b4-  Also"},{"kind":"italic_en","text":"A certain ornament"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"HaloYN","text_ar":"حَلْىٌ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"of the people of Mekkeh."},{"kind":"text","text":"(K.) ―         -b5-  And The"},{"kind":"italic_en","text":"small,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"young,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Ha$ow","text_ar":"حَشْو"},{"kind":"text","text":",)"},{"kind":"italic_en","text":"of camels."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","K","TA","M","IDrd","Sgh","Lth"]},{"entry_id":"n12790","headword_ar":"دِقَّةٌ","root":"dq","body":[{"kind":"text","text":"inf. n. of the intrans. verb"},{"kind":"arabic","text_bw":"daq~a","text_ar":"دَقَّ"},{"kind":"text","text":"[q. v.]. (S, Msb, K.) [As a simple subst.,] The"},{"kind":"italic_en","text":"state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quality, of that which is termed"},{"kind":"arabic","text_bw":"diq~N","text_ar":"دِقٌّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and"},{"kind":"arabic","text_bw":"daqiyqN","text_ar":"دَقِيقٌ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"properly"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"tropically:"},{"kind":"text","text":"i. e., it signifies"},{"kind":"italic_en","text":"slenderness,"},{"kind":"text","text":"&c.]: and"},{"kind":"italic_en","text":"smallness, littleness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"["},{"kind":"italic_en","text":"properly"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"tropically;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"EiZamN","text_ar":"عِظَمٌ"},{"kind":"text","text":". (K.) ―         -b2-  [Hence,] (tropical:)"},{"kind":"italic_en","text":"Littleness in estimation, paltriness, inconsiderableness, meanness, vileness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contemptibleness."},{"kind":"text","text":"(K, TA.) ―         -b3-  [And (assumed tropical:)"},{"kind":"italic_en","text":"Subtileness, niceness, abstruseness, reconditeness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obscureness."},{"kind":"text","text":"]"}],"source_refs":[]}]},"classical_definitions":null}