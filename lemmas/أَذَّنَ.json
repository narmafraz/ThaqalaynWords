{"lemma":"أَذَّنَ","slug":"أَذَّنَ","root":"#.ذ.ن","root_slug":"_-ذ-ن","root_link":"/words/roots/_-ذ-ن","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"أَذَّنْتَ","in_corpus":true,"count":2,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"أَذَّنْتِ","in_corpus":true,"count":12,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"أَذَّنْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"أَذَّنْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"أَذَّنْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"أَذَّنَ","in_corpus":true,"count":22,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"أَذَّنَت","in_corpus":true,"count":12,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"أَذَّنا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"أَذَّنَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"أَذَّنُوا","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"أَذَّنَّ","in_corpus":true,"count":118,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُؤَذِّن","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُؤَذِّنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُؤَذِّنِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُؤَذِّنانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُؤَذِّنا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُؤَذِّنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُؤَذِّنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُؤَذِّنَّ","in_corpus":true,"count":7,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُؤَذِّن","in_corpus":true,"count":56,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُؤَذِّن","in_corpus":true,"count":7,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُؤَذِّنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُؤَذِّنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُؤَذِّنانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُؤَذِّنا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُؤَذِّنُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُؤَذِّنُوا","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُؤَذِّنَّ","in_corpus":true,"count":56,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"أَذَّنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَذَّنْتُ","in_corpus":true,"count":12,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُؤَذِّن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُؤَذِّن","in_corpus":true,"count":7,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":320,"cross_references":{"qac":{"found":true,"lemma_key":"أَذَّنَ","root":"أذن","pos":"N","occurrence_count":39},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["","n14078","n484","n485","n486","n487","n488"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%B0%D9%8E%D9%91%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to announce, make known, inform (بِـ (bi-) about something)"},{"pos":"verb","gloss":"to announce, make known, inform (بِـ (bi-) about something); to call to prayer, to perform adhan","examples":[{"text":"آذَنَ المُؤَذِّنُ بِالصَلَاةِ","english":"The preacher called everyone to prayer"}]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14078","headword_ar":"اَذَنٌّ","root":"*n","body":[{"kind":"text","text":"A man (S, M)"},{"kind":"italic_en","text":"whose nose flows with what is termed"},{"kind":"arabic","text_bw":"*aniyn","text_ar":"ذَنِين"},{"kind":"text","text":": (S, M, K:) and one"},{"kind":"italic_en","text":"whose nostrils flow:"},{"kind":"text","text":"(T, M:) fem."},{"kind":"arabic","text_bw":"*an~aA='u","text_ar":"ذَنَّا=ءُ"},{"kind":"text","text":", (S, M, K,) applied to a woman. (S, M.) ―         -b2-  It is also applied to a nose; as in the prov.,"},{"kind":"arabic","text_bw":"A^anofuka minoka waA_ino kaAna","text_ar":"اَنْفُكَ مِنْكَ وَاـِنْ كَانَ"},{"kind":"arabic","text_bw":"A^a*an~a","text_ar":"اَذَنَّ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Thy nose is a part of thee though it be flowing with"},{"kind":"arabic","text_bw":"*aniyn","text_ar":"ذَنِين"},{"kind":"text","text":"]. (TA.) ―         -b3-  Hence, (TA,) the fem. signifies also (tropical:)  A woman"},{"kind":"italic_en","text":"whose menstrual discharge ceases not."},{"kind":"text","text":"(S, M, K.) ―         -b4-  And"},{"kind":"arabic","text_bw":"qaroHapN *an~aA='u","text_ar":"قَرْحَةٌ ذَنَّا=ءُ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"A wound"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"that will not be stanched."},{"kind":"text","text":"(TA.)"}],"source_refs":["S","M","K","T","TA"]},{"entry_id":"n484","headword_ar":"اُذْنٌ","root":"A*n","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^u*unN","text_ar":"اُذُنٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n485","headword_ar":"اـِذْنٌ","root":"A*n","body":[{"kind":"text","text":"[is held by some to be an inf. n., like ↓"},{"kind":"arabic","text_bw":"A^a*ayinN","text_ar":"اَذَيِنٌ","orth_type":"arrow"},{"kind":"text","text":": (see 1:) by others, to be] a simple subst.; (Msb;) signifying"},{"kind":"italic_en","text":"Permission; leave;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"concession of liberty,"},{"kind":"text","text":"to do a thing: and sometimes"},{"kind":"italic_en","text":"command:"},{"kind":"text","text":"and likewise"},{"kind":"italic_en","text":"will;"},{"kind":"text","text":"(Msb, TA;) as in the phrase"},{"kind":"arabic","text_bw":"biA_i*oni A@ll~`hi","text_ar":"بِاـِذْنِ ا@للّٰهِ"},{"kind":"italic_en","text":"by the will of God:"},{"kind":"text","text":"(Msb:) or, accord. to El-Harállee, the"},{"kind":"italic_en","text":"withdrawal,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"removal, of prevention"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prohibition,"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"giving of power"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ability, in respect of being and creation:"},{"kind":"text","text":"or, accord. to Ibn-El-Kemál, the"},{"kind":"italic_en","text":"rescission of prohibition, and concession of freedom of action, to him who has been prohibited by law:"},{"kind":"text","text":"or, accord. to Er-Rághib, the"},{"kind":"italic_en","text":"notification of the allowance"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"permission of a thing, and of indulgence in respect of it;"},{"kind":"text","text":"as in"},{"kind":"arabic","text_bw":"A_il~aA liyuTaAEa biA_i*oni","text_ar":"اـِلَّا لِيُطَاعَ بِاـِذْنِ"},{"kind":"arabic","text_bw":"A@ll~`hi","text_ar":"ا@للّٰهِ"},{"kind":"text","text":", [in the Kur iv. 67,] meaning ["},{"kind":"italic_en","text":"but that he may be obeyed"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"by the will of God,"},{"kind":"text","text":"and [also]"},{"kind":"italic_en","text":"by his command:"},{"kind":"text","text":"(TA:) or, as explained in the Ksh,"},{"kind":"italic_en","text":"facilitation;"},{"kind":"text","text":"an explanation founded upon the opinion that the actions of men are by their own effective power, but facilitated by God; and in this sense, Esh-Shiháb regards it as a metaphor, or a non-metaphorical trope: (MF:) and"},{"kind":"italic_en","text":"accommodation;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"tawofiyqN","text_ar":"تَوْفِيقٌ"},{"kind":"text","text":"; (Hr in explanation of a clause of iii. 139 of the Kur [which see below];) but Es-Semeen says that this requires consideration. (TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"Knowledge;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"EilomN","text_ar":"عِلْمٌ"},{"kind":"text","text":"; (T, M, K;) and so ↓"},{"kind":"arabic","text_bw":"A^a*iynN","text_ar":"اَذِينٌ","orth_type":"arrow"},{"kind":"text","text":"; (M, K;) as in the saying"},{"kind":"arabic","text_bw":"faEalahu biA_i*oniY","text_ar":"فَعَلَهُ بِاـِذْنِى"},{"kind":"text","text":"(T, * M, K) and ↓"},{"kind":"arabic","text_bw":"biA^a*iynY","text_ar":"بِاَذِينى","orth_type":"arrow"},{"kind":"text","text":"(M, K) ["},{"kind":"italic_en","text":"He did it with my knowledge"},{"kind":"text","text":"]: or"},{"kind":"arabic","text_bw":"A_i*onN","text_ar":"اـِذْنٌ"},{"kind":"text","text":"has a"},{"kind":"page_break","n":43},{"kind":"text","text":"more particular signification than"},{"kind":"arabic","text_bw":"EilomN","text_ar":"عِلْمٌ"},{"kind":"text","text":", being scarcely ever, or never, used save of that ["},{"kind":"italic_en","text":"knowledge"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"wherein is will, conjoined with command"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"not conjoined therewith;"},{"kind":"text","text":"for in the saying [in the Kur iii. 139, referred to above,]"},{"kind":"arabic","text_bw":"wamaA kaAna linafosK","text_ar":"وَمَا كَانَ لِنَفْسٍ"},{"kind":"arabic","text_bw":"A^ano tamuwta A_il~aA biA_i*oni A@ll~`hi","text_ar":"اَنْ تَمُوتَ اـِلَّا بِاـِذْنِ ا@للّٰهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And it is not for a soul to die save with the knowledge of God"},{"kind":"text","text":"], it is known that there are will and command; and in the saying [in the Kur ii. 96],"},{"kind":"arabic","text_bw":"wamaA humo biD~aAriyna bihi mino","text_ar":"وَمَا هُمْ بِضَّارِينَ بِهِ مِنْ"},{"kind":"arabic","text_bw":"A^aHadK A_il~aA bA_i*oni A@ll~`hi","text_ar":"اَحَدٍ اـِلَّا باـِذْنِ ا@للّٰهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"But they do not injure thereby any one save with the knowledge of God"},{"kind":"text","text":"], there is will in one respect, for there is no difference of opinion as to the fact that God hath made to exist in man a faculty wherein is the power of injuring another: (Er-Rághib:) but Es-Semeen says that this plea is adduced by Er-Rághib because of his inclining to the persuasion of the Moatezileh. (TA.) You say also,"},{"kind":"arabic","text_bw":"faEalotu ka*aA biA_i*onihi","text_ar":"فَعَلْتُ كَذَا بِاـِذْنِهِ"},{"kind":"text","text":"meaning"},{"kind":"italic_en","text":"I did thus by his command."},{"kind":"text","text":"(T.)"}],"source_refs":["Msb","TA","MF","M","K"]},{"entry_id":"n486","headword_ar":"اَذَنٌ","root":"A*n","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"A^a*anapN","text_ar":"اَذَنَةٌ"}],"source_refs":[]},{"entry_id":"n487","headword_ar":"اُذُنٌ","root":"A*n","body":[{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"A^u*onN","text_ar":"اُذْنٌ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Msb, K,) the latter a contraction of the former, [which is the more common,] (Msb,) [The"},{"kind":"italic_en","text":"ear;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"one of the organs of sense;"},{"kind":"text","text":"(M, TA;)"},{"kind":"italic_en","text":"well known:"},{"kind":"text","text":"(M:) of the fem. gender: (S, M, Msb, K:) as also ↓"},{"kind":"arabic","text_bw":"A^a*iynN","text_ar":"اَذِينٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) pl."},{"kind":"arabic","text_bw":"A=*aAnN","text_ar":"ا=ذَانٌ"},{"kind":"text","text":", (S, M, Msb, K,) its only pl. form: (M:) dim. ↓"},{"kind":"arabic","text_bw":"A^u*ayonapN","text_ar":"اُذَيْنَةٌ","orth_type":"arrow"},{"kind":"text","text":"; but when used as a proper name of a man,"},{"kind":"arabic","text_bw":"A^u*ayonu","text_ar":"اُذَيْنُ"},{"kind":"text","text":", though"},{"kind":"arabic","text_bw":"A^u*ayonapu","text_ar":"اُذَيْنَةُ"},{"kind":"text","text":"has been heard. (S.) You say,"},{"kind":"arabic","text_bw":"jaA='a naA$ir~aA A^u*unayohi","text_ar":"جَا=ءَ نَاشِرَّا اُذُنَيْهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He came spreading,"},{"kind":"text","text":"or, as we say,"},{"kind":"italic_en","text":"pricking up, his ears:"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"he came in a state of covetousness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"eagerness."},{"kind":"text","text":"(T, K, TA. [See also"},{"kind":"arabic","text_bw":"na$ara","text_ar":"نَشَرَ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"wajadotu fulaAnFA laA bisFA A^u*unayohi","text_ar":"وَجَدْتُ فُلَانًا لَا بِسًا اُذُنَيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I found such a one feigning himself inattentive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heedless."},{"kind":"text","text":"(T, TA.) And"},{"kind":"arabic","text_bw":"labisotu A^u*unaY~a lahu","text_ar":"لَبِسْتُ اُذُنَىَّ لَهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"I turned away from him, avoided him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shunned him:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"I feigned myself inattentive,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heedless, to him."},{"kind":"text","text":"(K, TA. [See also"},{"kind":"arabic","text_bw":"labisa","text_ar":"لَبِسَ"},{"kind":"text","text":".]) ―         -b2-  (tropical:)  A man"},{"kind":"italic_en","text":"who listens to what is said to him:"},{"kind":"text","text":"(M, K, TA:) or a man"},{"kind":"italic_en","text":"who hears the speech of every one:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"who relies upon what is said to him;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"waAbiSapu Als~amoEi","text_ar":"وَابِصَةُ السَّمْعِ"},{"kind":"text","text":": (M in art."},{"kind":"arabic","text_bw":"wbS","text_ar":"وبص"},{"kind":"text","text":":) applied as an epithet to one and to a pl. number, (S, M, K,) alike, (S, M,) and to two, and to a woman; not being pluralized nor dualized [nor having the fem. form given to it]: (IB:) you say"},{"kind":"arabic","text_bw":"rajulN A^N*onN","text_ar":"رَجُلٌ اٌذْنٌ"},{"kind":"text","text":"(AZ, S, M) and"},{"kind":"arabic","text_bw":"A^u*onN","text_ar":"اُذْنٌ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"rijaAlN A^u*unN","text_ar":"رِجَالٌ اُذُنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^u*onN","text_ar":"اُذْنٌ"},{"kind":"text","text":"[&c.]: (AZ, M:) and sometimes it is applied to a man as a name of evil import. (M.) It is said in the Kur [ix. 61],"},{"kind":"arabic","text_bw":"wayaquwluwna huwa A^u*unN qulo A^u*unu xayorK lakumo","text_ar":"وَيَقُولُونَ هُوَ اُذُنٌ قُلْ اُذُنُ خَيْرٍ لَكُمْ"},{"kind":"text","text":"(T, M)"},{"kind":"italic_en","text":"And they say, “He is one who hears and believes everything that is said to him:”"},{"kind":"text","text":"as though, by reason of the excess of his listening, he were altogether the organ of hearing; like as a spy is termed"},{"kind":"arabic","text_bw":"EayonN","text_ar":"عَيْنٌ"},{"kind":"text","text":"; or"},{"kind":"arabic","text_bw":"A^u*un","text_ar":"اُذُن"},{"kind":"text","text":"is here from"},{"kind":"arabic","text_bw":"A^a*ina","text_ar":"اَذِنَ"},{"kind":"text","text":"“he listened,” and is like"},{"kind":"arabic","text_bw":"A^unufN","text_ar":"اُنُفٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"$ululN","text_ar":"شُلُلٌ"},{"kind":"text","text":"in its derivation: (Bd:) for among the hypocrites was he who found fault with the Prophet, saying, “If anything be told him from me, I swear to him, and he receives it from me, because he is an"},{"kind":"arabic","text_bw":"A^u*un","text_ar":"اُذُن"},{"kind":"text","text":":” (M:) therefore he is commanded to answer,"},{"kind":"italic_en","text":"Say, “A hearer of good for you.”"},{"kind":"text","text":"(T, M, Bd.) ―         -b3-  (assumed tropical:)"},{"kind":"italic_en","text":"A sincere,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"faithful, adviser"},{"kind":"text","text":"of a people,"},{"kind":"italic_en","text":"who counsels to obedience:"},{"kind":"text","text":"(Msb:) a man's"},{"kind":"italic_en","text":"intimate, and special,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"particular, friend."},{"kind":"text","text":"(TA.) ―         -b4-  (assumed tropical:)"},{"kind":"italic_en","text":"A certain appertenance"},{"kind":"text","text":"of the heart; (M;) [i. e. either"},{"kind":"italic_en","text":"auricle"},{"kind":"text","text":"thereof;]"},{"kind":"arabic","text_bw":"A^u*unaA Alqalobi","text_ar":"اُذُنَا القَلْبِ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"two appendages"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"zanamataAni","text_ar":"زَنَمَتَانِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"in the upper part of the heart:"},{"kind":"text","text":"(K:) and (tropical:)  of a"},{"kind":"arabic","text_bw":"naSol","text_ar":"نَصْل"},{"kind":"text","text":"[or arrow-head or the like; i. e. either"},{"kind":"italic_en","text":"wing"},{"kind":"text","text":"thereof]: and (tropical:)  of an arrow;"},{"kind":"arabic","text_bw":"A=*aAnu Als~ahomi","text_ar":"ا=ذَانُ السَّهْمِ"},{"kind":"text","text":"signifying"},{"kind":"italic_en","text":"the feathers of the arrow,"},{"kind":"text","text":"as AHn says, when they are attached thereon; and"},{"kind":"arabic","text_bw":"*uw valaAvi A=*aAnK","text_ar":"ذُو ثَلَاثِ ا=ذَانٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"a thing having three such feathers"},{"kind":"text","text":"] meaning"},{"kind":"italic_en","text":"an arrow:"},{"kind":"text","text":"all so called by way of comparison: (M:) and (assumed tropical:)  of a sandal; (S, M, K;) i. e. the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"thereof"},{"kind":"italic_en","text":"that surrounds the"},{"kind":"arabic","text_bw":"qibaAl","text_ar":"قِبَال"},{"kind":"text","text":"[q. v.]: (M:) or"},{"kind":"arabic","text_bw":"A^u*unaA Aln~aEoli","text_ar":"اُذُنَا النَّعْلِ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the two parts,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"loops,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of the sandal, to which are tied the"},{"kind":"arabic","text_bw":"EaDudaAni","text_ar":"عَضُدَانِ"},{"kind":"italic_en","text":"of the"},{"kind":"arabic","text_bw":"$iraAk","text_ar":"شِرَاك"},{"kind":"text","text":", [or"},{"kind":"italic_en","text":"two branches of the thong that is attached to another thong between two of the toes, which two branches, however, sometimes pass through the"},{"kind":"arabic","text_bw":"A^u*unaAni","text_ar":"اُذُنَانِ"},{"kind":"text","text":","},{"kind":"italic_en","text":"encompassing the heel,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"behind the narrow part (xaSor) of the sole."},{"kind":"text","text":"(AO in an anonymous MS in my possession. See also"},{"kind":"arabic","text_bw":"xaSorN","text_ar":"خَصْرٌ"},{"kind":"text","text":".) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"A handle,"},{"kind":"text","text":"(M,) or ["},{"kind":"italic_en","text":"a loopshaped,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an ear-shaped, handle, such as is termed"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"Eurowap","text_ar":"عُرْوَة"},{"kind":"text","text":", (T, K,) of anything; (M, K) as, for instance, (M,) of a"},{"kind":"arabic","text_bw":"kuwz","text_ar":"كُوز"},{"kind":"text","text":"[or mug]; (T, M;) and of a"},{"kind":"arabic","text_bw":"dalow","text_ar":"دَلْو"},{"kind":"text","text":"[or bucket]: so called by way of comparison: and in all cases fem.: (M:) pl. as above. (T.) ―         -b6-  (assumed tropical:)"},{"kind":"italic_en","text":"What becomes sharp,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"pointed, and then falls off,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"out,"},{"kind":"text","text":"of the plants called"},{"kind":"arabic","text_bw":"Earofaj","text_ar":"عَرْفَج"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vumaAm","text_ar":"ثُمَام"},{"kind":"text","text":"when they put forth their"},{"kind":"arabic","text_bw":"xuwS","text_ar":"خُوص"},{"kind":"text","text":"[q. v.], or when their"},{"kind":"arabic","text_bw":"xwS","text_ar":"خوص"},{"kind":"text","text":"become perfect; because it has the shape of an ear. (AHn, M.)"}],"source_refs":["S","M","Msb","K","TA","IB","AZ","T","Bd"]},{"entry_id":"n488","headword_ar":"اـِذَنْ","root":"A*n","body":[{"kind":"text","text":", also written"},{"kind":"arabic","text_bw":"A_i*FA","text_ar":"اـِذًا"},{"kind":"text","text":": see art."},{"kind":"arabic","text_bw":"A*A","text_ar":"اذا"},{"kind":"text","text":"."}],"source_refs":[]}]}}