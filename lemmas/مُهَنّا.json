{"lemma":"مُهَنّا","slug":"مُهَنّا","root":"NTWS","root_slug":"NTWS","root_link":"/words/roots/NTWS","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n41354"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D9%87%D9%8E%D9%86%D9%91%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41354","headword_ar":"مَهْنَاٌ","root":"hnA^","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"haniY'N","text_ar":"هَنِىءٌ"},{"kind":"text","text":". ―         -b2-"},{"kind":"arabic","text_bw":"laka AlmahonaA^u","text_ar":"لَكَ المَهْنَاُ"},{"kind":"text","text":", (S,) and"},{"kind":"arabic","text_bw":"AlmahonaA","text_ar":"المَهْنَا"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"Unalloyed gratification to thee!"},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"laka AlmahonaA^u waEalayohi Alwizoru","text_ar":"لَكَ المَهْنَاُ وَعَلَيْهِ الوِزْرُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"To thee be unalloyed gratification, and on him be the burden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sin"},{"kind":"text","text":"]: said, accord. to a trad., to one who asked whether he should accept an invitation to eat the food of one who received unlawful interest or profit; and also said with respect to eating the food of a tyrannical intendant. (TA.)"}],"source_refs":["S","TA"]}]},"classical_definitions":null}