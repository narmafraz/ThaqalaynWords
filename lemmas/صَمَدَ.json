},{"role":"present_2mp","form":"تَصْمُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَصْمُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَصْمُد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَصْمُد","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَصْمُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَصْمُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَصْمُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَصْمُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَصْمُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَصْمُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَصْمُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نَصْمُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَصْمُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1ms","form":"صَمَدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"صَمَدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":10,"cross_references":{"qac":{"found":true,"lemma_key":"صَمَد","root":"صمد","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["adj","noun","verb"],"has_etymology":false,"sense_count":11},"lanes":{"found":true,"entry_ids":["","n24895","n24896"],"search_url":"https://lanelexicon.com/?s=%D8%B5%D9%8E%D9%85%D9%8E%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to betake oneself, to go"},{"pos":"verb","gloss":"to resist, to withstand"},{"pos":"verb","gloss":"to plug"},{"pos":"verb","gloss":"to betake oneself, go to see, visit"},{"pos":"verb","gloss":"to tend, repair repeatedly or frequently"},{"pos":"verb","gloss":"to wear or put on headcloth/headband"},{"pos":"verb","gloss":"to close, plug, cork, stopper"},{"pos":"verb","gloss":"to save, put by, place aside as net gain, lay by (money)"},{"pos":"verb","gloss":"to liquidate"},{"pos":"adj","gloss":"The meaning of this term is uncertain. Possibilities include: eternal, everlasting (epithet of God)","examples":[{"text":"اَلصَّمَد","english":"the Everlasting"},{"text":"ٱللّٰهُ الصَّمَدُ","english":"Allah the Everlasting"}]},{"pos":"noun","gloss":"verbal noun of صَمَدَ (ṣamada) (form I)","tags":["form-of","noun-from-verb"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n24895","headword_ar":"صَمْدٌ","root":"Smd","body":[{"kind":"text","text":"inf. n. of 1. (S, M, &c.) [Hence"},{"kind":"arabic","text_bw":"Samadotu","text_ar":"صَمَدْتُ"},{"kind":"arabic","text_bw":"Samodahu","text_ar":"صَمْدَهُ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"qaSadotu qaSodahu","text_ar":"قَصَدْتُ قَصْدَهُ"},{"kind":"text","text":", q. v.]       -A2-  Also, (S, L, K,) or ↓"},{"kind":"arabic","text_bw":"SamadN","text_ar":"صَمَدٌ","orth_type":"arrow"},{"kind":"text","text":", (as in a copy of the S and in one of the M,)"},{"kind":"italic_en","text":"Elevated ground:"},{"kind":"text","text":"(L:) or"},{"kind":"italic_en","text":"elevated and rugged ground,"},{"kind":"text","text":"(S, M, L, K,)"},{"kind":"italic_en","text":"not so high as to be a mountain:"},{"kind":"text","text":"(M, L:) or"},{"kind":"italic_en","text":"hard, firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tough, ground:"},{"kind":"text","text":"(AA:) pl."},{"kind":"arabic","text_bw":"A^aSomaAdN","text_ar":"اَصْمَادٌ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"SimaAdN","text_ar":"صِمَادٌ","orth_type":"arrow"},{"kind":"text","text":": (M:) or"},{"kind":"italic_en","text":"a narrow, rugged, and low part of a mountain, producing trees;"},{"kind":"text","text":"as also ↓"},{"kind":"arabic","text_bw":"SimaAdN","text_ar":"صِمَادٌ","orth_type":"arrow"},{"kind":"text","text":". (Aboo-Kheyreh.)"}],"source_refs":["S","L","K","M","AA"]},{"entry_id":"n24896","headword_ar":"صَمَدٌ","root":"Smd","body":[{"kind":"text","text":"(with the article"},{"kind":"arabic","text_bw":"Al","text_ar":"ال"},{"kind":"text","text":"an epithet applied to God, M)"},{"kind":"italic_en","text":"A lord;"},{"kind":"text","text":"because one repairs, betakes himself, or has recourse, to him in exigencies; (S, A, K; *) or, when applied to God, because affairs are stayed, or rested, upon Him, ("},{"kind":"arabic","text_bw":"A^uSomidato","text_ar":"اُصْمِدَتْ"},{"kind":"arabic","text_bw":"A_ilayohi","text_ar":"اـِلَيْهِ"},{"kind":"text","text":",) and none but He accomplishes them: (M, A, L:) or"},{"kind":"italic_en","text":"a person to whom one repairs, betakes himself,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has recourse, in exigencies:"},{"kind":"text","text":"(M, A: *) you say,"},{"kind":"arabic","text_bw":"say~idN SamadN","text_ar":"سَيِّدٌ صَمَدٌ"},{"kind":"text","text":", meaning"},{"kind":"italic_en","text":"a lord,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"chief, to whom recourse is had:"},{"kind":"text","text":"(A:) or"},{"kind":"arabic","text_bw":"SamadN","text_ar":"صَمَدٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"a lord to whom obedience is rendered, without whom no affair is accomplished:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one to whom lordship ultimately pertains:"},{"kind":"text","text":"(M, L:) or"},{"kind":"italic_en","text":"a lord whose lordship has attained its utmost point"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"degree;"},{"kind":"text","text":"in which sense it is not applicable to God: (T, L:) or the"},{"kind":"italic_en","text":"Being that continues,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continues for ever"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is everlasting:"},{"kind":"text","text":"(M, K:) or the"},{"kind":"italic_en","text":"Being that continues,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"continues for ever, after his creatures have perished:"},{"kind":"text","text":"(M:) or the"},{"kind":"italic_en","text":"Creator of everything, of whom nothing is independent, and whose unity everything indicates:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"one who takes no nourishment,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"food:"},{"kind":"text","text":"(M, L:) also"},{"kind":"italic_en","text":"high,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"elevated;"},{"kind":"text","text":"(L, K;) applied to anything: (L:) a man"},{"kind":"italic_en","text":"above whom is no one:"},{"kind":"text","text":"(L:) a man"},{"kind":"italic_en","text":"who neither thirsts nor hungers in war."},{"kind":"text","text":"(AA, K.) ―         -b2-  Also"},{"kind":"italic_en","text":"Solid; not hollow;"},{"kind":"text","text":"(M, K;) in which sense it may not be applied to God: (M:) and so ↓"},{"kind":"arabic","text_bw":"muSomadN","text_ar":"مُصْمَدٌ","orth_type":"arrow"},{"kind":"text","text":", a dial. var. of"},{"kind":"arabic","text_bw":"muSomatN","text_ar":"مُصْمَتٌ"},{"kind":"text","text":". (S.) ―         -b3-  And"},{"kind":"italic_en","text":"A people having no trade,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"occupation, nor anything by means of which they may live."},{"kind":"text","text":"(K.)       -A2-  See also"},{"kind":"arabic","text_bw":"SamodN","text_ar":"صَمْدٌ"},{"kind":"text","text":"."}],"source_refs":["M","A","L","T","K"]}]},"classical_definitions":null}