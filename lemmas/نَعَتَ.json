:null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to describe, to characterize, to bewrite","examples":[{"text":"وَنَعَتَنِي بِأَلْفَاظٍ غَيْرِ لَائِقَةٍ، كَانَ فِي حَالةِ هِيَاجٍ جُنُونِيَّةٍ وَٱلشَرَرِ يُقْدَحُ مِن عَيْنَيْهِ، […]","english":"And he called me unseemly epithets, in a frantic state of commotion, sparks firing from his eyes."}]},{"pos":"verb","gloss":"to attributize, to qualify, to epithetize"},{"pos":"noun","gloss":"verbal noun of نَعَتَ (naʕata) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"description, qualification, characterization"},{"pos":"noun","gloss":"quality, property"},{"pos":"noun","gloss":"attribute","tags":["attributive"]},{"pos":"noun","gloss":"adjective, epithet"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n40077","headword_ar":"نَعَتَ","root":"nEt","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naEotN","text_ar":"نَعْتٌ"},{"kind":"text","text":"; and ↓"},{"kind":"arabic","text_bw":"AntEt","text_ar":"انتعت","orth_type":"arrow"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He described,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"characterized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"designated,"},{"kind":"text","text":"(S, K,) a thing; (S;) syn."},{"kind":"arabic","text_bw":"waSafa","text_ar":"وَصَفَ"},{"kind":"text","text":": (S, K:) or"},{"kind":"italic_en","text":"he described"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"by mentioning what was in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what it possessed;"},{"kind":"text","text":"whereas, in the"},{"kind":"arabic","text_bw":"waSof","text_ar":"وَصْف"},{"kind":"text","text":"of a thing one may exaggerate: (L;) ["},{"kind":"italic_en","text":"he distinguished"},{"kind":"text","text":"a person or a thing"},{"kind":"italic_en","text":"by an epithet:"},{"kind":"text","text":"and hence,"},{"kind":"italic_en","text":"he qualified"},{"kind":"text","text":"a substantive"},{"kind":"italic_en","text":"by an epithet:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he used"},{"kind":"text","text":"a word"},{"kind":"italic_en","text":"as an epithet"},{"kind":"text","text":"] or"},{"kind":"italic_en","text":"he described"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"by mentioning what was in it that was good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goodly;"},{"kind":"text","text":"not with reference to what was bad. or foul, or ugly; unless by a straining of the meaning one say"},{"kind":"arabic","text_bw":"naEotN sawo'N","text_ar":"نَعْتٌ سَوْءٌ"},{"kind":"text","text":"; whereas"},{"kind":"arabic","text_bw":"waSafa","text_ar":"وَصَفَ"},{"kind":"text","text":"is said with respect to what is good, or goodly and what is bad, or foul, or ugly: (IAth: or"},{"kind":"arabic","text_bw":"naEata","text_ar":"نَعَتَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he described by mentioning the make,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"form,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"other outward characteristic,"},{"kind":"text","text":"as tallness and shortness; and"},{"kind":"arabic","text_bw":"waSafa","text_ar":"وَصَفَ"},{"kind":"text","text":"respects action, as beating: or, accord. to Th,"},{"kind":"arabic","text_bw":"naEata","text_ar":"نَعَتَ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"he described by mentioning something in some particular place in the body,"},{"kind":"text","text":"such as lameness; whereas"},{"kind":"arabic","text_bw":"waSafa","text_ar":"وَصَفَ"},{"kind":"text","text":"is used with respect to what is common to the whole, as greatness, and generosity; therefore God is an object of"},{"kind":"arabic","text_bw":"waSof","text_ar":"وَصْف"},{"kind":"text","text":", but not of"},{"kind":"arabic","text_bw":"naEot","text_ar":"نَعْت"},{"kind":"text","text":". (TA.) ―         -b2-"},{"kind":"arabic","text_bw":"naEata nafosuh","text_ar":"نَعَتَ نَفْسُه"},{"kind":"arabic","text_bw":"bAloHayori","text_ar":"بالْحَيْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He described himself as possessing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"characterized by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distinguished by, goodness."},{"kind":"text","text":"] (Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"naEata","text_ar":"نَعَتَ"},{"kind":"text","text":", aor"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naEaAtapN","text_ar":"نَعَاتَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was naturally endowed with powers of description, and skilful in the use of those powers."},{"kind":"text","text":"(TA.) ―         -b4-"},{"kind":"arabic","text_bw":"naEut","text_ar":"نَعُت"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"naEaAnapN","text_ar":"نَعَانَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, what is termed"},{"kind":"arabic","text_bw":"naEotN","text_ar":"نَعْتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. e., generous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fleet, &c."},{"kind":"text","text":"(L, K.) ―         -b5-"},{"kind":"arabic","text_bw":"naEata","text_ar":"نَعَتَ"},{"kind":"text","text":", (L,) or"},{"kind":"arabic","text_bw":"naEita","text_ar":"نَعِتَ"},{"kind":"text","text":", of the same measure as"},{"kind":"arabic","text_bw":"fariHa","text_ar":"فَرِحَ"},{"kind":"text","text":", (K,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a horse)"},{"kind":"italic_en","text":"affected,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavoured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"constrained himself, to be,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become, what is termed"},{"kind":"arabic","text_bw":"naEotN","text_ar":"نَعْتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"i. e., generous,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fleet, &c."},{"kind":"text","text":"(L, K.) MF remarks that"},{"kind":"arabic","text_bw":"naEita","text_ar":"نَعِتَ"},{"kind":"text","text":", in this sense, is strange, as"},{"kind":"arabic","text_bw":"faEila","text_ar":"فَعِلَ"},{"kind":"text","text":"is not a measure denoting"},{"kind":"arabic","text_bw":"takal~uf","text_ar":"تَكَلُّف"},{"kind":"text","text":". (TA.)"}],"source_refs":["S","K","L"]}]}}