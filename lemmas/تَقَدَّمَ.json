_count":8},"lanes":{"found":true,"entry_ids":["n42569"],"search_url":"https://lanelexicon.com/?s=%D8%AA%D9%8E%D9%82%D9%8E%D8%AF%D9%8E%D9%91%D9%85%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to precede"},{"pos":"verb","gloss":"to proceed"},{"pos":"noun","gloss":"verbal noun of تَقَدَّمَ (taqaddama) (form V)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"preeminence"},{"pos":"noun","gloss":"priority"},{"pos":"noun","gloss":"premise"},{"pos":"noun","gloss":"advance, drive"},{"pos":"noun","gloss":"progression, progress"}]},"etymology":null,"ipa":["/ta.qad.da.ma/","/ta.qad.dum/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n42569","headword_ar":"تَقَدَّمَ","root":"qdm","body":[{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ahead; preceded; had,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"took, precedence; contr. of"},{"kind":"arabic","text_bw":"taA^ax~ara","text_ar":"تَاَخَّرَ"},{"kind":"text","text":", q. v. See 1. ―         -b2-"},{"kind":"arabic","text_bw":"taqad~ama A_ilaY","text_ar":"تَقَدَّمَ اـِلَى"},{"kind":"arabic","text_bw":"AlHaAy^iTi","text_ar":"الحَايِطِ"},{"kind":"italic_en","text":"He drew near,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"approached, to the wall."},{"kind":"text","text":"(Msb.) ―         -b3-"},{"kind":"arabic","text_bw":"taqad~ama","text_ar":"تَقَدَّمَ"},{"kind":"italic_en","text":"He advanced; went forward,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"onward."},{"kind":"text","text":"(L, art."},{"kind":"arabic","text_bw":"qwd","text_ar":"قود"},{"kind":"text","text":".) ―         -b4-"},{"kind":"arabic","text_bw":"taqad~ama","text_ar":"تَقَدَّمَ"},{"kind":"arabic","text_bw":"EalaY AlHaq~i","text_ar":"عَلَى الحَقِّ"},{"kind":"text","text":": see Bd, xviii. 27. ―         -b5-"},{"kind":"arabic","text_bw":"taqad~ama","text_ar":"تَقَدَّمَ"},{"kind":"italic_en","text":"He became advanced,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"promoted."},{"kind":"text","text":"―         -b6-"},{"kind":"arabic","text_bw":"taqad~ama minohu kalAamN","text_ar":"تَقَدَّمَ مِنْهُ كَلاَمٌ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"faraTa","text_ar":"فَرَطَ"},{"kind":"text","text":": but the primary meaning is,"},{"kind":"italic_en","text":"Speech proceeded from him previously."},{"kind":"text","text":"―         -b7-"},{"kind":"arabic","text_bw":"taqad~ama EalaY","text_ar":"تَقَدَّمَ عَلَى"},{"kind":"arabic","text_bw":"gayorihi","text_ar":"غَيْرِهِ"},{"kind":"text","text":"quasi-pass. of"},{"kind":"arabic","text_bw":"qad~amahu EalaY gayorihi","text_ar":"قَدَّمَهُ عَلَى غَيْرِهِ"},{"kind":"text","text":";"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, before,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"had precedence of, another, in time:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in place;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, before another; preceded another; went before another:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"in rank,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dignity;"},{"kind":"text","text":"i. e."},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, preferred before another;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honoured,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"esteemed, above another:"},{"kind":"text","text":"in all these senses like"},{"kind":"arabic","text_bw":"taqad~ama gayorahu","text_ar":"تَقَدَّمَ غَيْرَهُ"},{"kind":"text","text":". See"},{"kind":"arabic","text_bw":"bak~ara","text_ar":"بَكَّرَ"},{"kind":"text","text":". ―         -b8-"},{"kind":"arabic","text_bw":"taqad~ama fiY A^amorK","text_ar":"تَقَدَّمَ فِى اَمْرٍ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He was forward in an affair"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"qabola fiEolihi","text_ar":"قَبْلَ فِعْلِهِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"before doing it"},{"kind":"text","text":"]. (A'Obeyd, T in art."},{"kind":"arabic","text_bw":"rmY","text_ar":"رمى"},{"kind":"text","text":".) ―         -b9-"},{"kind":"arabic","text_bw":"taqad~ama","text_ar":"تَقَدَّمَ"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"sabaqa","text_ar":"سَبَقَ"},{"kind":"text","text":"; (K, art."},{"kind":"arabic","text_bw":"sbq","text_ar":"سبق"},{"kind":"text","text":", &c.;) and"},{"kind":"italic_en","text":"contr. of"},{"kind":"arabic","text_bw":"taA^ax~ara","text_ar":"تَاَخَّرَ"},{"kind":"text","text":". (TA, art."},{"kind":"arabic","text_bw":"A^xr","text_ar":"اخر"},{"kind":"text","text":".) ―         -b10-"},{"kind":"arabic","text_bw":"taqad~ama A_ilayohi fiY ka*aA","text_ar":"تَقَدَّمَ اـِلَيْهِ فِى كَذَا"},{"kind":"text","text":", (K,) or"},{"kind":"arabic","text_bw":"bika*aA","text_ar":"بِكَذَا"},{"kind":"text","text":", (Msb,) or both, (Mgh,)"},{"kind":"italic_en","text":"He commanded, ordered, bade, charged, or enjoined, him respecting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to do, such a thing;"},{"kind":"text","text":"(Mgh, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"qad~ama","text_ar":"قَدَّمَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"taqodiymN","text_ar":"تَقْدِيمٌ"},{"kind":"text","text":". (Msb.)"}],"source_refs":["K","Msb","Mgh"]}]}}