d":"text","text":":       -A2-  and see also"},{"kind":"arabic","text_bw":"haAjirapN","text_ar":"هَاجِرَةٌ"},{"kind":"text","text":"."}],"source_refs":[]},{"entry_id":"n40936","headword_ar":"هُجْرٌ","root":"hjr","body":[{"kind":"text","text":", a subst. from"},{"kind":"arabic","text_bw":"A^ahojara","text_ar":"اَهْجَرَ"},{"kind":"text","text":"; (S, Mgh;) or from its syn."},{"kind":"arabic","text_bw":"hajara","text_ar":"هَجَرَ"},{"kind":"text","text":"; (Msb;)"},{"kind":"italic_en","text":"Foul, evil, bad, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unseemly, language,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"talk;"},{"kind":"text","text":"(As, Ks, T, S, A, Mgh, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"hajoraA='u","text_ar":"هَجْرَا=ءُ","orth_type":"arrow"},{"kind":"text","text":"; (Sgh, K;) and ↓"},{"kind":"arabic","text_bw":"haAjirapN","text_ar":"هَاجِرَةٌ","orth_type":"arrow"},{"kind":"text","text":"; of which last the pl. is"},{"kind":"arabic","text_bw":"hawaAjiru","text_ar":"هَوَاجِرُ"},{"kind":"text","text":", incorrectly said by IJ to be an irreg. pl. of"},{"kind":"arabic","text_bw":"hujorN","text_ar":"هُجْرٌ"},{"kind":"text","text":"; or ↓"},{"kind":"arabic","text_bw":"haAjirapN","text_ar":"هَاجِرَةٌ","orth_type":"arrow"},{"kind":"text","text":"may be an inf. n., like"},{"kind":"arabic","text_bw":"kaA*ibapN","text_ar":"كَاذِبَةٌ"},{"kind":"text","text":"&c. (IB.) You say,"},{"kind":"arabic","text_bw":"qaAla hujorFA wabujorFA","text_ar":"قَالَ هُجْرًا وَبُجْرًا"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"hajorFA","text_ar":"هَجْرًا","orth_type":"arrow"},{"kind":"arabic","text_bw":"wabajorFA","text_ar":"وَبَجْرًا"},{"kind":"text","text":", ["},{"kind":"italic_en","text":"He said"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"a foul"},{"kind":"text","text":"["},{"kind":"italic_en","text":"and a wonderful"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"thing:"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"hajorN","text_ar":"هَجْرٌ","orth_type":"arrow"},{"kind":"text","text":"is an inf. n., and"},{"kind":"arabic","text_bw":"hujorN","text_ar":"هُجْرٌ"},{"kind":"text","text":"is a simple subst. (L, TA.) And ↓"},{"kind":"arabic","text_bw":"ramaAhu biA@lohaAjiraAti","text_ar":"رَمَاهُ بِا@لْهَاجِرَاتِ","orth_type":"arrow"},{"kind":"italic_en","text":"He assailed him with foul words:"},{"kind":"arabic","text_bw":"hAjrAt","text_ar":"هاجرات"},{"kind":"text","text":"being a word of the same class as"},{"kind":"arabic","text_bw":"laAbino","text_ar":"لَابِنْ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"taAmirN","text_ar":"تَامِرٌ"},{"kind":"text","text":". (A, Msb.) And ↓"},{"kind":"arabic","text_bw":"ramaAhu bihaAjiraAtK","text_ar":"رَمَاهُ بِهَاجِرَاتٍ","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"bimuhojiraAtK","text_ar":"بِمُهْجِرَاتٍ","orth_type":"arrow"},{"kind":"text","text":", (S, K,) or"},{"kind":"arabic","text_bw":"biA@lohaAjiraAti","text_ar":"بِا@لْهَاجِرَاتِ"},{"kind":"text","text":", (A,) and"},{"kind":"arabic","text_bw":"biA@lomuhojiraAti","text_ar":"بِا@لْمُهْجِرَاتِ"},{"kind":"text","text":", (A, Msb,)"},{"kind":"italic_en","text":"He accused him of evil things that exposed him to disgrace:"},{"kind":"text","text":"(S, K:) or"},{"kind":"italic_en","text":"of foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil, actions."},{"kind":"text","text":"(A, Msb.) And ↓"},{"kind":"arabic","text_bw":"takal~ama biA@lomahaAjiri","text_ar":"تَكَلَّمَ بِا@لْمَهَاجِرِ","orth_type":"arrow"},{"kind":"text","text":"(in the CK"},{"kind":"arabic","text_bw":"bAlmuhAjiri","text_ar":"بالمُهاجِرِ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"He spoke foul,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evil, language."},{"kind":"text","text":"(L, K.)"}],"source_refs":["S","K","A","Msb"]},{"entry_id":"n40937","headword_ar":"هِجِرٌّ","root":"hjr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"hijorapN","text_ar":"هِجْرَةٌ"},{"kind":"text","text":"."}],"source_refs":[]}]}}