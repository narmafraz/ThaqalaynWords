"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to ridicule, belittle,"}]},"etymology":null,"ipa":["/sax.xa.fa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n19211","headword_ar":"سَخُفَ","root":"sxf","body":[{"kind":"text","text":", [aor."},{"kind":"text","text":",] inf. n."},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":"(Mgh, Msb, TA) and"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":", or, accord. to Kh, the former only, (Msb,) said of a garment, or piece of cloth, (Mgh, Msb, TA,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thin, flimsy,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsubstantial;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"scanty in the yarn;"},{"kind":"text","text":"(Mgh, Msb;) or"},{"kind":"italic_en","text":"thin in texture."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"saxufa","text_ar":"سَخُفَ"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":", said of anything,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thin, slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unsubstantial."},{"kind":"text","text":"(Msb, * TA. [See"},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":"below, voce"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":".]) And"},{"kind":"arabic","text_bw":"saxufa","text_ar":"سَخُفَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":", (K,) or rather"},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":", accord. to what is said below of a distinction between these two ns., (TA,) said of a skin for water or milk,"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, unsound,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"altered for the worse, old, and worn out."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"saxufa","text_ar":"سَخُفَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"saxaAfapN","text_ar":"سَخَافَةٌ"},{"kind":"text","text":", [or"},{"kind":"arabic","text_bw":"suxofN","text_ar":"سُخْفٌ"},{"kind":"text","text":", q. v. infrà,] is also said of a man, meaning"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slender,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shallow,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weak, in intellect."},{"kind":"text","text":"(S, K. *) And it is also said of the intellect, meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, slender,"},{"kind":"text","text":"&c. (K, * TK.)"}],"source_refs":["Mgh","Msb","TA","K"]}]}}