{"lemma":"مُغْبَرَّةٍ","slug":"مُغْبَرَّةٍ","root":"غ.ب.ر","root_slug":"غ-ب-ر","root_link":"/words/roots/غ-ب-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n31361"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8F%D8%BA%D9%92%D8%A8%D9%8E%D8%B1%D9%8E%D9%91%D8%A9%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n31361","headword_ar":"مُغَبِّرَةٌ","root":"gbr","body":[{"kind":"italic_en","text":"A party of men praising,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glorifying, God, by saying"},{"kind":"arabic","text_bw":"laA A_il`aha A_il~aA A@ll~`hu","text_ar":"لَا اـِلَٰهَ اـِلَّا ا@للّٰهُ"},{"kind":"text","text":", and"},{"kind":"italic_en","text":"reiterating the the voice in reciting"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the Kur-án"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"&c.:"},{"kind":"text","text":"(Lth, K, TA:) accord. to Zj, (TA,) so called because of their exciting men to be desirous of the"},{"kind":"arabic","text_bw":"gaAbirap","text_ar":"غَابِرَة"},{"kind":"text","text":", which means the"},{"kind":"arabic","text_bw":"baAqiyap","text_ar":"بَاقِيَة"},{"kind":"text","text":"[or lasting, or everlasting, state of existence], (K, TA,) and to be undesirous of the evanescent, which is the present, state (TA.) [See 2.]"}],"source_refs":["Lth","K","TA"]}]},"classical_definitions":null}