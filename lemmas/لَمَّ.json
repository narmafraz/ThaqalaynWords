d"},{"role":"present_2mp","form":"تَلُمُّونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَلُمُّوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَلْمُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَلُمّ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَلْمُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَلُمّ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَلْمُم","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَلُمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَلُمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَلُمّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَلُمّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَلُمُّونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَلُمُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَلْمُمْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَلُمّ","in_corpus":true,"count":75,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَلُمّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"لَمَمْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"لَمَمْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":4690,"cross_references":{"qac":{"found":true,"lemma_key":"لَمّ","root":"لمم","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["adv","particle","verb"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n43393"],"search_url":"https://lanelexicon.com/?s=%D9%84%D9%8E%D9%85%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"particle","gloss":"not (negating past tense)","examples":[{"text":"لَمْ يَكْتُبْ","english":"He has not written."},{"text":"لَمْ يَكُنِ ٱلَّذِينَ كَفَرُوا مِنْ أَهْلِ ٱلْكِتَابِ وَٱلْمُشْرِكِينَ مُنْفَكِّينَ حَتَّى تَأْتِيَهُمُ ٱلْبَيِّنَةُ.","english":"Those who disbelieved among the People of the Scripture and the polytheists were not to be parted [from misbelief] until there came to them clear evidence."}]},{"pos":"adv","gloss":"for what, why","examples":[{"text":"يَا أَيُّهَا ٱلَّذِينَ آمَنُوا لِمَ تَقُولُونَ مَا لَا تَفْعَلُونَ\n كَبُرَ مَقْتًا عِنْدَ ٱللّٰهِ أَن تَقُولُوا مَا لَا تَفْعَلُونَ","english":"O you who have believed! Why do you say what you do not do? Great is hatred in the sight of Allah that you say what you do not do."}]}]},"etymology":{"source":"wiktextract","text":"From لِـ (li-, “for”) + مَا (mā, “what”), literally “for what”."},"ipa":["/lam/","/li.ma/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43393","headword_ar":"لَمْ","root":"lm","body":[{"kind":"text","text":"with an aor. following it is often to be rendered in English by the preterperfect: ex.,"},{"kind":"arabic","text_bw":"lamo A^arahu","text_ar":"لَمْ اَرَهُ"},{"kind":"arabic","text_bw":"mu*u yawomaAni","text_ar":"مُذُ يَوْمَانِ"},{"kind":"italic_en","text":"I have not seen him for two days."},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"lamo yaDoribo","text_ar":"لَمْ يَضْرِبْ"},{"kind":"italic_en","text":"He did not beat."},{"kind":"text","text":"(S, &c.) See also"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"text","text":". ―         -b3-"},{"kind":"arabic","text_bw":"A^alamo","text_ar":"اَلَمْ"},{"kind":"text","text":": see the latter half of art."},{"kind":"arabic","text_bw":"A^alaA","text_ar":"اَلَا"},{"kind":"text","text":"; and the former part of art."},{"kind":"arabic","text_bw":"A^amaA","text_ar":"اَمَا"},{"kind":"text","text":". ―         -b4-"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"text","text":"as a particle of exception [is equivalent to our"},{"kind":"italic_en","text":"But;"},{"kind":"text","text":"meaning both"},{"kind":"italic_en","text":"except"},{"kind":"text","text":"and, after an oath or the like,"},{"kind":"italic_en","text":"only,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"nothing more than;"},{"kind":"text","text":"and] is put before a nominal proposition; as,"},{"kind":"arabic","text_bw":"A_ino kul~u nafosK","text_ar":"اـِنْ كُلُّ نَفْسٍ"},{"kind":"arabic","text_bw":"lam~aA EalayohaA HaAfiZN","text_ar":"لَمَّا عَلَيْهَا حَافِظٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"There is not any soul but over it is a guardian,"},{"kind":"text","text":"(Kur lxxxvi. 4,)] accord. to those who pronounce the"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"with teshdeed: and before a verb which is literally, but not in meaning, a preterite; as in"},{"kind":"arabic","text_bw":"A^ano$uduka A@ll~`ha lam~aA","text_ar":"اَنْشُدُكَ ا@للّٰهَ لَمَّا"},{"kind":"arabic","text_bw":"fEalota","text_ar":"فعَلْتَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I conjure,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beg,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"beseech, thee by God but that thou do"},{"kind":"text","text":"such a thing], i. e."},{"kind":"arabic","text_bw":"maA A^asoA^aluka A_al~aA","text_ar":"مَا اَسْاَلُكَ اـَلَّا"},{"kind":"arabic","text_bw":"fiEolaka","text_ar":"فِعْلَكَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I do not ask of thee anything save thy doing such a thing"},{"kind":"text","text":"]. (Mughnee.) See its syn."},{"kind":"arabic","text_bw":"A_il~aA","text_ar":"اـِلَّا"},{"kind":"text","text":". In the Kur xxxviii. 13, accord. to one reading, it occurs before a verb which is a preterite literally and in meaning. ―         -b5-"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"text","text":", accord. to Ibn-Málik, is"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"A_i*o","text_ar":"اـِذْ"},{"kind":"text","text":": [and sometimes, like"},{"kind":"arabic","text_bw":"A_i*o","text_ar":"اـِذْ"},{"kind":"text","text":", it means"},{"kind":"italic_en","text":"Since,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"because:"},{"kind":"text","text":"] one may say,"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"arabic","text_bw":"A^akoramotaniY A^amosi A^akoramotuka Alyawoma","text_ar":"اَكْرَمْتَنِى اَمْسِ اَكْرَمْتُكَ اليَوْمَ"},{"kind":"text","text":": but this is said to mean"},{"kind":"arabic","text_bw":"lah~aA vabata Alyawoma A_ikoraAmuka liY A^amosi A^akoramotuka","text_ar":"لَهَّا ثَبَتَ اليَوْمَ اـِكْرَامُكَ لِى اَمْسِ اَكْرَمْتُكَ"},{"kind":"text","text":". (Mughnee.) See also an ex. voce"},{"kind":"arabic","text_bw":"razaqa","text_ar":"رَزَقَ"},{"kind":"text","text":". ―         -b6-"},{"kind":"arabic","text_bw":"lam~aA","text_ar":"لَمَّا"},{"kind":"arabic","text_bw":"yaDoribo","text_ar":"يَضْرِبْ"},{"kind":"italic_en","text":"He has not yet beaten."},{"kind":"text","text":"(S, &c.) See also"},{"kind":"arabic","text_bw":"lamo","text_ar":"لَمْ"},{"kind":"text","text":"."}],"source_refs":[]}]}}