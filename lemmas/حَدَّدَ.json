y_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n7266","n7275"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D9%8E%D8%AF%D9%8E%D9%91%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to sharpen"},{"pos":"verb","gloss":"to confine"},{"pos":"verb","gloss":"to define"},{"pos":"verb","gloss":"to determine(?)"},{"pos":"verb","gloss":"to identify"},{"pos":"verb","gloss":"to forge iron"},{"pos":"verb","gloss":"to be a blacksmith"}]},"etymology":null,"ipa":["/ħad.da.da/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7266","headword_ar":"حّدد","root":"Hd","body":[{"kind":"text","text":"as a trans. v.: see 1, in five places."},{"kind":"page_break","n":525},{"kind":"text","text":"―         -b2-"},{"kind":"arabic","text_bw":"Hd~d baladFA","text_ar":"حدّد بَلَدًا"},{"kind":"italic_en","text":"He repaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook himself, to the limits,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"boundaries, of a country,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"town."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"Hd~d A_ilayohi","text_ar":"حدّد اـِلَيْهِ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lahu","text_ar":"لَهُ"},{"kind":"italic_en","text":"He repaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"betook himself, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it."},{"kind":"text","text":"(K.)       -A2-  As an intrans. v., inf. n."},{"kind":"arabic","text_bw":"taHodiydN","text_ar":"تَحْدِيدٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(seed-produce)"},{"kind":"italic_en","text":"was late in coming forth because of the lateness of rain,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"and then came forth"},{"kind":"text","text":"["},{"kind":"italic_en","text":"pointed,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"without forking,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shooting forth into separate stalks"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stems."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"Hd~d Ealayohi","text_ar":"حدّد عَلَيْهِ"},{"kind":"text","text":": see 1."}],"source_refs":["K","TA"]},{"entry_id":"n7275","headword_ar":"حَدَدٌ","root":"Hd","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"Had~N","text_ar":"حَدٌّ"},{"kind":"text","text":", first four sentences. ―         -b2-  You say also,"},{"kind":"arabic","text_bw":"maAliY Eano h`*aA AlA^amori HadadN","text_ar":"مَالِى عَنْ هٰذَا الاَمْرِ حَدَدٌ"},{"kind":"text","text":", (S, A, *) and ↓"},{"kind":"arabic","text_bw":"mAlY Eanohu muHotad~N","text_ar":"مالى عَنْهُ مُحْتَدٌّ","orth_type":"arrow"},{"kind":"text","text":", (K,) and ↓"},{"kind":"arabic","text_bw":"muHad~N","text_ar":"مُحَدٌّ","orth_type":"arrow"},{"kind":"text","text":", (K, TA,) with damm, of the same measure as"},{"kind":"arabic","text_bw":"mukoramN","text_ar":"مُكْرَمٌ"},{"kind":"text","text":", (TA,) or ↓"},{"kind":"arabic","text_bw":"maHad~N","text_ar":"مَحَدٌّ","orth_type":"arrow"},{"kind":"text","text":", (so in the CK,)"},{"kind":"italic_en","text":"I have no way of avoiding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"escaping, this thing."},{"kind":"text","text":"(S, A, K.) And"},{"kind":"arabic","text_bw":"walaA mulotad~FA","text_ar":"وَلَا مُلْتَدًّا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^ajidu minohu muHotad~FA","text_ar":"مَا اَجِدُ مِنْهُ مُحْتَدًّا","orth_type":"arrow"},{"kind":"italic_en","text":"I find not any way of avoiding, nor any way of escaping, it."},{"kind":"text","text":"(S.)       -A2-  Also, (L,) and ↓"},{"kind":"arabic","text_bw":"maHoduwdN","text_ar":"مَحْدُودٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb,)"},{"kind":"italic_en","text":"Prevented, hindered, impeded, withheld, restrained, debarred, inhibited, forbidden, prohibited,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"interdicted."},{"kind":"text","text":"(L, Msb.) You say,"},{"kind":"arabic","text_bw":"h`*aA A^amorN HadadN","text_ar":"هٰذَا اَمْرٌ حَدَدٌ"},{"kind":"italic_en","text":"This is a forbidden,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prohibited, thing; a thing unlawful to be done,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committed."},{"kind":"text","text":"(S. [See also what follows.]) And"},{"kind":"arabic","text_bw":"HadadFA A^ano yakuwna ka*aA","text_ar":"حَدَدًا اَنْ يَكُونَ كَذَا"},{"kind":"text","text":"(S, * A, L)"},{"kind":"italic_en","text":"Forbidden be it that it should be so:"},{"kind":"text","text":"like as you say,"},{"kind":"arabic","text_bw":"maEaA*a A@ll~`hi qado Had~a A@ll~`hu *`lika Ean~aA","text_ar":"مَعَاذَ ا@للّٰهِ قَدْ حَدَّ ا@للّٰهُ ذٰلِكَ عَنَّا"},{"kind":"text","text":". (S, A, * L.)"},{"kind":"arabic","text_bw":"A^amorN HadadN","text_ar":"اَمْرٌ حَدَدٌ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"A disallowed, and vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false, thing"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"daEowapN","text_ar":"دَعْوَةٌ"},{"kind":"arabic","text_bw":"HadadN","text_ar":"حَدَدٌ"},{"kind":"italic_en","text":"A vain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"false, pretension."},{"kind":"text","text":"(S, L, K.)"}],"source_refs":["K","TA","L","Msb"]}]},"classical_definitions":null}