{"lemma":"فِطامٌ","slug":"فِطامٌ","root":"ف.ط.م","root_slug":"ف-ط-م","root_link":"/words/roots/ف-ط-م","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n34165"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%90%D8%B7%D8%A7%D9%85%D9%8C"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n34165","headword_ar":"فِطَامٌ","root":"fTm","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"act of weaning,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ablactation,"},{"kind":"text","text":"of a child or young one: (S, Msb, * K:) a subst. in this sense. (K.)       -A2-  And [it is also, app., an epithet:] you say"},{"kind":"arabic","text_bw":"nAqp fTAm","text_ar":"ناقة فطام"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"naAqapN fiTaAmN","text_ar":"نَاقَةٌ فِطَامٌ"},{"kind":"text","text":", like as you say"},{"kind":"arabic","text_bw":"naAqapN faATimN","text_ar":"نَاقَةٌ فَاطِمٌ"},{"kind":"text","text":", q. v.], meaning"},{"kind":"italic_en","text":"A she-camel whose young one has been weaned from her:"},{"kind":"text","text":"thus in the A. (TA.) ―         -b2-  [And hence it seems to be used as a proper name of a woman; like"},{"kind":"arabic","text_bw":"faATimapu","text_ar":"فَاطِمَةُ"},{"kind":"text","text":"; for it is said,] and the woman is named"},{"kind":"arabic","text_bw":"fiTaAmN","text_ar":"فِطَامٌ"},{"kind":"text","text":", like"},{"kind":"arabic","text_bw":"kitaAbN","text_ar":"كِتَابٌ"},{"kind":"text","text":", [in form]. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}