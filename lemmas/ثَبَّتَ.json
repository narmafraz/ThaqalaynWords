{"lemma":"ثَبَّتَ","slug":"ثَبَّتَ","root":"ث.ب.ت","root_slug":"ث-ب-ت","root_link":"/words/roots/ث-ب-ت","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"ثَبَّتَّ","in_corpus":true,"count":56,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"ثَبَّتِّ","in_corpus":true,"count":56,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"ثَبَّتُّما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"ثَبَّتُّم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"ثَبَّتُّنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"ثَبَّتَ","in_corpus":true,"count":56,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"ثَبَّتَت","in_corpus":true,"count":10,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"ثَبَّتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"ثَبَّتَتا","in_corpus":true,"count":2,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"ثَبَّتُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"ثَبَّتْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تُثَبِّت","in_corpus":true,"count":10,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تُثَبِّتِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تُثَبِّتِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تُثَبِّتانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُثَبِّتا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تُثَبِّتُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تُثَبِّتُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تُثَبِّتْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يُثَبِّت","in_corpus":true,"count":18,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تُثَبِّت","in_corpus":true,"count":10,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يُثَبِّتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُثَبِّتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُثَبِّتانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُثَبِّتا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُثَبِّتُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُثَبِّتُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُثَبِّتْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1ms","form":"ثَبَّتُّ","in_corpus":true,"count":56,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"ثَبَّتْنا","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُثَبِّت","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُثَبِّت","in_corpus":true,"count":18,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":293,"cross_references":{"qac":{"found":true,"lemma_key":"ثَبَّتَ","root":"ثبت","pos":"V","occurrence_count":10},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":7},"lanes":{"found":true,"entry_ids":["n4299","n4305","n4306"],"search_url":"https://lanelexicon.com/?s=%D8%AB%D9%8E%D8%A8%D9%8E%D9%91%D8%AA%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"proof"},{"pos":"noun","gloss":"list, index"},{"pos":"verb","gloss":"to be firm, fixed, stable","tags":["intransitive"]},{"pos":"verb","gloss":"to withstand","tags":["intransitive"]},{"pos":"verb","gloss":"to make firm, fixed, stable","tags":["intransitive"],"examples":[{"text":"يَا أَيُّهَا ٱلَّذِينَ آمَنُوا إِنْ تَنْصُرُوا اللَّهَََ يَنْصُرْكُمْ وَيُثَبِّتْ أَقْدَامَكُمْ","english":"O you who have believed, if you support Allah, He will support you and plant firmly your feet."}]},{"pos":"verb","gloss":"to confine, to restrict","tags":["intransitive"]},{"pos":"verb","gloss":"to make or keep (something) constant in motion","tags":["intransitive"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n4299","headword_ar":"ثَبَتَ","root":"vbt","body":[{"kind":"text","text":", (S, M, A, &c.,) aor."},{"kind":"text","text":", (M, Msb,) inf. n."},{"kind":"arabic","text_bw":"vubuwtN","text_ar":"ثُبُوتٌ"},{"kind":"text","text":"(S, M, A, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"vabaAtN","text_ar":"ثَبَاتٌ"},{"kind":"text","text":", (S, M, Mgh, K,) or this latter is a simple subst., (Msb,) [unexplained in the S and M and A and K, as being well known,]"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, M, Msb)"},{"kind":"italic_en","text":"continued, subsisted, lasted, endured, remained, remained fixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stationary, stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rested; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, permanent, constant, firm, steady, steadfast, stable, fixed, fast, settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"established: it obtained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held:"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"daAma","text_ar":"دَامَ"},{"kind":"text","text":": (Mgh, Msb:) and"},{"kind":"arabic","text_bw":"Aisotaqar~a","text_ar":"اِسْتَقَرَّ"},{"kind":"text","text":": (Msb:) ["},{"kind":"italic_en","text":"it stood, as a fact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth; it stood,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"held, good; it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, a fact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an established, fact"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth:"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved, sound, valid, substantial, real, sure, certain, true, right, correct, just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proper;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"text","text":". (Msb.) ―         -b2-"},{"kind":"arabic","text_bw":"vabata biAlmakaAni","text_ar":"ثَبَتَ بِالمَكَانِ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"vuburtN","text_ar":"ثُبُرتٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He continued, remained, dwelt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode, in the place."},{"kind":"text","text":"(T.) ―         -b3-"},{"kind":"arabic","text_bw":"vabata AljaraAdu","text_ar":"ثَبَتَ الجَرَادُ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"v~bt","text_ar":"ثّبت","orth_type":"arrow"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Avbt","text_ar":"اثبت","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"The locusts stuck their tails into the ground to lay their eggs."},{"kind":"text","text":"(T.) ―         -b4-"},{"kind":"arabic","text_bw":"vabat~u EalaY AlA^amori","text_ar":"ثَبَتُّ عَلَى الاَمْرِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"I kept constantly, firmly, steadily, steadfastly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixedly, to the affair"},{"kind":"text","text":"]. (K in art."},{"kind":"arabic","text_bw":"zmE","text_ar":"زمع"},{"kind":"text","text":".) ―         -b5-"},{"kind":"arabic","text_bw":"vabata liboduka","text_ar":"ثَبَتَ لِبْدُكَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"May thy case,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition, be permanent."},{"kind":"text","text":"(A, TA.) ―         -b6-  ["},{"kind":"arabic","text_bw":"vabata Einodahu ka*aA","text_ar":"ثَبَتَ عِنْدَهُ كَذَا"},{"kind":"italic_en","text":"Such a thing was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, a settled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an established, fact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"truth, with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in his opinion; it became established, substantiated, made good,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verified, in his opinion"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"estimation:"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"text","text":". And"},{"kind":"arabic","text_bw":"vabata Ealayohi","text_ar":"ثَبَتَ عَلَيْهِ"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, established against him."},{"kind":"text","text":"Hence,"},{"kind":"arabic","text_bw":"vabata lahu Ealayohi ka*aA","text_ar":"ثَبَتَ لَهُ عَلَيْهِ كَذَا"},{"kind":"italic_en","text":"Such a thing became established,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"verified, as due to him from him:"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"SaH~a","text_ar":"صَحَّ"},{"kind":"text","text":". And hence,]"},{"kind":"arabic","text_bw":"vabata","text_ar":"ثَبَتَ"},{"kind":"text","text":"is also"},{"kind":"italic_en","text":"syn. with"},{"kind":"arabic","text_bw":"wajaba","text_ar":"وَجَبَ"},{"kind":"text","text":"[as meaning"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, binding, obligatory, incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, necessitated, necessary,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"requisite:"},{"kind":"text","text":"so that"},{"kind":"arabic","text_bw":"vabata Ealayohi","text_ar":"ثَبَتَ عَلَيْهِ"},{"kind":"text","text":"means also"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, binding, obligatory,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"incumbent, on him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it rested,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"lay, on him; as a debt,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a duty:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a sentence &c.)"},{"kind":"italic_en","text":"became necessitated to take effect upon him:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"vabata lahu","text_ar":"ثَبَتَ لَهُ"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proved to be, due to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"owing to him"},{"kind":"text","text":"]. (Telweeh, TA in art."},{"kind":"arabic","text_bw":"wjb","text_ar":"وجب"},{"kind":"text","text":".) ―         -b7-  ["},{"kind":"arabic","text_bw":"vabata lahu","text_ar":"ثَبَتَ لَهُ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"It belonged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"appertained, as an attribute,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a quality,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a property, to him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it; it was affirmable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"predicable, of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":".]       -A2-"},{"kind":"arabic","text_bw":"vabuta","text_ar":"ثَبُتَ"},{"kind":"text","text":", (S, M, A, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"vabaAtapN","text_ar":"ثَبَاتَةٌ"},{"kind":"text","text":"(M, A, K) and"},{"kind":"arabic","text_bw":"vubuwtapN","text_ar":"ثُبُوتَةٌ"},{"kind":"text","text":", (M, K,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, firm in intellect, understanding,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mind:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, in fight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"intelligent, and possessing self-restraint:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seldom erring"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making a mistake"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committing a fault:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"firm of heart"},{"kind":"text","text":"in war: (Msb:) or"},{"kind":"italic_en","text":"courageous as a horseman,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"earnest in the charge."},{"kind":"text","text":"(TA.)"}],"source_refs":["M","Msb","S","A","Mgh","K","TA"]},{"entry_id":"n4305","headword_ar":"ثَبْتٌ","root":"vbt","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"vaAbitN","text_ar":"ثَابِتٌ"},{"kind":"text","text":". ―         -b2-  Also A man"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, of heart;"},{"kind":"text","text":"(S;) and so"},{"kind":"arabic","text_bw":"vabotu AljanaAni","text_ar":"ثَبْتُ الجَنَانِ"},{"kind":"text","text":"; (A, Msb, TA;) pl."},{"kind":"arabic","text_bw":"vubotN","text_ar":"ثُبْتٌ"},{"kind":"text","text":": (TA:) or a man"},{"kind":"italic_en","text":"who acts,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"proceeds, [firmly, steadily,] deliberately,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"leisurely,"},{"kind":"text","text":"(A, Msb,)"},{"kind":"italic_en","text":"in his affairs:"},{"kind":"text","text":"(Msb:) and"},{"kind":"italic_en","text":"a courageous horseman,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"earnest in the charge;"},{"kind":"text","text":"(TA;) as also ↓"},{"kind":"arabic","text_bw":"vabiytN","text_ar":"ثَبِيتٌ","orth_type":"arrow"},{"kind":"text","text":": (M, K, TA:) both of which signify also"},{"kind":"italic_en","text":"intelligent, and possessing self-restraint;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seldom erring"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"making a mistake"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"committing a fault."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"vabotu AlmaqaAmi","text_ar":"ثَبْتُ المَقَامِ"},{"kind":"text","text":"A man"},{"kind":"italic_en","text":"who does not quit his station,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"abode."},{"kind":"text","text":"(M.) And"},{"kind":"arabic","text_bw":"vabotu Alqadami","text_ar":"ثَبْتُ القَدَمِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Firm-footed;"},{"kind":"text","text":"] one"},{"kind":"italic_en","text":"who makes no slip in contention,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in fight."},{"kind":"text","text":"(A, TA.) And"},{"kind":"arabic","text_bw":"vabotu Algadari","text_ar":"ثَبْتُ الغَدَرِ"},{"kind":"text","text":"A man"},{"kind":"italic_en","text":"firm,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steady, in fight,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in speech,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"discourse:"},{"kind":"text","text":"(M, L, TA:) or"},{"kind":"italic_en","text":"whose tongue makes no slip in contentions."},{"kind":"text","text":"(S, TA.) ―         -b3-  See also"},{"kind":"arabic","text_bw":"vabatN","text_ar":"ثَبَتٌ"},{"kind":"text","text":": ―         -b4-  and"},{"kind":"arabic","text_bw":"vabiytN","text_ar":"ثَبِيتٌ"},{"kind":"text","text":"."}],"source_refs":["TA","A","Msb","M","K","L"]},{"entry_id":"n4306","headword_ar":"ثَبَتٌ","root":"vbt","body":[{"kind":"italic_en","text":"Firmness of heart"},{"kind":"text","text":"in war. (Msb, TA.) You say,"},{"kind":"arabic","text_bw":"lahu vabatN Einoda AlHamolapi","text_ar":"لَهُ ثَبَتٌ عِنْدَ الحَمْلَةِ"},{"kind":"italic_en","text":"He has firmness,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"steadiness, on the occasion of the charge,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"assault."},{"kind":"text","text":"(S, A.) And"},{"kind":"arabic","text_bw":"lahu vabatN Einoda AlHimaAmi","text_ar":"لَهُ ثَبَتٌ عِنْدَ الحِمَامِ"},{"kind":"italic_en","text":"He has firmness on the occasion of death."},{"kind":"text","text":"(L.) [See also"},{"kind":"arabic","text_bw":"vabaAtN","text_ar":"ثَبَاتٌ"},{"kind":"text","text":".] ―         -b2-  Hence, (Msb,)"},{"kind":"italic_en","text":"A proof, and evidence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a voucher."},{"kind":"text","text":"(S, Mgh, Msb, TA.) You say,"},{"kind":"arabic","text_bw":"laA A^aHokumu bika*aA A_il~aA bivabatK","text_ar":"لَا اَحْكُمُ بِكَذَا اـِلَّا بِثَبَتٍ"},{"kind":"italic_en","text":"I will not decide so unless on the ground of proof,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence."},{"kind":"text","text":"(S.) And it is said in a trad. respecting the day of doubt, [i. e. the day of which one doubts whether it be the last of Shaabán or the first of Ramadán,]"},{"kind":"arabic","text_bw":"vum~a jaA='a Alv~abatu A^an~ahu mino ramaDaAna","text_ar":"ثُمَّ جَا=ءَ الثَّبَتُ اَنَّهُ مِنْ رَمَضَانَ"},{"kind":"italic_en","text":"Then came the proof,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"evidence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voucher, that it was of Ramadán."},{"kind":"text","text":"(TA.) ―         -b3-  And hence, (Mgh,) applied to a man, (A, Mgh, [in which latter it is said to be tropical when thus applied, but not so in the A,]) and sometimes written ↓"},{"kind":"arabic","text_bw":"vabotN","text_ar":"ثَبْتٌ","orth_type":"arrow"},{"kind":"text","text":", (TA,) (assumed tropical:)"},{"kind":"italic_en","text":"One who is an authoritative evidence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"voucher, by reason of his trustworthiness in that which he relates:"},{"kind":"text","text":"(A, TA:) or (tropical:)"},{"kind":"italic_en","text":"one who is trustworthy"},{"kind":"text","text":"(Mgh, K *)"},{"kind":"italic_en","text":"in that which he relates:"},{"kind":"text","text":"(Mgh: [in the K, only the pl. is mentioned:]) or (assumed tropical:)"},{"kind":"italic_en","text":"one who is just,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"equitable, [in that which he relates,] and exact,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"honest:"},{"kind":"text","text":"(Msb:) pl."},{"kind":"arabic","text_bw":"A^avobaAtN","text_ar":"اَثْبَاتٌ"},{"kind":"text","text":". (A, Mgh, Msb, K.) ―         -b4-  Also (assumed tropical:)"},{"kind":"italic_en","text":"An index,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a table of contents, in which a relater of traditions collects a list of what he has related from others, and of his sheykhs"},{"kind":"text","text":"["},{"kind":"italic_en","text":"who are his authorities"},{"kind":"text","text":"]: said by some to be a conventional term of the relaters of traditions: perhaps tropical. (TA.)"}],"source_refs":["Msb","Mgh","TA","A"]}]}}