ext":"He remained awake during the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part of the night:"},{"kind":"text","text":"(Msb:) ["},{"kind":"italic_en","text":"he passed the night,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a part of the night, sleepless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"without sleeping:"},{"kind":"text","text":"] and"},{"kind":"arabic","text_bw":"sahirotu","text_ar":"سَهِرْتُ"},{"kind":"arabic","text_bw":"AlbaAriHapa","text_ar":"البَارِحَةَ"},{"kind":"italic_en","text":"I remained awake last night."},{"kind":"text","text":"(A.) ―         -b2-"},{"kind":"arabic","text_bw":"maAlahu sahira waEahira","text_ar":"مَالَهُ سَهِرَ وَعَهِرَ"},{"kind":"italic_en","text":"What aileth him? May he be"},{"kind":"page_break","n":1452},{"kind":"italic_en","text":"sleepless by night, and may he grieve,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mourn,"},{"kind":"text","text":"is an imprecation of the Arabs. (AZ, TA in this art. and art."},{"kind":"arabic","text_bw":"Ebr","text_ar":"عبر"},{"kind":"text","text":".) ―         -b3-"},{"kind":"arabic","text_bw":"sahira Albaroqu","text_ar":"سَهِرَ البَرْقُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The lightning gleamed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"glistened, during the night."},{"kind":"text","text":"(A.)"}],"source_refs":["Msb"]},{"entry_id":"n21044","headword_ar":"سَهَرٌ","root":"shr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"saAhuwrN","text_ar":"سَاهُورٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}