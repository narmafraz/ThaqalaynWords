":"m","num":"s"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n41889"],"search_url":"https://lanelexicon.com/?s=%D9%88%D9%8E%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"alternative form of إِوَزّ (ʔiwazz)","tags":["alt-of","alternative","collective"]}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41889","headword_ar":"وَزٌّ","root":"wz","body":[{"kind":"text","text":"a dial. var. of"},{"kind":"arabic","text_bw":"A_iwaz~N","text_ar":"اـِوَزٌّ"},{"kind":"text","text":", (S, K,)"},{"kind":"italic_en","text":"A kind of water-fowl;"},{"kind":"text","text":"(S;) [the"},{"kind":"italic_en","text":"goose,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"geese;"},{"kind":"text","text":"and the"},{"kind":"italic_en","text":"duck,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ducks;"},{"kind":"text","text":"but generally the former of these birds;] as also ↓"},{"kind":"arabic","text_bw":"waz~iynN","text_ar":"وَزِّينٌ","orth_type":"arrow"},{"kind":"text","text":": (K:) n. un. of the former,"},{"kind":"arabic","text_bw":"waz~apN","text_ar":"وَزَّةٌ"},{"kind":"text","text":"; (Msb, art."},{"kind":"arabic","text_bw":"wz","text_ar":"وز"},{"kind":"text","text":";) and of the latter,"},{"kind":"arabic","text_bw":"waz~iynapN","text_ar":"وَزِّينَةٌ"},{"kind":"text","text":". (Sgh, TA.) See"},{"kind":"arabic","text_bw":"kurokY~","text_ar":"كُرْكىّ"},{"kind":"text","text":"."}],"source_refs":["S","K"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D9%88%D8%B2/","headword_ar":"وز","entries":[{"lexicon_id":"dictionary_32","lexicon_en":"Supplément aux dictionnaires arabes by Reinhart Dozy (d. 1883 CE)","lexicon_ar":"تكملة المعاجم العربية لرينهارت دوزي","permalink":"https://arabiclexicon.hawramani.com/?p=53395#913368","body_html":"وز:<br>وزَ يوز واسم المصدر وزُوز: دن، طن، دوّى (بقطر).<br>وَزّ: وز عراقي أنظر مادة أوز.<br>وز الفرط: من أجناس الطير (ياقوت 16:885:1)؛ وفي رواية وز القرض أو القرط.<br>وزاز: الوزاز هو الذي يقوم بالعناية بالوز (الكالا) ( ansareria) ، أي الموضع الذي يربّى فيه الوز) وزّازين؛ أنظر هذه الكلمات وما يشابهها في (معجم الأسبانية 8 - 356)."},{"lexicon_id":"dictionary_49","lexicon_en":"Arabic-English Lexicon by Edward William Lane (d. 1876)","lexicon_ar":"المعجم العربي الإنجليزي لإدوارد وليام لين","permalink":"https://arabiclexicon.hawramani.com/?p=53395#bd073a","body_html":"<h3>وز</h3><br><br>وَزٌّ a <abbr title=\"dialect, لُغَةٌ\">dial.</abbr> var. of إِوَزٌّ, (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>, <abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>,) A kind of water-fowl; (<abbr title=\"The Ṣiḥāḥ (of al-Jawharī)\">S</abbr>;) [the goose, or geese; and the duck, or ducks; but generally the former of these birds;] as also ↓ وَزِّينٌ: (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>:) <abbr title=\"noun of unity, وَاحِدَةٌ or وَاحِدٌ\">n. un.</abbr> of the former, وَزَّةٌ; (<abbr title=\"The Miṣbāḥ of al-Fayyūmī\">Msb</abbr>, art. وز;) and of the latter, وَزِّينَةٌ. (<abbr title=\"al-Saghānī, author of the ʿUbāb and the Takmilah fī al-Ṣiḥāḥ\">Sgh</abbr>, <abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.) See كُرْكىّ.<br><br>وَزِّينٌ and وَزِّينَةٌ: see وَزٌّ.<br><br>أَرْضٌ مَوَزَّةٌ A land abounding with the birds called وَزّ; (<abbr title=\"al-Qāmūs al-Muḥīṭ of Firuzabadi\">K</abbr>;) like مَأْوَزَةٌ from إِوَزٌّ. (<abbr title=\"The Tāj al-ʿArūs of Sayyid Murtaḍā al-Zabīdī\">TA</abbr>.)"}]}}