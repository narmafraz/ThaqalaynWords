{"lemma":"طالِبٌ","slug":"طالِبٌ","root":"ط.ل.ب","root_slug":"ط-ل-ب","root_link":"/words/roots/ط-ل-ب","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":true,"lemma_key":"طالِب","root":"طلب","pos":"N","occurrence_count":1},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun","verb"],"has_etymology":true,"sense_count":7},"lanes":{"found":true,"entry_ids":["n26906"],"search_url":"https://lanelexicon.com/?s=%D8%B7%D8%A7%D9%84%D9%90%D8%A8%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"seeker, pursuer"},{"pos":"noun","gloss":"student","examples":[{"text":"وبهذا المسجد جماعة من الطلبة يتعلمون العلم ولهم مرتبات من مال المسجد، وله مطبخة يصنع فيها الطعام للوارد والصادر ولإطعام الفقراء من المسلمين بها.","english":"In this mosque also there are a number of students of religious science who receive stipends from its revenue, and it has a kitchen from which all travellers and the poor Muslims of the town are supplied with food."}]},{"pos":"noun","gloss":"scholar"},{"pos":"noun","gloss":"claimant"},{"pos":"noun","gloss":"applicant, petitioner"},{"pos":"noun","gloss":"candidate"},{"pos":"verb","gloss":"to request, to demand, to ask for"}]},"etymology":{"source":"wiktextract","text":"Derived from the active participle of طَلَبَ (ṭalaba)."},"ipa":["/tˤaː.lib/","/tˤaː.la.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n26906","headword_ar":"طَالِبٌ","root":"Tlb","body":[{"kind":"italic_en","text":"Seeking, desiring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"demanding;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"seeking, desiring,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"endeavouring, to find and to get"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"take;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a seeker,"},{"kind":"text","text":"&c.: (Msb, * K, TA:) [and used for"},{"kind":"arabic","text_bw":"TaAlibu EilomK","text_ar":"طَالِبُ عِلْمٍ"},{"kind":"italic_en","text":"a student of science"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knowledge:"},{"kind":"text","text":"] pl."},{"kind":"arabic","text_bw":"Tul~aAbN","text_ar":"طُلَّابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TalabapN","text_ar":"طَلَبَةٌ"},{"kind":"text","text":"(Msb, K, TA) and"},{"kind":"arabic","text_bw":"Tul~abN","text_ar":"طُلَّبٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"TaAlibuwna","text_ar":"طَالِبُونَ"},{"kind":"text","text":"(Msb) and"},{"kind":"arabic","text_bw":"A^aTolaAbN","text_ar":"اَطْلَابٌ"},{"kind":"text","text":"[a"},{"kind":"page_break","n":1865},{"kind":"text","text":"pl. of pauc., like"},{"kind":"arabic","text_bw":"A^aSoHaAbN","text_ar":"اَصْحَابٌ"},{"kind":"text","text":",] (A) and ↓"},{"kind":"arabic","text_bw":"TalabN","text_ar":"طَلَبٌ","orth_type":"arrow"},{"kind":"text","text":", (S, A, O, K,) or this last, as is said in the M, is [properly speaking] a quasi-pl. n., (TA,) or, (Mgh, TA,) as IAth says, (TA,) it is either a pl. of"},{"kind":"arabic","text_bw":"TaAlibN","text_ar":"طَالِبٌ"},{"kind":"text","text":"or an inf. n. used as such, (Mgh, TA,) for"},{"kind":"arabic","text_bw":"A^aholu AlT~alabi","text_ar":"اَهْلُ الطَّلَبِ"},{"kind":"text","text":": (TA:) fem., applied to a woman,"},{"kind":"arabic","text_bw":"TaAlibapN","text_ar":"طَالِبَةٌ"},{"kind":"text","text":"; of which the pl. is"},{"kind":"arabic","text_bw":"TaAlibaAtN","text_ar":"طَالِبَاتٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TawaAlibu","text_ar":"طَوَالِبُ"},{"kind":"text","text":". (Msb.) You say,"},{"kind":"arabic","text_bw":"huwa TaAlibN lil$~aYo'i","text_ar":"هُوَ طَالِبٌ لِلشَّىْءِ"},{"kind":"italic_en","text":"He is a seeker,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"of the thing."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"h`w^ulaA='i","text_ar":"هٰوُلَا=ءِ"},{"kind":"arabic","text_bw":"A^aEodaAy^ihimo","text_ar":"اَعْدَايِهِمْ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Talabu","text_ar":"طَلَبُ","orth_type":"arrow"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^aTolaAbuhumo","text_ar":"اَطْلَابُهُمْ"},{"kind":"italic_en","text":"These are"},{"kind":"text","text":"the troops that are"},{"kind":"italic_en","text":"the seekers"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"pursuers"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of their enemies."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"nisaA='K","text_ar":"نِسَا=ءٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"huwa Tilobu","text_ar":"هُوَ طِلْبُ","orth_type":"arrow"},{"kind":"text","text":", (A, K,) with kesr, (K,)"},{"kind":"italic_en","text":"He is a seeker,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desirer, of women:"},{"kind":"text","text":"(A, K:) pl."},{"kind":"arabic","text_bw":"A^aTolaAbN","text_ar":"اَطْلَابٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"TilabapN","text_ar":"طِلَبَةٌ"},{"kind":"text","text":". (K.)"}],"source_refs":["Msb","K","TA","A","S","O","Mgh"]}]},"classical_definitions":null}