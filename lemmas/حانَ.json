form":"تَحِينُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَحِينُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَحِنْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَحِن","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَحِين","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَحِن","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَحِين","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَحِينا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَحِينانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَحِينا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَحِينانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَحِينُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَحِينُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَحِنْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"حِنّا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"حِنْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَحِين","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَحِين","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":13,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":4},"lanes":{"found":true,"entry_ids":["n9253","n9372","n9795"],"search_url":"https://lanelexicon.com/?s=%D8%AD%D8%A7%D9%86%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to approach"},{"pos":"verb","gloss":"to come near"},{"pos":"verb","gloss":"to draw near"},{"pos":"verb","gloss":"to arrive (time)"}]},"etymology":null,"ipa":["/ħaː.na/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n9253","headword_ar":"حَانٌّ","root":"Hn","body":[{"kind":"italic_en","text":"Yearning, longing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"desiring:"},{"kind":"text","text":"(S:) or"},{"kind":"italic_en","text":"being affected with an intense emotion of grief"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of joy."},{"kind":"text","text":"(K.) ―         -b2-  [Hence, the fem.]"},{"kind":"arabic","text_bw":"HaAn~apN","text_ar":"حَانَّةٌ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"A she-camel;"},{"kind":"text","text":"[because of her yearning towards her young one;] (S, K;) as also ↓"},{"kind":"arabic","text_bw":"musotaHan~N","text_ar":"مُسْتَحَنٌّ","orth_type":"arrow"},{"kind":"text","text":", (as in some copies of the S,) or ↓"},{"kind":"arabic","text_bw":"musotaHin~N","text_ar":"مُسْتَحِنٌّ","orth_type":"arrow"},{"kind":"text","text":", (as in other copies of the S and in the K,) [both of which may be correct, as"},{"kind":"arabic","text_bw":"AstHn~","text_ar":"استحنّ"},{"kind":"text","text":"is both trans. and intrans.:] or"},{"kind":"arabic","text_bw":"musotaHan~N","text_ar":"مُسْتَحَنٌّ"},{"kind":"text","text":"signifies one who is"},{"kind":"italic_en","text":"affected with intense emotion by longing for his home"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Al~a*iY","text_ar":"الَّذِى"},{"kind":"arabic","text_bw":"A@sotaHan~ahu Al$~awoqu A_ilaY waTanihi","text_ar":"ا@سْتَحَنَّهُ الشَّوْقُ اـِلَى وَطَنِهِ"},{"kind":"text","text":"). (IB, TA.) One says,"},{"kind":"arabic","text_bw":"maAlahu HaAn~apN walaA A=n~apN","text_ar":"مَالَهُ حَانَّةٌ وَلَا ا=نَّةٌ"},{"kind":"italic_en","text":"He has not a she-camel nor a sheep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"goat."},{"kind":"text","text":"(S, TA.) [See also"},{"kind":"arabic","text_bw":"A=n~N","text_ar":"ا=نٌّ"},{"kind":"text","text":".] AZ mentions the saying,"},{"kind":"arabic","text_bw":"maAlahu HaAn~apN walaA jaAr~apN","text_ar":"مَالَهُ حَانَّةٌ وَلَا جَارَّةٌ"},{"kind":"text","text":", as meaning"},{"kind":"italic_en","text":"He has not camels that yearn"},{"kind":"text","text":"[towards their young ones] ("},{"kind":"arabic","text_bw":"taHin~u","text_ar":"تَحِنُّ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"nor such as carry goods,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"furniture and utensils, and wheat,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"food."},{"kind":"text","text":"(TA.)"}],"source_refs":["S"]},{"entry_id":"n9372","headword_ar":"حَانٍ","root":"Hnw and HnY","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Bending,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"curving"},{"kind":"text","text":"]. ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"HaAniyapN","text_ar":"حَانِيَةٌ"},{"kind":"text","text":", applied to a ewe, (K,) and to a she-camel, (TA,)"},{"kind":"italic_en","text":"That twists her neck, without any disease;"},{"kind":"text","text":"(K;) as also ↓"},{"kind":"arabic","text_bw":"HanowaA='u","text_ar":"حَنْوَا=ءُ","orth_type":"arrow"},{"kind":"text","text":", applied to a ewe or she-goat: (TA:) and sometimes, the former,"},{"kind":"italic_en","text":"from a disease."},{"kind":"text","text":"(TA.)       -A2-  And"},{"kind":"arabic","text_bw":"HaAniyapN","text_ar":"حَانِيَةٌ"},{"kind":"text","text":", applied to a woman,"},{"kind":"italic_en","text":"That undertakes the care and maintenance of her children,"},{"kind":"text","text":"(AZ, S, TA,) or"},{"kind":"italic_en","text":"acts affectionately towards them,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"and does not marry again, after"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the loss of"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"their father:"},{"kind":"text","text":"(AZ, S, TA:) pl."},{"kind":"arabic","text_bw":"HawaAnK","text_ar":"حَوَانٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HaAniyaAtN","text_ar":"حَانِيَاتٌ"},{"kind":"text","text":"; the latter applied in a similar sense to she-camels. (TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"HaAnK","text_ar":"حَانٍ"},{"kind":"text","text":", applied to a ewe, (As, S, M,) and to a wild cow, (S,)"},{"kind":"italic_en","text":"Desiring the male,"},{"kind":"text","text":"(As, S, M,)"},{"kind":"italic_en","text":"and submitting herself to him:"},{"kind":"text","text":"(M:) and"},{"kind":"arabic","text_bw":"HaAniyapN","text_ar":"حَانِيَةٌ"},{"kind":"text","text":", (K,) applied to a ewe, (TA,)"},{"kind":"italic_en","text":"vehemently desirous of the male."},{"kind":"text","text":"(K.)"},{"kind":"page_break","n":661}],"source_refs":["K","TA","AZ","S","As","M"]},{"entry_id":"n9795","headword_ar":"حَانَ","root":"Hyn","body":[{"kind":"text","text":", (Msb, K,) or"},{"kind":"arabic","text_bw":"HAn Hiynuhu","text_ar":"حان حِينُهُ"},{"kind":"text","text":", (S,) aor."},{"kind":"arabic","text_bw":"yaHiynu","text_ar":"يَحِينُ"},{"kind":"text","text":", (S, Msb,) [inf. n. as in the exs. following,]"},{"kind":"italic_en","text":"It,"},{"kind":"text","text":"(Msb, K,) or"},{"kind":"italic_en","text":"its time,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"season,"},{"kind":"text","text":"(S,)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was at hand:"},{"kind":"text","text":"(S, Msb, K:) and"},{"kind":"italic_en","text":"its time came."},{"kind":"text","text":"(Msb, K. *) You say,"},{"kind":"arabic","text_bw":"HaAna lahu A^ano yafoEala ka*aA","text_ar":"حَانَ لَهُ اَنْ يَفْعَلَ كَذَا"},{"kind":"text","text":", aor. as above, inf. n."},{"kind":"arabic","text_bw":"HiynN","text_ar":"حِينٌ"},{"kind":"text","text":"[and as in the next ex.],"},{"kind":"italic_en","text":"The time came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near, for him to do,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"that he should"},{"kind":"page_break","n":689},{"kind":"italic_en","text":"do, such a thing;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"A=na","text_ar":"ا=نَ"},{"kind":"text","text":". (S.) And"},{"kind":"arabic","text_bw":"HaAnati","text_ar":"حَانَتِ"},{"kind":"arabic","text_bw":"AlS~alaApu","text_ar":"الصَّلَاةُ"},{"kind":"text","text":", (Msb, TA,) inf. n."},{"kind":"arabic","text_bw":"HayonN","text_ar":"حَيْنٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HiynN","text_ar":"حِينٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HayonuwnapN","text_ar":"حَيْنُونَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"The time of prayer came:"},{"kind":"text","text":"(Msb:) or"},{"kind":"italic_en","text":"the prayer was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew, near."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"HAn Als~unobulu","text_ar":"حان السُّنْبُلُ"},{"kind":"italic_en","text":"The ears of corn became dry,"},{"kind":"text","text":"(K, TA,)"},{"kind":"italic_en","text":"so that the time of the reaping thereof came,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drew near."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"HAn Hayonu Aln~afosi","text_ar":"حان حَيْنُ النَّفْسِ"},{"kind":"italic_en","text":"The soul died,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"HAn","text_ar":"حان"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HayonN","text_ar":"حَيْنٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"died,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perished."},{"kind":"text","text":"(S.) ―         -b5-"},{"kind":"italic_en","text":"He experienced a trial,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"trying affliction."},{"kind":"text","text":"(K: a meaning indicated therein, but not expressed.) ―         -b6-  Also, (Az, K,) aor. as above, inf. n."},{"kind":"arabic","text_bw":"HayonN","text_ar":"حَيْنٌ"},{"kind":"text","text":", (Az, TA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"was not accomodated, adapted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disposed, to the right way"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"course"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"direction;"},{"kind":"text","text":"(Az, K, TA;) as also ↓"},{"kind":"arabic","text_bw":"tHy~n","text_ar":"تحيّن","orth_type":"arrow"},{"kind":"text","text":". (K.) ―         -b7-  And"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"Ait~afaqa","text_ar":"اِتَّفَقَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"It happened,"},{"kind":"text","text":"&c.]. (Har p. 382.)"}],"source_refs":["Msb","K","S","TA","Az"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%AD%D8%A7%D9%86/","headword_ar":"حانانيا","entries":[{"lexicon_id":"dictionary_48","lexicon_en":"Sultan Qaboos Encyclopedia of Arab Names (Sultan Qaboos University, 1985)","lexicon_ar":"موسوعة السلطان قابوس لأسماء العرب","permalink":"https://arabiclexicon.hawramani.com/?p=113816#a392f1","body_html":"حانانيا<br>عن العبرية بمعنى الله عطوف والله كريم والله عظيم. يستخدم للذكور."}]}}