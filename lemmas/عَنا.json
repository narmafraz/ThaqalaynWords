{"lemma":"عَنا","slug":"عَنا","root":"ع.ن.#","root_slug":"ع-ن-_","root_link":"/words/roots/ع-ن-_","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"عَنَوْتَ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"عَنَوْتِ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"عَنَوْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"عَنَوْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"عَنَوْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"عَنا","in_corpus":true,"count":56,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"عَنَت","in_corpus":true,"count":3,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"عَنَوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"عَنَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"عَنَوْا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"عَنَوْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَعْن","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تَعْنُو","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2ms","form":"تُعْنَى","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَعْنِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَعْنِي","in_corpus":true,"count":6,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَعْنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَعْنُوانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تُعْنَيا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَعْنُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَعْنُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَعْنُوْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_2fp","form":"تُعْنَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَعْن","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَعْنُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يُعْنَى","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَعْن","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَعْنُو","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تُعْنَى","in_corpus":true,"count":6,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَعْنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَعْنُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُعْنَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَعْنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَعْنُوانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْنَيانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُعْنَيا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَعْنُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَعْنُونَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَعْنُوْنَ","in_corpus":true,"count":3,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يُعْنَيْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَعْن","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْن","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"عَنَوْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"عَنَوْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَعْنُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَعْنُو","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1mp","form":"نُعْنَى","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُعْنَى","in_corpus":true,"count":1,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":91,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n30821","n30826"],"search_url":"https://lanelexicon.com/?s=%D8%B9%D9%8E%D9%86%D8%A7"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n30821","headword_ar":"عَنَا","root":"Enw","body":[{"kind":"text","text":", (S, Mgh, Msb,) first pers."},{"kind":"arabic","text_bw":"Eanawotu","text_ar":"عَنَوْتُ"},{"kind":"text","text":", (K,) aor."},{"kind":"arabic","text_bw":"yaEonuw","text_ar":"يَعْنُو"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"Eunuw~N","text_ar":"عُنُوٌّ"},{"kind":"text","text":", (S, Mgh, Msb, K, *) and ↓"},{"kind":"arabic","text_bw":"EanowapN","text_ar":"عَنْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"is the subst. thereof, (Mgh, K, * TA,) [and] so is ↓"},{"kind":"arabic","text_bw":"EanaA='N","text_ar":"عَنَا=ءٌ","orth_type":"arrow"},{"kind":"text","text":", (Msb,) or"},{"kind":"arabic","text_bw":"EanowapN","text_ar":"عَنْوَةٌ"},{"kind":"text","text":"is its inf. n., (MA,) [and so, app., is"},{"kind":"arabic","text_bw":"EanaA='N","text_ar":"عَنَا=ءٌ"},{"kind":"text","text":", in this sense as well as in another sense, accord. to the K,]"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive;"},{"kind":"text","text":"(S, MA, Mgh, Msb, K,) and"},{"kind":"italic_en","text":"obedient;"},{"kind":"text","text":"(MA, TA;) to the truth, &c. (TA.) You say,"},{"kind":"arabic","text_bw":"EanaA lahu","text_ar":"عَنَا لَهُ"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lowly, humble,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"submissive, to him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obedient to him."},{"kind":"text","text":"(MA.) And hence the saying in the Kur [xx. 110],"},{"kind":"arabic","text_bw":"waEanati A@lowajuwhu","text_ar":"وَعَنَتِ ا@لْوَجُوهُ"},{"kind":"arabic","text_bw":"liloHaY~i Alqay~uwmi","text_ar":"لِلْحَىِّ القَيُّومِ"},{"kind":"text","text":"(S, TA)"},{"kind":"italic_en","text":"And the countenances shall be lowly"},{"kind":"text","text":"&c. ["},{"kind":"italic_en","text":"to the Deathless,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"Ever-living, the Self-subsisting by Whom all things subsist:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shall be downcast;"},{"kind":"text","text":"like the Hebr. phrases ending verses 5 and 6 in Gen. iv.]: or"},{"kind":"italic_en","text":"shall be submissive like captives:"},{"kind":"text","text":"or the meaning is ["},{"kind":"italic_en","text":"shall be depressed by"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the depressing of the forehead and the knee"},{"kind":"text","text":"[or rather"},{"kind":"italic_en","text":"knees"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"and the hands in the lowering of the head and the prostrating oneself"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in prayer"},{"kind":"text","text":"]: or ["},{"kind":"arabic","text_bw":"Eanat","text_ar":"عَنَت"},{"kind":"text","text":"is here from"},{"kind":"arabic","text_bw":"EanaY","text_ar":"عَنَى"},{"kind":"text","text":", belonging to art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"Alwjwh","text_ar":"الوجوه"},{"kind":"text","text":"is used by a synecdoche for"},{"kind":"italic_en","text":"the persons"},{"kind":"text","text":"(as being the most noble of all the parts thereof), and the meaning is]"},{"kind":"italic_en","text":"shall suffer fatigue,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"weariness,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"shall toil."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EanaA","text_ar":"عَنَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eunuw~N","text_ar":"عُنُوٌّ"},{"kind":"text","text":"(M, Msb, K, TA, accord. to some copies of the K [erroneously]"},{"kind":"arabic","text_bw":"EanowN","text_ar":"عَنْوٌ"},{"kind":"text","text":") and"},{"kind":"arabic","text_bw":"EuniY~N","text_ar":"عُنِىٌّ"},{"kind":"text","text":"(TA) and"},{"kind":"arabic","text_bw":"EanaA='N","text_ar":"عَنَا=ءٌ"},{"kind":"text","text":"; (K;) and"},{"kind":"arabic","text_bw":"EaniYa","text_ar":"عَنِىَ"},{"kind":"text","text":"; (M, K;)"},{"kind":"italic_en","text":"He became a captive:"},{"kind":"text","text":"(K:) and the latter verb signifies also"},{"kind":"italic_en","text":"he stuck fast in captivity:"},{"kind":"text","text":"(K in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":":) or both of these verbs have this latter signification: (Msb:) [or] you say,"},{"kind":"arabic","text_bw":"EanaA fiyhimo fulaAnN A^asiyrFA","text_ar":"عَنَا فِيهِمْ فُلَانٌ اَسِيرًا"},{"kind":"italic_en","text":"Such a one remained among them a captive;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"was in a state of confinement:"},{"kind":"text","text":"(S:) and"},{"kind":"arabic","text_bw":"EanaA='N","text_ar":"عَنَا=ءٌ"},{"kind":"text","text":"signifies also"},{"kind":"italic_en","text":"confinement,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"imprisonment, in hardship and humiliation."},{"kind":"text","text":"(TA.) Hence the trad.,"},{"kind":"arabic","text_bw":"AlxaAlu waArivu","text_ar":"الخَالُ وَارِثُ"},{"kind":"arabic","text_bw":"mano laA waAriva lahu yafuk~u Euniy~ahu","text_ar":"مَنْ لَا وَارِثَ لَهُ يَفُكُّ عُنِيَّهُ"},{"kind":"text","text":"i. e."},{"kind":"arabic","text_bw":"A^asorahu","text_ar":"اَسْرَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The maternal uncle is the heir of him who has no"},{"kind":"text","text":"more nearlyallied"},{"kind":"italic_en","text":"heir: he shall loose his"},{"kind":"text","text":"(the latter's)"},{"kind":"italic_en","text":"captivity"},{"kind":"text","text":"]: meaning [he shall acquit him of] what is incumbent on him, and clings to him, because of the actions that require punishment or retaliation, the way [or custom] of which is that the"},{"kind":"arabic","text_bw":"EaAqilap","text_ar":"عَاقِلَة"},{"kind":"text","text":"[q. v., of whom he is a member,] bear the responsibility for them. (Nh, TA.) And ↓"},{"kind":"arabic","text_bw":"EanowapN","text_ar":"عَنْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"is the subst. of the verb in this sense also. (K, * TA.)       -A2-  And"},{"kind":"arabic","text_bw":"EanaA","text_ar":"عَنَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEonuw","text_ar":"يَعْنُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"EanowapN","text_ar":"عَنْوَةٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He took a thing by force:"},{"kind":"text","text":"―         -b2-  and also"},{"kind":"italic_en","text":"he took it peaceably,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"by surrender:"},{"kind":"text","text":"thus having two contr. significations. (Msb.) [But see below, where"},{"kind":"arabic","text_bw":"EanowapN","text_ar":"عَنْوَةٌ"},{"kind":"text","text":"is expl. as though it were the subst. of the verb in these two senses.]       -A3-"},{"kind":"arabic","text_bw":"Eanawotu Al$~aYo'a","text_ar":"عَنَوْتُ الشَّىْءَ"},{"kind":"italic_en","text":"I put forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"produced, the thing:"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"I made the thing apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed it:"},{"kind":"text","text":"(S:) or it has the latter signification; (K;) as also"},{"kind":"arabic","text_bw":"Eanayotu Al$~aYo'a","text_ar":"عَنَيْتُ الشَّىْءَ"},{"kind":"text","text":": (IKtt, TA in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":":) and"},{"kind":"arabic","text_bw":"Eanawotu biAl$~aYo'i","text_ar":"عَنَوْتُ بِالشَّىْءِ"},{"kind":"text","text":"has the former signification. (K.) And ↓"},{"kind":"arabic","text_bw":"EanowapN","text_ar":"عَنْوَةٌ","orth_type":"arrow"},{"kind":"text","text":"is the subst. of the verb thus used, (K, TA,) i. e. in these two senses, as well as in others mentioned above. (TA.) And one says,"},{"kind":"arabic","text_bw":"Eanati AlA^aroDu biAln~abaAti","text_ar":"عَنَتِ الاَرْضُ بِالنَّبَاتِ"},{"kind":"text","text":", (ISk, S, and K in this art. and in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":",) aor."},{"kind":"arabic","text_bw":"taEonuw","text_ar":"تَعْنُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eunuw~N","text_ar":"عُنُوٌّ"},{"kind":"text","text":"; (ISk, S;) and aor."},{"kind":"arabic","text_bw":"taEoniY","text_ar":"تَعْنِى"},{"kind":"text","text":"; (Ks, S;)"},{"kind":"italic_en","text":"The land made apparent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"showed,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"put forth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"produced,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"its plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"A^aEonatohu","text_ar":"اَعْنَتْهُ","orth_type":"arrow"},{"kind":"text","text":". (K.) And"},{"kind":"arabic","text_bw":"lamo taEonu bilaAdunaA bi$aYo'K","text_ar":"لَمْ تَعْنُ بِلَادُنَا بِشَىْءٍ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lamo taEoni","text_ar":"لَمْ تَعْنِ"},{"kind":"italic_en","text":"Our country did not give growth to anything."},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"AlA^aroDu $ayoy^FA","text_ar":"الاَرْضُ شَيْيًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"maA A^aEonati","text_ar":"مَا اَعْنَتِ","orth_type":"arrow"},{"kind":"italic_en","text":"The land did not give growth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"has not given growth, to anything."},{"kind":"text","text":"(S.) ―         -b2-  And [hence, app.,]"},{"kind":"arabic","text_bw":"saA^alotuhu falamo","text_ar":"سَاَلْتُهُ فَلَمْ"},{"kind":"arabic","text_bw":"yaEonu liY bi$aYo'K","text_ar":"يَعْنُ لِى بِشَىْءٍ"},{"kind":"italic_en","text":"I asked him, and he did not"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"lamo yanoda","text_ar":"لَمْ يَنْدَ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"lamo yabiD~a","text_ar":"لَمْ يَبِضَّ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"to me,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"for me, anything."},{"kind":"text","text":"(TA.)       -A4-"},{"kind":"arabic","text_bw":"Eanato bihi A^umuwrN","text_ar":"عَنَتْ بِهِ اُمُورٌ"},{"kind":"italic_en","text":"Events befell him."},{"kind":"text","text":"(S, K.) [See also 1 in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":".] ―         -b2-  And"},{"kind":"arabic","text_bw":"EanaA AlA^amoru Ealayohi","text_ar":"عَنَا الاَمْرُ عَلَيْهِ"},{"kind":"italic_en","text":"The event,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, was difficult,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"distressing, to him; distressed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"troubled, him."},{"kind":"text","text":"(ISd, K, TA.) ―         -b3-"},{"kind":"arabic","text_bw":"EanaAhu AlA^amoru","text_ar":"عَنَاهُ الاَمْرُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEonuwhu","text_ar":"يَعْنُوهُ"},{"kind":"text","text":": see 1 in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":", first sentence. ―         -b4-  And"},{"kind":"arabic","text_bw":"EanaA fiyhi AlA^kolu","text_ar":"عَنَا فِيهِ الاكْلُ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEonuw","text_ar":"يَعْنُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eunuw~N","text_ar":"عُنُوٌّ"},{"kind":"text","text":": see 1 in art."},{"kind":"arabic","text_bw":"EnY","text_ar":"عنى"},{"kind":"text","text":".       -A5-"},{"kind":"arabic","text_bw":"EanaA Alkalobu Al$~aYo'a","text_ar":"عَنَا الكَلْبُ الشَّىْءَ"},{"kind":"text","text":", (CK, [in the TA and in my MS. copy of the K"},{"kind":"arabic","text_bw":"ll$Y'","text_ar":"للشىء"},{"kind":"text","text":", but see what follows,]) aor."},{"kind":"arabic","text_bw":"yaEonuwhu","text_ar":"يَعْنُوهُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Enw","text_ar":"عنو"},{"kind":"text","text":"[app., supposing the verb to be trans. by itself,"},{"kind":"arabic","text_bw":"EanowN","text_ar":"عَنْوٌ"},{"kind":"text","text":"], (TA,)"},{"kind":"italic_en","text":"The dog came to the thing and smelt it:"},{"kind":"text","text":"(K, TA:) and one says,"},{"kind":"arabic","text_bw":"h`*aA yaEonuw h`*aA","text_ar":"هٰذَا يَعْنُو هٰذَا"},{"kind":"italic_en","text":"This comes to this and smells it."},{"kind":"text","text":"(TA.)       -A6-"},{"kind":"arabic","text_bw":"Eanati Alqirobapu bimaA='K","text_ar":"عَنَتِ القِرْبَةُ بِمَا=ءٍ"},{"kind":"arabic","text_bw":"kaviyrK","text_ar":"كَثِيرٍ"},{"kind":"text","text":", (K, TA,) aor."},{"kind":"arabic","text_bw":"taEonuw","text_ar":"تَعْنُو"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"The water-skin did not keep,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"retain, much water, so that it appeared"},{"kind":"text","text":"["},{"kind":"italic_en","text":"oozing from it"},{"kind":"text","text":"]: (K, TA:) or, as some say,"},{"kind":"arabic","text_bw":"Eanati Alqirobapu","text_ar":"عَنَتِ القِرْبَةُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"the water-skin let flow its water."},{"kind":"text","text":"(TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"EanaA","text_ar":"عَنَا"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eunw~N","text_ar":"عُنوٌّ"},{"kind":"text","text":", said of blood,"},{"kind":"italic_en","text":"It flowed."},{"kind":"text","text":"(IKtt, TA.)       -A7-  And"},{"kind":"arabic","text_bw":"EanaA","text_ar":"عَنَا"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaEonuw","text_ar":"يَعْنُو"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"Eunuw~N","text_ar":"عُنُوٌّ"},{"kind":"text","text":", signifies also"},{"kind":"arabic","text_bw":"qaAma","text_ar":"قَامَ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, stood;"},{"kind":"text","text":"&c.]. (IKtt, TA.)       -A8-  See also Q. Q. 1."}],"source_refs":["S","Mgh","Msb","K","MA","TA"]},{"entry_id":"n30826","headword_ar":"عِنًا","root":"Enw","body":[{"kind":"text","text":": see the paragraph next following."}],"source_refs":[]}]}}