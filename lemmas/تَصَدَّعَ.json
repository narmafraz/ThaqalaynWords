E%D9%91%D8%B9%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n23954","headword_ar":"تصدّع","root":"SdE","body":[{"kind":"text","text":", of which"},{"kind":"arabic","text_bw":"AiS~ad~aEa","text_ar":"اِصَّدَّعَ"},{"kind":"text","text":"is a var.: (O, K:) see 7, in four places. ―         -b2-  Also"},{"kind":"italic_en","text":"It became separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scattered."},{"kind":"text","text":"(K.) One says,"},{"kind":"arabic","text_bw":"tSd~E Alqawomu","text_ar":"تصدّع القَوْمُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, became separated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"scattered."},{"kind":"text","text":"(S, Msb, TA.) And"},{"kind":"arabic","text_bw":"tSd~EwA Ean~iY","text_ar":"تصدّعوا عَنِّى"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"They became separated,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"from me."},{"kind":"text","text":"(TA.)"},{"kind":"arabic","text_bw":"yawomay^i*K yaS~ad~aEuwna","text_ar":"يَوْمَيِذٍ يَصَّدَّعُونَ"},{"kind":"text","text":", in the Kur [xxx. 42], means"},{"kind":"italic_en","text":"On that day they shall become separated into two parties,"},{"kind":"text","text":"a party in Paradise and a party in Hell. (Zj, O, TA.) And one says,"},{"kind":"arabic","text_bw":"tSd~E Als~aHaAbu","text_ar":"تصدّع السَّحَابُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The clouds became"},{"kind":"text","text":"["},{"kind":"italic_en","text":"scattered,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"dissundered."},{"kind":"text","text":"(TA.) And"},{"kind":"arabic","text_bw":"taSad~aEati","text_ar":"تَصَدَّعَتِ"},{"kind":"arabic","text_bw":"AlA^aroDu bifulaAnK","text_ar":"الاَرْضُ بِفُلَانٍ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Such a one, fleeing, became concealed in the earth"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"land"},{"kind":"text","text":"["},{"kind":"italic_en","text":"as though it became cloven with him"},{"kind":"text","text":"]. (O, K, and Ham pp. 136 and 418.)       -A2-"},{"kind":"arabic","text_bw":"tSd~E lahu","text_ar":"تصدّع لَهُ"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"tSd~A^","text_ar":"تصدّا"},{"kind":"text","text":", in art."},{"kind":"arabic","text_bw":"SdA^","text_ar":"صدا"},{"kind":"text","text":"."}],"source_refs":["O","K"]}]}}