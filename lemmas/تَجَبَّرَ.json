": "(a sick man)"}, {"kind": "italic_en", "text": "became in a good state."}, {"kind": "text", "text": "(K.) (assumed tropical:)"}, {"kind": "italic_en", "text": "It"}, {"kind": "text", "text": "(a plant, TA, and a tree, K)"}, {"kind": "italic_en", "text": "became green, and put forth leaves"}, {"kind": "text", "text": "(K, TA)"}, {"kind": "italic_en", "text": "and fresh green twigs, when dry: produced fresh shoots in its dry parts:"}, {"kind": "text", "text": "(TA:)"}, {"kind": "italic_en", "text": "it"}, {"kind": "text", "text": "(herbage)"}, {"kind": "italic_en", "text": "became somewhat restored to a good state after having been eaten:"}, {"kind": "text", "text": "(K, * TA:) or"}, {"kind": "italic_en", "text": "grew after having been eaten."}, {"kind": "text", "text": "(S.) ―         -b2-"}, {"kind": "italic_en", "text": "He"}, {"kind": "text", "text": "(a man, S)"}, {"kind": "italic_en", "text": "magnified himself; behaved proudly, haughtily,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "insolently."}, {"kind": "text", "text": "(S, A, K.)       -A2-  (assumed tropical:)"}, {"kind": "italic_en", "text": "He"}, {"kind": "text", "text": "(a man)"}, {"kind": "italic_en", "text": "obtained"}, {"kind": "text", "text": "wealth, or property: (K:) but"}, {"kind": "page_break", "n": 374}, {"kind": "text", "text": "Lh explains it as meaning, intransitively,"}, {"kind": "italic_en", "text": "he obtained wealth,"}, {"kind": "text", "text": "or"}, {"kind": "italic_en", "text": "property."}, {"kind": "text", "text": "(TA.)"}], "source_refs": ["K", "TA"]}]}, "classical_definitions": null, "translations_attribution": {"model": "qwen36-35b-heretic", "generated_date": "2026-05-18", "pipeline_version": "words.translation.v1.spark"}}