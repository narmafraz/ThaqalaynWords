{"lemma":"شِرِّيبٍ","slug":"شِرِّيبٍ","root":"ش.ر.ب","root_slug":"ش-ر-ب","root_link":"/words/roots/ش-ر-ب","pos":"ADJ","pos_camel":"adj","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n22041","n22046"],"search_url":"https://lanelexicon.com/?s=%D8%B4%D9%90%D8%B1%D9%90%D9%91%D9%8A%D8%A8%D9%8D"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n22041","headword_ar":"شَرِيبٌ","root":"$rb","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"$araAbN","text_ar":"شَرَابٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"$aruwbN","text_ar":"شَرُوبٌ"},{"kind":"text","text":"; the latter in five places.       -A2-  Also"},{"kind":"italic_en","text":"One who drinks with another:"},{"kind":"text","text":"(S, K:) and"},{"kind":"italic_en","text":"one who waters his camels with those of another:"},{"kind":"text","text":"of the measure"},{"kind":"arabic","text_bw":"faEiylN","text_ar":"فَعِيلٌ"},{"kind":"text","text":"in the sense of the measure"},{"kind":"arabic","text_bw":"mufaAEilN","text_ar":"مُفَاعِلٌ"},{"kind":"text","text":": (S:) and"},{"kind":"italic_en","text":"one who draws water,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"is given to drink, with another."},{"kind":"text","text":"(IAar, K.) You say,"},{"kind":"arabic","text_bw":"huwa $ariyibiY","text_ar":"هُوَ شَرِيِبِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He is my companion in drinking;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in watering his camels with mine:"},{"kind":"text","text":"&c.]. (TA.) And a rájiz says,"},{"kind":"quote","text":"rub~a $ariybK laka *iY HusaAsi\n                      \n                     \n                        kaAlHaz~i biAlmawaAsiY ↓ \n      $iraAbuhu"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Many a one who waters his camels with thine,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"who draws water with thee"},{"kind":"text","text":"for the watering of camels,"},{"kind":"italic_en","text":"having an evil disposition, his watering"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"is like the cutting with razors"},{"kind":"text","text":"]: i. e., thy waiting for him at the watering-trough is [a cause of] killing to thee and to thy camels. (TA.)"}],"source_refs":["S","K"]},{"entry_id":"n22046","headword_ar":"شِرِّيبٌ","root":"$rb","body":[{"kind":"italic_en","text":"Addicted to"},{"kind":"arabic","text_bw":"$araAb","text_ar":"شَرَاب"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"drink,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wine"},{"kind":"text","text":"]; (S, K, TA;) like"},{"kind":"arabic","text_bw":"xim~iyrN","text_ar":"خِمِّيرٌ"},{"kind":"text","text":"; (S;) as also ↓"},{"kind":"arabic","text_bw":"$ar~aAbN","text_ar":"شَرَّابٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$aruwbN","text_ar":"شَرُوبٌ","orth_type":"arrow"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"$aAribN","text_ar":"شَارِبٌ","orth_type":"arrow"},{"kind":"text","text":". (TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"$aruwbN","text_ar":"شَرُوبٌ"},{"kind":"text","text":"."}],"source_refs":[]}]},"classical_definitions":null}