e,"entry_ids":["n43569"],"search_url":"https://lanelexicon.com/?s=%D9%85%D9%8E%D8%B2%D9%8E%D9%91%D9%82%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to tear, to tear to pieces"},{"pos":"verb","gloss":"to abuse, to slander"},{"pos":"noun","gloss":"verbal noun of مَزَقَ (mazaqa)","tags":["form-of","noun-from-verb"]},{"pos":"verb","gloss":"to tear, to rend, to destroy"}]},"etymology":null,"ipa":["/ma.za.qa/","/maz.za.qa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n43569","headword_ar":"مَزَّقَ","root":"mzq","body":[{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He scattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dispersed."},{"kind":"text","text":"(Kur, xxxiv, 18; and Expos. of the Jeláleyn.) ―         -b2-  ["},{"kind":"arabic","text_bw":"mar~aqa","text_ar":"مَرَّقَ"},{"kind":"text","text":", used tropically, may sometimes be rendered (assumed tropical:)"},{"kind":"italic_en","text":"He mangled, rent much,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissundered;"},{"kind":"text","text":"but more generally, (assumed tropical:)"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, shattered, disorganized,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissipated;"},{"kind":"text","text":"or (assumed tropical:)"},{"kind":"italic_en","text":"he,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, marred,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impaired;"},{"kind":"text","text":"being opposed to"},{"kind":"arabic","text_bw":"A^aSolaHa","text_ar":"اَصْلَحَ"},{"kind":"text","text":", or to"},{"kind":"arabic","text_bw":"raqaEa","text_ar":"رَقَعَ"},{"kind":"text","text":"or"},{"kind":"arabic","text_bw":"raq~aEa","text_ar":"رَقَّعَ"},{"kind":"text","text":", in the sense of"},{"kind":"arabic","text_bw":"A^aSolaHa","text_ar":"اَصْلَحَ"},{"kind":"text","text":", as in an ex. cited voce"},{"kind":"arabic","text_bw":"raqaEa","text_ar":"رَقَعَ"},{"kind":"text","text":"; sometimes several of these renderings will be found to be appropriate in a single instance. You say,"},{"kind":"arabic","text_bw":"maz~aqa EiroDahu","text_ar":"مَزَّقَ عِرْضَهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He mangled, rent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"marred, his honour,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"reputation."},{"kind":"text","text":"And"},{"kind":"arabic","text_bw":"maz~aqa","text_ar":"مَزَّقَ"},{"kind":"arabic","text_bw":"Eaqolahu","text_ar":"عَقْلَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"raA^oyahu","text_ar":"رَاْيَهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"A^amorahu","text_ar":"اَمْرَهُ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"It shattered,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disorganized"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissipated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it marred"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"impaired, his intellect,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his judgment,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his state of affairs"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"circumstances."},{"kind":"text","text":"] ―         -b3-"},{"kind":"arabic","text_bw":"maz~aiqahu","text_ar":"مَزَِّقَهُ"},{"kind":"italic_en","text":"He rent it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tore it, much;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in several,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"many, places. mangled,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dissundered, it;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"cut it much;"},{"kind":"text","text":"&c. (TA.)"}],"source_refs":[]}]},"classical_definitions":null}