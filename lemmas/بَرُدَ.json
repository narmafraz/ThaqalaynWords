{"lemma":"بَرُدَ","slug":"بَرُدَ","root":"ب.ر.د","root_slug":"ب-ر-د","root_link":"/words/roots/ب-ر-د","pos":"V","pos_camel":"verb","paradigm":[{"role":"past_2ms","form":"بَرُدْتَ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"m","num":"s"},{"role":"past_2fs","form":"بَرُدْتِ","in_corpus":true,"count":1,"asp":"p","per":"2","gen":"f","num":"s"},{"role":"past_2md","form":"بَرُدْتُما","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"d"},{"role":"past_2mp","form":"بَرُدْتُم","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"m","num":"p"},{"role":"past_2fp","form":"بَرُدْتُنَّ","in_corpus":false,"count":null,"asp":"p","per":"2","gen":"f","num":"p"},{"role":"past_3ms","form":"بَرُدَ","in_corpus":true,"count":54,"asp":"p","per":"3","gen":"m","num":"s"},{"role":"past_3fs","form":"بَرُدَت","in_corpus":true,"count":1,"asp":"p","per":"3","gen":"f","num":"s"},{"role":"past_3md","form":"بَرُدا","in_corpus":true,"count":25,"asp":"p","per":"3","gen":"m","num":"d"},{"role":"past_3fd","form":"بَرُدَتا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"d"},{"role":"past_3mp","form":"بَرُدُوا","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"m","num":"p"},{"role":"past_3fp","form":"بَرُدْنَ","in_corpus":false,"count":null,"asp":"p","per":"3","gen":"f","num":"p"},{"role":"present_2ms","form":"تَبْرُد","in_corpus":true,"count":4,"asp":"i","per":"2","gen":"m","num":"s"},{"role":"present_2fs","form":"تَبْرُدِينَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2fs","form":"تَبْرُدِي","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"s"},{"role":"present_2md","form":"تَبْرُدا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2md","form":"تَبْرُدانِ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"d"},{"role":"present_2mp","form":"تَبْرُدُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَبْرُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَبْرُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَبْرُد","in_corpus":true,"count":14,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَبْرُد","in_corpus":true,"count":4,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَبْرُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَبْرُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَبْرُدا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَبْرُدانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَبْرُدُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَبْرُدُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَبْرُدْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"بَرُدْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"بَرُدْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَبْرُد","in_corpus":true,"count":3,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَبْرُد","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":108,"cross_references":{"qac":{"found":true,"lemma_key":"بَرُدَ","root":"برد","pos":"N","occurrence_count":2},"wiktextract":{"found":true,"entry_count":8,"pos_tags":["adj","noun","verb"],"has_etymology":true,"sense_count":19},"lanes":{"found":true,"entry_ids":["n2212"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D8%B1%D9%8F%D8%AF%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be or become cold, to cool off"},{"pos":"verb","gloss":"to feel cold"},{"pos":"verb","gloss":"to cool, chill"},{"pos":"verb","gloss":"to soothe, to alleviate (pain)"},{"pos":"verb","gloss":"to become fixed, settled, established","tags":["obsolete"]},{"pos":"verb","gloss":"to be or become cold"},{"pos":"verb","gloss":"to cool, to refrigerate","examples":[{"text":"بَرِّدْ حَشَايَ إِنِ ٱسْتَطَعْتَ بِلَفْظَةٍ / فَلَقَدْ تَضُرُّ إِذَا تَشَاءُ وَتَنْفَعُ"}]},{"pos":"verb","gloss":"to soothe, to alleviate"},{"pos":"verb","gloss":"to make obligatory, to establish","tags":["obsolete"]},{"pos":"noun","gloss":"verbal noun of بَرَدَ (barada) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"cold, coldness"},{"pos":"noun","gloss":"cooling"},{"pos":"noun","gloss":"cold (illness)"},{"pos":"noun","gloss":"hail, hailstones","tags":["collective"]},{"pos":"adj","gloss":"cold"},{"pos":"adj","gloss":"hailing"},{"pos":"verb","gloss":"to file, to pare"},{"pos":"noun","gloss":"a kind of striped upper garment"},{"pos":"noun","gloss":"a kind of coat","examples":[{"text":"خَرَجَ رَسُولِ اللَّهِ صَلَّى اللّٰهُ عَلَيْهِ وَسَلَّمَ وَعَلَيْهِ حُلَّةٌ حَمْرَاءُ، بُرُودٌ يَمَانِيَّةٌ، قِطْرِيٌّ.","english":"The prophet came out clad in red attire, burūd of Yemen, striped."}]}]},"etymology":{"source":"wiktextract","text":"Compare Aramaic בַּרְדָא (barəḏā), Hebrew בָּרָד (bārāḏ), Amharic በረዶ (bärädo).\n\nBorrowed from Old Armenian բուրդ (burd)."},"ipa":["/ba.ra.da/","/ba.ru.da/","/bar.ra.da/","/bard/","/ba.rad/","/ba.rid/","/burd/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n2212","headword_ar":"بَرُدَ","root":"brd","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"buruwdapN","text_ar":"بُرُودَةٌ"},{"kind":"text","text":"; (S, M, Mgh, Msb, K;) and"},{"kind":"arabic","text_bw":"barada","text_ar":"بَرَدَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", (M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":"; (M, Msb;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a thing, S, Msb, and the latter said of water, Msb)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, cold, chill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool;"},{"kind":"text","text":"[see"},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":"below;] (S, M;)"},{"kind":"italic_en","text":"its heat became allayed."},{"kind":"text","text":"(Msb.) The latter verb is also used transitively, as will be shown below. (Msb.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"baruda maDojaEahu","text_ar":"بَرُدَ مَضْجَعَهُ"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"His bed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"place of sleep, became cold;"},{"kind":"text","text":"meaning] (tropical:)"},{"kind":"italic_en","text":"he went on a journey."},{"kind":"text","text":"(A.) ―         -b3-"},{"kind":"arabic","text_bw":"barada","text_ar":"بَرَدَ"},{"kind":"text","text":"also signifies (tropical:)"},{"kind":"italic_en","text":"He died;"},{"kind":"text","text":"(As, T, S, A, K;) because death is the non-existence of the heat of the soul; (L;) or it is allusive to the extinction of the natural heat; or to the cessation of motion. (MF.) For ―         -b4-"},{"kind":"arabic","text_bw":"barada","text_ar":"بَرَدَ"},{"kind":"text","text":", (MF,) aor."},{"kind":"text","text":", (Mgh,) inf. n."},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":", (MF,) likewise signifies (assumed tropical:)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, still, quiet,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless;"},{"kind":"text","text":"(Mgh, MF;) for instance, a slaughtered sheep or goat [&c.]. (Mgh.) And (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(beverage of the kind called"},{"kind":"arabic","text_bw":"nabiy*","text_ar":"نَبِيذ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"became still, and without briskness."},{"kind":"text","text":"(TA, from a trad.) You say,"},{"kind":"arabic","text_bw":"ruEiba fabarada makaAnahu","text_ar":"رُعِبَ فَبَرَدَ مَكَانَهُ"},{"kind":"text","text":"[(assumed tropical:)"},{"kind":"italic_en","text":"He became frightened, and remained motionless in his place;"},{"kind":"arabic","text_bw":"makaAnahu","text_ar":"مَكَانَهُ"},{"kind":"text","text":"meaning"},{"kind":"arabic","text_bw":"fiY makaAnahu","text_ar":"فِى مَكَانَهُ"},{"kind":"text","text":": and hence,] (tropical:)"},{"kind":"italic_en","text":"he became amazed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stupified."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"baradato Eayonuhu","text_ar":"بَرَدَتْ عَيْنُهُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The pain in his eye became allayed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stilled."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"barada A^amorunaA","text_ar":"بَرَدَ اَمْرُنَا"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Our affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, became easy."},{"kind":"text","text":"(TA, from a trad. [See also"},{"kind":"arabic","text_bw":"baAridN","text_ar":"بَارِدٌ"},{"kind":"text","text":".]) ―         -b5-  Also, inf. n."},{"kind":"arabic","text_bw":"barod","text_ar":"بَرْد"},{"kind":"text","text":", [which see below,] (assumed tropical:)"},{"kind":"italic_en","text":"He slept."},{"kind":"text","text":"(T.) ―         -b6-  And hence, (tropical:)"},{"kind":"italic_en","text":"It remained,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became permanent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled."},{"kind":"text","text":"(T.) So in the saying,"},{"kind":"arabic","text_bw":"lamo yaborudo biyadiY minohu $ayo'N","text_ar":"لَمْ يَبْرُدْ بِيَدِى مِنْهُ شَيْءٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"There did not remain,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"become permanent"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fixed"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled, in my hand, thereof, anything."},{"kind":"text","text":"(T, L. *) You say also,"},{"kind":"arabic","text_bw":"barada A^asiyrFA fiY A^ayodiyohimo","text_ar":"بَرَدَ اَسِيرًا فِى اَيْدِيْهِمْ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He remained safely a captive in their hands."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"barada","text_ar":"بَرَدَ"},{"kind":"arabic","text_bw":"fiY A^ayodiyhmo salomFA","text_ar":"فِى اَيْدِيهمْ سَلْمًا"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He became a permanent captive, remaining in their hands, not to be ransomed nor liberated nor demanded."},{"kind":"text","text":"(L.) And"},{"kind":"arabic","text_bw":"barada Almawoti","text_ar":"بَرَدَ المَوْتِ"},{"kind":"arabic","text_bw":"EalaYmuSoTalaAhu","text_ar":"عَلَىمُصْطَلَاهُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Death fixed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"settled,"},{"kind":"text","text":"["},{"kind":"italic_en","text":"upon his face and extremities,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"upon his limbs,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"upon his arms and legs and face and every prominent part,"},{"kind":"text","text":"which become cold at the time of death, and which are warmed at the fire. (AHeyth, L.) And"},{"kind":"arabic","text_bw":"barada Almawoti Ealayohi","text_ar":"بَرَدَ المَوْتِ عَلَيْهِ"},{"kind":"text","text":"[(tropical:)"},{"kind":"italic_en","text":"Death became impressed upon him;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"the marks,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"signs, of death became apparent upon him."},{"kind":"text","text":"(A.) ―         -b7-  [And hence, app.,] (tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a right, or due,)"},{"kind":"italic_en","text":"became incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory,"},{"kind":"text","text":"(M, K, TA,)"},{"kind":"italic_en","text":"and established."},{"kind":"text","text":"(TA.) You say,"},{"kind":"arabic","text_bw":"barada liY Haq~iY EalaY fulaAnK","text_ar":"بَرَدَ لِى حَقِّى عَلَى فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"My right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, became incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, on such a one, and established against him."},{"kind":"text","text":"(M, * A, * TA.) And"},{"kind":"arabic","text_bw":"maA barada laka EalaY fulaAnK","text_ar":"مَا بَرَدَ لَكَ عَلَى فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"What hath become incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, to thee, on such a one, and established against him?"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what hath become owed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, to thee, by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from, such a one?"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"maA *aAba laka Ealayohi","text_ar":"مَا ذَابَ لَكَ عَلَيْهِ"},{"kind":"text","text":". (S.) And"},{"kind":"arabic","text_bw":"barada liY Ealayohi","text_ar":"بَرَدَ لِى عَلَيْهِ"},{"kind":"arabic","text_bw":"ka*aA mina AlmaAli","text_ar":"كَذَا مِنَ المَالِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Such an amount of the property,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of property, became incumbent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"obligatory, to me, on him, and established against him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became owed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due, to me, by,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from, him."},{"kind":"text","text":"(S.) ―         -b8-  Also, (K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":", (TA, [but see the next sentence,]) (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, weak;"},{"kind":"text","text":"and so"},{"kind":"arabic","text_bw":"burida","text_ar":"بُرِدَ"},{"kind":"text","text":", a verb like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":". (K.) And, inf. n."},{"kind":"arabic","text_bw":"buraAdN","text_ar":"بُرَادٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"buruwdN","text_ar":"بُرُودٌ"},{"kind":"text","text":", (M, K,) (assumed tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, languid,"},{"kind":"text","text":"(K,) or"},{"kind":"italic_en","text":"weak and languid, from leanness"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disease:"},{"kind":"text","text":"(M:) or"},{"kind":"italic_en","text":"weak in the legs, from hunger"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"fatigue."},{"kind":"text","text":"(Ibn-Buzurj, T.) And"},{"kind":"arabic","text_bw":"barada mux~uhu","text_ar":"بَرَدَ مُخُّهُ"},{"kind":"text","text":", (A, K,) aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":", (TA,) (tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, lean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"emaciated;"},{"kind":"text","text":"(A, K;) and so"},{"kind":"arabic","text_bw":"baradato EiZaAmuhu","text_ar":"بَرَدَتْ عِظَامُهُ"},{"kind":"text","text":". (A, TA.) ―         -b9-  (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a sword [or the like])"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, blunt."},{"kind":"text","text":"(M, K.)       -A2-"},{"kind":"arabic","text_bw":"baradahu","text_ar":"بَرَدَهُ"},{"kind":"text","text":", (S, Msb, K,) aor."},{"kind":"text","text":", (Msb,) inf. n."},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":"; (K;) and ↓"},{"kind":"arabic","text_bw":"br~dhu","text_ar":"برّدهُ","orth_type":"arrow"},{"kind":"text","text":", (S, M, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"taboriydN","text_ar":"تَبْرِيدٌ"},{"kind":"text","text":"; (S;)"},{"kind":"italic_en","text":"He made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered it,"},{"kind":"text","text":"(for ex., water, M, Msb, K,)"},{"kind":"italic_en","text":"cold, chill,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cool:"},{"kind":"text","text":"(S, &c.:) but the latter has an intensive signification ["},{"kind":"italic_en","text":"he made it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"rendered it, very cold,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"very cool"},{"kind":"text","text":"]: (Msb:) or both signify, (K,) or the former signifies, (M, TA,)"},{"kind":"italic_en","text":"he mixed it with snow:"},{"kind":"text","text":"(M, K:) one does not say ↓"},{"kind":"arabic","text_bw":"Abrdhu","text_ar":"ابردهُ","orth_type":"arrow"},{"kind":"text","text":", except in a bad dialect. (S.)"},{"kind":"arabic","text_bw":"bar~idiyhi","text_ar":"بَرِّدِيهِ"},{"kind":"text","text":", being used by a poet for"},{"kind":"arabic","text_bw":"balo ridiyhi","text_ar":"بَلْ رِدِيهِ"},{"kind":"text","text":", has been erroneously supposed to mean “Make thou it hot.” (M.) You say,"},{"kind":"arabic","text_bw":"baradanaA All~ayolu","text_ar":"بَرَدَنَا اللَّيْلُ"},{"kind":"text","text":", (aor. and inf. n. as above, M,) and"},{"kind":"arabic","text_bw":"barada EalayonaA","text_ar":"بَرَدَ عَلَيْنَا"},{"kind":"text","text":","},{"kind":"italic_en","text":"The night affected us with its cold."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"saqayotuhu $arobapF baradato fuw^aAdahu","text_ar":"سَقَيْتُهُ شَرْبَةً بَرَدَتْ فُوَادَهُ"},{"kind":"text","text":", (S, M, *) aor. and inf. n. as above, (S,)"},{"kind":"italic_en","text":"I gave him to drink a draught"},{"kind":"page_break","n":184},{"kind":"italic_en","text":"that cooled his heart:"},{"kind":"text","text":"(S, M:) or"},{"kind":"arabic","text_bw":"baradotu bihaA fuw^aAdahu","text_ar":"بَرَدْتُ بِهَا فُوَادَهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"with which I cooled his heart"},{"kind":"text","text":"]. (So in the T.) And"},{"kind":"arabic","text_bw":"fuw^aAdaka bi$arobapK","text_ar":"فُوَادَكَ بِشَرْبَةٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"bar~ido","text_ar":"بَرِّدْ","orth_type":"arrow"},{"kind":"italic_en","text":"Cool thy heart by a draught."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"AisoqiniY sawiyqFA A^aborudo bihi kabidiY","text_ar":"اِسْقِنِى سَوِيقًا اَبْرُدْ بِهِ كَبِدِى"},{"kind":"text","text":"["},{"kind":"italic_en","text":"Give thou me to drink"},{"kind":"arabic","text_bw":"swyq","text_ar":"سويق"},{"kind":"italic_en","text":"with which I may cool my liver"},{"kind":"text","text":"]. (T.) And"},{"kind":"arabic","text_bw":"barada Eayonuhu biAlokuHoli","text_ar":"بَرَدَ عَيْنُهُ بِالْكُحْلِ"},{"kind":"text","text":", (A'Obeyd, T, M,) or"},{"kind":"arabic","text_bw":"biAlobaruwdi","text_ar":"بِالْبَرُودِ"},{"kind":"text","text":", (S, Msb, K,) aor. and inf. n. as above, (M,) ["},{"kind":"italic_en","text":"He cooled his eye with the collyrium,"},{"kind":"text","text":"or]"},{"kind":"italic_en","text":"he applied the cooling collyrium to his eye,"},{"kind":"text","text":"(T, * S, M, * Msb, K, *)"},{"kind":"italic_en","text":"and allayed its pain."},{"kind":"text","text":"(M.) The following words, cited by IAar,"},{"kind":"quote","text":"baraduwA gawaAriba A^ayonuqK Hudobi"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"They cooled the fore parts of the humps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the backs, of humped she-camels"},{"kind":"text","text":"], mean (tropical:)"},{"kind":"italic_en","text":"they put off from them their saddles, that their backs might become cool."},{"kind":"text","text":"(M.) You say also, ↓"},{"kind":"arabic","text_bw":"bar~ido","text_ar":"بَرِّدْ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Zahora farasika saAEapF","text_ar":"ظَهْرَ فَرَسِكَ سَاعَةً"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Relieve thy horse from riding"},{"kind":"text","text":"[lit."},{"kind":"italic_en","text":"cool his back"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"awhile."},{"kind":"text","text":"(A.) And ↓"},{"kind":"arabic","text_bw":"laA tubar~ido","text_ar":"لَا تُبَرِّدْ","orth_type":"arrow"},{"kind":"arabic","text_bw":"Eano fulaAnK","text_ar":"عَنْ فُلَانٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"Do not thou alleviate the punishment"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the world to come"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"due to the offence of such a one by thy reviling him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cursing him,"},{"kind":"text","text":"when he has acted injuriously to thee. (T, S, * M, * A, * L.) And"},{"kind":"arabic","text_bw":"barada Alxuboza","text_ar":"بَرَدَ الخُبْزَ"},{"kind":"text","text":", (T, L, K,)"},{"kind":"arabic","text_bw":"biAlomaA='i","text_ar":"بِالْمَا=ءِ"},{"kind":"text","text":", (T,)"},{"kind":"italic_en","text":"He poured"},{"kind":"text","text":"["},{"kind":"italic_en","text":"cold"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"water upon the bread,"},{"kind":"text","text":"(T, L, K,) and"},{"kind":"italic_en","text":"moistened it"},{"kind":"text","text":"["},{"kind":"italic_en","text":"therewith:"},{"kind":"text","text":"see"},{"kind":"arabic","text_bw":"baruwdN","text_ar":"بَرُودٌ"},{"kind":"text","text":"]. (T, L.) ―         -b2-"},{"kind":"arabic","text_bw":"burida","text_ar":"بُرِدَ"},{"kind":"text","text":"(a verb like"},{"kind":"arabic","text_bw":"EuniYa","text_ar":"عُنِىَ"},{"kind":"text","text":", K)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a company of men)"},{"kind":"italic_en","text":"was hailed upon."},{"kind":"text","text":"(S, M, K.) And"},{"kind":"arabic","text_bw":"buridati","text_ar":"بُرِدَتِ"},{"kind":"text","text":"."},{"kind":"arabic","text_bw":"AlA^aruDu","text_ar":"الاَرُضُ"},{"kind":"italic_en","text":"The land,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ground, was hailed upon."},{"kind":"text","text":"(S.)       -A3-"},{"kind":"arabic","text_bw":"barada","text_ar":"بَرَدَ"},{"kind":"text","text":", (S, M, &c.,) aor"},{"kind":"text","text":", (TA,) inf. n."},{"kind":"arabic","text_bw":"barodN","text_ar":"بَرْدٌ"},{"kind":"text","text":", (Mgh, TA,) also signifies"},{"kind":"italic_en","text":"He filed"},{"kind":"text","text":"(M, Mgh, K) iron, (S, M, &c.,) and the like, (M,) with a"},{"kind":"arabic","text_bw":"miborad","text_ar":"مِبْرَد"},{"kind":"text","text":".(S, M, Mgh, Msb, K.)       -A4-"},{"kind":"arabic","text_bw":"baradahu","text_ar":"بَرَدَهُ"},{"kind":"text","text":"and ↓"},{"kind":"arabic","text_bw":"Abrdhu","text_ar":"ابردهُ","orth_type":"arrow"},{"kind":"italic_en","text":"He sent him as a"},{"kind":"arabic","text_bw":"bariyd","text_ar":"بَرِيد"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"messenger on a postmule"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"post-horse"},{"kind":"text","text":"]. (K.) And"},{"kind":"arabic","text_bw":"barada barydFA","text_ar":"بَرَدَ بَريدًا"},{"kind":"text","text":", (M,) and ↓"},{"kind":"arabic","text_bw":"Abrdhu","text_ar":"ابردهُ","orth_type":"arrow"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"He sent a"},{"kind":"arabic","text_bw":"bryd","text_ar":"بريد"},{"kind":"text","text":". (M, A.) And"},{"kind":"arabic","text_bw":"A_iloyahi","text_ar":"اـِلْيَهِ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Abrd","text_ar":"ابرد","orth_type":"arrow"},{"kind":"text","text":", (S,) or"},{"kind":"arabic","text_bw":"Alyh bariydFA","text_ar":"اليه بَرِيدًا"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"Abrd","text_ar":"ابرد","orth_type":"arrow"},{"kind":"text","text":", (T, TA.)"},{"kind":"italic_en","text":"He sent to him a"},{"kind":"arabic","text_bw":"bryd","text_ar":"بريد"},{"kind":"text","text":". (T, S.)"}],"source_refs":["M","Msb","K","MF","Mgh","TA","A","S","T","L"]}]}}