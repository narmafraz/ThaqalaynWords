{"lemma":"قَطْرَةٍ","slug":"قَطْرَةٍ","root":"ق.ط.ر","root_slug":"ق-ط-ر","root_link":"/words/roots/ق-ط-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["noun"],"has_etymology":true,"sense_count":2},"lanes":{"found":true,"entry_ids":["n35893","n35904"],"search_url":"https://lanelexicon.com/?s=%D9%82%D9%8E%D8%B7%D9%92%D8%B1%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a drop (of liquid)","tags":["singulative"],"examples":[{"text":"أَوَّلُ الْغَيْثِ قَطْرَةٌ","english":"The beginning of rain is a drop"},{"text":"مَا عِلْمِي فِي بَحْرِهِ إِلَّا قَطْرَةٌ","english":"My knowledge compared to his sea, is but a droplet."}]},{"pos":"noun","gloss":"a small or vile thing, a little bit","tags":["singulative"]}]},"etymology":{"source":"wiktextract","text":"Instance noun from the root ق ط ر (q ṭ r)."},"ipa":["/qatˤ.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n35893","headword_ar":"قطّرهُ","root":"qTr","body":[{"kind":"text","text":": see 1. ―         -b2-"},{"kind":"arabic","text_bw":"bihi taqoTiyrN","text_ar":"بِهِ تَقْطِيرٌ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"He has a dribbling of his urine"},{"kind":"text","text":"] is said of a man who cannot retain his urine, (Mgh, K, *) by reason of cold affecting the bladder. (TA.)       -A2-"},{"kind":"arabic","text_bw":"qT~r AlA_ibila","text_ar":"قطّر الاـِبِلَ"},{"kind":"text","text":": see 1.       -A3-"},{"kind":"arabic","text_bw":"TaEanahu faqaT~arahu","text_ar":"طَعَنَهُ فَقَطَّرَهُ"},{"kind":"text","text":"(inf. n."},{"kind":"arabic","text_bw":"taqoTiyrN","text_ar":"تَقْطِيرٌ"},{"kind":"text","text":", S)"},{"kind":"italic_en","text":"He pierced him"},{"kind":"text","text":"[with his spear]"},{"kind":"italic_en","text":"and threw him down on one of his sides."},{"kind":"text","text":"(S, Msb.) And"},{"kind":"arabic","text_bw":"qT~rhu farasuhu","text_ar":"قطّرهُ فَرَسُهُ"},{"kind":"text","text":"; in the copies of the K"},{"kind":"arabic","text_bw":"qT~rhu EalaY farasihi","text_ar":"قطّرهُ عَلَى فَرَسِهِ"},{"kind":"text","text":", but this is a mistake; (TA;) and ↓"},{"kind":"arabic","text_bw":"AqTrhu","text_ar":"اقطرهُ","orth_type":"arrow"},{"kind":"text","text":"; and"},{"kind":"arabic","text_bw":"bih","text_ar":"بِه"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tqT~r","text_ar":"تقطّر","orth_type":"arrow"},{"kind":"text","text":"; (K;) vulgarly"},{"kind":"arabic","text_bw":"taqanoTara bihi","text_ar":"تَقَنْطَرَ بِهِ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"His horse threw him down on one of his sides."},{"kind":"text","text":"(K, * TA.) See"},{"kind":"arabic","text_bw":"quTorN","text_ar":"قُطْرٌ"},{"kind":"text","text":": see also 1.       -A4-"},{"kind":"arabic","text_bw":"qT~r vawobahu","text_ar":"قطّر ثَوْبَهُ"},{"kind":"text","text":", inf. n. as above,"},{"kind":"italic_en","text":"He fumigated his garment with"},{"kind":"arabic","text_bw":"quTor","text_ar":"قُطْر"},{"kind":"text","text":", i. e.,"},{"kind":"italic_en","text":"aloes-wood."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n35904","headword_ar":"قَطْرَةٌ","root":"qTr","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"qaTorN","text_ar":"قَطْرٌ"},{"kind":"text","text":", in two places."}],"source_refs":[]}]},"classical_definitions":null}