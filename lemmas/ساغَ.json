mp","form":"تَسُوغُوا","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2mp","form":"تَسُوغُونَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"m","num":"p"},{"role":"present_2fp","form":"تَسُغْنَ","in_corpus":false,"count":null,"asp":"i","per":"2","gen":"f","num":"p"},{"role":"present_3ms","form":"يَسُغ","in_corpus":true,"count":2,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَسُوغ","in_corpus":true,"count":15,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَسُغ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَسُوغ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَسُوغا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَسُوغانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَسُوغا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَسُوغانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَسُوغُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَسُوغُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَسُغْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"سُغْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"سُغْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَسُوغ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَسُوغ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":20,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n21254"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D8%A7%D8%BA%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n21254","headword_ar":"سَاغَ","root":"swg","body":[{"kind":"text","text":", (S, Mgh, Msb, K,) or"},{"kind":"arabic","text_bw":"sAg fiY AlHaloqi","text_ar":"ساغ فِى الحَلْقِ"},{"kind":"text","text":", (JK,) aor."},{"kind":"arabic","text_bw":"yasuwgu","text_ar":"يَسُوغُ"},{"kind":"text","text":", (S, Msb,) inf. n."},{"kind":"arabic","text_bw":"sawogN","text_ar":"سَوْغٌ"},{"kind":"text","text":"(JK, S, Mgh, Msb, K) and"},{"kind":"arabic","text_bw":"sawaAgN","text_ar":"سَوَاغٌ"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"suwaAgN","text_ar":"سُوَاغٌ"},{"kind":"text","text":", accord. to different copies of the K, (TA,) and"},{"kind":"arabic","text_bw":"sawagaAnN","text_ar":"سَوَغَانٌ"},{"kind":"text","text":", (CK, [not in my MS. copy of the K nor in the TA,]) and"},{"kind":"arabic","text_bw":"masaAgN","text_ar":"مَسَاغٌ"},{"kind":"text","text":", (MA,)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(beverage, or wine, JK, S, K, or food, Mgh, or each of these, TA) ["},{"kind":"italic_en","text":"was easy and agreeable to swallow;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"was easy of entrance into the fauces;"},{"kind":"text","text":"(S, Mgh, Msb, K; *) or"},{"kind":"italic_en","text":"passed the fauces easily and agreeably."},{"kind":"text","text":"(Bd in xiv. 20.) [See an ex. in a verse cited voce"},{"kind":"arabic","text_bw":"HamiymN","text_ar":"حَمِيمٌ"},{"kind":"text","text":".] ―         -b2-  [Hence,] one says, ↓"},{"kind":"arabic","text_bw":"sugo fiY AlA^aroDi maAwajadota masaAgFA","text_ar":"سُغْ فِى الاَرْضِ مَاوَجَدْتَ مَسَاغًا","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Enter thou into the land while thou findest a place of entrance."},{"kind":"text","text":"(TA.) ―         -b3-  And"},{"kind":"arabic","text_bw":"sAg fiEolu Al$~aYo'i","text_ar":"ساغ فِعْلُ الشَّىْءِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The doing of the thing was allowable;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed for lawful."},{"kind":"text","text":"(Msb.) And"},{"kind":"arabic","text_bw":"sAg lahu maAfaEala","text_ar":"ساغ لَهُ مَافَعَلَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"What he did was allowable to him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"passed for lawful to him."},{"kind":"text","text":"(S, K, TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"sAg Aln~ahaAru","text_ar":"ساغ النَّهَارُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The day was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, easy."},{"kind":"text","text":"(TA.) ―         -b5-"},{"kind":"arabic","text_bw":"sAgt bihi AlA^aroDu","text_ar":"ساغت بِهِ الاَرْضُ"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"sawogN","text_ar":"سَوْغٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"saAxato","text_ar":"سَاخَتْ"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"The ground,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"earth, sank with him;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sank with him and swallowed him up,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"enclosed him"},{"kind":"text","text":"]. (AA, K, TA.) ―         -b6-  And"},{"kind":"arabic","text_bw":"sAgt Aln~aAqapu","text_ar":"ساغت النَّاقَةُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The she-camel became apart,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"alone,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"$a*~ato","text_ar":"شَذَّتْ"},{"kind":"text","text":", (K, TA,) or"},{"kind":"italic_en","text":"ran,"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"$ad~ato","text_ar":"شَدَّتْ"},{"kind":"text","text":", (JK, and so in the CK and in my MS. copy of the K,)"},{"kind":"italic_en","text":"and went far away."},{"kind":"text","text":"(JK, TA.)       -A2-  See also 4, in two places."}],"source_refs":["S","Mgh","Msb","K","JK","TA","MA"]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B3%D8%A7%D8%BA/","headword_ar":"ساغ","entries":[{"lexicon_id":"dictionary_31","lexicon_en":"Al-Rāghib al-Isfahānī, al-Mufradāt fī Gharīb al-Qurʾān (d. c. 1109 CE)","lexicon_ar":"المفردات في غريب القرآن للراغب الأصفهاني","permalink":"https://arabiclexicon.hawramani.com/?p=61776#cc3101","body_html":"<span class=\"title1\">ساغ</span><br><span>سَاغَ الشّراب في الحلق: سهل انحداره، وأَسَاغَهُ كذا. قال: سائِغاً لِلشَّارِبِينَ</span><br><span>[النحل/ 66] ، وَلا يَكادُ يُسِيغُهُ</span><br><span>[إبراهيم/ 17] ، وسَوَّغْتُهُ مالا مستعار منه، وفلان سوغ أخيه: إذا ولد إثره عاجلا تشبيها بذلك.</span>"}]}}