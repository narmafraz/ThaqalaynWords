,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَنْتَحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْتَحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْتِحانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَنْتِحا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَنْتَحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْتَحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْتِحُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَنْتِحُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَنْتَحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَنْتِحْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1ms","form":"أَنْتَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْتَح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"past_1mp","form":"نَتَحْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"نَتَحْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1ms","form":"أَنْتِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَنْتِح","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":false},"lanes":{"found":true,"entry_ids":["n39284"],"search_url":"https://lanelexicon.com/?s=%D9%86%D9%8E%D8%AA%D9%8E%D8%AD%D9%8E"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n39284","headword_ar":"نَتَحَ","root":"ntH","body":[{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"natoHN","text_ar":"نَتْحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, sweated."},{"kind":"text","text":"(L.) ―         -b2-"},{"kind":"arabic","text_bw":"nataHa","text_ar":"نَتَحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"natoHN","text_ar":"نَتْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nutuwHN","text_ar":"نُتُوحٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(a leathern vessel, or skin,)"},{"kind":"italic_en","text":"sweated,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"exuded moisture,"},{"kind":"text","text":"(S, L,) as when a skin sweats with the butter that is in it. (L.) ―         -b3-"},{"kind":"arabic","text_bw":"nataHa","text_ar":"نَتَحَ"},{"kind":"text","text":", aor."},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"natoHN","text_ar":"نَتْحٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"nutuwjN","text_ar":"نُتُوجٌ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(sweat)"},{"kind":"italic_en","text":"exuded"},{"kind":"text","text":"(S, L, K) from the skin, (L, K,) or from the roots of the hair; (T, L;) and grease, from a skin; and moisture, from the soil. (L, K.) ―         -b4-  [And said of moisture,"},{"kind":"italic_en","text":"It percolated:"},{"kind":"text","text":"see an ex. voce"},{"kind":"arabic","text_bw":"Eariqa","text_ar":"عَرِقَ"},{"kind":"text","text":".] ―         -b5-"},{"kind":"arabic","text_bw":"fulaAnN yanotiHu natiyHa AlHamiyti","text_ar":"فُلَانٌ يَنْتِحُ نَتِيحَ الحَمِيتِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one sweats like a butter-skin"},{"kind":"text","text":"]: said of one who is fat. (A.) ―         -b6-"},{"kind":"arabic","text_bw":"tanaHato *iforaY AlbaEiyri EaraqFA","text_ar":"تَنَحَتْ ذِفْرَى البَعِيرِ عَرَقًا"},{"kind":"italic_en","text":"The camel's protuberance behind his ear dripped with sweat,"},{"kind":"text","text":"by reason of his journeying during a vehemently hot summer-day. (L.) ―         -b7-"},{"kind":"arabic","text_bw":"nataHati","text_ar":"نَتَحَتِ"},{"kind":"arabic","text_bw":"AldumuwEu","text_ar":"الدُمُوعُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"natoHN","text_ar":"نَتْحٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"The tears flowed."},{"kind":"text","text":"(MF.) ―         -b8-"},{"kind":"arabic","text_bw":"nataHahu","text_ar":"نَتَحَهُ"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(heat, L, K, and some other thing, L,)"},{"kind":"italic_en","text":"made him to sweat."},{"kind":"text","text":"(L, K.) [Its aor. seems to be"},{"kind":"arabic","text_bw":"yanotaHu","text_ar":"يَنْتَحُ"},{"kind":"text","text":"; and MF thinks that, in an instance which follows, it may be written with"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"after the"},{"kind":"arabic","text_bw":"t","text_ar":"ت"},{"kind":"text","text":"by poetic licence.] F observes, that J has fallen into three errors with respect to"},{"kind":"arabic","text_bw":"AinotaAHa","text_ar":"اِنْتَاحَ"},{"kind":"text","text":"; [saying that"},{"kind":"arabic","text_bw":"AlAinotiyaAHu","text_ar":"الاِنْتِيَاحُ"},{"kind":"text","text":"(in the place of which is put, in some copies of the S,"},{"kind":"arabic","text_bw":"AlAinotitaAHu","text_ar":"الاِنْتِتَاحُ"},{"kind":"text","text":", as is mentioned in the TA,) is like"},{"kind":"arabic","text_bw":"Aln~atoHu","text_ar":"النَّتْحُ"},{"kind":"text","text":", and citing these words of Dhu-r-Rummeh, describing a camel making his voice to reciprocate in the"},{"kind":"arabic","text_bw":"$iqo$iqap","text_ar":"شِقْشِقَة"},{"kind":"text","text":","},{"kind":"quote","text":"raqo$aA='u tanotaAHu All~ugaAma AlmuzobidaA"},{"kind":"text","text":"first, because the root of the present art. is sound, so that"},{"kind":"arabic","text_bw":"AlAntyAH","text_ar":"الانتياح"},{"kind":"text","text":"has no place in it; secondly, because this word has no meaning (in this art. TA); and thirdly, because the [correct] reading is"},{"kind":"arabic","text_bw":"tamotaAHu","text_ar":"تَمْتَاحُ"},{"kind":"text","text":", meaning “ casts forth ” the froth of the mouth. Neither IB nor IM has animadverted on J in this case. MF, however, observes, that one relation of a verse &c., does not impugn the correctness of another relation that differs from it; and that perhaps the"},{"kind":"arabic","text_bw":"n","text_ar":"ن"},{"kind":"text","text":"of"},{"kind":"arabic","text_bw":"tntAH","text_ar":"تنتاح"},{"kind":"text","text":"is a substitute for"},{"kind":"arabic","text_bw":"m","text_ar":"م"},{"kind":"text","text":"; such substitution being frequent; [as in the case of"},{"kind":"arabic","text_bw":"A_inotataHa","text_ar":"اـِنْتَتَحَ"},{"kind":"text","text":";] or that the"},{"kind":"arabic","text_bw":"A","text_ar":"ا"},{"kind":"text","text":"is what is termed"},{"kind":"arabic","text_bw":"A^alifu A_i$obaAEK","text_ar":"اَلِفُ اـِشْبَاعٍ"},{"kind":"text","text":", and added for the sake of the metre. (TA.)"}],"source_refs":["S","L","K"]}]}}