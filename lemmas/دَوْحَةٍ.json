{"lemma":"دَوْحَةٍ","slug":"دَوْحَةٍ","root":"د.#.ح","root_slug":"د-_-ح","root_link":"/words/roots/د-_-ح","pos":"N","pos_camel":"noun_prop","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["name","noun"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n13363"],"search_url":"https://lanelexicon.com/?s=%D8%AF%D9%8E%D9%88%D9%92%D8%AD%D9%8E%D8%A9%D9%8D"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"a great tree; a huge tree with numerous branches and plentiful leaves."},{"pos":"name","gloss":"construct state of اَلدَّوْحَة (ad-dawḥa, “Doha”)","tags":["construct","form-of"]}]},"etymology":null,"ipa":["/daw.ħa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n13363","headword_ar":"دَوْحَةٌ","root":"dwH","body":[{"kind":"italic_en","text":"A great tree,"},{"kind":"text","text":"(S, A, Msb, K,)"},{"kind":"italic_en","text":"with spreading branches,"},{"kind":"text","text":"(TA,)"},{"kind":"italic_en","text":"of whatever kind it be:"},{"kind":"text","text":"(S, Msb:) pl. ↓"},{"kind":"arabic","text_bw":"dawoHN","text_ar":"دَوْحٌ","orth_type":"arrow"},{"kind":"text","text":", (S, Msb, K,) [or rather this is the coll. gen. n. of the n. un."},{"kind":"arabic","text_bw":"dawoHapN","text_ar":"دَوْحَةٌ"},{"kind":"text","text":",] like as"},{"kind":"arabic","text_bw":"tamorN","text_ar":"تَمْرٌ"},{"kind":"text","text":"is of"},{"kind":"arabic","text_bw":"tamorapN","text_ar":"تَمْرَةٌ"},{"kind":"text","text":"; (Msb;) and"},{"kind":"arabic","text_bw":"A^adowaAHN","text_ar":"اَدْوَاحٌ"},{"kind":"text","text":"is pl. of"},{"kind":"arabic","text_bw":"dawoHN","text_ar":"دَوْحٌ"},{"kind":"text","text":": (TA:) and ↓"},{"kind":"arabic","text_bw":"$ajarapN daAy^iHapN","text_ar":"شَجَرَةٌ دَايِحَةٌ","orth_type":"arrow"},{"kind":"text","text":"signifies the same; (A, * K;) and the pl. is"},{"kind":"arabic","text_bw":"dawaAy^iHu","text_ar":"دَوَايِحُ"},{"kind":"text","text":"; (A, K;) or"},{"kind":"arabic","text_bw":"dawaAy^iHu","text_ar":"دَوَايِحُ"},{"kind":"text","text":"signifies"},{"kind":"italic_en","text":"great trees,"},{"kind":"text","text":"one of which is called"},{"kind":"arabic","text_bw":"dawoHapN","text_ar":"دَوْحَةٌ"},{"kind":"text","text":", and its sing., though it be not used, seems to be"},{"kind":"arabic","text_bw":"daAy^iHapN","text_ar":"دَايِحَةٌ"},{"kind":"text","text":". (AHn, TA.) One says,"},{"kind":"arabic","text_bw":"fulaAnN","text_ar":"فُلَانٌ"},{"kind":"arabic","text_bw":"mino dawoHapi Alkarami","text_ar":"مِنْ دَوْحَةِ الكَرَمِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one is of a great generous stock"},{"kind":"text","text":"]. (A, TA.) ―         -b2-  Also"},{"kind":"italic_en","text":"A great"},{"kind":"text","text":"["},{"kind":"italic_en","text":"tent of the kind called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"miZal~ap","text_ar":"مِظَلَّة"},{"kind":"text","text":". (TA. [See also"},{"kind":"arabic","text_bw":"dawoHN","text_ar":"دَوْحٌ"},{"kind":"text","text":".])"}],"source_refs":["S","A","Msb","K","TA"]}]},"classical_definitions":null}