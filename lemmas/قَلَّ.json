ind":"italic_en","text":"scanty; she became scant in her milk."},{"kind":"text","text":"―         -b4-"},{"kind":"arabic","text_bw":"qal~a xayoruhu","text_ar":"قَلَّ خَيْرُهُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"His good things,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wealth,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his beneficence, became few,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"little; scanty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wanting; he became poor;"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"he became niggardly:"},{"kind":"text","text":"] for"},{"kind":"arabic","text_bw":"qil~apu xayorK","text_ar":"قِلَّةُ خَيْرٍ"},{"kind":"text","text":"signifies “ poverty ” and “ niggardliness. ” (A, TA, in art."},{"kind":"arabic","text_bw":"Hjd","text_ar":"حجد"},{"kind":"text","text":".) And"},{"kind":"italic_en","text":"It became scanty,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"deficient,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wanting, in goodness."},{"kind":"text","text":"―         -b5-"},{"kind":"arabic","text_bw":"qal~a","text_ar":"قَلَّ"},{"kind":"italic_en","text":"He had few aiders:"},{"kind":"text","text":"sec an ex. voce"},{"kind":"arabic","text_bw":"fal~a","text_ar":"فَلَّ"},{"kind":"text","text":"."}],"source_refs":[]}]}}