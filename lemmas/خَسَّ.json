lettuce”), from Sumerian 𒄭𒄑𒊬 (ḫi-izˢᵃʳ /⁠hiz⁠/, “lettuce”); cognates with Classical Syriac ܚ̈ܲܣܸܐ (ḥassā) and Hebrew חַסָּה (ḥássā). Note also Old Armenian հազար (hazar)."},"ipa":["/xas.sa/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n10573","headword_ar":"خَسَّ","root":"xs","body":[{"kind":"text","text":", (Msb, TA,) sec. pers."},{"kind":"arabic","text_bw":"xasisota","text_ar":"خَسِسْتَ"},{"kind":"text","text":", (Fr, S,"},{"kind":"page_break","n":736},{"kind":"text","text":"A, Msb, K,) aor."},{"kind":"arabic","text_bw":"yaxas~u","text_ar":"يَخَسُّ"},{"kind":"text","text":"; (A, Msb, TA;) and"},{"kind":"arabic","text_bw":"xas~a","text_ar":"خَسَّ"},{"kind":"text","text":", sec. pers."},{"kind":"arabic","text_bw":"xasasota","text_ar":"خَسَسْتَ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxis~u","text_ar":"يَخِسُّ"},{"kind":"text","text":"; (Msb, TA;) inf. n."},{"kind":"arabic","text_bw":"xis~apN","text_ar":"خِسَّةٌ"},{"kind":"text","text":"(Fr, S, A, K) and"},{"kind":"arabic","text_bw":"xasaAsapN","text_ar":"خَسَاسَةٌ"},{"kind":"text","text":"(Fr, S, A, Msb, K) and"},{"kind":"arabic","text_bw":"xusuwsN","text_ar":"خُسُوسٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble, base, vile, mean"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid, weak;"},{"kind":"text","text":"(Fr, S, A, K;) [or, more commonly,]"},{"kind":"italic_en","text":"contemptible:"},{"kind":"text","text":"(Fr, * S, * A, K:) and"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(a thing)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, base, vile,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mean;"},{"kind":"text","text":"(TA;) or"},{"kind":"italic_en","text":"contemptible, paltry,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"inconsiderable;"},{"kind":"text","text":"(Msb, * TA;) and"},{"kind":"italic_en","text":"bad, corrupt, abominable,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disapproved."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"xas~a fiEoluhu","text_ar":"خَسَّ فِعْلُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"qawoluhu","text_ar":"قَوْلُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"raA^oyuhu","text_ar":"رَاْيُهُ"},{"kind":"text","text":", and"},{"kind":"arabic","text_bw":"HaZ~uhu","text_ar":"حَظُّهُ"},{"kind":"text","text":", (tropical:)  ["},{"kind":"italic_en","text":"His action,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his saying,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his opinion,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"his fortune, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble,"},{"kind":"text","text":"&c.] (A.) ―         -b3-"},{"kind":"arabic","text_bw":"xas~a","text_ar":"خَسَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxis~u","text_ar":"يَخِسُّ"},{"kind":"text","text":","},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, light of weight, not equal to what corresponded with it."},{"kind":"text","text":"(Msb.) ―         -b4-"},{"kind":"arabic","text_bw":"xas~a","text_ar":"خَسَّ"},{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yaxus~u","text_ar":"يَخُسُّ"},{"kind":"text","text":"; (Msb;) and ↓"},{"kind":"arabic","text_bw":"Axs~","text_ar":"اخسّ","orth_type":"arrow"},{"kind":"text","text":", (ISk, S, Msb, K,) inf. n."},{"kind":"arabic","text_bw":"A_ixosaAsN","text_ar":"اـِخْسَاسٌ"},{"kind":"text","text":"; (ISk, S;) (tropical:)"},{"kind":"italic_en","text":"He did what was low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble, base, vile, mean"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sordid, weak;"},{"kind":"text","text":"[or, more commonly,]"},{"kind":"italic_en","text":"contemptible:"},{"kind":"text","text":"(ISk, * S, * Msb, * K:) or ↓ the latter signifies"},{"kind":"italic_en","text":"he did something low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"in actions."},{"kind":"text","text":"(TA.)       -A2-"},{"kind":"arabic","text_bw":"xas~a naSiybahu","text_ar":"خَسَّ نَصِيبَهُ"},{"kind":"text","text":", (S, A, Mgh, * K,) aor."},{"kind":"arabic","text_bw":"yaxus~u","text_ar":"يَخُسُّ"},{"kind":"text","text":"; (S, TA;) and ↓"},{"kind":"arabic","text_bw":"Axs~hu","text_ar":"اخسّهُ","orth_type":"arrow"},{"kind":"text","text":"; (Mgh;)"},{"kind":"italic_en","text":"He made his lot, portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"share, to be low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble, base, vile, mean;"},{"kind":"text","text":"[or, more commonly,]"},{"kind":"italic_en","text":"contemptible:"},{"kind":"text","text":"(S, * A, Mgh, * K:) and"},{"kind":"arabic","text_bw":"xas~a AlHaZ~a","text_ar":"خَسَّ الحَظَّ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"Axs~hu","text_ar":"اخسّهُ","orth_type":"arrow"},{"kind":"text","text":","},{"kind":"italic_en","text":"He made the lot, portion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"share, little,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"incomplete."},{"kind":"text","text":"(TA.) ―         -b2-  Also"},{"kind":"arabic","text_bw":"xas~a HaZ~ahu","text_ar":"خَسَّ حَظَّهُ"},{"kind":"text","text":", [and ↓"},{"kind":"arabic","text_bw":"Axs~hu","text_ar":"اخسّهُ","orth_type":"arrow"},{"kind":"text","text":",] (tropical:)  ["},{"kind":"italic_en","text":"He made his fortune to be low"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"ignoble,"},{"kind":"text","text":"&c.; or"},{"kind":"italic_en","text":"contemptible;"},{"kind":"text","text":"differing from the signification immediately preceding, being said to be tropical.] (A.) The Arabs say of a man without any good fortune in the present life,"},{"kind":"arabic","text_bw":"A@ll~`hu HaZ~ahu","text_ar":"ا@للّٰهُ حَظَّهُ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"A^axas~a","text_ar":"اَخَسَّ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)  ["},{"kind":"italic_en","text":"God made his fortune mean,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"contemptible"},{"kind":"text","text":"]; as also"},{"kind":"arabic","text_bw":"A^axat~ahu","text_ar":"اَخَتَّهُ"},{"kind":"text","text":". (AM, TA.)"}],"source_refs":["Msb","TA","Fr","S","A","K","ISk"]}]},"classical_definitions":null}