{"lemma":"بَيْدَرٌ","slug":"بَيْدَرٌ","root":"ب.د.ر","root_slug":"ب-د-ر","root_link":"/words/roots/ب-د-ر","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":true,"sense_count":1},"lanes":{"found":true,"entry_ids":["n1985"],"search_url":"https://lanelexicon.com/?s=%D8%A8%D9%8E%D9%8A%D9%92%D8%AF%D9%8E%D8%B1%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"threshing-floor"}]},"etymology":{"source":"wiktextract","text":"Borrowed from Aramaic בַּי דְּרִי (bay dərī, literally “house of to-be-threshed-grain”)."},"ipa":["/baj.dar/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n1985","headword_ar":"بَيْدَرٌ","root":"bdr","body":[{"kind":"text","text":"a word of the dial. of El-'Irák, (A 'Obeyd in art."},{"kind":"arabic","text_bw":"rbd","text_ar":"ربد"},{"kind":"text","text":"in the TA,)"},{"kind":"italic_en","text":"A place in which wheat,"},{"kind":"text","text":"(S, Mgh, K,) or"},{"kind":"italic_en","text":"grain,"},{"kind":"text","text":"(Msb,)"},{"kind":"italic_en","text":"is trodden out."},{"kind":"text","text":"(S, Mgh, Msb, K.) ―         -b2-  It may also mean, tropically, (tropical:)  The"},{"kind":"italic_en","text":"wheat and straw therein:"},{"kind":"text","text":"(Mgh:) or rather, as Az says, on the authority of IAar, it signifies [also] (Mgh)"},{"kind":"italic_en","text":"reaped grain collected together;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"wheat collected together in the place in which it is trodden out;"},{"kind":"text","text":"syn."},{"kind":"arabic","text_bw":"kudosN","text_ar":"كُدْسٌ"},{"kind":"text","text":", (M, Mgh, K,) and"},{"kind":"arabic","text_bw":"EaramapN","text_ar":"عَرَمَةٌ"},{"kind":"text","text":": (Mgh:) Kr restricts it to wheat. (M.) ―         -b3-  Accord. to the Towsheeh, it is ["},{"kind":"italic_en","text":"A place] for [drying] dates."},{"kind":"text","text":"(TA in art."},{"kind":"arabic","text_bw":"jrn","text_ar":"جرن"},{"kind":"text","text":".)"}],"source_refs":["S","Mgh","K","Msb","M"]}]},"classical_definitions":null}