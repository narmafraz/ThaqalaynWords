{"lemma":"سُمُطٌ","slug":"سُمُطٌ","root":"س.م.ط","root_slug":"س-م-ط","root_link":"/words/roots/س-م-ط","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":4,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":5},"lanes":{"found":true,"entry_ids":["","n20704"],"search_url":"https://lanelexicon.com/?s=%D8%B3%D9%8F%D9%85%D9%8F%D8%B7%D9%8C"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to scald"},{"pos":"verb","gloss":"to prepare"},{"pos":"noun","gloss":"verbal noun of سَمَطَ (samaṭa) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"pauper, man of modest means"},{"pos":"noun","gloss":"string, thread (of a necklace))"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n20704","headword_ar":"سِمْطٌ","root":"smT","body":[{"kind":"italic_en","text":"A thread,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"string, having upon it beads"},{"kind":"page_break","n":1427},{"kind":"text","text":"(S, Mgh) or"},{"kind":"italic_en","text":"pearls;"},{"kind":"text","text":"(Mgh;) otherwise it is called"},{"kind":"arabic","text_bw":"silokN","text_ar":"سِلْكٌ"},{"kind":"text","text":": (S, Mgh:)"},{"kind":"italic_en","text":"a string of beads"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like;"},{"kind":"text","text":"(M, K;) so called because it is hung, or suspended; (M;)"},{"kind":"italic_en","text":"a single string thereof;"},{"kind":"text","text":"like"},{"kind":"arabic","text_bw":"yako","text_ar":"يَكْ"},{"kind":"arabic","text_bw":"rasano","text_ar":"رَسَنْ"},{"kind":"text","text":"[in Persian]; a necklace of two strings thereof being called"},{"kind":"arabic","text_bw":"*aAtu simoTayoni","text_ar":"ذَاتُ سِمْطَيْنِ"},{"kind":"text","text":": (IDrd:) or it signifies, (M,) or signifies also, (K,)"},{"kind":"italic_en","text":"a necklace longer than the"},{"kind":"arabic","text_bw":"mixonaqap","text_ar":"مِخْنَقَة"},{"kind":"text","text":": (IDrd, M, K:) or [simply]"},{"kind":"italic_en","text":"a necklace:"},{"kind":"text","text":"(Msb:) pl."},{"kind":"arabic","text_bw":"sumuwTN","text_ar":"سُمُوطٌ"},{"kind":"text","text":": (M, K:) which also signifies the"},{"kind":"italic_en","text":"things that are suspended"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"maEaAliyqu","text_ar":"مَعَالِيقُ"},{"kind":"text","text":")"},{"kind":"italic_en","text":"from necklaces."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"italic_en","text":"A thong,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"strap, that is suspended from the horse's saddle;"},{"kind":"text","text":"(S, K;) sing. of"},{"kind":"arabic","text_bw":"sumuwTN","text_ar":"سُمُوطٌ"},{"kind":"text","text":". (S.) ―         -b3-  The"},{"kind":"italic_en","text":"redundant part of the turban, which is left hanging down upon the breast and the shoulder-blades:"},{"kind":"text","text":"(K:) pl. as above. (TA.) ―         -b4-"},{"kind":"italic_en","text":"A coat of mail which the horseman hangs upon the hinder part of his horse."},{"kind":"text","text":"(M, K.) ―         -b5-  (tropical:)"},{"kind":"italic_en","text":"A trail,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"long and elevated tract,"},{"kind":"text","text":"("},{"kind":"arabic","text_bw":"Habol","text_ar":"حَبْل"},{"kind":"text","text":",) of sand, (K, TA,)"},{"kind":"italic_en","text":"regularly disposed, as though it were a necklace."},{"kind":"text","text":"(TA.)       -A2-  See also"},{"kind":"arabic","text_bw":"sumuTN","text_ar":"سُمُطٌ"},{"kind":"text","text":", in two places."}],"source_refs":["S","Mgh","IDrd","M","K","Msb","TA"]}]},"classical_definitions":null}