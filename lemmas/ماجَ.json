d":"arabic","text_bw":"majajapN","text_ar":"مَجَجَةٌ"},{"kind":"text","text":". (IAar.)"}],"source_refs":["K","S","TA","IAar"]},{"entry_id":"n39027","headword_ar":"مَاجَ","root":"mwj","body":[{"kind":"text","text":", aor."},{"kind":"arabic","text_bw":"yamuwju","text_ar":"يَمُوجُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mawojN","text_ar":"مَوْجٌ"},{"kind":"text","text":"(S, K, &c.) and"},{"kind":"arabic","text_bw":"mawajaAnN","text_ar":"مَوَجَانٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"muw^uwjN","text_ar":"مُوُوجٌ"},{"kind":"text","text":"; (TA;)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(the sea)"},{"kind":"italic_en","text":"was in a state of commotion; was tumultuous;"},{"kind":"text","text":"(Msb;)"},{"kind":"italic_en","text":"was agitated with waves, conflicting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dashing together;"},{"kind":"text","text":"(S, K;) as also ↓"},{"kind":"arabic","text_bw":"tmw~j","text_ar":"تموّج","orth_type":"arrow"},{"kind":"text","text":": (TA;) or this latter signifies"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"(the sea)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, very tumultuous."},{"kind":"text","text":"(Msb.) [You say,]"},{"kind":"arabic","text_bw":"maAja Almawoju","text_ar":"مَاجَ المَوْجُ"},{"kind":"italic_en","text":"The waves were in a state of commotion; were tumultuous; conflicted,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"dashed together."},{"kind":"text","text":"(TA.) [And hence,]"},{"kind":"arabic","text_bw":"maAja A^amoruhumo","text_ar":"مَاجَ اَمْرُهُمْ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"Their affair became in a confused and disturbed state."},{"kind":"text","text":"(TA.) ―         -b2-"},{"kind":"arabic","text_bw":"maAja","text_ar":"مَاجَ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mawojN","text_ar":"مَوْجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"mawajaAnN","text_ar":"مَوَجَانٌ"},{"kind":"text","text":", (assumed tropical:)"},{"kind":"italic_en","text":"It"},{"kind":"text","text":"(anything)"},{"kind":"italic_en","text":"was in a state of commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation."},{"kind":"text","text":"(TA.) ―         -b3-"},{"kind":"arabic","text_bw":"maAja","text_ar":"مَاجَ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was in a state of commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"agitation, and confounded, perplexed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amazed."},{"kind":"text","text":"(IAar.) ―         -b4-"},{"kind":"arabic","text_bw":"Aln~aAsu yamuwjuwnN","text_ar":"النَّاسُ يَمُوجُونٌ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"men, are in a state of commotion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"tumultuous."},{"kind":"text","text":"(S.) ―         -b5-"},{"kind":"arabic","text_bw":"maAjati Aln~aAsu","text_ar":"مَاجَتِ النَّاسُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The people were in a discordant and disturbed state of affairs."},{"kind":"text","text":"(Msb.) ―         -b6-"},{"kind":"arabic","text_bw":"maAja","text_ar":"مَاجَ"},{"kind":"arabic","text_bw":"Eani AlHaq~i","text_ar":"عَنِ الحَقِّ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"mawojN","text_ar":"مَوْجٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"He declined from the truth,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from the true, right,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"just, course."},{"kind":"text","text":"(A, K.) ―         -b7-"},{"kind":"arabic","text_bw":"maAjati Ald~aAgiSapu","text_ar":"مَاجَتِ الدَّاغِصَةُ"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"muw^uwjN","text_ar":"مُوُوجٌ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"The patella,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"knee-pan, moved backwards and forwards,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from side to side, between the skin and the bone,"},{"kind":"text","text":"or, as in one copy of the K,"},{"kind":"italic_en","text":"flesh:"},{"kind":"text","text":"(K, TA:) and in like manner"},{"kind":"arabic","text_bw":"Als~iloEapu","text_ar":"السِّلْعَةُ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"the ganglion"},{"kind":"text","text":"]. (TA.)"}],"source_refs":["K","TA"]}]}}