nition":{"source":"lanes","entries":[{"entry_id":"n21600","headword_ar":"شَبِقَ","root":"$bq","body":[{"kind":"text","text":", (S, M, O, Msb, K,) aor."},{"kind":"text","text":", (Msb, K,) inf. n."},{"kind":"arabic","text_bw":"$abaqN","text_ar":"شَبَقٌ"},{"kind":"text","text":", (S, M, Mgh, O, Msb,)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, affected with vehement lust,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"carnal desire:"},{"kind":"text","text":"(S, M, Mgh, O, Msb, K:) said of a man; (M, Msb;) and in like manner one says of a woman; and also, sometimes, of other than human beings. (M, TA.) ―         -b2-  And"},{"kind":"arabic","text_bw":"$abiqa mina All~aHomi","text_ar":"شَبِقَ مِنَ اللَّحْمِ"},{"kind":"italic_en","text":"He suffered indigestion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"turned away with disgust, from flesh-meat."},{"kind":"text","text":"(Ibn-'Abbád, O, K.)"}],"source_refs":["S","M","O","Msb","K","Mgh"]}]}}