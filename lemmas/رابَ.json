","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَرِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَرُوب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3ms","form":"يَرِيب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"s"},{"role":"present_3fs","form":"تَرُب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَرِب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَرُوب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3fs","form":"تَرِيب","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"s"},{"role":"present_3md","form":"يَرُوبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرُوبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يَرِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تَرُوبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرُوبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرِيبا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تَرِيبانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يَرُوبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرُوبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرِيبُوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يَرِيبُونَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يَرُبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_3fp","form":"يَرِبْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"past_1mp","form":"رُبْنا","in_corpus":true,"count":74,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رُبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"رِبْنا","in_corpus":true,"count":74,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"رِبْتُ","in_corpus":true,"count":1,"asp":"p","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرُوب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرُوب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نَرِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أَرِيب","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":154,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":2,"pos_tags":["verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["n14246","n14247","n14398","n14636","n16949","n16952","n17215"],"search_url":"https://lanelexicon.com/?s=%D8%B1%D8%A7%D8%A8%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be thick, to solidify","tags":["intransitive"]},{"pos":"verb","gloss":"to be perplexed"},{"pos":"verb","gloss":"to raise suspicions, make someone doubtful, skeptical about (فِي (fī))","tags":["transitive"]}]},"etymology":null,"ipa":["/raː.ba/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n14246","headword_ar":"رَاَبَ","root":"rA^b","body":[{"kind":"text","text":", (T, S, M, A, K,) aor."},{"kind":"text","text":", (M, A, K,) inf. n."},{"kind":"arabic","text_bw":"raA^obN","text_ar":"رَاْبٌ"},{"kind":"text","text":". (M, TA,)"},{"kind":"italic_en","text":"He repaired,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"mended,"},{"kind":"text","text":"(T, S, M, A, K,) a [cracked, or broken,] vessel, (S,) or a crack, or fissure; (M, A, K;) as also ↓"},{"kind":"arabic","text_bw":"rA^~b","text_ar":"راّب","orth_type":"arrow"},{"kind":"text","text":", (M, TA,) in some copies of the K ↓"},{"kind":"arabic","text_bw":"ArtA^b","text_ar":"ارتاب","orth_type":"arrow"},{"kind":"text","text":", [agreeably with an explanation of"},{"kind":"arabic","text_bw":"murotaA^abN","text_ar":"مُرْتَاَبٌ"},{"kind":"text","text":", its pass. part. n., which see below,] and in others [and in a copy of the A] ↓"},{"kind":"arabic","text_bw":"A^aroA^aba","text_ar":"اَرْاَبَ","orth_type":"arrow"},{"kind":"text","text":", but the right reading is"},{"kind":"arabic","text_bw":"rA^~b","text_ar":"راّب"},{"kind":"text","text":". (TA.) It is related of AHát, that he heard"},{"kind":"arabic","text_bw":"rabN","text_ar":"رَبٌ"},{"kind":"text","text":"said, [as the imperative, for"},{"kind":"arabic","text_bw":"AiroA^abo","text_ar":"اِرْاَبْ"},{"kind":"text","text":",] and that it is a good dial. var., like"},{"kind":"arabic","text_bw":"salo","text_ar":"سَلْ"},{"kind":"text","text":"for"},{"kind":"arabic","text_bw":"AisoA^alo","text_ar":"اِسْاَلْ"},{"kind":"text","text":". (TA.) ―         -b2-  (assumed tropical:)"},{"kind":"italic_en","text":"He rectified, repaired, mended,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amended,"},{"kind":"text","text":"anything. (M.) You say,"},{"kind":"arabic","text_bw":"raA^aba bayona Alqawomi","text_ar":"رَاَبَ بَيْنَ القَوْمِ"},{"kind":"text","text":", (M, K,) aor. and inf. n. as above, (M,) (assumed tropical:)"},{"kind":"italic_en","text":"He effected a reconciliation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"made peace, between the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"company of men."},{"kind":"text","text":"(M, K.) And"},{"kind":"arabic","text_bw":"Aall~`hum~a A@roA^abo","text_ar":"اَللّٰهُمَّ ا@رْاَبْ"},{"kind":"arabic","text_bw":"bayonahumo","text_ar":"بَيْنَهُمْ"},{"kind":"text","text":"(S, A) (assumed tropical:)"},{"kind":"italic_en","text":"O God, effect a reconciliation,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"make peace, between them:"},{"kind":"text","text":"(S:) or (tropical:)"},{"kind":"italic_en","text":"rectify the matter,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"affair, between them."},{"kind":"text","text":"(A.) And"},{"kind":"arabic","text_bw":"Aall~`hum~a A@roA^abo HaAlanaA","text_ar":"اَللّٰهُمَّ ا@رْاَبْ حَالَنَا"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"O God, rectify,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amend, our state,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"condition"},{"kind":"text","text":"]. (TA.) ―         -b3-  Also, inf. n. as above, (assumed tropical:)"},{"kind":"italic_en","text":"He collected"},{"kind":"text","text":"a thing"},{"kind":"italic_en","text":"together, and bound"},{"kind":"text","text":"it"},{"kind":"italic_en","text":"gently."},{"kind":"text","text":"(TA.) ―         -b4-  And"},{"kind":"arabic","text_bw":"raA^abati AlA^aroDu","text_ar":"رَاَبَتِ الاَرْضُ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The land produced its"},{"kind":"text","text":"["},{"kind":"italic_en","text":"trefoil called"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"raTobap","text_ar":"رَطْبَة"},{"kind":"text","text":", or"},{"kind":"arabic","text_bw":"ruTobap","text_ar":"رُطْبَة"},{"kind":"text","text":", [so accord. to different copies of the K,]"},{"kind":"italic_en","text":"after the cutting"},{"kind":"text","text":"["},{"kind":"italic_en","text":"of a crop thereof"},{"kind":"text","text":"]. (K.)"}],"source_refs":["T","S","M","A","K","TA"]},{"entry_id":"n14247","headword_ar":"رَاْبٌ","root":"rA^b","body":[{"kind":"text","text":"an inf. n. used in the sense of [the act. part. n.] ↓"},{"kind":"arabic","text_bw":"raAy^ibN","text_ar":"رَايِبٌ","orth_type":"arrow"},{"kind":"text","text":": so in the saying,"},{"kind":"arabic","text_bw":"kafaY bifulaAnK","text_ar":"كَفَى بِفُلَانٍ"},{"kind":"arabic","text_bw":"raA^obFA liA^amorika","text_ar":"رَاْبًا لِاَمْرِكَ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one is sufficient as a rectifier, or an amender, of thine affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"thy case"},{"kind":"text","text":"]. (A.) You say also,"},{"kind":"arabic","text_bw":"fulaAnN raA^obu A^amori","text_ar":"فُلَانٌ رَاْبُ اَمْرِ"},{"kind":"text","text":", and ↓"},{"kind":"arabic","text_bw":"raw^uwbu","text_ar":"رَوُوبُ","orth_type":"arrow"},{"kind":"arabic","text_bw":"A^umuwrK","text_ar":"اُمُورٍ"},{"kind":"text","text":", (tropical:)"},{"kind":"italic_en","text":"Such a one is a rectifier,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"an amender, of an affair,"},{"kind":"text","text":"and ["},{"kind":"italic_en","text":"a skilful rectifier"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amender"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"of affairs."},{"kind":"text","text":"(A.) [See also"},{"kind":"arabic","text_bw":"ruw^obapN","text_ar":"رُوْبَةٌ"},{"kind":"text","text":": and"},{"kind":"arabic","text_bw":"miroA^abN","text_ar":"مِرْاَبٌ"},{"kind":"text","text":".] ―         -b2-  Also (tropical:)"},{"kind":"italic_en","text":"A chief who rectifies,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"amends, the affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case, of a people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party."},{"kind":"text","text":"(A.) ―         -b3-  (tropical:)"},{"kind":"italic_en","text":"A big, bulky, portly,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"corpulent, chief."},{"kind":"text","text":"(K, TA.)       -A2-"},{"kind":"italic_en","text":"A herd of seventy camels."},{"kind":"text","text":"(K.)"}],"source_refs":[]},{"entry_id":"n14398","headword_ar":"رَابٌّ","root":"rb","body":[{"kind":"text","text":"; and its fem., with"},{"kind":"arabic","text_bw":"p","text_ar":"ة"},{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"rabiybN","text_ar":"رَبِيبٌ"},{"kind":"text","text":"in three places."}],"source_refs":[]},{"entry_id":"n14636","headword_ar":"رَابٍ","root":"rbw","body":[{"kind":"text","text":"["},{"kind":"italic_en","text":"Increasing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"augmenting:"},{"kind":"text","text":"&c. ―         -b2-  Hence,]"},{"kind":"arabic","text_bw":"faA^axa*ahumo A^axo*apF raAbiyapF","text_ar":"فَاَخَذَهُمْ اَخْذَةً رَابِيَةً"},{"kind":"text","text":", in the Kur [lxix. 10],"},{"kind":"italic_en","text":"And He punished them with a punishment exceeding"},{"kind":"text","text":"other punishments; (Fr, * S, * M, * K, * Jel;)"},{"kind":"italic_en","text":"a vehement punishment."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"AimoraA^apN raAbiyapN","text_ar":"اِمْرَاَةٌ رَابِيَةٌ"},{"kind":"italic_en","text":"A woman affected with what is termed"},{"kind":"arabic","text_bw":"rabowN","text_ar":"رَبْوٌ"},{"kind":"text","text":"; [i. e.,"},{"kind":"italic_en","text":"out of breath;"},{"kind":"text","text":"&c.; (see 1, near the end of the paragraph;)] (T, TA;) as also ↓"},{"kind":"arabic","text_bw":"rabowaA='u","text_ar":"رَبْوَا=ءُ","orth_type":"arrow"},{"kind":"text","text":". (TA.)"}],"source_refs":[]},{"entry_id":"n16949","headword_ar":"رَابَ","root":"rwb","body":[{"kind":"text","text":", (T, S, M, &c.,) aor."},{"kind":"arabic","text_bw":"yaruwbu","text_ar":"يَرُوبُ"},{"kind":"text","text":", (T, S, &c.,) inf. n."},{"kind":"arabic","text_bw":"rawobN","text_ar":"رَوْبٌ"},{"kind":"text","text":", (Lth, T, Msb,) or"},{"kind":"arabic","text_bw":"ruw^uwbN","text_ar":"رُوُوبٌ"},{"kind":"text","text":", (S,) or both, (T, M, Mgh, K,) said of milk, (T, S, M, &c.,)"},{"kind":"italic_en","text":"It was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"coagulated:"},{"kind":"text","text":"(M, A, Msb, K:) or"},{"kind":"italic_en","text":"was churned, and deprived of its butter:"},{"kind":"text","text":"(M, * A, K: *) or"},{"kind":"italic_en","text":"it was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fit to be churned:"},{"kind":"text","text":"(T:) or"},{"kind":"italic_en","text":"thick,"},{"kind":"text","text":"(S,) or"},{"kind":"italic_en","text":"having a compact pellicle upon its surface, and thick,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"resembling liver so that it quivered,"},{"kind":"text","text":"(Lth, T,)"},{"kind":"italic_en","text":"and fit to be churned:"},{"kind":"text","text":"(Lth, T, S:) or"},{"kind":"italic_en","text":"such as had become thick;"},{"kind":"text","text":"(Fr, A'Obeyd, T, S, * Mgh;)"},{"kind":"italic_en","text":"until its butter was taken forth;"},{"kind":"text","text":"(Fr, A'Obeyd, T, S; *) or"},{"kind":"italic_en","text":"before and after it had been deprived of its butter."},{"kind":"text","text":"(Mgh.) ―         -b2-  [Hence,]"},{"kind":"arabic","text_bw":"raAba damuhu","text_ar":"رَابَ دَمُهُ"},{"kind":"text","text":", (T, M, A, K,) aor. as above, (T,) inf. n."},{"kind":"arabic","text_bw":"rawobN","text_ar":"رَوْبٌ"},{"kind":"text","text":", (M,) (tropical:)  ["},{"kind":"italic_en","text":"His blood is about to be shed;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"his death,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"destruction, is at hand:"},{"kind":"text","text":"(M, K:) said of one who has exposed himself to that which will cause his blood to be shed; (T;) of one who has exposed himself to slaughter: (A:) like the phrase"},{"kind":"arabic","text_bw":"yafuwru damuhu","text_ar":"يَفُورُ دَمُهُ"},{"kind":"text","text":"; (T;) or like"},{"kind":"arabic","text_bw":"yagoliY damuhu","text_ar":"يَغْلِى دَمُهُ"},{"kind":"text","text":": his blood being likened to milk that has become thick, and fit to be churned. (A.) ―         -b3-  And"},{"kind":"arabic","text_bw":"raAba Alr~ajulu","text_ar":"رَابَ الرَّجُلُ"},{"kind":"text","text":", (As, T, S, &c.,) aor. as above, (TA,) inf. n."},{"kind":"arabic","text_bw":"rawobN","text_ar":"رَوْبٌ"},{"kind":"text","text":"(S, M, K) and"},{"kind":"arabic","text_bw":"ruw^uwbN","text_ar":"رُوُوبٌ"},{"kind":"text","text":", (M, K,) (tropical:)"},{"kind":"italic_en","text":"The man was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, confused,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"disturbed,"},{"kind":"text","text":"(As, T, S, K,)"},{"kind":"italic_en","text":"in his affair,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"case,"},{"kind":"text","text":"(As, T,) or"},{"kind":"italic_en","text":"in his reason,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intellect,"},{"kind":"text","text":"(S, K,)"},{"kind":"italic_en","text":"and his opinion:"},{"kind":"text","text":"(As, T, S:) or"},{"kind":"italic_en","text":"confounded,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"perplexed; unable to see his right course:"},{"kind":"text","text":"(M, K:) and"},{"kind":"italic_en","text":"languid in spirit, by reason of satiety,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"drowsiness,"},{"kind":"text","text":"(M, A,) or"},{"kind":"italic_en","text":"intoxication;"},{"kind":"text","text":"as also"},{"kind":"arabic","text_bw":"raAbato nafosuhu","text_ar":"رَابَتْ نَفْسُهُ"},{"kind":"text","text":": (A:) or"},{"kind":"italic_en","text":"he arose"},{"kind":"text","text":"(M, K, TA)"},{"kind":"italic_en","text":"from sleep"},{"kind":"text","text":"(M, TA)"},{"kind":"italic_en","text":"disordered in body and mind:"},{"kind":"text","text":"(M, K, TA:) or"},{"kind":"italic_en","text":"he was intoxicated with sleep:"},{"kind":"text","text":"(M, K:) or"},{"kind":"italic_en","text":"he was lazy, sluggish,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slothful."},{"kind":"text","text":"(Aboo-Sa'eed, T.) ―         -b4-  And"},{"kind":"arabic","text_bw":"raAba","text_ar":"رَابَ"},{"kind":"text","text":", (Th, M, K,) inf. n."},{"kind":"arabic","text_bw":"rawobN","text_ar":"رَوْبٌ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"rw~b","text_ar":"روّب","orth_type":"arrow"},{"kind":"text","text":", (Th, M,) inf. n."},{"kind":"arabic","text_bw":"tarowiybN","text_ar":"تَرْوِيبٌ"},{"kind":"text","text":"; (K;) (assumed tropical:)"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, Th, M)"},{"kind":"italic_en","text":"was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded."},{"kind":"text","text":"(Th, M, K.) And"},{"kind":"arabic","text_bw":"maTiy~apu fulaAnK","text_ar":"مَطِيَّةُ فُلَانٍ"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"raw~abato","text_ar":"رَوَّبَتْ","orth_type":"arrow"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"The riding-camel of such a one was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, fatigued,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"jaded."},{"kind":"text","text":"(T.) ―         -b5-  And"},{"kind":"arabic","text_bw":"raAba","text_ar":"رَابَ"},{"kind":"text","text":"(assumed tropical:)"},{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, quiet, still,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"motionless."},{"kind":"text","text":"(IAar, T.) ―         -b6-  It is said in a prov., of him who does wrong and does right, [or of him who does right and does wrong,]"},{"kind":"arabic","text_bw":"huwa ya$uwbu wa yaruwbu","text_ar":"هُوَ يَشُوبُ وَ يَرُوبُ"},{"kind":"text","text":", meaning, accord. to Aboo-Sa'eed, (assumed tropical:)"},{"kind":"italic_en","text":"He defends"},{"kind":"text","text":"his companion [at one time],"},{"kind":"italic_en","text":"and is lazy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sluggish"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slothful"},{"kind":"text","text":"[at another time]: or it means"},{"kind":"italic_en","text":"he defends without energy"},{"kind":"text","text":"at one time,"},{"kind":"italic_en","text":"and"},{"kind":"text","text":"at another time"},{"kind":"italic_en","text":"is lazy"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sluggish"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"slothful,"},{"kind":"text","text":"so that he defends not at all: or, as some say,"},{"kind":"italic_en","text":"he mixes water with the milk,"},{"kind":"text","text":"and so spoils it,"},{"kind":"italic_en","text":"and he makes it good;"},{"kind":"text","text":"from the saying of IAar that"},{"kind":"arabic","text_bw":"raAba","text_ar":"رَابَ"},{"kind":"text","text":"signifies"},{"kind":"arabic","text_bw":"A^aSolaHa","text_ar":"اَصْلَحَ"},{"kind":"text","text":"; but if it have this meaning, it is originally"},{"kind":"arabic","text_bw":"raA^aba","text_ar":"رَاَبَ"},{"kind":"text","text":", with hemz. (T. [See more in art."},{"kind":"arabic","text_bw":"$wb","text_ar":"شوب"},{"kind":"text","text":".])       -A2-  Accord. to IAar,"},{"kind":"arabic","text_bw":"raAba","text_ar":"رَابَ"},{"kind":"text","text":"also signifies"},{"kind":"italic_en","text":"He suspected."},{"kind":"text","text":"(T. [But in this sense it seems to belong to art."},{"kind":"arabic","text_bw":"ryb","text_ar":"ريب"},{"kind":"text","text":".])       -A3-  Also"},{"kind":"italic_en","text":"He lied."},{"kind":"text","text":"(K. [But in the T, this signification is assigned to"},{"kind":"arabic","text_bw":"$aAba","text_ar":"شَابَ"},{"kind":"text","text":", not to"},{"kind":"arabic","text_bw":"raAba","text_ar":"رَابَ"},{"kind":"text","text":"; app. in relation to the prov. above cited.])"}],"source_refs":["Lth","T","Msb","S","M","Mgh","K","A","TA","As","Th"]},{"entry_id":"n16952","headword_ar":"رَابٌ","root":"rwb","body":[{"kind":"text","text":"The"},{"kind":"italic_en","text":"equal in quantity"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"measure"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"the like:"},{"kind":"text","text":"so in the saying,"},{"kind":"arabic","text_bw":"ha*aA raAbu ka*aA","text_ar":"هَذَا رَابُ كَذَا"},{"kind":"text","text":"["},{"kind":"italic_en","text":"This is the equal in quantity"},{"kind":"text","text":"&c."},{"kind":"italic_en","text":"of such a thing."},{"kind":"text","text":"(K, * TA.)"}],"source_refs":[]},{"entry_id":"n17215","headword_ar":"رَابٌ","root":"ryb","body":[{"kind":"italic_en","text":"Want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"need."},{"kind":"text","text":"(TA.) Hence, in a trad.,"},{"kind":"arabic","text_bw":"maA rabukumo A_ilayohi","text_ar":"مَا رَبُكُمْ اـِلَيْهِ"},{"kind":"italic_en","text":"What is"},{"kind":"text","text":"[the reason of]"},{"kind":"italic_en","text":"your want of him?"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"your wanting to ask him?"},{"kind":"text","text":"(TA.) And, in another trad.,"},{"kind":"arabic","text_bw":"maA raAbuka A_ilaY qaToEihaA","text_ar":"مَا رَابُكَ اـِلَى قَطْعِهَا"},{"kind":"italic_en","text":"What is"},{"kind":"text","text":"[the reason of]"},{"kind":"italic_en","text":"thy wanting to cut it off?"},{"kind":"text","text":"thus, says El-Khattábee, they relate it, with damm to the"},{"kind":"arabic","text_bw":"b","text_ar":"ب"},{"kind":"text","text":": but IAth says that it is properly"},{"kind":"arabic","text_bw":"maA A^arabuka","text_ar":"مَا اَرَبُكَ"},{"kind":"text","text":", meaning the same: or, accord. to Aboo-Moosà, the right reading may be"},{"kind":"arabic","text_bw":"mA raAbaka","text_ar":"ما رَابَكَ"},{"kind":"text","text":", expl. in the preceding paragraph. (TA.)"}],"source_refs":[]}]},"classical_definitions":{"source":"hawramani","url":"https://arabiclexicon.hawramani.com/%D8%B1%D8%A7%D8%A8/","headword_ar":"رَابَ","entries":[{"lexicon_id":"dictionary_19","lexicon_en":"Firuzabadi, al-Qāmūs al-Muḥīṭ (d. 1414 CE)","lexicon_ar":"القاموس المحيط للفيروزآبادي","permalink":"https://arabiclexicon.hawramani.com/?p=24298#1f8205","body_html":"<span>رَابَ اللَّبَنُ رَوْباً ورُؤُوباً: خَثُرَ، ولَبَنٌ رَوْبٌ ورائِبٌ، أو هو ما يُمْخَضُ ويُخْرَجُ زُبْدُهُ. ورَوَّبَهُ وأرابَهُ.</span><br><span>والمِرْوَبُ، كَمِنْبَرٍ: السِّقاءُ يَرُوبُ فيه.</span><br><span>وسِقاءٌ مُرَوَّبٌ، كَمُعَظَّمٍ: رُوِّبَ فيه اللَّبَنُ.</span><br><span>والرَّوْبَةُ، ويُضَمُّ: خَمِيرَةُ اللَّبَنِ، أو بَقِيَّةُ اللَّبَنِ، وجِمامُ ماءِ الفَحْلِ وهو اجْتِماعُهُ، أو ماؤُهُ في رَحِمِ الناقَةِ، والحاجَةُ، وقِوامُ العَيْشِ،</span><br><span>وـ مِنَ الأَمْرِ: جماعُهُ، والقِطْعَةُ من اللَّيْلِ، ومنه ابنُ العَجَّاجِ فيمنْ لا يَهْمِزُ، والقِطْعَةُ من اللَّحْمِ، وكَلُّوبٌ يُخْرِجُ الصَّيْدَ من جُحْرِهِ، والفَقْرُ، وشَجَرَةُ النُّلْكِ، النِّلْكِ، والكَسَلُ، والتَّواني، والمُكْرَمَةُ من الأرضِ الكَثيرَةُ النَّباتِ.</span><br><span>ورَابَ رَوْباً ورُؤُوباً: تَحَيَّرَ، وفَتَرَتْ نَفْسُهُ من شِبَعٍ أو نُعاسٍ، أو قامَ خائِرَ البَدَنِ والنَّفْسِ، أو سَكِرَ مِنْ نَوْمٍ، ورَجُلٌ رائِبٌ، وأرْوَبُ ورَوْبانُ،</span><br><span>و=أعْيَا، وكَذَبَ، واخْتَلَطَ عَقْلُهُ.</span><br><span>ورَابَ دَمُه: حانَ هَلاَكُهُ.</span><br><span>وكَطُوبٍ: ة بِبَلْخَ.</span><br><span>وكَطُوبَى: ة بِبَغْدَادَ.</span><br><span>والتَّرْوِيبُ: الإِعْياءُ.</span><br><span>ورَابُ كذا: قَدْرُهُ.</span>"}]}}