ttps://lanelexicon.com/?s=%D8%A7%D9%90%D9%86%D9%92%D8%AD%D9%8E%D8%AF%D9%8E%D8%B1%D9%8E"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to come down, to descend; to decline, to stoop"},{"pos":"verb","gloss":"to derive, to stem, to descend"}]},"etymology":null,"ipa":["/in.ħa.da.ra/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n7342","headword_ar":"انحدر","root":"Hdr","body":[{"kind":"italic_en","text":"He,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it, descended; went down, downwards, down a declivity,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"from a higher to a lower place"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"position:"},{"kind":"text","text":"(S, A, Msb, K:) and [in like manner] ↓"},{"kind":"arabic","text_bw":"Hadara","text_ar":"حَدَرَ","orth_type":"arrow"},{"kind":"text","text":", inf. n."},{"kind":"arabic","text_bw":"HadorN","text_ar":"حَدْرٌ"},{"kind":"text","text":", (TA,) or"},{"kind":"arabic","text_bw":"HuduwrN","text_ar":"حُدُورٌ"},{"kind":"text","text":", (A,)"},{"kind":"italic_en","text":"he went down,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"descended, a declivity."},{"kind":"text","text":"(A, TA.) [Hence,]"},{"kind":"arabic","text_bw":"AinoHadarotu A_ilaY AlbaSorapi","text_ar":"اِنْحَدَرْتُ اـِلَى البَصْرَةِ"},{"kind":"italic_en","text":"I went down to El-Basrah."},{"kind":"text","text":"(S.) ―         -b2-  Also"},{"kind":"italic_en","text":"He journeyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, towards El-'Irák,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"Syria,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"'Omán:"},{"kind":"text","text":"opposed to"},{"kind":"arabic","text_bw":"A^aSoEada","text_ar":"اَصْعَدَ"},{"kind":"text","text":", which signifies “ he journeyed, or went, towards Nejd, and El- Hijáz, and El-Yemen: ” (ISk, on the authority of 'Omárah, TA in art."},{"kind":"arabic","text_bw":"SEd","text_ar":"صعد"},{"kind":"text","text":":) or the former,"},{"kind":"italic_en","text":"he journeyed,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"went, towards El-'Irák:"},{"kind":"text","text":"and the latter, “ he journeyed, or went, towards the Kibleh: ” (Aboo-Sakhr, T, TA ubi suprà:) and ↓"},{"kind":"arabic","text_bw":"munoHadarN","text_ar":"مُنْحَدَرٌ","orth_type":"arrow"},{"kind":"text","text":"is used as an inf. n. of the former; like as"},{"kind":"arabic","text_bw":"muSEadN","text_ar":"مُصعَدٌ"},{"kind":"text","text":"is of the latter: (T, TA ubi suprà:) also, the former verb,"},{"kind":"italic_en","text":"he returned from any town or country:"},{"kind":"text","text":"and the latter, “ he commenced a journey or the like, in any direction. ” (Ibn-'Arafeh, TA ubi suprà.) ―         -b3-  Also, said of a place,"},{"kind":"italic_en","text":"It sloped down."},{"kind":"text","text":"(Msb.)       -A2-  See also 1, last sentence but one."}],"source_refs":["S","A","Msb","K","TA"]}]},"classical_definitions":null}