"role":"present_3md","form":"يُخِلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3md","form":"يُخِلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"d"},{"role":"present_3fd","form":"تُخَلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخَلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخِلّانِ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3fd","form":"تُخِلّا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"d"},{"role":"present_3mp","form":"يُخَلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخَلُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخِلُّونَ","in_corpus":true,"count":1,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3mp","form":"يُخِلُّوا","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"m","num":"p"},{"role":"present_3fp","form":"يُخْلِلْنَ","in_corpus":false,"count":null,"asp":"i","per":"3","gen":"f","num":"p"},{"role":"present_1mp","form":"نُخَلّ","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخَلّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"present_1mp","form":"نُخِلّ","in_corpus":true,"count":13,"asp":"i","per":"1","gen":"m","num":"p"},{"role":"present_1ms","form":"أُخِلّ","in_corpus":true,"count":2,"asp":"i","per":"1","gen":"m","num":"s"},{"role":"past_1mp","form":"أَخْلَلْنا","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"p"},{"role":"past_1ms","form":"أَخْلَلْتُ","in_corpus":false,"count":null,"asp":"p","per":"1","gen":"m","num":"s"}],"frequency_in_corpus":95,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":0},"lanes":{"found":true,"entry_ids":["n11160","n11190"],"search_url":"https://lanelexicon.com/?s=%D8%A3%D9%8E%D8%AE%D9%8E%D9%84%D9%8E%D9%91"}},"translations":null,"definition":null,"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n11160","headword_ar":"اَخَلَّ","root":"xl","body":[{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^uxil~a bihi","text_ar":"اُخِلَّ بِهِ"},{"kind":"text","text":": see 1, near the beginning. ―         -b2-"},{"kind":"arabic","text_bw":"A^xal~a bihi","text_ar":"اخَلَّ بِهِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man)"},{"kind":"italic_en","text":"fell,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"stopped, short in it; fell short of accomplishing it; fell short of doing what was requisite,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"due,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"what he ought to have done, in it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"with respect to it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"flagged,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was remiss, in it;"},{"kind":"text","text":"namely, a thing; syn."},{"kind":"arabic","text_bw":"qaS~ara fiyhi","text_ar":"قَصَّرَ فِيهِ"},{"kind":"text","text":"; (Msb;) as, for instance, in belief, and in confession thereof, and in works: (Ksh and Bd in ii. 2:)"},{"kind":"italic_en","text":"he left it, neglected it, omitted it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"left it undone:"},{"kind":"text","text":"(Har p. 402:) or"},{"kind":"italic_en","text":"i. q."},{"kind":"arabic","text_bw":"A^ajoHafa bihi","text_ar":"اَجْحَفَ بِهِ"},{"kind":"text","text":"[app. as meaning"},{"kind":"italic_en","text":"he was near to falling short of accomplishing it,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"of doing what was requisite in it;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"was near to being remiss in it"},{"kind":"text","text":"]; namely, a thing. (K.) ―         -b3-"},{"kind":"italic_en","text":"He failed of fulfilling his compact with him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"his promise to him."},{"kind":"text","text":"(K.) ―         -b4-"},{"kind":"italic_en","text":"He became absent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he absented himself, from it; he left, abandoned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted, it;"},{"kind":"text","text":"namely, a place &c. (K.) You say,"},{"kind":"arabic","text_bw":"Axl~ bimarokazihi","text_ar":"اخلّ بِمَرْكَزِهِ"},{"kind":"italic_en","text":"He"},{"kind":"text","text":"(a man, S, or a horseman, Mgh)"},{"kind":"italic_en","text":"left, abandoned,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quitted, his station"},{"kind":"text","text":"(S, Mgh)"},{"kind":"italic_en","text":"which the commander had appointed him."},{"kind":"text","text":"(Mgh.) And"},{"kind":"arabic","text_bw":"Axl~ bihimo","text_ar":"اخلّ بِهِمْ"},{"kind":"italic_en","text":"He became absent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"he absented himself, from them."},{"kind":"text","text":"(JK.) ―         -b5-"},{"kind":"arabic","text_bw":"Axl~ AlwaAliY biAlv~uguwri","text_ar":"اخلّ الوَالِى بِالثُّغُورِ"},{"kind":"italic_en","text":"The prefect made the frontiers to be kept by a small body of troops."},{"kind":"text","text":"(K.)       -A2-"},{"kind":"arabic","text_bw":"A^axal~a A_ilayohi","text_ar":"اَخَلَّ اـِلَيْهِ"},{"kind":"text","text":": see 8.       -A3-"},{"kind":"arabic","text_bw":"Axl~hu","text_ar":"اخلّهُ"},{"kind":"italic_en","text":"He made him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused him, to want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be in need."},{"kind":"text","text":"(JK, S, K.) You say,"},{"kind":"arabic","text_bw":"maA A^axal~aka A_ilaY h`*aA","text_ar":"مَا اَخَلَّكَ اـِلَى هٰذَا"},{"kind":"italic_en","text":"What has made thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused thee, to want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be in need of, this?"},{"kind":"text","text":"(S.) And"},{"kind":"arabic","text_bw":"maA A^axal~aka A@ll~`hu A_ilayohi","text_ar":"مَا اَخَلَّكَ ا@للّٰهُ اـِلَيْهِ"},{"kind":"italic_en","text":"What has God made thee,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"caused thee, to want,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"be in need of?"},{"kind":"text","text":"(Lh, K.)       -A4-"},{"kind":"arabic","text_bw":"Axl~ AlA^ibila","text_ar":"اخلّ الاِبِلَ"},{"kind":"text","text":": see 1, near the end of the paragraph.       -A5-"},{"kind":"arabic","text_bw":"Axl~wA","text_ar":"اخلّوا"},{"kind":"text","text":", (K,) inf. n."},{"kind":"arabic","text_bw":"A_ixolaAlN","text_ar":"اـِخْلَالٌ"},{"kind":"text","text":", (TA,)"},{"kind":"italic_en","text":"Their camels pastured upon what is termed"},{"kind":"arabic","text_bw":"xul~ap","text_ar":"خُلَّة"},{"kind":"text","text":". (K.) ―         -b2-  Hence,"},{"kind":"arabic","text_bw":"Axl~","text_ar":"اخلّ"},{"kind":"text","text":"said of a man signifies (assumed tropical:)"},{"kind":"arabic","text_bw":"A^axa*a mino qubulK","text_ar":"اَخَذَ مِنْ قُبُلٍ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"He took frontways"},{"kind":"text","text":"]: opposed to"},{"kind":"arabic","text_bw":"A^aHomaDa","text_ar":"اَحْمَضَ"},{"kind":"text","text":"[and"},{"kind":"arabic","text_bw":"Ham~aDa","text_ar":"حَمَّضَ"},{"kind":"text","text":", q. v.], meaning"},{"kind":"arabic","text_bw":"A^axa*a mino duburK","text_ar":"اَخَذَ مِنْ دُبُرٍ"},{"kind":"text","text":". (TA.)       -A6-"},{"kind":"arabic","text_bw":"Axl~t Aln~axolapu","text_ar":"اخلّت النَّخْلَةُ"},{"kind":"italic_en","text":"The palmtree produced bad fruit."},{"kind":"text","text":"(A' Obeyd, JK, S, K.) ―         -b2-  And"},{"kind":"italic_en","text":"The palm-tree produced dates such as are termed"},{"kind":"arabic","text_bw":"xalaAl","text_ar":"خَلَال"},{"kind":"text","text":": [like"},{"kind":"arabic","text_bw":"A^abolaHat","text_ar":"اَبْلَحَت"},{"kind":"text","text":"from"},{"kind":"arabic","text_bw":"balaHN","text_ar":"بَلَحٌ"},{"kind":"text","text":":] thus it bears two contr. significations. (K.)"}],"source_refs":["S","Mgh","K","TA"]},{"entry_id":"n11190","headword_ar":"اَخَلُّ","root":"xl","body":[{"kind":"italic_en","text":"More,"},{"kind":"text","text":"and"},{"kind":"italic_en","text":"most, poor,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"needy:"},{"kind":"text","text":"(K, TA:) from"},{"kind":"arabic","text_bw":"A^axal~a A_ilayohi","text_ar":"اَخَلَّ اـِلَيْهِ"},{"kind":"text","text":"signifying “ he wanted it, ” or “ needed it. ” (TA.) Hence the phrase"},{"kind":"arabic","text_bw":"A^axal~u A_ilayohi","text_ar":"اَخَلُّ اـِلَيْهِ"},{"kind":"text","text":"[meaning"},{"kind":"italic_en","text":"More,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"most, in need of him,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it"},{"kind":"text","text":"]. (TA.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"xaliylN","text_ar":"خَلِيلٌ"},{"kind":"text","text":"."}],"source_refs":["K","TA"]}]}}