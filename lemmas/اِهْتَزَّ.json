:"present_1mp","form":"نَهْتَزّ","in_corpus":false,"count":null,"asp":"i","per":"1","gen":"m","num":"p"}],"frequency_in_corpus":14,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["verb"],"has_etymology":false,"sense_count":2},"lanes":{"found":true,"entry_ids":["n41151"],"search_url":"https://lanelexicon.com/?s=%D8%A7%D9%90%D9%87%D9%92%D8%AA%D9%8E%D8%B2%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to be moved, to tremble, to quiver, to writhe","tags":["intransitive"],"examples":[{"text":"وَأَلْقِ عَصَاكَ فَلَمَّا رَءَاهَا تَهْتَزُّ كَأَنَّهَا جَانٌّ وَلَّى مُدْبِرًا وَلَمْ يُعَقِّبْ","english":"And [he was told]: “Throw down your staff.” But when he saw it writhing as if it were a snake, he turned in flight and did not return."}]},{"pos":"verb","gloss":"(of plants) to develop, to grow longer or higher","tags":["figuratively","intransitive"],"examples":[{"text":"وَتَرَى ٱلْأَرْضَ هَامِدَةً فَإِذَا أَنْزَلْنَا عَلَيْهَا ٱلْمَاءَ ٱهْتَزَّتْ وَرَبَتْ وَأَنْبَتَتْ مِنْ كُلِّ زَوْجٍ بَهِيجٍ","english":"And you see the earth barren, but when We send down upon it rain, it quivers and swells and grows [something] of every beautiful kind."}]}]},"etymology":null,"ipa":["/ih.taz.za/"],"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n41151","headword_ar":"اهتزّ","root":"hz","body":[{"kind":"text","text":", (inf. n."},{"kind":"arabic","text_bw":"AihotizaAzN","text_ar":"اِهْتِزَازٌ"},{"kind":"text","text":",) quasi-pass. of"},{"kind":"arabic","text_bw":"haz~ahu","text_ar":"هَزَّهُ"},{"kind":"text","text":", (TA,) ["},{"kind":"italic_en","text":"It shook;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"quivered;"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"it became in motion,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"in a state of commotion;"},{"kind":"text","text":"(S, Msb, K;) as also ↓"},{"kind":"arabic","text_bw":"thz~z","text_ar":"تهزّز","orth_type":"arrow"},{"kind":"text","text":", (S, K,) quasi-pass. of"},{"kind":"arabic","text_bw":"hz~zhu","text_ar":"هزّزهُ"},{"kind":"text","text":"; (TA;) and ↓"},{"kind":"arabic","text_bw":"tahazohaza","text_ar":"تَهَزْهَزَ","orth_type":"arrow"},{"kind":"text","text":", (S, A, K,) [quasi-pass. of"},{"kind":"arabic","text_bw":"hazohazahu","text_ar":"هَزْهَزَهُ"},{"kind":"text","text":"; meaning, accord. to explanations of"},{"kind":"arabic","text_bw":"haz~ahu","text_ar":"هَزَّهُ"},{"kind":"text","text":"in the TA,"},{"kind":"italic_en","text":"it became moved by being pulled and pushed;"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became moved to the right and left:"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"it became so moved with violence,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"vehemence."},{"kind":"text","text":"] ―         -b2-"},{"kind":"arabic","text_bw":"Ahtz~ AlmiaA='u fY jazoyihi","text_ar":"اهتزّ المَِا=ءُ فى جَزْيِهِ"},{"kind":"text","text":"(tropical:)  [app."},{"kind":"italic_en","text":"the water quivered in its running"},{"kind":"text","text":"]: and"},{"kind":"arabic","text_bw":"Alkawokabu fiY A@noqiDaADihi","text_ar":"الكَوْكَبُ فِى ا@نْقِضَاضِهِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"the star in its shooting,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"darting, down"},{"kind":"text","text":"]: (S, A, TA:) and"},{"kind":"arabic","text_bw":"Ahtz~ Alkawokabu","text_ar":"اهتزّ الكَوْكَبُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"the star shot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"darted, down"},{"kind":"text","text":"[app."},{"kind":"italic_en","text":"with a quivering motion"},{"kind":"text","text":"]; (O, L, TA;) as also"},{"kind":"arabic","text_bw":"haz~a","text_ar":"هَزَّ"},{"kind":"text","text":". (A, K.) ―         -b3-"},{"kind":"arabic","text_bw":"Ahtz~ Almawokibu","text_ar":"اهتزّ المَوْكِبُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The procession,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cavalcade, went quickly:"},{"kind":"text","text":"(En-Nadr, TA:) or"},{"kind":"italic_en","text":"made a noise and clamour."},{"kind":"text","text":"(S.) ―         -b4-"},{"kind":"arabic","text_bw":"Ahtz~t AlA_ibilu","text_ar":"اهتزّت الاـِبِلُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The camels,"},{"kind":"text","text":"being urged on by the singing of their driver,"},{"kind":"italic_en","text":"became brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"sprightly."},{"kind":"text","text":"(S, * A, TA.) You say also,"},{"kind":"arabic","text_bw":"Ahtz~ liA^amorK","text_ar":"اهتزّ لِاَمْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He was,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"became, active,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prompt, and brisk,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"cheerfully excited, at a thing,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"to do a thing."},{"kind":"text","text":"(TA.) [Ex.]"},{"kind":"arabic","text_bw":"Ahtz~ lixayorK","text_ar":"اهتزّ لِخَيْرٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He rejoiced"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"was active"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prompt,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to do good"},{"kind":"text","text":"]: said of a generous man. (En-Nadr, TA.) And"},{"kind":"arabic","text_bw":"huwa yahotaz~u lilomaEoruwfi","text_ar":"هُوَ يَهْتَزُّ لِلْمَعْرُوفِ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"He rejoices,"},{"kind":"text","text":"or is"},{"kind":"italic_en","text":"active,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"prompt,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to do what is beneficent,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"kind"},{"kind":"text","text":"]. (A.) [Hence the saying,]"},{"kind":"arabic","text_bw":"fulaAnN laA yahotaz~u wal`kin~ahu yakutaz~u","text_ar":"فُلَانٌ لَا يَهْتَزُّ وَلٰكِنَّهُ يَكُتَزُّ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"Such a one does not rejoice,"},{"kind":"text","text":"&c.,"},{"kind":"italic_en","text":"to give, but he shrinks from giving"},{"kind":"text","text":"]. (A, TA, art."},{"kind":"arabic","text_bw":"kz","text_ar":"كز"},{"kind":"text","text":".) [Hence also,]"},{"kind":"arabic","text_bw":"A_ihutaz~a Earo$u Alr~aHomaAni limawoti saEodK","text_ar":"اـِهُتَزَّ عَرْشُ الرَّحْمَانِ لِمَوْتِ سَعْدٍ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The empyrean of the Compassionate rejoiced at the death of Saad;"},{"kind":"text","text":"(En-Nadr, IAth, K, TA;) meaning Saad Ibn-Mo'ádh; (TA;) i. e., when he [meaning his soul] was taken up; (IAth, TA;) because of the honour in which he was held by his Lord; (K;) or"},{"kind":"italic_en","text":"the inhabitants of the empyrean rejoiced at his death:"},{"kind":"text","text":"these words occur in a trad., of which there is another relation,"},{"kind":"arabic","text_bw":"Ahtz~ AlEaro$u","text_ar":"اهتزّ العَرْشُ"},{"kind":"text","text":": and some say, that by"},{"kind":"arabic","text_bw":"AlEr$","text_ar":"العرش"},{"kind":"text","text":"is meant the bier upon which Saad was removed to his grave. (TA.) You also say,"},{"kind":"arabic","text_bw":"A_ilayohi qalobiY","text_ar":"اـِلَيْهِ قَلْبِى"},{"kind":"text","text":"↓"},{"kind":"arabic","text_bw":"tahazohaza","text_ar":"تَهَزْهَزَ","orth_type":"arrow"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"My heart became moved by a cheerful,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"joyful, affection towards him."},{"kind":"text","text":"(K, TA.) ―         -b5-"},{"kind":"arabic","text_bw":"Ahtz~ Aln~abaAtu","text_ar":"اهتزّ النَّبَاتُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The plant,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage, became tall."},{"kind":"text","text":"(A, TA.) ―         -b6-"},{"kind":"arabic","text_bw":"Ahtz~t AlA^aroDu","text_ar":"اهتزّت الاَرْضُ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"The land produced plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage:"},{"kind":"text","text":"(A:) or"},{"kind":"italic_en","text":"became put in motion, and produced plants,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"herbage."},{"kind":"text","text":"(TA.)"}],"source_refs":["TA","S","K","A"]}]},"classical_definitions":null}