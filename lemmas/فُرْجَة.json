{"lemma":"فُرْجَة","slug":"فُرْجَة","root":"ف.ر.ج","root_slug":"ف-ر-ج","root_link":"/words/roots/ف-ر-ج","pos":"N","pos_camel":"noun","paradigm":[],"frequency_in_corpus":0,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":1,"pos_tags":["noun"],"has_etymology":false,"sense_count":1},"lanes":{"found":true,"entry_ids":["n33377","n33378","n33379","n33380"],"search_url":"https://lanelexicon.com/?s=%D9%81%D9%8F%D8%B1%D9%92%D8%AC%D9%8E%D8%A9"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"noun","gloss":"crack, fissure"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n33377","headword_ar":"فَرْجَةٌ","root":"frj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"farajN","text_ar":"فَرَجٌ"},{"kind":"text","text":", in five places. ―         -b2-  It is said in the T, that"},{"kind":"arabic","text_bw":"A^adorakuwA Alqawoma EalaY farojatihimo","text_ar":"اَدْرَكُوا القَوْمَ عَلَى فَرْجَتِهِمْ"},{"kind":"text","text":"or ↓"},{"kind":"arabic","text_bw":"furojatihimo","text_ar":"فُرْجَتِهِمْ","orth_type":"arrow"},{"kind":"text","text":"occurs in a trad. as meaning"},{"kind":"arabic","text_bw":"ElY hziymatihimo","text_ar":"على هزِيمَتِهِمْ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"They overtook the people,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"party, in their state of defeat"},{"kind":"text","text":"]: but it is also related as with"},{"kind":"arabic","text_bw":"qAf","text_ar":"قاف"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"HA='","text_ar":"حا=ء"},{"kind":"text","text":"[app."},{"kind":"arabic","text_bw":"qaroHatihimo","text_ar":"قَرْحَتِهِمْ"},{"kind":"text","text":"]. (TA.)"}],"source_refs":[]},{"entry_id":"n33378","headword_ar":"فُرْجَةٌ","root":"frj","body":[{"kind":"italic_en","text":"An opening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intervening space,"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"a gap,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"breach,"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between two things;"},{"kind":"text","text":"(Msb, TA;) as also ↓"},{"kind":"arabic","text_bw":"farojN","text_ar":"فَرْجٌ","orth_type":"arrow"},{"kind":"text","text":", (A,) of which the pl. is"},{"kind":"arabic","text_bw":"furuwjN","text_ar":"فُرُوجٌ"},{"kind":"text","text":"only; (TA;) [and so ↓"},{"kind":"arabic","text_bw":"maforajN","text_ar":"مَفْرَجٌ","orth_type":"arrow"},{"kind":"text","text":", lit."},{"kind":"italic_en","text":"a place of opening,"},{"kind":"text","text":"occurring in the K in art."},{"kind":"arabic","text_bw":"wdY","text_ar":"ودى"},{"kind":"text","text":", &c.;] and ↓"},{"kind":"arabic","text_bw":"munofarajN","text_ar":"مُنْفَرَجٌ","orth_type":"arrow"},{"kind":"text","text":": (JK and K voce"},{"kind":"arabic","text_bw":"xalalN","text_ar":"خَلَلٌ"},{"kind":"text","text":", &c.:) the pl. of the first is"},{"kind":"arabic","text_bw":"furajN","text_ar":"فُرَجٌ"},{"kind":"text","text":"(Msb, TA) and"},{"kind":"arabic","text_bw":"furujaAtN","text_ar":"فُرُجَاتٌ"},{"kind":"text","text":": (TA:) and it is also in a wall, (S, Msb, K,) and the like: (S, Msb:) and signifies also"},{"kind":"italic_en","text":"an opening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"a space,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"room, made by persons for a man entering among them,"},{"kind":"text","text":"in a place of standing or of sitting. (Msb.) One says,"},{"kind":"arabic","text_bw":"bayonahumaA furojapN","text_ar":"بَيْنَهُمَا فُرْجَةٌ"},{"kind":"text","text":", meaning"},{"kind":"arabic","text_bw":"AnofiraAjN","text_ar":"انْفِرَاجٌ"},{"kind":"text","text":"[i. e."},{"kind":"italic_en","text":"Between them two is an opening,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"intervening space,"},{"kind":"text","text":"&c.]. (S.)"},{"kind":"arabic","text_bw":"furaju Al$~ayoTaAni","text_ar":"فُرَجُ الشَّيْطَانِ"},{"kind":"text","text":"["},{"kind":"italic_en","text":"The Devil's gaps"},{"kind":"text","text":"], occurring in a trad., means"},{"kind":"italic_en","text":"the gaps,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"unoccupied spaces, in the ranks of men praying"},{"kind":"text","text":"["},{"kind":"italic_en","text":"in the mosque"},{"kind":"text","text":"]. (L.) ―         -b2-  See also"},{"kind":"arabic","text_bw":"farojN","text_ar":"فَرْجٌ"},{"kind":"text","text":", last sentence: ―         -b3-  and see"},{"kind":"arabic","text_bw":"farajN","text_ar":"فَرَجٌ"},{"kind":"text","text":", in seven places: ―         -b4-  and"},{"kind":"arabic","text_bw":"farojapN","text_ar":"فَرْجَةٌ"},{"kind":"text","text":"."}],"source_refs":["A","Msb","TA","S","K"]},{"entry_id":"n33379","headword_ar":"فِرْجَةٌ","root":"frj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"farajN","text_ar":"فَرَجٌ"},{"kind":"text","text":", in three places."}],"source_refs":[]},{"entry_id":"n33380","headword_ar":"فُرَجَةٌ","root":"frj","body":[{"kind":"text","text":": see"},{"kind":"arabic","text_bw":"furujN","text_ar":"فُرُجٌ"},{"kind":"text","text":", last sentence."}],"source_refs":[]}]}}