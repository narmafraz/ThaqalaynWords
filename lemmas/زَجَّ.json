","num":"s"}],"frequency_in_corpus":1,"cross_references":{"qac":{"found":false},"wiktextract":{"found":true,"entry_count":3,"pos_tags":["noun","verb"],"has_etymology":false,"sense_count":3},"lanes":{"found":true,"entry_ids":["","n17469"],"search_url":"https://lanelexicon.com/?s=%D8%B2%D9%8E%D8%AC%D9%8E%D9%91"}},"translations":null,"definition":{"source":"wiktextract","senses":[{"pos":"verb","gloss":"to throw, to cast, to put by hurling, to warp","examples":[{"text":"زَجَّهُ فِي السِّجْنِ","english":"He threw him into prison."}]},{"pos":"noun","gloss":"verbal noun of زَجَّ (zajja) (form I)","tags":["form-of","noun-from-verb"]},{"pos":"noun","gloss":"the protruding lower extremity of something, like the ferrule of an arrow, spear or the like, or a pivot or subscūs in other technical applications, or between the ulna and the os humeri, or a tush of a beast"}]},"etymology":null,"ipa":null,"lanes_definition":{"source":"lanes","entries":[{"entry_id":"n17469","headword_ar":"زُجٌّ","root":"zj","body":[{"kind":"text","text":"[The"},{"kind":"italic_en","text":"pointed iron foot,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"heel,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"shoe, of a spear;"},{"kind":"text","text":"] the"},{"kind":"italic_en","text":"iron at the lower extremity of a spear;"},{"kind":"text","text":"(S, A, Msb, K;) i. e. the"},{"kind":"italic_en","text":"iron which is fixed upon the lower extremity of a spear, and with which the spear is stuck into the ground:"},{"kind":"text","text":"the iron which is fixed upon its upper extremity, and with which one pierces, being called"},{"kind":"arabic","text_bw":"sinaAnN","text_ar":"سِنَانٌ"},{"kind":"text","text":": (ISd, TA:) pl. [of mult.]"},{"kind":"arabic","text_bw":"zijaAjN","text_ar":"زِجَاجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zijajapN","text_ar":"زِجَجَةٌ"},{"kind":"text","text":"(S, Msb, K) and [of pauc.]"},{"kind":"arabic","text_bw":"A^azojaAjN","text_ar":"اَزْجَاجٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"A^azij~apN","text_ar":"اَزِجَّةٌ"},{"kind":"text","text":", (TA,) or this last is not allowable, (S, Msb, TA,) accord. to ISk. (Msb.) Zuheyr says,"},{"kind":"quote","text":"wamano yaEoSi A^aToraAfa Alz~ijaAji faA_in~ahu\n                      \n                     \n                        yuTiyEu AlEawaAliY ruk~ibato kul~a laho*ami"},{"kind":"text","text":"["},{"kind":"italic_en","text":"And he who refuses to yield to the points of the iron feet of the spears shall yield to the upper extremities thereof mounted with every sharp spear-head"},{"kind":"text","text":"]: ISk says, he means that he who refuses to yield to a small thing will encounter a great thing: and Khálid Ibn-Kulthoom says, they used to meet their enemies, when they desired peace, with the iron feet of their spears turned towards them; and if they refused peace, they turned their spears' heads to them, and combated them. (TA.) [By a synecdoche, the pl.]"},{"kind":"arabic","text_bw":"zijaAjN","text_ar":"زِجَاجٌ"},{"kind":"text","text":"is also used to signify"},{"kind":"italic_en","text":"Spears,"},{"kind":"text","text":"altogether. (Ham p. 147.) ―         -b2-  Hence, as being likened to the"},{"kind":"arabic","text_bw":"zuj~","text_ar":"زُجّ"},{"kind":"text","text":"of the spear, (L,) (tropical:)  The"},{"kind":"italic_en","text":"extremity of the elbow,"},{"kind":"text","text":"(S, L, K,)"},{"kind":"italic_en","text":"which is pointed:"},{"kind":"text","text":"(L:) or the"},{"kind":"italic_en","text":"part"},{"kind":"text","text":"[or"},{"kind":"italic_en","text":"joint"},{"kind":"text","text":"]"},{"kind":"italic_en","text":"between the lower extremity of the os humeri and the extremity of the ulna at the elbow:"},{"kind":"text","text":"(T in art."},{"kind":"arabic","text_bw":"Abr","text_ar":"ابر"},{"kind":"text","text":":) or [simply] the"},{"kind":"italic_en","text":"elbow."},{"kind":"text","text":"(A.) You say,"},{"kind":"arabic","text_bw":"Ait~akaA^a EalaY zuj~ayohi","text_ar":"اِتَّكَاَ عَلَى زُجَّيْهِ"},{"kind":"text","text":"(tropical:)"},{"kind":"italic_en","text":"He leaned upon his elbows:"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"Ait~akaw^uwA EalaY zijaAji","text_ar":"اِتَّكَوُوا عَلَى زِجَاجِ"},{"kind":"arabic","text_bw":"maraAfiqihimo","text_ar":"مَرَافِقِهِمْ"},{"kind":"text","text":"(tropical:)  ["},{"kind":"italic_en","text":"They leaned upon the extremities of their elbows"},{"kind":"text","text":"]. (A.) ―         -b3-  [Hence also, (tropical:)"},{"kind":"italic_en","text":"A tush,"},{"kind":"text","text":"or"},{"kind":"italic_en","text":"canine tooth:"},{"kind":"text","text":"]"},{"kind":"arabic","text_bw":"zijaAju AlfaHoli","text_ar":"زِجَاجُ الفَحْلِ"},{"kind":"text","text":"signifies (tropical:)"},{"kind":"italic_en","text":"the tushes of the stallion-camel."},{"kind":"text","text":"(A, K.) ―         -b4-  [Hence also a signification mentioned by Golius on the authority of Meyd, (assumed tropical:)"},{"kind":"italic_en","text":"An iron pivot"},{"kind":"text","text":"(“ subscus ferrea ”)"},{"kind":"italic_en","text":"round which a mill-stone turns."},{"kind":"text","text":"] ―         -b5-  Also"},{"kind":"italic_en","text":"An arrow-head:"},{"kind":"text","text":"(IAar, K:) pl."},{"kind":"arabic","text_bw":"zijajapN","text_ar":"زِجَجَةٌ"},{"kind":"text","text":"and"},{"kind":"arabic","text_bw":"zijaAjN","text_ar":"زِجَاجٌ"},{"kind":"text","text":"(K) and"},{"kind":"arabic","text_bw":"A^azij~apN","text_ar":"اَزِجَّةٌ"},{"kind":"text","text":". (TA.)"}],"source_refs":["ISd","TA","S","Msb","K","L","IAar"]}]},"classical_definitions":null}